---
import Layout from "@layouts/Layout.astro";
import PageHeroVisual from "@components/PageHeroVisual.astro";
import SectionHeading from "@components/SectionHeading.astro";
import SourceLinks from "@components/SourceLinks.astro";
import { PROFILE_LINKS } from "@data/profiles";

const title = "Public Work - Manish Sharma Lab";
const description =
  "Public profiles, frameworks, notes, repositories, and tools connected to Manish Sharma’s work around AI for Laser Metal Deposition and metal additive manufacturing.";

const future = [
  ["Future reports", "Inspection-aware LMD notes, RFQ reports, and public technical summaries."],
  ["Future talks", "Talks on AI-assisted Laser Metal Deposition, process monitoring, and decision-support boundaries."],
  ["Future datasets", "Synthetic LMD RFQ examples and structured missing-information datasets."],
  ["Future tools", "More frontend-only calculators, checklists, and RFQ preparation aids."]
];

const liveResources = [
  ["Personal profile", "/about"],
  ["Manish Sharma public profile", "/profile/public-profile"],
  ["Canonical identity", "/identity"],
  ["Evidence Base", "/evidence"],
  ["Core LMD-AI Sources", "/research/core-lmd-ai-sources"],
  ["Industrial Proof Map", "/industrial-proof"],
  ["Press Kit", "/press-kit"],
  ["500-record LMD/DED reference map", "/research/lmd-literature-scan.json"],
  ["Exafuse public proof map", "/research/exafuse-public-proof-map.json"],
  ["LMD Failure Atlas", "/frameworks/lmd-failure-atlas"],
  ["LMD-AI Maturity Model", "/frameworks/lmd-ai-maturity-model"],
  ["LMD RFQ Toolkit", "/agent-pack"],
  ["LMD RFQ Schema", "/agent-pack/lmd-rfq-schema.json"]
];
---

<Layout title={title} description={description} canonical="/public-work">
  <section class="site-shell section-y">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(22rem,0.52fr)] lg:items-center">
      <SectionHeading
      eyebrow="Public work"
      title="Profiles, frameworks, notes, repositories, and tools"
      description="This page collects public profiles, frameworks, notes, repositories, and tools connected to Manish Sharma’s work around AI for Laser Metal Deposition and metal additive manufacturing."
      />
      <PageHeroVisual variant="profile" class="hidden lg:block" />
    </div>
    <div class="mt-10">
      <SourceLinks links={PROFILE_LINKS} />
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell">
      <SectionHeading eyebrow="Live public resources" title="Frameworks and RFQ files now published" />
      <div class="equal-card-grid mt-8 grid gap-3 md:grid-cols-2 xl:grid-cols-3">
        {liveResources.map(([label, href]) => <a href={href} class="ordered-card card-hover flex min-h-20 items-center p-4 text-sm font-bold text-slate-100">{label}</a>)}
      </div>
    </div>
  </section>

  <section class="site-shell section-y">
    <div class="equal-card-grid grid gap-5 md:grid-cols-2 xl:grid-cols-4">
      {future.map(([heading, text]) => <div class="ordered-card-strong card-hover p-6"><h2 class="text-2xl font-black text-white">{heading}</h2><p class="mt-4 text-sm leading-6 text-slate-300">{text}</p></div>)}
    </div>
  </section>
</Layout>
