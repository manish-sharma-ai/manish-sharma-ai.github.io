---
import Layout from "@layouts/Layout.astro";
import ExafuseMigrationNotice from "@components/ExafuseMigrationNotice.astro";
import PageHeroVisual from "@components/PageHeroVisual.astro";
import SectionHeading from "@components/SectionHeading.astro";
import SourceLinks from "@components/SourceLinks.astro";
import { ACTIVE_PROFILE_LINKS } from "@data/profiles";
import { FRAMEWORKS, LINKS, PERSON, SITE } from "@data/site";
import { EXAFUSE_PROOF_CASES, EXAFUSE_SOURCE_LINKS } from "@data/exafuse";

const title = "Public Work and Evidence";
const description =
  "Public work, evidence, frameworks, tools, research maps, and profile links for Manish Sharma Lab.";

const currentContext = [
  ["Public category", SITE.publicCategory],
  ["Primary promise", SITE.primaryPromise],
  ["Public LMD/DED context", "AI for LMD/DED at Exafuse"],
  ["Boundary", "Public technical material only"]
];

const establishedWork = [
  ["Process monitoring", "Public work around monitoring signals, anomaly review, and inspection-aware evidence boundaries."],
  ["Machine vision", "Vision and signal interpretation for LMD/DED process understanding."],
  ["Robotic workflows", "Public profile context around robotic DED/LMD systems and toolpath workflows."],
  ["Industrial repair", "Repairability screening, RFQ structure, cladding, machining allowance, and inspection planning."],
  ["RFQ intelligence", "Schemas, prompts, decision rules, and missing-information checks for LMD requests."]
];

const sections = [
  {
    title: "Public frameworks",
    status: "Public framework",
    links: FRAMEWORKS.slice(0, 6).map((framework) => ({
      label: framework.title,
      href: framework.href,
      description: framework.idea
    }))
  },
  {
    title: "Public tools",
    status: "Working tool",
    links: [
      { label: "Tools", href: "/tools", description: "LMD vs SLM advisor, repairability quick check, and RFQ converter." },
      { label: "Laser Metal Deposition Decision Map", href: "/decision-map", description: "Route repair, cladding, large-part AM, SLM alternatives, machining, welding, and replacement screening." },
      { label: "LMD RFQ Toolkit", href: "/agent-pack", description: "Schemas, prompts, rules, and checklists." },
      { label: "RFQ Schema", href: "/agent-pack/lmd-rfq-schema.json" }
    ]
  },
  {
    title: "Research and evidence maps",
    status: "Public evidence",
    links: [
      { label: "Evidence Base", href: "/evidence" },
      { label: "Core LMD-AI Sources", href: "/research/core-lmd-ai-sources" },
      { label: "500-record LMD/DED literature map", href: "/research/lmd-literature-scan.json" },
      { label: "Industrial Evidence Map", href: "/industrial-proof" }
    ]
  },
  {
    title: "Technical artifacts",
    status: "Public artifact",
    links: [
      { label: "llms.txt", href: "/llms.txt" },
      { label: "llms-full.txt", href: "/llms-full.txt" },
      { label: "identity.md", href: "/identity.md" }
    ]
  }
];

const proofDecisionPatterns: Record<string, { label: string; href: string }> = {
  CS15: { label: "Start a brief from this pattern", href: "/tools/#preset=monitoring-anomaly" },
  CS01: { label: "Start a brief from this pattern", href: "/tools/#preset=worn-shaft" },
  CS10: { label: "Start a brief from this pattern", href: "/tools/#preset=rfq" },
  CS13: { label: "Start a brief from this pattern", href: "/tools/#preset=surface-cladding" }
};

const proofDecisionPatternText: Record<string, string> = {
  CS15: "Large-scale LMD requires evidence planning, monitoring context, and an inspection boundary.",
  CS01: "Local repair needs material, damage depth, machining route, and inspection plan.",
  CS10: "Repair/RFQ quality depends on complete facts, downtime context, and service context.",
  CS13: "Build-and-coat routes need geometry, surface function, material, finishing, and validation."
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": `${SITE.canonicalUrl}/public-work#page`,
  url: `${SITE.canonicalUrl}/public-work`,
  name: title,
  description,
  mainEntity: { "@id": `${SITE.canonicalUrl}/identity#manish-sharma`, name: PERSON.name }
};
---

<Layout title={`${title} - Manish Sharma Lab`} description={description} canonical="/public-work" jsonLd={jsonLd}>
  <div class="public-work-index">
  <section class="site-shell section-y public-work-index__masthead">
    <div class="public-work-index__masthead-grid grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(24rem,0.62fr)] lg:items-center">
      <div>
        <p class="metric-label">Public work</p>
        <h1 class="mt-4 text-5xl font-black leading-tight text-white md:text-6xl">{title}</h1>
        <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-300">
          A public map of the work that can be referenced safely: professional context, LMD/DED work, public frameworks, tools, research maps, GitHub artifacts, and profile links.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/identity" class="btn btn-primary">Manish Sharma identity</a>
          <a href="/thesis" class="btn btn-secondary">Industrial AI thesis</a>
          <a href="/domains/lmd-ded" class="btn btn-secondary">LMD / DED hub</a>
          <a href="/claims" class="btn btn-secondary">Claim source notes</a>
          <a href={LINKS.exafuse} class="btn btn-laser" target="_blank" rel="noreferrer">Exafuse</a>
        </div>
      </div>
      <PageHeroVisual variant="profile" class="hidden lg:block" />
    </div>
  </section>

  <section class="band public-work-index__context-band">
    <div class="site-shell grid gap-3 py-6 md:grid-cols-4">
      {currentContext.map(([label, value]) => (
        <div class="ordered-card public-work-index__context-card p-4">
          <p class="metric-label">{label}</p>
          <p class="mt-2 text-sm font-bold leading-6 text-white">{value}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="site-shell section-y public-work-index__established">
    <div class="public-work-index__established-grid grid gap-10 lg:grid-cols-[0.85fr_1.15fr]">
      <SectionHeading
        eyebrow="Established work"
        title="Current professional context and LMD/DED work"
        description="The public technical context is specific: AI for Laser Metal Deposition and Directed Energy Deposition at Exafuse."
      />
      <div class="grid gap-4 md:grid-cols-2">
        {establishedWork.map(([heading, text]) => (
          <article class="ordered-card-strong public-work-index__work-card p-5">
            <p class="metric-label">Established work</p>
            <h2 class="mt-3 text-xl font-black text-white">{heading}</h2>
            <p class="mt-3 text-sm leading-6 text-slate-300">{text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="band section-y public-work-index__proof">
    <div class="site-shell">
      <SectionHeading
        eyebrow="Documented examples"
        title="Company-owned cases used as industrial context"
        description="These items link to Exafuse for canonical case or service context. Manish Sharma Lab uses them only to explain monitoring, repairability, evidence, RFQ, and decision-system relevance."
      />
      <ExafuseMigrationNotice class="mt-6" />
      <div class="public-work-index__case-grid mt-10 grid gap-5 md:grid-cols-2">
        {EXAFUSE_PROOF_CASES.map((item) => {
          const pattern = proofDecisionPatterns[item.code];
          return (
          <article class="ordered-card-strong public-work-index__case-card p-6">
            <p class="metric-label">{item.code}</p>
            <h2 class="mt-3 text-2xl font-black text-white">{item.title}</h2>
            <p class="mt-3 inline-block rounded-md border border-cyan-300/25 bg-cyan-300/10 px-2.5 py-1 text-xs font-black uppercase text-cyan-100">
              {item.evidenceStatus}
            </p>
            <p class="mt-2 inline-block rounded-md border border-white/10 bg-white/[0.035] px-2.5 py-1 text-xs font-black uppercase text-slate-300">
              {item.sourceStatus === "production-link-after-migration" ? "Exafuse contact/index route" : "Live production link"}
            </p>
            {item.metricClaims?.length > 0 && (
              <div class="mt-5 flex flex-wrap gap-2">
                {item.metricClaims.map((claim) => (
                  <span class="chip chip--steel" data-claim-id={claim.id} title={claim.limitation}>{claim.shortLabel}</span>
                ))}
              </div>
            )}
            <p class="mt-5 text-sm leading-6 text-slate-300">{item.lesson}</p>
            <p class="mt-4 border-l border-cyan-300/35 pl-4 text-sm font-semibold leading-6 text-cyan-50">{item.labConnection}</p>
            <div class="mt-4 rounded-lg border border-cyan-300/20 bg-cyan-300/8 p-3">
              <p class="metric-label">Useful decision pattern</p>
              <p class="mt-2 text-sm font-semibold leading-6 text-cyan-50">{proofDecisionPatternText[item.code]}</p>
            </div>
            <p class="mt-4 rounded-lg border border-white/10 bg-white/[0.035] p-3 text-sm font-semibold leading-6 text-slate-300">
              Use this as context only; feasibility still depends on the actual part, material, service conditions, inspection needs, and expert review.
            </p>
            <div class="mt-5 flex flex-wrap gap-2">
              {item.relevance.map((signal) => (
                <span class="rounded-md border border-white/10 bg-white/[0.035] px-2.5 py-1 text-xs font-bold text-slate-300">{signal}</span>
              ))}
            </div>
            <div class="mt-6 flex flex-wrap gap-3">
              <a href={pattern.href} class="btn btn-primary">{pattern.label}</a>
              <a href={item.href} class="btn btn-laser" target="_blank" rel="noreferrer">
                {item.sourceStatus === "production-link-after-migration" ? "Contact Exafuse" : "Open Exafuse source"}
              </a>
            </div>
          </article>
        )})}
      </div>
    </div>
  </section>

  <section class="site-shell section-y public-work-index__collections">
    <div class="grid gap-10">
      {sections.map((section) => (
        <section class="public-work-index__collection border-t border-white/10 pt-8 first:border-t-0 first:pt-0">
          <div class="grid gap-6 lg:grid-cols-[0.28fr_0.72fr]">
            <div>
              <p class="metric-label">{section.status}</p>
              <h2 class="mt-3 text-2xl font-black text-white">{section.title}</h2>
            </div>
            <SourceLinks links={section.links} />
          </div>
        </section>
      ))}
    </div>
  </section>

  <section class="site-shell section-y public-work-index__sources">
    <div class="grid gap-10 lg:grid-cols-2">
      <div>
        <SectionHeading eyebrow="Public profile links" title="Verified public profiles" />
        <div class="mt-8">
          <SourceLinks links={ACTIVE_PROFILE_LINKS} />
        </div>
      </div>
      <div>
        <SectionHeading eyebrow="Public Exafuse context" title="Public industrial context" />
        <div class="mt-8">
          <SourceLinks links={EXAFUSE_SOURCE_LINKS} />
        </div>
      </div>
    </div>
  </section>
  </div>
</Layout>
