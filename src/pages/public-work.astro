---
import Layout from "@layouts/Layout.astro";
import ExafuseProofMedia from "@components/ExafuseProofMedia.astro";
import PageHeroVisual from "@components/PageHeroVisual.astro";
import SectionHeading from "@components/SectionHeading.astro";
import SourceLinks from "@components/SourceLinks.astro";
import { ACTIVE_PROFILE_LINKS } from "@data/profiles";
import { EXAFUSE_PUBLIC_PROOF } from "@data/exafusePublicProof";
import { FRAMEWORKS, LINKS, PERSON, SITE } from "@data/site";
import { EXAFUSE_SOURCE_LINKS } from "@data/exafuse";

const title = "Current Work and Public Evidence";
const description =
  "Manish Sharma's current public work in Industrial AI & Decision Systems, grounded in LMD/DED, process monitoring, robotics, and evidence-aware engineering decisions at Exafuse.";

const currentContext = [
  ["Public category", SITE.publicCategory],
  ["Core thesis", SITE.primaryPromise],
  ["Current proving ground", "LMD/DED at Exafuse"],
  ["Boundary", "Public technical material only"]
];

const establishedWork = [
  ["Process monitoring", "Public work around monitoring signals, anomaly review, and inspection-aware evidence boundaries."],
  ["Machine vision", "Vision and signal interpretation for LMD/DED process understanding."],
  ["Robotic workflows", "Public profile context around robotic DED/LMD systems and toolpath workflows."],
  ["Industrial repair", "Repairability screening, RFQ structure, cladding, machining allowance, and inspection planning."],
  ["RFQ intelligence", "Schemas, prompts, decision rules, and missing-information checks for LMD requests."]
];

const sections = [
  {
    title: "Public frameworks",
    status: "Public framework",
    links: FRAMEWORKS.slice(0, 6).map((framework) => ({
      label: framework.title,
      href: framework.href,
      description: framework.idea
    }))
  },
  {
    title: "Public tools",
    status: "Working tool",
    links: [
      { label: "Tools", href: "/tools", description: "LMD vs SLM advisor, repairability quick check, and RFQ converter." },
      { label: "Laser Metal Deposition Decision Map", href: "/decision-map", description: "Route repair, cladding, large-part AM, SLM alternatives, machining, welding, and replacement screening." },
      { label: "LMD RFQ Toolkit", href: "/agent-pack", description: "Schemas, prompts, rules, and checklists." },
      { label: "RFQ Schema", href: "/agent-pack/lmd-rfq-schema.json" }
    ]
  },
  {
    title: "Research and evidence maps",
    status: "Public evidence",
    links: [
      { label: "Evidence Base", href: "/evidence" },
      { label: "Core LMD-AI Sources", href: "/research/core-lmd-ai-sources" },
      { label: "500-record LMD/DED literature map", href: "/research/lmd-literature-scan.json" },
      { label: "Industrial Evidence Map", href: "/industrial-proof" }
    ]
  },
  {
    title: "Technical artifacts",
    status: "Public artifact",
    links: [
      { label: "llms.txt", href: "/llms.txt" },
      { label: "llms-full.txt", href: "/llms-full.txt" },
      { label: "identity.md", href: "/identity.md" }
    ]
  }
];

const proofDecisionPatterns: Record<string, { label: string; href: string }> = {
  "cs15-duisburg-bridge": { label: "Start a brief from this pattern", href: "/tools/#preset=monitoring-anomaly" },
  "cs10-nobufil-extrusion-screw": { label: "Start a brief from this pattern", href: "/tools/#preset=rfq" },
  "cs05-valve-seat-ring": { label: "Start a brief from this pattern", href: "/tools/#preset=surface-cladding" },
  "cs13-zipp-drill": { label: "Start a brief from this pattern", href: "/tools/#preset=surface-cladding" }
};

const proofDecisionPatternText: Record<string, string> = {
  "cs15-duisburg-bridge": "Large-scale LMD requires evidence planning, monitoring context, and an inspection boundary.",
  "cs10-nobufil-extrusion-screw": "Repair/RFQ quality depends on complete facts, downtime context, and service context.",
  "cs05-valve-seat-ring": "Surface function needs material, heat, finishing, inspection, and acceptance context.",
  "cs13-zipp-drill": "Build-and-coat routes need geometry, surface function, material, finishing, and validation."
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": `${SITE.canonicalUrl}/public-work#page`,
  url: `${SITE.canonicalUrl}/public-work`,
  name: title,
  description,
  mainEntity: { "@id": `${SITE.canonicalUrl}/identity#manish-sharma`, name: PERSON.name }
};
---

<Layout title={`${title} - Manish Sharma Lab`} description={description} canonical="/public-work" jsonLd={jsonLd}>
  <div class="public-work-index">
  <div class="public-work-chapter public-work-chapter--identity" data-page-chapter="identity">
  <section class="site-shell section-y public-work-index__masthead">
    <div class="public-work-index__masthead-grid grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(24rem,0.62fr)] lg:items-center">
      <div>
        <p class="metric-label">Public work</p>
        <h1 class="mt-4 text-5xl font-black leading-tight text-white md:text-6xl">{title}</h1>
        <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-300">
          A public map of my current work that can be referenced safely: professional context, LMD/DED work, public frameworks, tools, research maps, GitHub artifacts, and profile links.
        </p>
        <div class="public-work-index__masthead-actions mt-8 flex flex-wrap gap-3">
          <a href="/about" class="btn btn-primary">About Manish</a>
          <a href="/thesis" class="btn btn-secondary">Read the method</a>
          <a href="/domains/lmd-ded" class="btn btn-secondary">Current LMD/DED work</a>
          <a href="/claims" class="btn btn-secondary">Claim source notes</a>
          <a href={LINKS.exafuse} class="btn btn-laser" target="_blank" rel="noreferrer">Exafuse</a>
        </div>
      </div>
      <PageHeroVisual variant="profile" class="hidden lg:block" />
    </div>
  </section>

  <section class="band public-work-index__context-band">
    <div class="site-shell grid gap-3 py-6 md:grid-cols-4">
      {currentContext.map(([label, value]) => (
        <div class="ordered-card public-work-index__context-card p-4">
          <p class="metric-label">{label}</p>
          <p class="mt-2 text-sm font-bold leading-6 text-white">{value}</p>
        </div>
      ))}
    </div>
  </section>
  </div>

  <div class="public-work-chapter public-work-chapter--proof" data-page-chapter="proof">
  <section class="site-shell section-y public-work-index__established">
    <div class="public-work-index__established-grid grid gap-10 lg:grid-cols-[0.85fr_1.15fr]">
      <SectionHeading
        eyebrow="Established work"
        title="Current professional context: LMD/DED"
        description="This is the deepest current public proof for my broader Industrial AI & Decision Systems work: AI for Laser Metal Deposition and Directed Energy Deposition at Exafuse."
      />
      <div class="grid gap-4 md:grid-cols-2">
        {establishedWork.map(([heading, text]) => (
          <article class="ordered-card-strong public-work-index__work-card p-5">
            <p class="metric-label">Established work</p>
            <h2 class="mt-3 text-xl font-black text-white">{heading}</h2>
            <p class="mt-3 text-sm leading-6 text-slate-300">{text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="band section-y public-work-index__proof">
    <div class="site-shell">
      <SectionHeading
        eyebrow="Documented examples"
        title="Company-owned cases used as source-bound industrial context"
        description="Each story keeps the real industrial problem, exact public source, and limitation together. Manish Sharma Lab uses them to explain decision patterns, not to claim company project ownership."
      />
      <div class="public-work-index__case-grid public-work-index__case-grid--proof-led mt-10">
        {EXAFUSE_PUBLIC_PROOF.map((item, index) => {
          const pattern = proofDecisionPatterns[item.id];
          return (
          <article class:list={["public-work-index__case-card public-work-index__case-card--proof", index === 0 && "public-work-index__case-card--lead"]}>
            <div class="public-work-index__case-summary">
              <p class="metric-label">Exafuse public case</p>
              <h2 class="mt-3 text-2xl font-black text-white">{item.title}</h2>
              <p class="public-work-index__case-context">{item.industrialContext}</p>
              {item.publicMetrics.length > 0 && (
                <div class="mt-5 flex flex-wrap gap-2">
                  {item.publicMetrics.slice(0, 3).map((metric) => (
                    <span class="chip chip--steel" title={metric.limitation} data-exafuse-proof-metric={metric.sourcePath}>{metric.value}{metric.unit ? ` ${metric.unit}` : ""} · {metric.label}</span>
                  ))}
                </div>
              )}
              <p class="mt-5 text-sm leading-6 text-slate-300">{item.mainDecisionLesson}</p>
            </div>
            <div class="public-work-index__case-evidence">
              <ExafuseProofMedia proof={item} sizes="(max-width: 767px) calc(100vw - 2rem), 38vw" />
              <div class="public-work-index__case-lesson">
                <p class="metric-label">Useful decision pattern</p>
                <p>{proofDecisionPatternText[item.id]}</p>
              </div>
              <p class="public-work-index__case-limit">{item.whatItDoesNotProve[0]}</p>
              <div class="public-work-index__case-actions mt-6 flex flex-wrap gap-3">
                <a href={pattern.href} class="btn btn-primary">{pattern.label}</a>
                <a href={`/public-work/exafuse/${item.slug}`} class="btn btn-secondary">Read the proof story</a>
              </div>
            </div>
          </article>
        )})}
      </div>
    </div>
  </section>
  </div>

  <div class="public-work-chapter public-work-chapter--supporting" data-page-chapter="supporting-evidence">
  <section class="site-shell section-y public-work-index__collections">
    <div class="grid gap-10">
      {sections.map((section) => (
        <section class="public-work-index__collection border-t border-white/10 pt-8 first:border-t-0 first:pt-0">
          <div class="grid gap-6 lg:grid-cols-[0.28fr_0.72fr]">
            <div>
              <p class="metric-label">{section.status}</p>
              <h2 class="mt-3 text-2xl font-black text-white">{section.title}</h2>
            </div>
            <SourceLinks links={section.links} />
          </div>
        </section>
      ))}
    </div>
  </section>
  </div>

  <div class="public-work-chapter public-work-chapter--reference" data-page-chapter="reference">
  <section class="site-shell section-y public-work-index__sources">
    <div class="public-work-index__source-sequence">
      <div class="public-work-index__source-group public-work-index__source-group--profiles">
        <SectionHeading eyebrow="Public profile links" title="Verified public profiles" />
        <div>
          <SourceLinks links={ACTIVE_PROFILE_LINKS} />
        </div>
      </div>
      <details class="public-work-index__source-group public-work-index__source-group--industrial public-work-index__source-group--collapsible">
        <summary><SectionHeading eyebrow="Public Exafuse context" title="Public industrial context" /></summary>
        <div class="public-work-index__source-links">
          <SourceLinks links={EXAFUSE_SOURCE_LINKS} />
        </div>
      </details>
    </div>
  </section>
  </div>
  </div>
</Layout>
