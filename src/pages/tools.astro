---
import CTAButton from "@components/CTAButton.astro";
import Chip from "@components/Chip.astro";
import Layout from "@layouts/Layout.astro";
import LmdVsSlmAdvisor from "@components/LmdVsSlmAdvisor";
import RepairabilityQuickCheck from "@components/RepairabilityQuickCheck";
import RfqStructureConverter from "@components/RfqStructureConverter";
import SectionHeading from "@components/SectionHeading.astro";
import VisualPanel from "@components/VisualPanel.astro";
import { SITE } from "@data/site";
import { EXAFUSE_LINKS } from "@data/siteConfig";

const title = "LMD Decision Workbench - Manish Sharma Lab";
const description =
  "Frontend-only LMD Decision Workbench for turning vague LMD/DED questions into known facts, missing information, risk flags, and a next action.";

const toolStats = [
  ["Runtime", "Frontend-only"],
  ["Data sent", "None by this site"],
  ["Output type", "Preliminary decision support"],
  ["Final route", "Expert review / Exafuse RFQ"]
];

const workbenchJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "@id": `${SITE.canonicalUrl}/tools#lmd-decision-workbench`,
  name: "LMD Decision Workbench",
  url: `${SITE.canonicalUrl}/tools`,
  applicationCategory: "EngineeringApplication",
  operatingSystem: "Web browser",
  description,
  author: { "@id": `${SITE.canonicalUrl}/identity#manish-sharma` },
  isAccessibleForFree: true,
  featureList: [
    "LMD vs SLM decision support",
    "LMD repairability quick check",
    "RFQ prompt-to-structure conversion",
    "Missing-information and risk-flag summaries"
  ],
  potentialAction: {
    "@type": "UseAction",
    target: `${SITE.canonicalUrl}/tools`
  }
};

const toolBlocks = [
  {
    eyebrow: "Tool 1",
    title: "LMD vs SLM Advisor",
    description: "Compare early process-selection signals for Laser Metal Deposition and SLM/LPBF.",
    output: "A preliminary process direction, why-signals, missing RFQ fields, risk flags, and next action.",
    component: "lmd-vs-slm"
  },
  {
    eyebrow: "Tool 2",
    title: "LMD Repairability Quick Check",
    description: "Screen whether an industrial part has enough preliminary signals to be reviewed as an LMD repair candidate.",
    output: "A repairability score, candidate band, missing evidence, risk flags, and next action.",
    component: "repairability"
  },
  {
    eyebrow: "Tool 3",
    title: "RFQ Prompt-to-Structure Converter",
    description: "Turn free text into known facts, missing fields, risk flags, and a copyable RFQ summary.",
    output: "A structured RFQ preview with part/material/damage hints, missing fields, risk flags, and copy buttons.",
    component: "rfq"
  }
];
---

<Layout title={title} description={description} canonical="/tools" jsonLd={workbenchJsonLd}>
  <section class="site-shell inner-hero-grid section-y">
    <div>
      <div class="flex flex-wrap gap-2">
        <Chip>LMD Decision Workbench</Chip>
        <Chip tone="steel">No backend</Chip>
        <Chip tone="amber">No data sent by this site</Chip>
      </div>
      <p class="metric-label mt-8">Frontend-only workbench</p>
      <h1 class="mt-4 max-w-5xl text-5xl font-black leading-tight text-white md:text-6xl">
        LMD Decision Workbench
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-300">
        Use this page to turn a vague LMD/DED question into known facts, missing information, risk flags, and a next action.
      </p>
      <p class="mt-4 max-w-3xl text-base leading-7 text-slate-400">
        Outputs are preliminary decision support only. Final feasibility depends on material, geometry, service conditions, inspection requirements, and expert review.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <CTAButton href="/agent-pack" variant="primary">Open RFQ Toolkit</CTAButton>
        <CTAButton href="/thesis" variant="secondary">Read the thesis</CTAButton>
        <CTAButton href={EXAFUSE_LINKS.rfqBuilder} variant="laser" external>Prepare Exafuse RFQ</CTAButton>
      </div>
    </div>
    <VisualPanel title="Inputs -> gaps -> risks -> next action" subtitle="LMD decision workbench" />
  </section>

  <section class="band">
    <div class="site-shell grid gap-3 py-6 sm:grid-cols-2 lg:grid-cols-4">
      {toolStats.map(([label, value]) => (
        <div class="ordered-card p-4">
          <p class="metric-label">{label}</p>
          <p class="mt-2 text-sm font-black leading-6 text-white">{value}</p>
        </div>
      ))}
    </div>
  </section>

  {toolBlocks.map((tool, index) => (
    <section class:list={[index % 2 === 1 ? "band" : "", "section-y"]}>
      <div class="site-shell">
        <div class="grid gap-8 lg:grid-cols-[0.86fr_1.14fr] lg:items-end">
          <SectionHeading eyebrow={tool.eyebrow} title={tool.title} description={tool.description} />
          <div class="ordered-card p-5">
            <p class="metric-label">What you get</p>
            <p class="mt-3 text-sm leading-6 text-slate-300">{tool.output}</p>
            <p class="mt-4 text-sm leading-6 text-slate-500">
              Sample outputs are keyword/rule-based and intentionally conservative. Missing information and risk flags stay visible because they often change the decision.
            </p>
          </div>
        </div>
        <div class="mt-10">
          {tool.component === "lmd-vs-slm" && <LmdVsSlmAdvisor client:load />}
          {tool.component === "repairability" && <RepairabilityQuickCheck client:load />}
          {tool.component === "rfq" && <RfqStructureConverter client:load />}
        </div>
      </div>
    </section>
  ))}
</Layout>
