---
import CTAButton from "@components/CTAButton.astro";
import Chip from "@components/Chip.astro";
import Layout from "@layouts/Layout.astro";
import LmdDecisionCockpit from "@components/LmdDecisionCockpit";
import LmdVsSlmAdvisor from "@components/LmdVsSlmAdvisor";
import ProcessLoop from "@components/ProcessLoop.astro";
import RepairabilityQuickCheck from "@components/RepairabilityQuickCheck";
import RfqStructureConverter from "@components/RfqStructureConverter";
import SectionHeading from "@components/SectionHeading.astro";
import { BRIEF_QUALITY_RUBRIC } from "@data/briefStandard";
import { resolveExafuseLink } from "../config/externalLinks";
import { SITE } from "@data/site";

const title = "LMD Decision Workbench - Manish Sharma Lab";
const description =
  "Frontend-only LMD Decision Workbench for turning vague LMD/DED questions into LMD Decision Brief v1.0: known facts, missing information, risk flags, evidence needed, and a next action.";
const exafuseRfqLink = resolveExafuseLink("rfq");

const toolStats = [
  ["Runtime", "Frontend-only"],
  ["Data sent", "None by this site"],
  ["Output type", "Preliminary decision-support"],
  ["Final route", "Expert review / Exafuse RFQ"]
];

const workbenchJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "@id": `${SITE.canonicalUrl}/tools#lmd-decision-workbench`,
  name: "LMD Decision Workbench",
  url: `${SITE.canonicalUrl}/tools`,
  applicationCategory: "EngineeringApplication",
  operatingSystem: "Web browser",
  description,
  author: { "@id": `${SITE.canonicalUrl}/identity#manish-sharma` },
  isAccessibleForFree: true,
  featureList: [
    "Guided LMD Decision Cockpit",
    "LMD vs SLM decision support",
    "LMD repairability quick check",
    "RFQ prompt-to-structure conversion",
    "Missing-information and risk-flag summaries"
  ],
  potentialAction: {
    "@type": "UseAction",
    target: `${SITE.canonicalUrl}/tools`
  }
};

const toolBlocks = [
  {
    eyebrow: "Tool 1",
    id: "route-module",
    title: "Process route module",
    toolName: "LMD vs SLM Advisor",
    description: "Compare early process-selection signals for Laser Metal Deposition and SLM/LPBF.",
    output: "A preliminary process direction, why, missing RFQ fields, risk flags, evidence needed, readiness, and next action.",
    whatChanges: ["Feature size", "Internal channels", "Part size", "Need for local deposition", "Tolerance target", "Material and qualification requirements"],
    component: "lmd-vs-slm"
  },
  {
    eyebrow: "Tool 2",
    id: "repairability-module",
    title: "Repairability module",
    toolName: "LMD Repairability Quick Check",
    description: "Screen whether an industrial part has enough preliminary signals to be reviewed as an LMD repair candidate.",
    output: "A repairability signal, known support, missing information, risk flags, evidence needed, readiness, and next action.",
    whatChanges: ["Unknown material", "Cracks beyond visible damage", "Tight tolerance", "No post-machining route", "Safety-critical service", "No inspection plan"],
    component: "repairability"
  },
  {
    eyebrow: "Tool 3",
    id: "rfq-module",
    title: "RFQ structure module",
    toolName: "RFQ Prompt-to-Structure Converter",
    description: "Turn free text into known facts, missing fields, risk flags, and a copyable RFQ summary.",
    output: "A structured RFQ preview with part/material/damage hints, missing fields, risk flags, evidence needed, readiness, and copy buttons.",
    whatChanges: ["Missing material grade", "Missing drawing/CAD", "Missing damage depth", "Missing operating conditions", "Missing tolerance", "Missing deadline"],
    component: "rfq"
  }
];
---

<Layout title={title} description={description} canonical="/tools" jsonLd={workbenchJsonLd}>
  <section class="site-shell inner-hero-grid section-y">
    <div>
      <div class="flex flex-wrap gap-2">
        <Chip>LMD Decision Workbench</Chip>
        <Chip tone="steel">No backend</Chip>
        <Chip tone="amber">No data sent by this site</Chip>
      </div>
      <p class="metric-label mt-8">Frontend-only workbench</p>
      <h1 class="mt-4 max-w-5xl text-5xl font-black leading-tight text-white md:text-6xl">
        LMD Decision Workbench
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-300">
        Turn a vague LMD/DED request into <strong class="text-white">LMD Decision Brief v1.0</strong>: known facts, missing information, risk flags, evidence needed, and a next action.
      </p>
      <p class="mt-4 max-w-3xl text-base font-bold leading-7 text-cyan-100">
        Every standard brief can travel as a Technical Decision Brief, an Exafuse-ready email draft, an AI-agent-safe summary, Markdown, JSON, grouped checklists, and print/PDF.
      </p>
      <p class="mt-4 max-w-3xl text-base leading-7 text-slate-400">
        Outputs are preliminary decision-support only. Final feasibility depends on material, geometry, service conditions, inspection requirements, and expert review.
      </p>
      <p class="mt-3 max-w-3xl text-sm font-bold leading-6 text-cyan-100">
        This browser tool does not send, store, or analyze your inputs outside this page.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <CTAButton href="#lmd-decision-cockpit" variant="primary">Start Decision Cockpit</CTAButton>
        <CTAButton href="/decision-map" variant="secondary">Open Decision Map</CTAButton>
        <CTAButton href="/brief-standard" variant="secondary">Brief standard</CTAButton>
        <CTAButton href="/demo" variant="secondary">90-second demo</CTAButton>
        <CTAButton href="/agent-pack" variant="secondary">Open RFQ Toolkit</CTAButton>
        <CTAButton href={exafuseRfqLink.href} variant="laser" external>{exafuseRfqLink.label}</CTAButton>
      </div>
    </div>
    <div class="ordered-card-strong p-5">
      <p class="metric-label">Workbench status</p>
      <h2 class="mt-3 text-2xl font-black leading-tight text-white">Browser-local decision support.</h2>
      <div class="mt-5 grid gap-3 sm:grid-cols-2 lg:grid-cols-1 xl:grid-cols-2">
        {toolStats.map(([label, value]) => (
          <div class="ordered-card p-4">
            <p class="metric-label">{label}</p>
            <p class="mt-2 text-sm font-black leading-6 text-white">{value}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="site-shell section-y">
    <LmdDecisionCockpit client:load defaultMode="example" exafuseUrl={exafuseRfqLink.href} exafuseLabel={exafuseRfqLink.label} />
  </section>

  {toolBlocks.map((tool, index) => (
    <section id={tool.id} class:list={[index % 2 === 1 ? "band" : "", "section-y", "scroll-mt-24"]}>
      <div class="site-shell">
        <div class="grid gap-8 lg:grid-cols-[0.86fr_1.14fr] lg:items-end">
          <SectionHeading eyebrow={tool.eyebrow} title={tool.title} description={`${tool.toolName}: ${tool.description}`} />
          <div class="ordered-card p-5">
            <p class="metric-label">Sample output</p>
            <p class="mt-3 text-sm leading-6 text-slate-300">{tool.output}</p>
            <p class="mt-4 text-sm leading-6 text-slate-500">
              Sample outputs are keyword/rule-based and intentionally conservative. Missing information and risk flags stay visible because they often change the decision.
            </p>
            <p class="metric-label mt-5">Your live output</p>
            <p class="mt-3 text-sm leading-6 text-slate-300">
              Change the inputs below. The output updates in your browser only; this site does not send, store, or analyze your entered data.
            </p>
            <p class="metric-label mt-5">What changes the decision</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {tool.whatChanges.map((item) => (
                <span class="rounded-md border border-white/10 bg-white/[0.035] px-2.5 py-1 text-xs font-bold text-slate-300">{item}</span>
              ))}
            </div>
          </div>
        </div>
        <div class="mt-10">
          {tool.component === "lmd-vs-slm" && <LmdVsSlmAdvisor client:load exafuseUrl={exafuseRfqLink.href} exafuseLabel={exafuseRfqLink.label} />}
          {tool.component === "repairability" && <RepairabilityQuickCheck client:load exafuseUrl={exafuseRfqLink.href} exafuseLabel={exafuseRfqLink.label} />}
          {tool.component === "rfq" && <RfqStructureConverter client:load exafuseUrl={exafuseRfqLink.href} exafuseLabel={exafuseRfqLink.label} />}
        </div>
      </div>
    </section>
  ))}

  <section class="site-shell section-y">
    <div class="ordered-card-strong grid gap-6 p-6 lg:grid-cols-[0.38fr_0.62fr] lg:items-start">
      <div>
        <p class="metric-label">Brief quality rubric</p>
        <h2 class="mt-3 text-3xl font-black leading-tight text-white">What makes a brief useful?</h2>
        <p class="mt-4 text-sm font-bold leading-6 text-amber-100">
          This rubric checks brief quality, not technical feasibility.
        </p>
      </div>
      <ul class="grid gap-2 sm:grid-cols-2">
        {BRIEF_QUALITY_RUBRIC.map((item) => (
          <li class="result-card text-sm font-semibold leading-6 text-slate-300">{item}</li>
        ))}
      </ul>
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell">
      <ProcessLoop variant="compact" title="Inputs -> gaps -> risks -> next action" subtitle="The workbench keeps the loop short: structure the question, expose uncertainty, then route serious cases to expert review." />
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell grid gap-5 lg:grid-cols-2">
      <div class="ordered-card-strong p-7">
        <p class="metric-label">From personal decision support</p>
        <h2 class="mt-3 text-3xl font-black leading-tight text-white">Manish Sharma Lab structures the question.</h2>
        <p class="mt-4 text-sm leading-7 text-slate-300">
          The workbench helps separate known facts, missing information, risk flags, and a bounded next action. It is public, frontend-only, and intentionally conservative.
        </p>
        <div class="mt-6">
          <CTAButton href="/decision-map" variant="secondary">Open LMD Decision Map</CTAButton>
        </div>
      </div>
      <div class="ordered-card p-7">
        <p class="metric-label">To Exafuse review</p>
        <h2 class="mt-3 text-3xl font-black leading-tight text-white">Exafuse performs commercial and technical review.</h2>
        <p class="mt-4 text-sm leading-7 text-slate-300">
          Final feasibility depends on material, geometry, service conditions, inspection requirements, and expert review. Use Exafuse for RFQs, services, company claims, and technical/commercial decisions.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <CTAButton href={exafuseRfqLink.href} variant="laser" external>{exafuseRfqLink.label}</CTAButton>
          <CTAButton href="/no-hype" variant="secondary">No-hype boundary</CTAButton>
          <CTAButton href="/contact" variant="secondary">Contact routes</CTAButton>
        </div>
      </div>
    </div>
  </section>
</Layout>
