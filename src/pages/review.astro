---
import Badge from "@components/Badge.astro";
import CTAButton from "@components/CTAButton.astro";
import ReviewFeedbackComposer from "@components/ReviewFeedbackComposer";
import Layout from "@layouts/Layout.astro";
import SectionHeading from "@components/SectionHeading.astro";
import { PUBLIC_REVIEW_TASKS } from "../lib/publicReview";
import { PERSON, SITE } from "@data/site";

const title = "Review a Public LMD Decision Journey";
const description = "Run a short public-safe review of Manish Sharma Lab, create a browser-local feedback note, and help validate decision-support clarity without sharing technical data.";
const protocolUrl = `${SITE.repoUrl}/blob/main/docs/privacy-safe-outcome-validation.md`;

const reviewJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${SITE.canonicalUrl}/review#page`,
  url: `${SITE.canonicalUrl}/review`,
  name: title,
  description,
  author: { "@id": SITE.personId, name: PERSON.name }
};
---

<Layout title={`${title} - Manish Sharma Lab`} description={description} canonical="/review" jsonLd={reviewJsonLd}>
  <section class="site-shell section-y">
    <div class="max-w-4xl">
      <div class="flex flex-wrap gap-2">
        <Badge>Public review</Badge>
        <Badge tone="steel">5 minutes</Badge>
        <Badge tone="laser">No data collection</Badge>
      </div>
      <p class="metric-label mt-8">Human evidence, without technical intake</p>
      <h1 class="mt-4 text-5xl font-black leading-tight text-white md:text-6xl">Review one decision journey. Help make the next one clearer.</h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-300 md:text-xl">
        This is a public-safe, voluntary review path for the site’s navigation, outputs, boundaries, and handoff logic. It is not an RFQ, an engineering assessment, or a request for confidential information.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <CTAButton href="#review-tasks" variant="primary">Choose a public task</CTAButton>
        <CTAButton href={protocolUrl} variant="secondary" external>Read the review protocol</CTAButton>
        <CTAButton href="/contact" variant="ghost">Contact routes</CTAButton>
      </div>
    </div>
  </section>

  <section class="band section-y" id="review-tasks">
    <div class="site-shell">
      <SectionHeading eyebrow="Step 1" title="Pick one short, public-safe task" description="Do not enter real part, customer, employer, personal, credential, or safety-critical information." />
      <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        {PUBLIC_REVIEW_TASKS.map((task, index) => (
          <article class="ordered-card-strong grid content-between p-6">
            <div>
              <p class="metric-label">Task {index + 1}</p>
              <h2 class="mt-3 text-2xl font-black leading-tight text-white">{task.label}</h2>
              <p class="mt-4 text-sm leading-6 text-slate-300">{task.check}</p>
            </div>
            <a href={task.href} class="btn btn-secondary mt-6 w-fit">Open task</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="site-shell section-y">
    <SectionHeading eyebrow="Step 2" title="Record the experience without recording a person" description="The feedback composer produces a browser-local note and compact JSON record. It never sends or saves the selections; you decide whether to copy, download, or share either output." />
    <div class="mt-10">
      <ReviewFeedbackComposer client:visible />
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell grid gap-5 lg:grid-cols-3">
      <article class="ordered-card-strong p-6">
        <p class="metric-label">What this improves</p>
        <h2 class="mt-3 text-2xl font-black text-white">Observed clarity</h2>
        <p class="mt-4 text-sm leading-6 text-slate-300">Task completion, time bands, first friction, and boundary comprehension can reveal whether the site’s intended path is actually understandable.</p>
      </article>
      <article class="ordered-card p-6">
        <p class="metric-label">What this never asks for</p>
        <h2 class="mt-3 text-2xl font-black text-white">Technical or personal intake</h2>
        <p class="mt-4 text-sm leading-6 text-slate-300">No real RFQ, part geometry, material, customer, employer, personal, credential, or safety-critical information belongs in a public review note.</p>
      </article>
      <article class="ordered-card p-6">
        <p class="metric-label">Current evidence status</p>
        <h2 class="mt-3 text-2xl font-black text-white">Ready to test, not yet tested</h2>
        <p class="mt-4 text-sm leading-6 text-slate-300">This page does not claim participant results. The strict score changes only after anonymized aggregate evidence is recorded through the published protocol.</p>
      </article>
    </div>
  </section>
</Layout>
