---
import Badge from "@components/Badge.astro";
import CTAButton from "@components/CTAButton.astro";
import Layout from "@layouts/Layout.astro";
import LmdDecisionMap from "@components/LmdDecisionMap";
import SectionHeading from "@components/SectionHeading.astro";
import SourceLinks from "@components/SourceLinks.astro";
import { resolveExafuseLink } from "../config/externalLinks";
import { DISCLAIMER, PERSON, SITE } from "@data/site";

const title = "Laser Metal Deposition Decision Map";
const description =
  "Interactive, browser-local LMD Decision Map for repair, cladding, large-part additive manufacturing, machining, welding, and replacement review.";
const exafuseRfqLink = resolveExafuseLink("rfq");

const mapQuestions = [
  ["Damaged or new?", "Start by separating repair/cladding from new-build process selection."],
  ["Large or small?", "Large and local often points toward LMD; small and fine-detail may point toward SLM/LPBF or CNC."],
  ["Local repair or full geometry?", "Local material addition is a strong LMD signal; full geometry needs a wider process comparison."],
  ["Wear, corrosion, heat, cracking, or machining error?", "The failure mode changes the material, inspection, and route risk."],
  ["Is SLM better?", "SLM/LPBF can be stronger when the part is small, complex, or needs internal channels."],
  ["Is machining, welding, or replacement better?", "Some requests are not LMD-first until missing stock, crack root cause, economics, or inspection are clarified."]
];

const referenceLinks = [
  { label: "Markdown source", href: "/decision-map/lmd-decision-map-v1.md", description: "AI-readable and copyable text version." },
  { label: "LMD Decision Brief Standard", href: "/brief-standard", description: "Convert the route signal into the standard brief." },
  { label: "LMD vs SLM Advisor", href: "/tools#route-module", description: "Run a narrower process route check." },
  { label: "LMD Repairability Index", href: "/frameworks/lmd-repairability-index", description: "Screen repair-specific readiness." }
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "@id": `${SITE.canonicalUrl}/decision-map#article`,
  url: `${SITE.canonicalUrl}/decision-map`,
  headline: "Laser Metal Deposition Decision Map: Repair, Cladding, Large-Part AM, and SLM Alternatives",
  description,
  author: { "@id": `${SITE.canonicalUrl}/identity#manish-sharma`, name: PERSON.name },
  about: ["Laser Metal Deposition", "Directed Energy Deposition", "SLM", "Laser Cladding", "Industrial Repair", "RFQ Intelligence"],
  isAccessibleForFree: true
};
---

<Layout title={`${title} - Manish Sharma Lab`} description={description} canonical="/decision-map" jsonLd={jsonLd}>
  <div class="decision-map-page">
  <section class="decision-map-page__masthead site-shell section-y">
    <div class="max-w-5xl">
      <div class="flex flex-wrap gap-2">
        <Badge>LMD Decision Map</Badge>
        <Badge tone="steel">Browser-local</Badge>
        <Badge tone="amber">Decision support only</Badge>
      </div>
      <p class="metric-label mt-8">Public decision map</p>
      <h1 class="mt-4 text-5xl font-black leading-tight text-white md:text-6xl">
        Laser Metal Deposition Decision Map
      </h1>
      <p class="mt-4 max-w-4xl text-2xl font-black leading-tight text-cyan-50">
        Repair, cladding, large-part AM, SLM alternatives, machining, welding, and replacement review.
      </p>
      <p class="mt-6 max-w-4xl text-lg leading-8 text-slate-300">
        Use this map to turn a rough part question into a preliminary route signal. It keeps LMD, SLM/LPBF, cladding, machining, welding, replacement, missing information, and inspection evidence in the same decision language.
      </p>
      <p class="mt-4 max-w-4xl text-base font-bold leading-7 text-amber-100">{DISCLAIMER}</p>
      <div class="mt-8 flex flex-wrap gap-3">
        <CTAButton href="#interactive-map" variant="primary">Start map</CTAButton>
        <CTAButton href="/decision-map/lmd-decision-map-v1.md" variant="secondary">Open Markdown</CTAButton>
        <CTAButton href={exafuseRfqLink.href} variant="laser" external>{exafuseRfqLink.label}</CTAButton>
      </div>
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell">
      <SectionHeading
        eyebrow="Decision structure"
        title="The map asks practical buyer questions first"
        description="It does not replace expert review. It makes the route conversation less vague before an RFQ or internal review starts."
      />
      <div class="mt-8 grid gap-3 md:grid-cols-2 lg:grid-cols-3">
        {mapQuestions.map(([question, answer]) => (
          <article class="ordered-card p-4">
            <h2 class="text-lg font-black text-white">{question}</h2>
            <p class="mt-2 text-sm leading-6 text-slate-300">{answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="interactive-map" class="site-shell section-y scroll-mt-24 premium-flow-tool-surface">
    <SectionHeading
      eyebrow="Interactive map"
      title="Choose the route signals"
      description="The output becomes a standard LMD Decision Brief object that can be copied, exported, and routed to expert review."
    />
    <div class="mt-10">
      <LmdDecisionMap client:load exafuseUrl={exafuseRfqLink.href} exafuseLabel={exafuseRfqLink.label} />
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell grid gap-8 lg:grid-cols-[0.42fr_0.58fr]">
      <SectionHeading
        eyebrow="Reference file"
        title="Use the text route map without the interactive tool"
        description="The Markdown source is useful for AI retrieval, internal notes, and source-aware reuse. Use browser print to save this page as a PDF."
      />
      <SourceLinks links={referenceLinks} />
    </div>
  </section>
  </div>
</Layout>
