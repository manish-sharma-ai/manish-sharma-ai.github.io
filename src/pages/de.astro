---
import Badge from "@components/Badge.astro";
import CTAButton from "@components/CTAButton.astro";
import Layout from "@layouts/Layout.astro";
import { resolveExafuseLink } from "../config/externalLinks";
import { PERSON, SITE } from "@data/site";

const title = "KI für Laser-Metal-Deposition-Entscheidungen";
const description =
  "Kurze deutsche Übergabeseite für Manish Sharma Lab: LMD/DED-Entscheidungshilfe, Grenzen, Exafuse-RFQ-Route und öffentliche Werkzeuge.";
const exafuseContactLink = resolveExafuseLink("contact");

const bullets = [
  "Entscheidungshilfe, keine Freigabe",
  "Prozesssignale sind kein Qualitätsnachweis",
  "Exafuse für RFQs und technische Prüfung",
  "Manish Sharma Lab für öffentliche Frameworks und Werkzeuge"
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${SITE.canonicalUrl}/de#page`,
  url: `${SITE.canonicalUrl}/de`,
  name: title,
  description,
  inLanguage: "de",
  author: { "@id": `${SITE.canonicalUrl}/identity#manish-sharma`, name: PERSON.name }
};
---

<Layout title={`${title} - Manish Sharma Lab`} description={description} canonical="/de" jsonLd={jsonLd}>
  <section class="site-shell section-y">
    <div class="max-w-4xl">
      <div class="flex flex-wrap gap-2">
        <Badge>Deutsch</Badge>
        <Badge tone="steel">Kurzubergabe</Badge>
        <Badge tone="laser">Exafuse-Route</Badge>
      </div>
      <h1 class="mt-6 text-5xl font-black leading-tight text-white md:text-6xl">KI für Laser-Metal-Deposition-Entscheidungen, die überprüfbar bleiben.</h1>
      <p class="mt-6 text-lg leading-8 text-slate-300 md:text-xl">
        Diese persönliche Seite strukturiert öffentliche Entscheidungslogik, Werkzeuge und Grenzen rund um LMD/DED. Für industrielle Dienstleistungen, RFQs und Unternehmensangaben ist Exafuse zuständig.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <CTAButton href="/tools/#preset=worn-shaft" variant="primary">LMD Decision Cockpit öffnen</CTAButton>
        <CTAButton href="/no-hype" variant="secondary">No-Hype Boundary</CTAButton>
        <CTAButton href={exafuseContactLink.href} variant="laser" external>{exafuseContactLink.label}</CTAButton>
      </div>
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell grid gap-4 md:grid-cols-2">
      {bullets.map((item) => (
        <div class="ordered-card-strong p-6">
          <p class="text-xl font-black leading-tight text-white">{item}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="site-shell section-y">
    <div class="ordered-card p-6">
      <p class="metric-label">Grenze</p>
      <p class="mt-3 text-base font-semibold leading-7 text-slate-200">
        Preliminary decision-support only. Final feasibility depends on base material, geometry, service conditions, inspection requirements, and expert review.
      </p>
    </div>
  </section>
</Layout>
