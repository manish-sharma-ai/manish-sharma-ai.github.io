---
import Badge from "@components/Badge.astro";
import CTAButton from "@components/CTAButton.astro";
import GermanBriefCopy from "@components/GermanBriefCopy";
import Layout from "@layouts/Layout.astro";
import { resolveExafuseLink } from "../config/externalLinks";
import {
  GERMAN_BRIEF_BOUNDARY,
  formatGermanDecisionBriefTemplateMarkdown
} from "../lib/decisionBrief";
import { PERSON, SITE } from "@data/site";

const title = "Deutsch: Manish Sharma — Industrielle KI und Entscheidungssysteme";
const description =
  "Deutsche Übersicht von Manish Sharma zu industrieller KI und Entscheidungssystemen, mit aktuellem öffentlichem Schwerpunkt auf LMD/DED bei Exafuse und nachweisgestützter Entscheidungshilfe.";
const exafuseContactLink = resolveExafuseLink("contact");
const germanTemplate = formatGermanDecisionBriefTemplateMarkdown();

const bullets = [
  "Manish Sharma: Industrielle KI und Entscheidungssysteme",
  "Arbeitsansatz: Signale → Modell → Entscheiden → Verifizieren",
  "Vorläufige Entscheidungshilfe, keine technische Freigabe",
  "Für technische Machbarkeitsprüfungen und Angebotsanfragen ist Exafuse der richtige Ansprechpartner."
];

const statusLines = [
  "Status: vorläufige technische Einordnung",
  "Geeignet für: Vorbereitung einer Machbarkeitsbewertung oder technischen Anfrage",
  "Nicht geeignet für: Freigabe, Zertifizierung, Bauteilabnahme oder sicherheitskritische Entscheidung"
];

const beforeText = "Verschlissene Stahlwelle im Lagersitzbereich, Fotos vorhanden, CAD fehlt, enge Toleranz.";
const afterItems = [
  ["Bekannte Fakten", "Stahlfamilie, lokaler Verschleiß, Fotos vorhanden, enge Toleranz."],
  ["Kritische Lücken", "Werkstoffgüte, CAD/Zeichnung, Schadenstiefe, Maße, Betriebsbedingungen, Prüfanforderung."],
  ["Risiken", "Enge Toleranz und unbekannte Betriebsbedingungen erhöhen Prüf- und Bearbeitungsaufwand."],
  ["Benötigte Nachweise", "Werkstoffangabe, Schadenskarte, Bearbeitungszugabe, Toleranzziel, Prüfanforderung."],
  ["Nächster Schritt", "Kurzbrief erstellen und eine technische Prüfung oder Angebotsanfrage vorbereiten."]
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${SITE.canonicalUrl}/de#page`,
  url: `${SITE.canonicalUrl}/de`,
  name: title,
  description,
  inLanguage: "de",
  author: { "@id": `${SITE.canonicalUrl}/identity#manish-sharma`, name: PERSON.name }
};
---

<Layout
  title={`${title} - Manish Sharma Lab`}
  description={description}
  canonical="/de"
  jsonLd={jsonLd}
  lang="de"
  alternates={[
    { lang: "de", href: "/de" },
    { lang: "en", href: "/" },
    { lang: "x-default", href: "/" }
  ]}
>
  <div class="info-page info-page--german">
  <section class="site-shell info-page__masthead section-y">
    <div class="max-w-4xl">
      <div class="flex flex-wrap gap-2">
        <Badge>Deutsch</Badge>
        <Badge tone="steel">Industrielle KI</Badge>
        <Badge tone="laser">Aktueller LMD/DED-Nachweis</Badge>
      </div>
      <h1 class="mt-6 text-5xl font-black leading-tight text-white md:text-6xl">
        Industrielle KI für Entscheidungen mit belastbaren Nachweisen.
      </h1>
      <p class="mt-6 text-lg leading-8 text-slate-300 md:text-xl">
        Ich arbeite an industrieller KI und Entscheidungssystemen. Meine stärkste aktuelle öffentliche Arbeit liegt in Laserauftragschweißen, Laser Metal Deposition (LMD) und Directed Energy Deposition (DED) bei Exafuse. Mein Arbeitsansatz verbindet Signale, Modelle, Entscheidungen und Verifizierung.
      </p>
      <p class="mt-4 text-base leading-7 text-slate-400">
        Für mich ist eine Modellvorhersage nur ein Teil der Aufgabe. Sie muss in eine klare nächste Handlung, offene Unsicherheiten und einen nachvollziehbaren Prüfpfad eingeordnet werden. Das LMD-Entscheidungswerkzeug hilft, diese Punkte vor einer technischen Prüfung zu strukturieren; Ihre Eingaben bleiben dabei im Browser dieses Geräts.
      </p>
      <div class="mt-6 rounded-lg border border-amber-300/25 bg-amber-400/10 p-4 text-sm font-bold leading-6 text-amber-50">
        <ul class="grid gap-2">
          {statusLines.map((line) => <li>{line}</li>)}
        </ul>
        <p class="mt-3">{GERMAN_BRIEF_BOUNDARY}</p>
      </div>
      <div class="mt-8 flex flex-wrap gap-3">
        <CTAButton href="/tools/#preset=worn-shaft" variant="primary">LMD-Entscheidungswerkzeug öffnen</CTAButton>
        <CTAButton href="/thesis" variant="secondary">Methode auf Englisch lesen</CTAButton>
        <GermanBriefCopy client:load />
        <CTAButton href={exafuseContactLink.href} variant="laser" external>Exafuse kontaktieren</CTAButton>
      </div>
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell grid gap-4 md:grid-cols-2">
      {bullets.map((item) => (
        <div class="ordered-card-strong p-6">
          <p class="text-xl font-black leading-tight text-white">{item}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="site-shell section-y">
    <div class="mb-10 grid gap-5 lg:grid-cols-2">
      <article class="ordered-card p-6">
        <p class="metric-label">Vorher</p>
        <h2 class="mt-3 text-2xl font-black text-white">Vage Anfrage</h2>
        <p class="mt-4 rounded-lg border border-white/10 bg-white/[0.035] p-4 text-sm font-bold leading-6 text-slate-200">{beforeText}</p>
      </article>
      <article class="ordered-card-strong p-6">
        <p class="metric-label">Nachher</p>
        <h2 class="mt-3 text-2xl font-black text-white">Strukturierter Kurzbrief</h2>
        <ul class="mt-4 grid gap-3 text-sm leading-6 text-slate-300">
          {afterItems.map(([label, text]) => (
            <li class="result-card">
              <span class="font-black text-white">{label}:</span> {text}
            </li>
          ))}
        </ul>
      </article>
    </div>
    <div class="grid gap-8 lg:grid-cols-[0.42fr_0.58fr]">
      <div>
        <p class="metric-label">LMD-Entscheidungsbrief v1.0</p>
        <h2 class="mt-3 text-3xl font-black leading-tight text-white">Kurzer, kopierbarer Überblick.</h2>
        <p class="mt-4 text-sm leading-7 text-slate-300">
          Ein kurzer, kopierbarer Überblick über Ziel, Bauteil, Material, vorhandene Daten, fehlende Informationen, Risiken, benötigte Nachweise und den nächsten Prüfschritt.
        </p>
        <div class="mt-6">
          <GermanBriefCopy client:load />
        </div>
      </div>
      <pre class="ordered-card-strong max-h-[36rem] overflow-auto p-5 text-sm leading-6 text-slate-200"><code>{germanTemplate}</code></pre>
    </div>
  </section>
  </div>
</Layout>
