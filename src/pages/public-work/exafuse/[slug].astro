---
import CTAButton from "@components/CTAButton.astro";
import ExafuseProofMedia from "@components/ExafuseProofMedia.astro";
import Layout from "@layouts/Layout.astro";
import {
  EXAFUSE_PUBLIC_PROOF,
  getExafuseProofSource,
  type ExafusePublicProof
} from "@data/exafusePublicProof";
import { PERSON, SITE } from "@data/site";
import { resolveExafuseLink } from "../../../config/externalLinks";

export function getStaticPaths() {
  return EXAFUSE_PUBLIC_PROOF.map((proof) => ({
    params: { slug: proof.slug },
    props: { proof }
  }));
}

const { proof } = Astro.props as { proof: ExafusePublicProof };
const source = getExafuseProofSource(proof);
const exafuseContact = resolveExafuseLink("contact");
const exafuseHome = resolveExafuseLink("home");
const canonical = `/public-work/exafuse/${proof.slug}`;
const title = `${proof.shortTitle}: public proof story`;
const description = `${proof.mainDecisionLesson} Public Exafuse case context interpreted by Manish Sharma Lab.`;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "@id": `${SITE.canonicalUrl}${canonical}#article`,
    headline: title,
    description,
    author: {
      "@type": "Person",
      "@id": `${SITE.canonicalUrl}/identity#manish-sharma`,
      name: PERSON.name
    },
    publisher: {
      "@type": "Organization",
      name: SITE.preferredSiteName,
      url: SITE.canonicalUrl
    },
    mainEntityOfPage: `${SITE.canonicalUrl}${canonical}`,
    isBasedOn: source.href,
    about: [
      { "@type": "Organization", name: "Exafuse", url: exafuseHome.href },
      "Laser Metal Deposition",
      "Industrial decision support"
    ],
    image: {
      "@type": "ImageObject",
      contentUrl: `${SITE.canonicalUrl}${proof.selectedMedia.src}`,
      creditText: "Exafuse",
      caption: proof.captions
    },
    dateModified: proof.lastReviewed
  },
  {
    "@context": "https://schema.org",
    "@type": "CreativeWork",
    name: `Exafuse public case context: ${proof.shortTitle}`,
    url: source.href,
    creator: { "@type": "Organization", name: "Exafuse", url: exafuseHome.href },
    citation: source.href
  }
];
---

<Layout
  title={`${title} - Manish Sharma Lab`}
  description={description}
  canonical={canonical}
  image={proof.selectedMedia.src}
  ogType="article"
  lastUpdated={proof.lastReviewed}
  jsonLd={jsonLd}
>
  <article class="exafuse-proof-story">
    <header class="exafuse-proof-story__masthead site-shell section-y">
      <div class="exafuse-proof-story__masthead-grid">
        <div class="exafuse-proof-story__intro">
          <p class="metric-label">Exafuse public case context</p>
          <h1>{proof.title}</h1>
          <p>{proof.problem}</p>
          <div class="exafuse-proof-story__masthead-actions">
            <CTAButton href="#proof-facts" variant="primary">Inspect the public facts</CTAButton>
            <CTAButton href={source.href} variant="secondary" external>View the Exafuse source</CTAButton>
          </div>
        </div>
        <ExafuseProofMedia proof={proof} loading="eager" sizes="(max-width: 900px) calc(100vw - 2rem), 52vw" />
      </div>
    </header>

    <section class="exafuse-proof-story__ownership" aria-label="Ownership boundary">
      <div class="site-shell">
        <p><strong>Exafuse owns the company case and commercial route.</strong> Manish Sharma Lab uses this public context to explain a decision pattern, not to claim project execution, engineering approval, or certification.</p>
      </div>
    </section>

    <section class="site-shell section-y exafuse-proof-story__route" aria-labelledby="route-title">
      <div class="exafuse-proof-story__section-heading">
        <p class="metric-label">Public route</p>
        <h2 id="route-title">The physical context and decision route</h2>
      </div>
      <div class="exafuse-proof-story__route-grid">
        <article>
          <h3>Industrial context</h3>
          <p>{proof.industrialContext}</p>
        </article>
        <article>
          <h3>Public process route</h3>
          <p>{proof.processRoute}</p>
        </article>
        <article>
          <h3>Material context</h3>
          <p>{proof.materialContext}</p>
        </article>
      </div>
    </section>

    <section id="proof-facts" class="exafuse-proof-story__facts" aria-labelledby="facts-title">
      <div class="site-shell section-y">
        <div class="exafuse-proof-story__facts-heading">
          <p class="metric-label">Verified public facts</p>
          <h2 id="facts-title">Facts with source and limit attached</h2>
          <p>These figures are public case context. They are not transferable commitments, acceptance criteria, or proof of another component’s feasibility.</p>
        </div>
        {proof.publicMetrics.length > 0 ? (
          <dl class="exafuse-proof-story__metrics">
            {proof.publicMetrics.map((metric) => (
              <div data-exafuse-proof-metric={metric.sourcePath}>
                <dt>{metric.label}</dt>
                <dd>{metric.value}{metric.unit ? ` ${metric.unit}` : ""}</dd>
                <p>{metric.limitation}</p>
                <a href={source.href} target="_blank" rel="noreferrer">Exafuse source <span aria-hidden="true">→</span></a>
              </div>
            ))}
          </dl>
        ) : (
          <p class="exafuse-proof-story__no-metrics">This public proof story is intentionally presented without numerical performance claims. The source supports the route and evidence context, not a transferable metric.</p>
        )}
      </div>
    </section>

    <section class="site-shell section-y exafuse-proof-story__evidence" aria-labelledby="evidence-title">
      <div class="exafuse-proof-story__evidence-grid">
        <div>
          <p class="metric-label">Evidence and validation</p>
          <h2 id="evidence-title">What the evidence needs to resolve</h2>
          <p>{proof.evidenceAndValidation}</p>
          {proof.monitoringContext && <p class="exafuse-proof-story__monitoring">{proof.monitoringContext}</p>}
        </div>
        <aside aria-label="Decision lesson">
          <p class="metric-label">Decision lesson</p>
          <p>{proof.mainDecisionLesson}</p>
        </aside>
      </div>
    </section>

    <section class="exafuse-proof-story__boundary" aria-labelledby="boundary-title">
      <div class="site-shell section-y exafuse-proof-story__boundary-grid">
        <div>
          <p class="metric-label">What this public case demonstrates</p>
          <h2 id="boundary-title">Useful public context—without stretching the claim</h2>
          <ul>
            {proof.whatItProves.map((item) => <li>{item}</li>)}
          </ul>
        </div>
        <div>
          <p class="metric-label">What it does not demonstrate</p>
          <ul>
            {proof.whatItDoesNotProve.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </div>
    </section>

    <section class="site-shell section-y exafuse-proof-story__interpretation" aria-labelledby="interpretation-title">
      <div class="exafuse-proof-story__interpretation-grid">
        <div>
          <p class="metric-label">Manish Sharma Lab interpretation</p>
          <h2 id="interpretation-title">Use the case to improve the next question</h2>
          <p>{proof.interpretationByManishSharmaLab}</p>
        </div>
        <nav aria-label="Related decision artifacts" class="exafuse-proof-story__related">
          <p class="metric-label">Related decision artifact</p>
          <a href="/tools#lmd-decision-cockpit">Run the LMD Decision Cockpit <span aria-hidden="true">→</span></a>
          <a href="/brief-standard">Read the LMD Decision Brief standard <span aria-hidden="true">→</span></a>
          <a href="/frameworks">Explore all frameworks <span aria-hidden="true">→</span></a>
        </nav>
      </div>
    </section>

    <section class="site-shell exafuse-proof-story__source-route" aria-label="Source and commercial route">
      <div>
        <p class="metric-label">Exact public source</p>
        <a href={source.href} target="_blank" rel="noreferrer">{source.label} <span aria-hidden="true">→</span></a>
        {proof.liveSourceStatus === "verified-index" && <p>The public case index is linked because an individual production case URL has not been independently confirmed for this import.</p>}
      </div>
      <div>
        <p class="metric-label">Company route</p>
        <a href={exafuseContact.href} target="_blank" rel="noreferrer">Contact Exafuse for company review, services, or RFQ <span aria-hidden="true">→</span></a>
      </div>
    </section>
  </article>
</Layout>
