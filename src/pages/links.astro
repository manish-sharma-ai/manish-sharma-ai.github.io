---
import Layout from "@layouts/Layout.astro";
import SectionHeading from "@components/SectionHeading.astro";
import SourceLinks from "@components/SourceLinks.astro";
import { PROFILE_LINKS } from "@data/profiles";

const title = "Links - Manish Sharma Lab";
const description = "Public links for Manish Sharma, Exafuse, GitHub, LinkedIn, and planned research profiles.";
---

<Layout title={title} description={description} canonical="/links">
  <section class="site-shell py-16 md:py-20">
    <SectionHeading eyebrow="Links" title="Public profiles and references" description="Active public links are clickable. Planned research profiles are shown without broken placeholder URLs." />
    <div class="mt-10">
      <SourceLinks links={PROFILE_LINKS} />
    </div>
  </section>
</Layout>
