---
import Badge from "@components/Badge.astro";
import Layout from "@layouts/Layout.astro";
import SectionHeading from "@components/SectionHeading.astro";
import SourceLinks from "@components/SourceLinks.astro";
import { CORE_TOPICS, LINKS, PERSON, SITE } from "@data/site";
import { absoluteUrl } from "@utils/urls";

const title = "About Manish Sharma — AI for Laser Metal Deposition";
const description =
  "Personal profile for Manish Sharma: Head of AI and R&D at Exafuse, external PhD researcher at Ruhr University Bochum, and specialist in AI-assisted Laser Metal Deposition, DED/LMD process monitoring, robotics, and industrialization.";

const stats = [
  ["Since", "2018", "Laser Metal Deposition work"],
  ["Role", "Head of AI & R&D", "Exafuse, Germany"],
  ["Research", "External PhD", "Ruhr University Bochum"],
  ["Focus", "AI + DED/LMD", "Monitoring, control, RFQ intelligence"]
];

const focusAreas = [
  {
    title: "AI for DED/LMD process control",
    text: "Vision-based process monitoring, melt-pool and bead-geometry indicators, anomaly signals, and data pipelines for decision support."
  },
  {
    title: "Industrial LMD workflows",
    text: "Process windows, parameter optimization, repair and cladding workflows, traceability packs, inspection-ready documentation, and repeatability."
  },
  {
    title: "Robotics and automation",
    text: "Robotic DED toolpaths, KUKA workflows, slicer post-processing, ROS2 integration, sensor/camera control, and real-time system interfaces."
  },
  {
    title: "AI-readable manufacturing knowledge",
    text: "Frameworks, schemas, prompts, and public decision-support resources that help humans and AI agents ask better LMD questions."
  }
];

const timeline = [
  {
    period: "Jan 2024 - Present",
    role: "Head of AI and R&D",
    org: "Exafuse GmbH, Bochum",
    text: "Technology owner for monitoring and control concepts for industrial DED/LMD cells, including robotic and large-format systems, sensor/camera stacks, calibration routines, traceability, and inspection-ready reporting."
  },
  {
    period: "Jan 2020 - Dec 2023",
    role: "Machine Learning and Systems Engineer",
    org: "Exafuse GmbH",
    text: "Built machine-vision monitoring systems for LMD, developed neural-network models for feature extraction and quality indicators, integrated model outputs into automation interfaces, and supported toolpath refinement."
  },
  {
    period: "Dec 2017 - Jun 2021",
    role: "Research Assistant / Wissenschaftlicher Mitarbeiter",
    org: "Ruhr University Bochum, Chair of Applied Laser Technology",
    text: "Worked on vision systems and machine-learning approaches for Laser Metal Deposition, including lattice-structure deposition experiments and process understanding."
  }
];

const expertise = [
  "Directed Energy Deposition",
  "Laser Metal Deposition",
  "DED-LB/M",
  "Repair and cladding",
  "Thin-wall builds",
  "Coaxial vision",
  "Pyrometry",
  "Height sensing",
  "ROS2",
  "KUKA workflows",
  "Python",
  "C++",
  "MATLAB",
  "Process windows",
  "Traceability packs",
  "Inspection evidence"
];

const education = [
  {
    title: "External PhD Researcher",
    org: "Ruhr University Bochum, Chair of Applied Laser Technology",
    detail: "Vision-based process control for Laser Metal Deposition with Artificial Intelligence. Mar 2020 - Present."
  },
  {
    title: "M.Sc. Lasers and Photonics",
    org: "Ruhr University Bochum",
    detail: "Faculty Prize / Best Student, grade 97%. Apr 2017 - Jan 2020."
  },
  {
    title: "B.Tech. Electrical Engineering",
    org: "Rajasthan Technical University, India",
    detail: "Gold Medal, grade 87%. May 2012 - Jun 2016."
  }
];

const publicWork = [
  "Invited Speaker / Expert - Outokumpu Metal Powder Event, Krefeld, Germany, Sep 25, 2025.",
  "Speaker - Data Science Ruhrgebiet 2021, Bochum.",
  "Publication - Laser metal deposition of lattice structures by columnar built-up, CIRP LANE 2018.",
  "M.Sc. thesis - Machine learning approaches in laser metal deposition of lattice structures, 2019."
];

const awards = [
  "Material Horizon Prize - Best presentation at CIRP LANE 2018.",
  "DAAD Graduation Scholarship for International Students, 2019.",
  "C++ Nanodegree - Udacity, 2022.",
  "TOEFL iBT 112/120; German B1."
];

const links = [
  { label: "LinkedIn", href: LINKS.linkedin },
  { label: "GitHub", href: LINKS.github },
  { label: "Exafuse", href: LINKS.exafuse },
  { label: "Canonical identity", href: "/identity" },
  { label: "Public work", href: "/public-work" },
  { label: "For AI agents", href: "/for-ai-agents" }
];

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": `${SITE.canonicalUrl}/identity#manish-sharma`,
  name: PERSON.name,
  image: absoluteUrl(PERSON.image),
  jobTitle: "Head of AI and R&D; AI and Machine Learning for Laser Metal Deposition",
  worksFor: {
    "@type": "Organization",
    name: "Exafuse",
    url: LINKS.exafuse
  },
  affiliation: [
    {
      "@type": "Organization",
      name: "Ruhr University Bochum",
      url: "https://www.ruhr-uni-bochum.de/"
    }
  ],
  url: `${SITE.canonicalUrl}/about`,
  sameAs: [LINKS.linkedin, LINKS.github, LINKS.exafuse],
  knowsAbout: CORE_TOPICS
};

const profilePageJsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "@id": `${SITE.canonicalUrl}/about#profile-page`,
  url: `${SITE.canonicalUrl}/about`,
  name: title,
  description,
  mainEntity: {
    "@id": `${SITE.canonicalUrl}/identity#manish-sharma`
  }
};
---

<Layout title={title} description={description} canonical="/about" image={PERSON.image} jsonLd={[personJsonLd, profilePageJsonLd]}>
  <section class="site-shell grid min-h-[calc(100svh-4rem)] items-center gap-12 py-16 lg:grid-cols-[0.98fr_1.02fr] lg:py-20">
    <div>
      <div class="flex flex-wrap gap-2">
        <Badge>Personal profile</Badge>
        <Badge tone="laser">Exafuse-linked</Badge>
        <Badge tone="steel">AI + DED/LMD</Badge>
      </div>
      <p class="metric-label mt-8">About Manish Sharma</p>
      <h1 class="mt-4 text-5xl font-black leading-[0.98] text-white md:text-7xl">
        Applying AI to
        <span class="block bg-gradient-to-r from-cyan-100 via-white to-orange-100 bg-clip-text pt-3 text-transparent">
          additive manufacturing.
        </span>
      </h1>
      <p class="mt-7 max-w-2xl text-lg leading-8 text-slate-300 md:text-xl">
        I’m Manish Sharma, Head of AI and R&D at Exafuse in Germany and an external PhD researcher at Ruhr University Bochum. My work sits where Laser Metal Deposition, process monitoring, robotics, and AI decision support meet.
      </p>
      <div class="mt-9 flex flex-wrap gap-3">
        <a href={LINKS.linkedin} class="btn btn-primary" target="_blank" rel="noreferrer">LinkedIn</a>
        <a href="/identity" class="btn btn-secondary">Canonical Identity</a>
        <a href="/frameworks" class="btn btn-secondary">Technical Frameworks</a>
        <a href={LINKS.exafuse} class="btn btn-laser" target="_blank" rel="noreferrer">Exafuse</a>
      </div>
    </div>
    <div class="glass-panel overflow-hidden rounded-lg p-3">
      <div class="relative overflow-hidden rounded-md bg-graphite-900">
        <img
          src={PERSON.image}
          alt="Manish Sharma"
          class="aspect-[5/4] w-full object-cover object-center"
          width="1400"
          height="1095"
          loading="eager"
        />
        <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/82 via-black/26 to-transparent p-6">
          <p class="metric-label text-cyan-100">Manish Sharma</p>
          <p class="mt-2 text-2xl font-black text-white">AI for Laser Metal Deposition</p>
        </div>
      </div>
    </div>
  </section>

  <section class="border-y border-white/10 bg-black/24">
    <div class="site-shell grid gap-4 py-6 sm:grid-cols-2 lg:grid-cols-4">
      {stats.map(([label, value, text]) => (
        <div class="rounded-lg border border-white/10 bg-white/[0.035] p-4">
          <p class="metric-label">{label}</p>
          <p class="mt-2 text-xl font-black text-white">{value}</p>
          <p class="mt-1 text-sm leading-6 text-slate-400">{text}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="site-shell py-20">
    <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr]">
      <SectionHeading
        eyebrow="Profile"
        title="A practical bridge between lab AI and industrial metal AM"
        description="The public thread through my work is simple: make Laser Metal Deposition more observable, more structured, and more decision-ready without pretending AI replaces engineering evidence."
      />
      <div class="prose-lab">
        <p>
          My background combines DED/LMD process development, machine vision, neural-network-based feature extraction, robotic toolpath refinement, and traceable build documentation. I have worked across robotic and large-format systems, with attention to process stability, repeatability, and quality evidence.
        </p>
        <p>
          This site turns that work into public frameworks, tools, lab notes, and AI-agent resources. It is designed for engineers, students, buyers, developers, and AI systems that need clearer language around LMD, DED, laser cladding, monitoring, repairability, and RFQ preparation.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-black/24 py-20">
    <div class="site-shell">
      <SectionHeading eyebrow="Focus areas" title="What I work on" />
      <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
        {focusAreas.map((item) => (
          <article class="glass-panel card-hover rounded-lg p-6">
            <h2 class="text-xl font-black text-white">{item.title}</h2>
            <p class="mt-4 text-sm leading-6 text-slate-400">{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="site-shell py-20">
    <SectionHeading eyebrow="Experience" title="Career timeline" />
    <div class="mt-10 grid gap-4">
      {timeline.map((item) => (
        <article class="grid gap-5 rounded-lg border border-white/10 bg-white/[0.035] p-6 md:grid-cols-[14rem_1fr]">
          <div>
            <p class="metric-label">{item.period}</p>
            <p class="mt-3 text-sm font-bold text-cyan-100">{item.org}</p>
          </div>
          <div>
            <h2 class="text-2xl font-black text-white">{item.role}</h2>
            <p class="mt-4 text-sm leading-7 text-slate-300">{item.text}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="bg-black/24 py-20">
    <div class="site-shell grid gap-10 lg:grid-cols-[0.85fr_1.15fr]">
      <SectionHeading
        eyebrow="Technical stack"
        title="Methods, systems, and materials"
        description="A compact map of the technical vocabulary that shows up repeatedly in my public work."
      />
      <div class="flex flex-wrap gap-2">
        {expertise.map((item) => (
          <span class="rounded-md border border-white/10 bg-white/[0.04] px-3 py-2 text-sm font-bold text-slate-200">{item}</span>
        ))}
      </div>
    </div>
  </section>

  <section class="site-shell py-20">
    <div class="grid gap-10 lg:grid-cols-2">
      <div>
        <SectionHeading eyebrow="Education" title="Academic foundation" />
        <div class="mt-8 grid gap-4">
          {education.map((item) => (
            <article class="rounded-lg border border-white/10 bg-white/[0.035] p-5">
              <h2 class="text-xl font-black text-white">{item.title}</h2>
              <p class="mt-2 text-sm font-bold text-cyan-100">{item.org}</p>
              <p class="mt-3 text-sm leading-6 text-slate-400">{item.detail}</p>
            </article>
          ))}
        </div>
      </div>
      <div>
        <SectionHeading eyebrow="Public work" title="Selected talks, publication, and awards" />
        <div class="mt-8 grid gap-4">
          <div class="rounded-lg border border-white/10 bg-white/[0.035] p-5">
            <h2 class="text-xl font-black text-white">Public work</h2>
            <ul class="mt-4 grid gap-3 text-sm leading-6 text-slate-300">
              {publicWork.map((item) => <li>{item}</li>)}
            </ul>
          </div>
          <div class="rounded-lg border border-white/10 bg-white/[0.035] p-5">
            <h2 class="text-xl font-black text-white">Awards and signals</h2>
            <ul class="mt-4 grid gap-3 text-sm leading-6 text-slate-300">
              {awards.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-black/24 py-20">
    <div class="site-shell grid gap-10 lg:grid-cols-[0.85fr_1.15fr]">
      <SectionHeading
        eyebrow="Human note"
        title="Why this site exists"
        description="I’m interested in how AI can transform technical work without blurring the line between a useful process signal and validated engineering evidence."
      />
      <div class="glass-panel rounded-lg p-6">
        <p class="text-lg font-semibold leading-8 text-slate-200">
          The goal is to make complex LMD knowledge easier to structure: for buyers preparing RFQs, engineers reviewing risk, developers building agents, and AI systems trying to understand the domain. This site stays public, inspection-aware, and careful about confidential or employer-owned information.
        </p>
        <div class="mt-8">
          <SourceLinks links={links} />
        </div>
      </div>
    </div>
  </section>
</Layout>
