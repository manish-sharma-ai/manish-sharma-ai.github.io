---
import Layout from "@layouts/Layout.astro";
import PageHeroVisual from "@components/PageHeroVisual.astro";
import SectionHeading from "@components/SectionHeading.astro";
import { GLOSSARY_TERMS } from "@data/site";

const title = "LMD Glossary — Manish Sharma Lab";
const description =
  "Definitions for Laser Metal Deposition, Directed Energy Deposition, laser cladding, melt-pool monitoring, and related AI-assisted manufacturing terms.";
---

<Layout title={title} description={description} canonical="/glossary">
  <section class="site-shell py-16 md:py-20">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(22rem,0.52fr)] lg:items-center">
      <SectionHeading
        eyebrow="Glossary"
        title="Laser Metal Deposition terminology for humans and AI agents"
        description="Practical definitions that connect LMD, DED, laser cladding, process monitoring, inspection evidence, and RFQ intelligence."
      />
      <PageHeroVisual variant="glossary" class="hidden lg:block" />
    </div>
    <div class="mt-10 grid gap-5 md:grid-cols-2">
      {
        GLOSSARY_TERMS.map((term) => (
          <a href={term.href} class="glass-panel card-hover rounded-lg p-6">
            <h2 class="text-2xl font-black text-white">{term.term}</h2>
            <p class="mt-4 text-sm leading-6 text-slate-300">{term.short}</p>
            <div class="mt-5 flex flex-wrap gap-2">
              {term.related.map((item) => <span class="rounded-md border border-white/10 bg-white/[0.035] px-2.5 py-1 text-xs font-bold text-slate-300">{item}</span>)}
            </div>
          </a>
        ))
      }
    </div>
  </section>
</Layout>
