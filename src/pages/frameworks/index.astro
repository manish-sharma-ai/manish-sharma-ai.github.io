---
import CTAButton from "@components/CTAButton.astro";
import Chip from "@components/Chip.astro";
import FrameworkCard from "@components/FrameworkCard.astro";
import Layout from "@layouts/Layout.astro";
import ProcessLoop from "@components/ProcessLoop.astro";
import SectionHeading from "@components/SectionHeading.astro";
import { RESEARCH_SCAN } from "@data/evidence";
import { FRAMEWORKS, LINKS } from "@data/site";

const title = "Public LMD and AI Frameworks - Manish Sharma Lab";
const description =
  "Inspection-aware frameworks for LMD/DED repair, RFQ intelligence, process monitoring, AI readiness, and quality evidence.";

const stats = [
  ["Frameworks", String(FRAMEWORKS.length)],
  ["Reference map", `${RESEARCH_SCAN.count} records`],
  ["Main domain", "LMD / DED"],
  ["Boundary", "Decision support only"]
];
---

<Layout title={title} description={description} canonical="/frameworks">
  <section class="site-shell inner-hero-grid section-y">
    <div>
      <div class="flex flex-wrap gap-2">
        <Chip>Framework library</Chip>
        <Chip tone="steel">Inspection-aware</Chip>
        <Chip tone="amber">Preliminary decision-support</Chip>
      </div>
      <p class="metric-label mt-8">Public LMD and AI frameworks</p>
      <h1 class="mt-4 max-w-5xl text-5xl font-black leading-tight text-white md:text-6xl">
        Structured decisions for LMD, monitoring, RFQs, and evidence.
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-300">
        Each framework uses the same discipline: separate signals, assumptions, risk flags, inspection needs, and expert-review boundaries before recommendations become claims.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <CTAButton href="/identity" variant="primary">Manish Sharma - AI for Laser Metal Deposition</CTAButton>
        <CTAButton href="/agent-pack" variant="secondary">LMD Agent Pack</CTAButton>
        <CTAButton href="/tools" variant="secondary">Open tools</CTAButton>
        <CTAButton href="/for-ai-agents" variant="secondary">For AI agents</CTAButton>
      </div>
    </div>
    <ProcessLoop variant="micro" title="Framework operating model" />
  </section>

  <section class="band">
    <div class="site-shell grid gap-3 py-6 sm:grid-cols-2 lg:grid-cols-4">
      {stats.map(([label, value]) => (
        <div class="ordered-card p-4">
          <p class="metric-label">{label}</p>
          <p class="mt-2 text-sm font-black leading-6 text-white">{value}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="site-shell section-y">
    <SectionHeading
      eyebrow="Framework index"
      title="Choose the decision layer you need"
      description="Use the cards as a cockpit: quality evidence, repairability, AI readiness, RFQ structure, failure language, and maturity planning."
    />
    <div class="equal-card-grid mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {FRAMEWORKS.map((framework) => <FrameworkCard {...framework} />)}
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell grid gap-5 lg:grid-cols-3">
      <div class="ordered-card-strong p-7 lg:col-span-2">
        <p class="metric-label">Evidence discipline</p>
        <h2 class="mt-3 text-3xl font-black leading-tight text-white">Sense -> Model -> Decide -> Verify</h2>
        <p class="mt-4 max-w-3xl leading-7 text-slate-300">
          The frameworks are not certification systems. They are public decision aids for turning rough LMD/DED questions into clearer facts, gaps, risk flags, source links, and verification needs.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <CTAButton href="/thesis" variant="primary">Read the thesis</CTAButton>
          <CTAButton href="/evidence" variant="secondary">Evidence base</CTAButton>
          <CTAButton href="/research/core-lmd-ai-sources" variant="secondary">Core source map</CTAButton>
        </div>
      </div>
      <div class="ordered-card p-7">
        <p class="metric-label">Commercial boundary</p>
        <h2 class="mt-3 text-2xl font-black leading-tight text-white">RFQs and delivery claims belong to Exafuse.</h2>
        <p class="mt-4 text-sm leading-6 text-slate-400">
          Use this personal site for public frameworks and explanation. Use Exafuse for company services, case studies, quality pages, and commercial contact.
        </p>
        <CTAButton href={LINKS.exafuse} variant="laser" external class="mt-6">Visit Exafuse</CTAButton>
      </div>
    </div>
  </section>
</Layout>
