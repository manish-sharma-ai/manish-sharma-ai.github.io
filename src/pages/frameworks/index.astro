---
import FrameworkCard from "@components/FrameworkCard.astro";
import Layout from "@layouts/Layout.astro";
import PageHeroVisual from "@components/PageHeroVisual.astro";
import SectionHeading from "@components/SectionHeading.astro";
import { RESEARCH_SCAN } from "@data/evidence";
import { FRAMEWORKS } from "@data/site";

const title = "Public LMD and AI Frameworks - Manish Sharma Lab";
const description =
  "Public frameworks for industrial AI decisions that connect signals, assumptions, decisions, and verification evidence, grounded in LMD/DED.";
---

<Layout title={title} description={description} canonical="/frameworks">
  <section class="site-shell section-y">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(24rem,0.62fr)] lg:items-center">
      <SectionHeading
        eyebrow="Frameworks"
        title="Working frameworks for LMD decisions"
        description="These public frameworks apply a common rule: industrial AI should connect signals, assumptions, decisions, and verification evidence. The current applied framework library is grounded in LMD/DED."
      />
      <PageHeroVisual variant="frameworks" class="hidden lg:block" />
    </div>
    <div class="equal-card-grid mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {FRAMEWORKS.map((framework) => <FrameworkCard {...framework} />)}
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell grid gap-5 md:grid-cols-2">
      <div class="ordered-card-strong card-hover grid min-h-[18rem] content-between p-8 md:col-span-2">
        <div>
          <p class="metric-label">Operating thesis</p>
          <h2 class="mt-4 text-3xl font-black text-white">Sense -> Model -> Decide -> Verify</h2>
          <p class="mt-4 max-w-4xl leading-7 text-slate-300">
            The public operating model behind the frameworks: connect observed signals to model assumptions, decision boundaries, and verification evidence.
          </p>
        </div>
        <a href="/thesis" class="btn btn-primary mt-7 w-fit">Read the thesis</a>
      </div>
      <div class="ordered-card-strong card-hover grid min-h-[18rem] content-between p-8 md:col-span-2">
        <div>
          <p class="metric-label">Applied LMD/DED frameworks</p>
          <h2 class="mt-4 text-3xl font-black text-white">{RESEARCH_SCAN.count}-record LMD/DED reference map</h2>
          <p class="mt-4 max-w-4xl leading-7 text-slate-300">
            The frameworks are connected to checked DED/LMD facts, my field notes, and a reference map that keeps the vocabulary grounded in real research literature.
          </p>
        </div>
        <a href="/evidence" class="btn btn-primary mt-7 w-fit">Open Evidence Base</a>
      </div>
      <div class="ordered-card-strong card-hover grid min-h-[18rem] content-between p-8">
        <div>
        <p class="metric-label">New framework</p>
        <h2 class="mt-4 text-3xl font-black text-white">LMD Failure Atlas</h2>
        <p class="mt-4 leading-7 text-slate-300">
          A working vocabulary for connecting LMD failure modes, monitoring visibility, AI risk signals, inspection methods, and validation evidence.
        </p>
        </div>
        <a href="/frameworks/lmd-failure-atlas" class="btn btn-primary mt-7">Open Failure Atlas</a>
      </div>
      <div class="ordered-card-strong card-hover grid min-h-[18rem] content-between p-8">
        <div>
        <p class="metric-label">New framework</p>
        <h2 class="mt-4 text-3xl font-black text-white">LMD-AI Maturity Model</h2>
        <p class="mt-4 leading-7 text-slate-300">
          A staged model for moving from manual records to structured data capture, offline analytics, AI decision support, and validated closed-loop development.
        </p>
        </div>
        <a href="/frameworks/lmd-ai-maturity-model" class="btn btn-primary mt-7">Open Maturity Model</a>
      </div>
    </div>
  </section>
</Layout>
