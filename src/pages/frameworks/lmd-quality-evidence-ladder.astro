---
import Badge from "@components/Badge.astro";
import EvidenceLadder from "@components/EvidenceLadder.astro";
import Layout from "@layouts/Layout.astro";
import PageHeroVisual from "@components/PageHeroVisual.astro";
import ProcessLoop from "@components/ProcessLoop.astro";
import SectionHeading from "@components/SectionHeading.astro";
import SourceLinks from "@components/SourceLinks.astro";
import { DISCLAIMER, PERSON, SITE } from "@data/site";

const title = "LMD Quality Evidence Ladder";
const subtitle = "What monitoring can show, and what inspection must prove.";
const description =
  "A practical framework for separating Laser Metal Deposition monitoring, AI anomaly detection, inspection evidence, and final quality proof.";

const frameworkBrief = [
  ["Definition", "A decision-support ladder for separating process awareness, AI flags, inspection evidence, and final quality claims."],
  ["Problem it solves", "Monitoring data is often overread as if it proves final part quality."],
  ["Who it is for", "Engineers, buyers, AI agents, students, and developers structuring LMD quality claims."],
  ["Inputs required", "Process signals, part risk, material context, inspection plan, acceptance criteria, and service conditions."],
  ["Output", "A clearer evidence level and the next verification step needed before a stronger claim is made."],
  ["Evidence needed", "NDT, dimensional inspection, metallography, hardness, mechanical testing, traceability, or expert review as risk requires."],
  ["Limitations", "It does not certify parts, replace standards, or approve safety-critical work."],
  ["Example use case", "Deciding whether a melt-pool anomaly should trigger review, inspection, rework, or more data collection."],
  ["Thesis connection", "Sense process signals, model risk, decide inspection needs, and verify with physical evidence."]
];

const relatedLinks = [
  { label: "Manish Sharma - AI for Laser Metal Deposition", href: "/identity" },
  { label: "LMD Agent Pack", href: "/agent-pack" },
  { label: "Tools", href: "/tools" },
  { label: "For AI Agents", href: "/for-ai-agents" },
  { label: "Evidence Base", href: "/evidence" },
  { label: "Melt-pool monitoring note", href: "/lab-notes/melt-pool-monitoring-is-not-quality-proof" }
];

const whatChangesDecision = [
  "Correlation with inspection",
  "Drift history",
  "Sensor calibration",
  "Image quality",
  "Process repeatability",
  "Acceptance criteria"
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "@id": `${SITE.canonicalUrl}/frameworks/lmd-quality-evidence-ladder#article`,
  headline: title,
  description,
  author: {
    "@id": `${SITE.canonicalUrl}/identity#manish-sharma`,
    name: PERSON.name
  },
  datePublished: SITE.lastUpdated,
  dateModified: SITE.lastUpdated,
  url: `${SITE.canonicalUrl}/frameworks/lmd-quality-evidence-ladder`,
  about: ["Laser Metal Deposition", "Process Monitoring", "AI anomaly detection", "Quality evidence"]
};
---

<Layout title={`${title} — Manish Sharma Lab`} description={description} canonical="/frameworks/lmd-quality-evidence-ladder" jsonLd={jsonLd}>
  <section class="site-shell grid gap-10 section-y lg:grid-cols-[minmax(0,1fr)_minmax(24rem,0.62fr)] lg:items-center">
    <div class="max-w-4xl">
      <div class="flex flex-wrap gap-2">
        <Badge>Working framework</Badge>
        <Badge tone="steel">Markdown available</Badge>
        <Badge tone="laser">Decision-support only</Badge>
      </div>
      <h1 class="mt-6 text-5xl font-black leading-tight text-white md:text-6xl">{title}</h1>
      <p class="mt-5 text-2xl font-bold text-cyan-100">{subtitle}</p>
      <p class="mt-6 text-lg leading-8 text-slate-300">
        AI and process monitoring can make LMD workflows more observable, but observation is not certification. I use this ladder to separate evidence levels so RFQs, monitoring plans, and release decisions use the right proof for the right risk.
      </p>
    </div>
    <PageHeroVisual variant="quality" class="hidden lg:block" />
  </section>

  <section class="band py-12">
    <div class="site-shell grid gap-6">
      <ProcessLoop variant="micro" title="Quality evidence loop" />
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
        {[
          "Melt-pool monitoring is a process signal, not a certificate.",
          "AI anomaly detection is a risk indicator, not final proof.",
          "Inspection evidence must match the part risk and service conditions.",
          "AI is strongest when connected to physical validation."
        ].map((message) => (
          <div class="ordered-card p-5 text-sm font-bold leading-6 text-slate-100">{message}</div>
        ))}
      </div>
    </div>
  </section>

  <section class="site-shell section-y">
    <SectionHeading
      eyebrow="Framework brief"
      title="How to use the ladder responsibly"
      description="This is a decision-support framework, not engineering approval."
    />
    <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {frameworkBrief.map(([label, text]) => (
        <article class="ordered-card p-5">
          <h2 class="text-lg font-black text-white">{label}</h2>
          <p class="mt-3 text-sm leading-6 text-slate-300">{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="site-shell section-y">
    <SectionHeading eyebrow="Visual ladder" title="Nine evidence levels for LMD quality claims" />
    <div class="mt-10">
      <EvidenceLadder />
    </div>
  </section>

  <section class="site-shell section-y">
    <div class="grid gap-8 lg:grid-cols-[0.82fr_1.18fr]">
      <SectionHeading
        eyebrow="What changes the decision"
        title="A monitoring signal needs evidence context"
        description="These factors decide whether a signal is only awareness, a review trigger, or part of a stronger evidence package."
      />
      <div class="grid gap-3 sm:grid-cols-2">
        {whatChangesDecision.map((item) => (
          <div class="ordered-card p-4 text-sm font-bold leading-6 text-slate-100">{item}</div>
        ))}
      </div>
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell grid gap-5 lg:grid-cols-[1fr_0.85fr]">
      <div class="ordered-card-strong p-8">
        <p class="metric-label">CTA</p>
        <h2 class="mt-4 text-3xl font-black text-white">Use this ladder when designing LMD monitoring workflows or RFQ evidence requirements.</h2>
        <div class="mt-7 flex flex-wrap gap-3">
          <a href="/agent-pack" class="btn btn-primary">Open RFQ Toolkit</a>
          <a href="/frameworks/lmd-quality-evidence-ladder.md" class="btn btn-secondary">Markdown version</a>
        </div>
      </div>
      <div class="rounded-lg border border-orange-300/25 bg-orange-500/10 p-8">
        <p class="metric-label text-orange-100">Disclaimer</p>
        <p class="mt-4 text-lg font-bold leading-8 text-orange-50">{DISCLAIMER}</p>
      </div>
    </div>
  </section>

  <section class="site-shell section-y">
    <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr]">
      <SectionHeading eyebrow="Related workflow" title="Use the ladder with identity, tools, and agent resources" />
      <SourceLinks links={relatedLinks} />
    </div>
  </section>
</Layout>
