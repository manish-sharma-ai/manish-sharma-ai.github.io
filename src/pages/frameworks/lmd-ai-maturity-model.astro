---
import Badge from "@components/Badge.astro";
import FrameworkArticle from "@components/FrameworkArticle.astro";
import Layout from "@layouts/Layout.astro";
import PageHeroVisual from "@components/PageHeroVisual.astro";
import ProcessLoop from "@components/ProcessLoop.astro";
import SectionHeading from "@components/SectionHeading.astro";
import SourceLinks from "@components/SourceLinks.astro";
import { DISCLAIMER, PERSON, SITE } from "@data/site";

const title = "The LMD-AI Maturity Model by Manish Sharma";
const description =
  "A six-level framework for moving LMD workflows from manual observation and sensor records toward validated, governed AI decision support.";

const frameworkBrief = [
  ["Definition", "A six-level model for moving LMD workflows from manual observation to validated closed-loop control candidates."],
  ["Problem it solves", "Organizations often jump to model claims before data capture, traceability, inspection linkage, and governance are ready."],
  ["Who it is for", "Manufacturing teams, engineers, AI developers, students, and managers planning LMD data maturity."],
  ["Inputs required", "RFQ records, material traceability, CAD/path linkage, logs, monitoring data, inspection outcomes, labels, comparable jobs, governance, and review rules."],
  ["Output", "A maturity level and the next practical capability to build."],
  ["Evidence needed", "Traceable records, linked inspection outcomes, validation results, drift checks, escalation rules, and model-update control."],
  ["Limitations", "It is a planning framework, not a qualification system or proof that closed-loop control is ready or safe."],
  ["Example use case", "Deciding whether a team should improve job IDs and inspection links before starting AI anomaly detection."],
  ["Thesis connection", "Sense records, model maturity, decide the next data capability, and verify with measured outcomes."]
];

const relatedLinks = [
  { label: "Manish Sharma - AI for Laser Metal Deposition", href: "/identity" },
  { label: "LMD Agent Pack", href: "/agent-pack" },
  { label: "Tools", href: "/tools" },
  { label: "For AI Agents", href: "/for-ai-agents" },
  { label: "LMD-AI Readiness Score", href: "/frameworks/lmd-ai-readiness-score" },
  { label: "LMD Quality Evidence Ladder", href: "/frameworks/lmd-quality-evidence-ladder" },
  { label: "Markdown version", href: "/frameworks/lmd-ai-maturity-model.md" }
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "@id": `${SITE.canonicalUrl}/frameworks/lmd-ai-maturity-model#article`,
  headline: title,
  description,
  author: { "@id": `${SITE.canonicalUrl}/identity#manish-sharma`, name: PERSON.name },
  datePublished: "2026-05-09",
  dateModified: SITE.lastUpdated,
  url: `${SITE.canonicalUrl}/frameworks/lmd-ai-maturity-model`,
  about: ["Laser Metal Deposition", "AI maturity", "Process monitoring", "Manufacturing data", "Closed-loop control"]
};

const stages = [
  {
    level: "0",
    title: "Manual observation",
    signal: "Operators watch the process and record judgment in notes, photos, or memory.",
    capability: "AI has no reliable process history to learn from.",
    next: "Start collecting consistent RFQ, material, parameter, photo, and inspection records."
  },
  {
    level: "1",
    title: "Sensor recording",
    signal: "Images, melt-pool video, machine logs, powder feed, laser power, and robot path data are recorded.",
    capability: "AI can help organize records, but linkage to outcomes is still weak.",
    next: "Create job IDs that connect RFQ, CAD/path, parameters, feedstock, and inspection evidence."
  },
  {
    level: "2",
    title: "Offline analysis",
    signal: "Jobs have linked material, geometry, parameters, feedstock batches, monitoring data, and operator notes.",
    capability: "AI can classify anomalies after the job and support offline risk summaries.",
    next: "Connect process signals to measured inspection outcomes and comparable build families."
  },
  {
    level: "3",
    title: "Real-time decision support",
    signal: "Monitoring data, parameter changes, inspection results, and defect labels can be analyzed together.",
    capability: "AI can warn operators during the build and route signals into evidence questions.",
    next: "Validate model behavior against known outcomes and define escalation rules."
  },
  {
    level: "4",
    title: "Semi-closed-loop correction",
    signal: "AI outputs are tested, bounded, logged, reviewed, and connected to expert decisions and controlled parameter-change recommendations.",
    capability: "AI can recommend parameter adjustments under engineering governance.",
    next: "Build governance for model updates, drift checks, and closed-loop experiments."
  },
  {
    level: "5",
    title: "Validated closed-loop control",
    signal: "Validated feedback loops connect process, inspection, and outcome data across repeated jobs.",
    capability: "AI may adjust the process automatically only with inspection-backed validation and controlled qualification.",
    next: "Treat deployment as a qualification program, not a software toggle."
  }
];
---

<Layout title={`${title} - Manish Sharma Lab`} description={description} canonical="/frameworks/lmd-ai-maturity-model" jsonLd={jsonLd}>
  <FrameworkArticle title={title}>
    <Fragment slot="eyebrow">
      <div class="flex flex-wrap gap-2">
        <Badge>Working framework</Badge>
        <Badge tone="steel">Markdown available</Badge>
        <Badge tone="laser">Decision-support only</Badge>
      </div>
    </Fragment>
    <Fragment slot="summary">
      <p class="framework-article__subtitle">
        A six-level model for moving from manual LMD observation to sensor recording, offline analysis, real-time decision support, semi-closed-loop correction, and validated closed-loop control.
      </p>
      <p>{DISCLAIMER}</p>
    </Fragment>
    <Fragment slot="visual"><PageHeroVisual variant="maturity" /></Fragment>

  <section class="band py-8">
    <div class="site-shell">
      <ProcessLoop variant="micro" title="Maturity loop" />
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell grid gap-4 md:grid-cols-3">
      {[
        ["Data before models", "The maturity question is not which model to use first. It is whether process, material, geometry, and inspection data are connected."],
        ["Decision support before autonomy", "Start with missing-information checks, risk routing, and evidence planning before any closed-loop claims."],
        ["Validation before confidence", "Useful AI maturity depends on validation, escalation rules, drift monitoring, and expert review."]
      ].map(([heading, text]) => (
        <div class="ordered-card p-5">
          <h2 class="text-lg font-black text-white">{heading}</h2>
          <p class="mt-3 text-sm leading-6 text-slate-400">{text}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="site-shell section-y">
    <SectionHeading
      eyebrow="Framework brief"
      title="Use maturity as a planning model"
      description={DISCLAIMER}
    />
    <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {frameworkBrief.map(([label, text]) => (
        <article class="ordered-card p-5">
          <h2 class="text-lg font-black text-white">{label}</h2>
          <p class="mt-3 text-sm leading-6 text-slate-300">{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="site-shell section-y">
    <SectionHeading eyebrow="Maturity stages" title="From scattered records to validated loops" />
    <div class="mt-10 grid gap-4">
      {
        stages.map((stage) => (
          <article class="ordered-card grid gap-5 p-6 md:grid-cols-[5rem_1fr]">
            <div class="grid h-16 w-16 place-items-center rounded-lg border border-cyan-300/35 bg-cyan-300/10 font-mono text-2xl font-black text-cyan-100">
              {stage.level}
            </div>
            <div>
              <h2 class="text-2xl font-black text-white">{stage.title}</h2>
              <div class="mt-5 grid gap-4 md:grid-cols-3">
                <p class="text-sm leading-6 text-slate-300"><strong class="text-white">Maturity signal:</strong> {stage.signal}</p>
                <p class="text-sm leading-6 text-cyan-50"><strong class="text-cyan-100">AI capability:</strong> {stage.capability}</p>
                <p class="text-sm leading-6 text-orange-50"><strong class="text-orange-100">Next move:</strong> {stage.next}</p>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
      <SectionHeading
        eyebrow="Related resources"
        title="Use with the readiness score and evidence ladder"
        description="The maturity model explains the organizational path. The readiness score checks the current data foundations. The evidence ladder keeps AI outputs connected to physical validation."
      />
      <div>
        <SourceLinks links={relatedLinks} />
      </div>
    </div>
  </section>
  </FrameworkArticle>
</Layout>
