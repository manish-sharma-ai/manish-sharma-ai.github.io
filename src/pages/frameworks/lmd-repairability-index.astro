---
import Badge from "@components/Badge.astro";
import Layout from "@layouts/Layout.astro";
import PageHeroVisual from "@components/PageHeroVisual.astro";
import ProcessLoop from "@components/ProcessLoop.astro";
import RepairabilityCalculator from "@components/RepairabilityCalculator";
import SectionHeading from "@components/SectionHeading.astro";
import SourceLinks from "@components/SourceLinks.astro";
import { DISCLAIMER, PERSON, SITE } from "@data/site";

const title = "LMD Repairability Index";
const description =
  "A practical way to think about whether an industrial part may be suitable for Laser Metal Deposition repair.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  headline: title,
  description,
  author: { "@id": `${SITE.canonicalUrl}/identity#manish-sharma`, name: PERSON.name },
  datePublished: "2026-05-09",
  dateModified: SITE.lastUpdated,
  url: `${SITE.canonicalUrl}/frameworks/lmd-repairability-index`
};

const categories = [
  "Material compatibility",
  "Damage geometry",
  "Access to repair zone",
  "Heat sensitivity and distortion risk",
  "Post-machining allowance",
  "Required properties",
  "Inspection feasibility",
  "Replacement cost",
  "Downtime cost",
  "Criticality and risk"
];

const bands = [
  ["0-20", "Not enough information or likely unsuitable"],
  ["21-40", "High uncertainty"],
  ["41-60", "Possible but needs engineering review"],
  ["61-80", "Likely candidate if material/inspection align"],
  ["81-100", "Strong candidate, subject to expert validation"]
];

const missing = [
  "material grade",
  "damage depth",
  "photos",
  "drawing/CAD",
  "operating conditions",
  "tolerance",
  "hardness/coating requirement",
  "inspection requirement"
];

const whatChangesDecision = [
  "Unknown material",
  "Cracks beyond visible damage",
  "Tight tolerance",
  "No post-machining route",
  "Safety-critical service",
  "No inspection plan"
];

const frameworkBrief = [
  ["Definition", "A preliminary scoring model for deciding whether an LMD repair request is worth expert feasibility review."],
  ["Problem it solves", "Repair requests often arrive before the material, damage, access, tolerance, and inspection facts are clear."],
  ["Who it is for", "Engineers, buyers, AI agents, students, and developers preparing LMD repair RFQs."],
  ["Inputs required", "Material grade, damage type and depth, access, geometry, service conditions, tolerance, inspection requirement, downtime, and replacement context."],
  ["Output", "A repairability band, missing-information list, risk flags, and a suggested next step."],
  ["Evidence needed", "Photos, drawing or CAD, material evidence, damage documentation, machining plan, inspection route, and expert review."],
  ["Limitations", "It does not approve repair, validate material compatibility, or guarantee final quality."],
  ["Example use case", "Screening whether a worn shaft, hammer, die, screw, or valve component has enough information for a first LMD review."],
  ["Thesis connection", "Sense RFQ facts, model repairability, decide review priority, and verify through inspection evidence."]
];

const relatedLinks = [
  { label: "Manish Sharma - AI for Laser Metal Deposition", href: "/identity" },
  { label: "LMD Agent Pack", href: "/agent-pack" },
  { label: "Tools", href: "/tools" },
  { label: "For AI Agents", href: "/for-ai-agents" },
  { label: "What AI needs before LMD repair", href: "/lab-notes/what-ai-needs-before-lmd-repair" },
  { label: "Laser Metal Deposition glossary", href: "/glossary/laser-metal-deposition" }
];
---

<Layout title={`${title} — Manish Sharma Lab`} description={description} canonical="/frameworks/lmd-repairability-index" jsonLd={jsonLd}>
  <section class="site-shell grid gap-10 section-y lg:grid-cols-[minmax(0,1fr)_minmax(24rem,0.62fr)] lg:items-center">
    <div class="max-w-4xl">
      <div class="flex flex-wrap gap-2">
        <Badge>Working framework</Badge>
        <Badge tone="laser">Interactive calculator</Badge>
      </div>
      <h1 class="mt-6 text-5xl font-black leading-tight text-white md:text-6xl">{title}</h1>
      <p class="mt-5 text-2xl font-bold text-cyan-100">A practical way to think about whether an industrial part may be suitable for Laser Metal Deposition repair.</p>
      <p class="mt-6 text-lg leading-8 text-slate-300">{DISCLAIMER}</p>
    </div>
    <PageHeroVisual variant="repairability" class="hidden lg:block" />
  </section>

  <section class="band section-y">
    <div class="site-shell">
      <div class="mb-8">
        <ProcessLoop variant="micro" title="Repairability loop" />
      </div>
      <SectionHeading eyebrow="Scoring categories" title="Repairability is not one variable" />
      <div class="mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-5">
        {categories.map((category) => <div class="ordered-card p-4 text-sm font-bold leading-6 text-slate-100">{category}</div>)}
      </div>
    </div>
  </section>

  <section class="site-shell section-y">
    <SectionHeading
      eyebrow="Framework brief"
      title="What the index does and does not decide"
      description={DISCLAIMER}
    />
    <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {frameworkBrief.map(([label, text]) => (
        <article class="ordered-card p-5">
          <h2 class="text-lg font-black text-white">{label}</h2>
          <p class="mt-3 text-sm leading-6 text-slate-300">{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="site-shell section-y">
    <SectionHeading eyebrow="Interactive" title="LMD Repairability Index calculator" description="Score each category from weak or unknown to strong. The output is a preliminary band, not a final feasibility decision." />
    <div class="mt-10">
      <RepairabilityCalculator client:load />
    </div>
  </section>

  <section class="site-shell section-y">
    <div class="grid gap-8 lg:grid-cols-[0.82fr_1.18fr]">
      <SectionHeading
        eyebrow="What changes the decision"
        title="Repairability can change quickly when risk facts appear"
        description="Use these as red-team checks before calling an LMD repair candidate promising."
      />
      <div class="grid gap-3 sm:grid-cols-2">
        {whatChangesDecision.map((item) => (
          <div class="ordered-card p-4 text-sm font-bold leading-6 text-slate-100">{item}</div>
        ))}
      </div>
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell grid gap-8 lg:grid-cols-2">
      <div>
        <SectionHeading eyebrow="Score bands" title="Interpretation bands" />
        <div class="mt-8 grid gap-3">
          {bands.map(([score, label]) => <div class="ordered-card flex items-center gap-4 p-4"><span class="w-20 font-mono font-black text-cyan-100">{score}</span><span class="font-semibold text-slate-100">{label}</span></div>)}
        </div>
      </div>
      <div>
        <SectionHeading eyebrow="Missing information" title="Minimum RFQ checklist" />
        <div class="mt-8 grid gap-3 sm:grid-cols-2">
          {missing.map((item) => <div class="ordered-card p-4 text-sm font-bold text-slate-100">{item}</div>)}
        </div>
      </div>
    </div>
  </section>

  <section class="site-shell section-y">
    <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr]">
      <SectionHeading eyebrow="Related workflow" title="Use the index with agent resources and tools" />
      <SourceLinks links={relatedLinks} />
    </div>
  </section>
</Layout>
