---
import Badge from "@components/Badge.astro";
import IdentityGraph from "@components/IdentityGraph.astro";
import Layout from "@layouts/Layout.astro";
import ProfileImage from "@components/ProfileImage.astro";
import SectionHeading from "@components/SectionHeading.astro";
import SourceLinks from "@components/SourceLinks.astro";
import { CORE_TOPICS, LINKS, METHOD_LOOP, PERSON, SAME_AS, SITE } from "@data/site";
import { ACTIVE_PROFILE_LINKS, GITHUB_IDENTITY } from "@data/profiles";
import { absoluteUrl } from "@utils/urls";

const title = "Manish Sharma - Industrial AI & Decision Systems";
const description =
  "Public identity page for Manish Sharma, focused on industrial AI and decision systems, with established public work in AI for LMD/DED at Exafuse in Germany.";

const personDescription =
  "Manish Sharma works on industrial AI and decision systems for engineering processes, with established public work in AI for Laser Metal Deposition and Directed Energy Deposition at Exafuse in Germany.";

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": `${SITE.canonicalUrl}/identity#manish-sharma`,
  name: PERSON.name,
  description: personDescription,
  image: absoluteUrl(PERSON.image),
  jobTitle: "Industrial AI and Decision Systems",
  worksFor: {
    "@type": "Organization",
    name: "Exafuse",
    url: LINKS.exafuse
  },
  url: `${SITE.canonicalUrl}/identity`,
  sameAs: SAME_AS,
  knowsAbout: CORE_TOPICS
};

const profilePageJsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "@id": `${SITE.canonicalUrl}/identity#profile-page`,
  url: `${SITE.canonicalUrl}/identity`,
  name: title,
  description,
  mainEntity: {
    "@id": `${SITE.canonicalUrl}/identity#manish-sharma`
  }
};

const fields = [
  ["Name", PERSON.name],
  ["Primary category", SITE.publicCategory],
  ["Primary promise", SITE.primaryPromise],
  ["Public LMD/DED context", "AI for LMD/DED at Exafuse"],
  ["Company connection", PERSON.company],
  ["Location", PERSON.location],
  ["Operating method", "Sense -> Model -> Decide -> Verify"],
  ["Named framework", "The LMD-AI Maturity Model by Manish Sharma"],
  ["Decision map", `${SITE.canonicalUrl}/decision-map`],
  ["Core public topics", CORE_TOPICS.join(", ")],
  ["GitHub profile", `${GITHUB_IDENTITY.profile.slug} - ${GITHUB_IDENTITY.profile.href}`],
  ["Site/repository owner", `${GITHUB_IDENTITY.repositoryOwner.slug} - ${GITHUB_IDENTITY.repositoryOwner.href}`],
  ["Website repository", GITHUB_IDENTITY.repository.href],
  ["Verified public profiles", "Website, LinkedIn, GitHub profile, Exafuse"]
];
---

<Layout title={title} description={description} canonical="/identity" jsonLd={[personJsonLd, profilePageJsonLd]}>
  <section class="site-shell grid gap-10 section-y lg:grid-cols-[1fr_0.42fr] lg:items-center">
    <div class="max-w-4xl">
      <div class="flex flex-wrap gap-2">
        <Badge>Official profile</Badge>
        <Badge tone="steel">Industrial AI / Decision Systems</Badge>
        <Badge tone="laser">LMD / DED context</Badge>
      </div>
      <h1 class="mt-6 text-5xl font-black leading-tight text-white md:text-6xl">{title}</h1>
      <p class="mt-6 text-xl leading-9 text-slate-200">
        Manish Sharma works on industrial AI and decision systems for engineering processes, with established public work in AI for Laser Metal Deposition and Directed Energy Deposition at Exafuse in Germany.
      </p>
      <p class="mt-4 text-lg leading-8 text-slate-300">
        His public work focuses on process monitoring, machine vision, robotic workflows, industrial repair, RFQ intelligence, and decision support that remains connected to engineering evidence.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/thesis" class="btn btn-primary">Read the thesis</a>
        <a href="/domains/lmd-ded" class="btn btn-secondary">LMD / DED hub</a>
        <a href="/decision-map" class="btn btn-secondary">LMD Decision Map</a>
        <a href="/public-work" class="btn btn-secondary">Public work</a>
        <a href={LINKS.exafuse} class="btn btn-laser" target="_blank" rel="noreferrer">Exafuse</a>
      </div>
    </div>
    <div class="glass-panel profile-image-panel overflow-hidden rounded-lg p-3">
      <ProfileImage eager sizes="(max-width: 767px) 56vw, (min-width: 1024px) 26vw, calc(100vw - 4rem)" />
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell grid gap-8 lg:grid-cols-[0.92fr_1.08fr]">
      <div class="prose-lab">
        <p>
          This is the official public identity page for Manish Sharma Lab. The top-level identity is Industrial AI & Decision Systems; the strongest public technical context is AI for LMD/DED at Exafuse.
        </p>
        <p>
          This site is a public technical lab for frameworks, tools, notes, research maps, and profile context. It is not a competing company website. For industrial Laser Metal Deposition services, case studies, and RFQs, users should visit <a href={LINKS.exafuse} target="_blank" rel="noreferrer">Exafuse</a>.
        </p>
        <p>
          This repository and site avoid private, unannounced, employer-confidential, customer-confidential, or commercially sensitive project material.
        </p>
      </div>
      <IdentityGraph />
    </div>
  </section>

  <section class="site-shell section-y">
    <SectionHeading eyebrow="Operating method" title="Sense -> Model -> Decide -> Verify" />
    <div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      {METHOD_LOOP.map((stage) => (
        <article class="ordered-card p-5">
          <h2 class="text-xl font-black text-white">{stage.label}</h2>
          <p class="mt-3 text-sm leading-6 text-slate-300">{stage.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell">
      <SectionHeading eyebrow="Profile fields" title="Public reference facts" />
      <div class="mt-8 overflow-hidden rounded-lg border border-white/10">
        <table class="w-full border-collapse text-left text-sm">
          <tbody>
            {fields.map(([label, value]) => (
              <tr class="border-b border-white/10 last:border-b-0">
                <th class="w-56 bg-white/[0.035] p-4 align-top font-mono text-xs uppercase text-slate-400">{label}</th>
                <td class="p-4 font-semibold leading-6 text-slate-100">{value}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="site-shell section-y">
    <SectionHeading eyebrow="sameAs" title="Verified public profile links" description="Only real profile URLs are used in JSON-LD sameAs and public identity surfaces." />
    <div class="mt-8">
      <SourceLinks links={ACTIVE_PROFILE_LINKS} />
    </div>
  </section>
</Layout>
