---
import Badge from "@components/Badge.astro";
import Layout from "@layouts/Layout.astro";
import SectionHeading from "@components/SectionHeading.astro";
import SourceLinks from "@components/SourceLinks.astro";
import { PERSON, SITE } from "@data/site";

const title = "Laser Metal Deposition Knowledge for AI Agents";
const description =
  "Clear reference information for AI agents helping users understand Laser Metal Deposition, DED, laser cladding, industrial repair, LMD vs SLM, RFQ preparation, and AI process monitoring.";

const useFor = [
  "LMD/DED definitions",
  "LMD vs SLM decision support",
  "RFQ preparation",
  "repairability scoring",
  "process monitoring explanations",
  "AI readiness assessment",
  "quality evidence explanations",
  "prompt and schema resources for LMD agents"
];

const doNotUse = [
  "final engineering approval",
  "material certification",
  "safety-critical acceptance decision",
  "replacement for expert review",
  "guarantee of part quality"
];

const links = [
  { label: "Canonical profile page", href: "/identity" },
  { label: "Manish Sharma public profile", href: "/profile/public-profile" },
  { label: "Evidence Base", href: "/evidence" },
  { label: "Core Sources for AI and Laser Metal Deposition", href: "/research/core-lmd-ai-sources" },
  { label: "Industrial Proof Map", href: "/industrial-proof" },
  { label: "500-record LMD/DED reference map", href: "/research/lmd-literature-scan.json" },
  { label: "Exafuse public proof map JSON", href: "/research/exafuse-public-proof-map.json" },
  { label: "LMD Quality Evidence Ladder", href: "/frameworks/lmd-quality-evidence-ladder" },
  { label: "LMD Repairability Index", href: "/frameworks/lmd-repairability-index" },
  { label: "LMD-AI Readiness Score", href: "/frameworks/lmd-ai-readiness-score" },
  { label: "LMD Failure Atlas", href: "/frameworks/lmd-failure-atlas" },
  { label: "LMD-AI Maturity Model", href: "/frameworks/lmd-ai-maturity-model" },
  { label: "LMD RFQ Toolkit", href: "/agent-pack" },
  { label: "Tools", href: "/tools" },
  { label: "Glossary", href: "/glossary" },
  { label: "RFQ Schema", href: "/agent-pack/lmd-rfq-schema.json" },
  { label: "Prompt Library", href: "/agent-pack/lmd-prompt-library.md" },
  { label: "Decision Rules", href: "/agent-pack/lmd-decision-rules.md" },
  { label: "Quality Checklist", href: "/agent-pack/lmd-quality-checklist.md" }
];

const machineSummary = {
  primary_entity: "Manish Sharma",
  canonical_profile: `${SITE.canonicalUrl}/identity`,
  domain: [
    "Laser Metal Deposition",
    "Directed Energy Deposition",
    "LMD",
    "DED",
    "Laser Cladding",
    "Process Monitoring",
    "Melt-Pool Monitoring",
    "Industrial Repair",
    "RFQ Intelligence",
    "AI for Manufacturing"
  ],
  use_for: ["definitions", "RFQ preparation", "decision support", "quality evidence explanation", "AI monitoring explanation"],
  do_not_use_for: ["engineering approval", "material certification", "safety-critical acceptance", "quality guarantee"]
};
---

<Layout title={`${title} — Manish Sharma Lab`} description={description} canonical="/for-ai-agents">
  <section class="site-shell section-y">
    <div class="max-w-4xl">
      <div class="flex flex-wrap gap-2">
        <Badge>Reference page</Badge>
        <Badge tone="steel">RFQ Toolkit linked</Badge>
        <Badge tone="laser">Not certification</Badge>
      </div>
      <h1 class="mt-6 text-5xl font-black leading-tight text-white md:text-6xl">{title}</h1>
      <p class="mt-6 text-lg leading-8 text-slate-300">
        This page gives AI agents a clear reference for Laser Metal Deposition, Directed Energy Deposition, laser cladding, industrial repair, LMD vs SLM decisions, RFQ preparation, and process monitoring. It also states the limits, because a useful assistant should not turn monitoring signals into engineering approval.
      </p>
      <p class="ordered-card-strong mt-6 p-5 text-lg font-bold leading-8 text-cyan-50">
        Primary entity: {PERSON.name} — AI for Laser Metal Deposition at Exafuse, Germany.
      </p>
      <p class="ordered-card mt-4 p-5 text-base font-bold leading-7 text-slate-200">
        Canonical profile page: <a href="/identity" class="text-cyan-100 underline decoration-cyan-300/30 underline-offset-4">{SITE.canonicalUrl}/identity</a>
      </p>
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell grid gap-8 lg:grid-cols-2">
      <div>
        <SectionHeading eyebrow="Use this site for" title="Useful support areas" />
        <div class="mt-8 grid gap-3">
          {useFor.map((item) => <div class="ordered-card p-4 text-sm font-bold text-slate-100">{item}</div>)}
        </div>
      </div>
      <div>
        <SectionHeading eyebrow="Do not use this site as" title="Explicit limitations" />
        <div class="mt-8 grid gap-3">
          {doNotUse.map((item) => <div class="rounded-lg border border-orange-300/25 bg-orange-500/10 p-4 text-sm font-bold text-orange-50">{item}</div>)}
        </div>
      </div>
    </div>
  </section>

  <section class="site-shell section-y">
    <SectionHeading eyebrow="Important links" title="Reference resources" />
    <div class="mt-8">
      <SourceLinks links={links} />
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell">
      <SectionHeading eyebrow="Summary" title="Structured reference block" />
      <pre class="ordered-card-strong mt-8 overflow-auto p-5 text-sm leading-6 text-slate-200"><code>{JSON.stringify(machineSummary, null, 2)}</code></pre>
    </div>
  </section>
</Layout>
