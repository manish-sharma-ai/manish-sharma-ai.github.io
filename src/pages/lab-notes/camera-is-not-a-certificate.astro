---
import Badge from "@components/Badge.astro";
import LabNoteArticle from "@components/LabNoteArticle.astro";
import LabNoteFooter from "@components/LabNoteFooter.astro";
import Layout from "@layouts/Layout.astro";
import NoteBox from "@components/NoteBox.astro";
import { resolveExafuseLink } from "../../config/externalLinks";
import { DISCLAIMER, PERSON, SITE } from "@data/site";

const title = "A Camera Is Not a Certificate";
const description =
  "Why camera and melt-pool signals can support LMD/DED process review but cannot certify final quality on their own.";
const exafuseRfqLink = resolveExafuseLink("rfq");

const sections = [
  ["One-line thesis", "A camera can show a process event; it does not certify the final part."],
  ["Why it matters in LMD/DED", "Vision and melt-pool data can reveal anomalies, drift, or review points, but release evidence depends on inspection, testing, and acceptance criteria."],
  ["Common mistake", "Interpreting a clean camera stream as proof that material quality, geometry, and service safety are all acceptable."],
  ["Better decision question", "What inspection evidence is needed to interpret this signal for the specific part risk?"],
  ["What evidence is needed", "Sensor context, calibration context, linked track/layer/part record, dimensional inspection, NDT or material evidence where risk requires it, and expert review."],
  ["What changes the decision", "Signal-to-part traceability, sensor condition, correlation with inspection, acceptance criteria, and part criticality change what the camera evidence can support."],
  ["Related playbook/tool", "Use the monitoring/evidence playbook or monitoring-anomaly cockpit preset before turning a signal into an LMD Decision Brief v1.0."],
  ["Exafuse route if commercial review is needed", `${exafuseRfqLink.label}: use Exafuse for company-owned technical and commercial review.`],
  ["Boundary disclaimer", DISCLAIMER]
];

const boundarySection = sections.find(([heading]) => heading === "Boundary disclaimer");
const readingSections = sections.filter(([heading]) => heading !== "Boundary disclaimer");

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "@id": `${SITE.canonicalUrl}/lab-notes/camera-is-not-a-certificate#article`,
  url: `${SITE.canonicalUrl}/lab-notes/camera-is-not-a-certificate`,
  headline: title,
  description,
  author: { "@id": `${SITE.canonicalUrl}/identity#manish-sharma`, name: PERSON.name }
};
---

<Layout title={`${title} - Manish Sharma Lab`} description={description} canonical="/lab-notes/camera-is-not-a-certificate" jsonLd={jsonLd}>
  <LabNoteArticle title={title} description={description} route="/lab-notes/camera-is-not-a-certificate/" supportingLabel="Evidence boundary">
    <Fragment slot="eyebrow"><Badge>Lab note</Badge></Fragment>

    {readingSections.map(([heading, text]) => (
      <section class="lab-note-article__section">
        <h2>{heading}</h2>
        <p>{text}</p>
      </section>
    ))}

    {boundarySection && (
      <Fragment slot="supporting">
        <NoteBox title={boundarySection[0]} tone="laser">
          {boundarySection[1]}
        </NoteBox>
      </Fragment>
    )}

    <LabNoteFooter
      slot="footer"
      links={[
        { label: "Signal is not proof", href: "/thesis#signal-is-not-proof" },
        { label: "LMD Quality Evidence Ladder", href: "/frameworks/lmd-quality-evidence-ladder" },
        { label: "Melt-Pool Monitoring glossary", href: "/glossary/melt-pool-monitoring" },
        { label: "Monitoring/evidence playbook", href: "/playbooks#monitoring-evidence" },
        { label: "Run monitoring cockpit preset", href: "/tools/#preset=monitoring-anomaly" },
        { label: exafuseRfqLink.label, href: exafuseRfqLink.href }
      ]}
    />
  </LabNoteArticle>
</Layout>
