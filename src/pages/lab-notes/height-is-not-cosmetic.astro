---
import Badge from "@components/Badge.astro";
import LabNoteArticle from "@components/LabNoteArticle.astro";
import LabNoteFooter from "@components/LabNoteFooter.astro";
import Layout from "@layouts/Layout.astro";
import NoteBox from "@components/NoteBox.astro";
import { resolveExafuseLink } from "../../config/externalLinks";
import { DISCLAIMER, PERSON, SITE } from "@data/site";

const title = "Height Is Not Cosmetic";
const description =
  "Why bead height, build-up height, and machining allowance affect LMD/DED repair decisions, evidence needs, and RFQ quality.";
const exafuseRfqLink = resolveExafuseLink("rfq");

const sections = [
  ["One-line thesis", "Height affects geometry, heat input, machining allowance, inspection access, and final tolerance. It is not a cosmetic variable."],
  ["Why it matters in LMD/DED", "In repair and cladding, deposited height influences how much material must be removed, whether final dimensions can be recovered, and how inspection should be planned."],
  ["Common mistake", "Treating a worn area as a surface problem without asking how much build-up and finishing allowance are needed."],
  ["Better decision question", "What final geometry, tolerance, and inspection route must the deposited height support?"],
  ["What evidence is needed", "Damage depth, target height, machining allowance, drawing/CAD, tolerance requirement, and post-machining inspection plan."],
  ["What changes the decision", "Final tolerance, damage depth, machining access, heat-sensitive geometry, and inspection access can turn a promising repair into a review-only candidate."],
  ["Related playbook/tool", "Use the LMD repair playbook and the worn-shaft cockpit preset before preparing an LMD Decision Brief v1.0."],
  ["Exafuse route if commercial review is needed", `${exafuseRfqLink.label}: use Exafuse for company-owned technical and commercial review.`],
  ["Boundary disclaimer", DISCLAIMER]
];

const boundarySection = sections.find(([heading]) => heading === "Boundary disclaimer");
const readingSections = sections.filter(([heading]) => heading !== "Boundary disclaimer");

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "@id": `${SITE.canonicalUrl}/lab-notes/height-is-not-cosmetic#article`,
  url: `${SITE.canonicalUrl}/lab-notes/height-is-not-cosmetic`,
  headline: title,
  description,
  author: { "@id": `${SITE.canonicalUrl}/identity#manish-sharma`, name: PERSON.name }
};
---

<Layout title={`${title} - Manish Sharma Lab`} description={description} canonical="/lab-notes/height-is-not-cosmetic" jsonLd={jsonLd}>
  <LabNoteArticle title={title} description={description} supportingLabel="Evidence boundary">
    <Fragment slot="eyebrow"><Badge>Lab note</Badge></Fragment>

    {readingSections.map(([heading, text]) => (
      <section class="lab-note-article__section">
          <h2>{heading}</h2>
          <p>{text}</p>
      </section>
    ))}

    {boundarySection && (
      <Fragment slot="supporting">
        <NoteBox title={boundarySection[0]} tone="laser">
          {boundarySection[1]}
        </NoteBox>
      </Fragment>
    )}

    <LabNoteFooter
      slot="footer"
      links={[
        { label: "LMD Repairability Index", href: "/frameworks/lmd-repairability-index" },
        { label: "LMD repair playbook", href: "/playbooks#lmd-repair" },
        { label: "Run worn-shaft cockpit preset", href: "/tools/#preset=worn-shaft" },
        { label: "Decision Brief Template", href: "/brief-template" },
        { label: "Laser Metal Deposition glossary", href: "/glossary/laser-metal-deposition" },
        { label: exafuseRfqLink.label, href: exafuseRfqLink.href }
      ]}
    />
  </LabNoteArticle>
</Layout>
