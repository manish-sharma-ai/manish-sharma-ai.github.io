---
import Badge from "@components/Badge.astro";
import LabNoteCard from "@components/LabNoteCard.astro";
import Layout from "@layouts/Layout.astro";
import PageHeroVisual from "@components/PageHeroVisual.astro";
import { LAB_NOTES } from "@data/site";

const title = "Field Notes — Manish Sharma";
const description =
  "Field notes from Manish Sharma's current LMD/DED proving ground: process monitoring, RFQ structure, repairability, decision systems, and inspection evidence.";
---

<Layout title={title} description={description} canonical="/lab-notes">
  <section class="site-shell section-y lab-notes-index">
    <header class="lab-notes-index__masthead">
      <div class="lab-notes-index__masthead-copy">
        <div class="lab-notes-index__context">
          <Badge>Field notes</Badge>
          <Badge tone="steel">Current LMD / DED proving ground</Badge>
        </div>
        <h1>Field Notes</h1>
        <p class="lab-notes-index__intro">
          I use these concise public notes to test and explain the decisions behind LMD/DED work: process signals, RFQ quality, repairability, route selection, and inspection evidence. They are the current technical proving ground for a broader Industrial AI & Decision Systems method.
        </p>
      </div>
      <PageHeroVisual variant="notes" class="lab-notes-index__visual hidden lg:block" />
    </header>

    <section class="lab-notes-index__collection" aria-label="Lab Notes">
      <ul class="lab-notes-index__list">
        {LAB_NOTES.map((note) => <LabNoteCard {...note} />)}
      </ul>
    </section>
  </section>
</Layout>
