---
import Badge from "@components/Badge.astro";
import Layout from "@layouts/Layout.astro";
import PageHeroVisual from "@components/PageHeroVisual.astro";
import { LAB_NOTES } from "@data/site";

const title = "Lab Notes — Manish Sharma Lab";
const description =
  "Short technical notes on Laser Metal Deposition, AI process monitoring, RFQ structuring, repairability, and LMD vs SLM decisions.";
---

<Layout title={title} description={description} canonical="/lab-notes">
  <section class="site-shell section-y">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(24rem,0.62fr)] lg:items-center">
      <div class="max-w-4xl">
        <Badge>Inspection-aware notes</Badge>
        <Badge tone="steel" class="ml-2">Applied LMD / DED notes</Badge>
        <h1 class="mt-6 text-5xl font-black leading-tight text-white md:text-6xl">Lab Notes</h1>
        <p class="mt-6 text-lg leading-8 text-slate-300">
          Concise public notes on LMD/DED decisions, process monitoring boundaries, repair RFQs, and manufacturing route selection.
        </p>
      </div>
      <PageHeroVisual variant="notes" class="hidden lg:block" />
    </div>
    <div class="equal-card-grid mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
      {
        LAB_NOTES.map((note) => (
          <a href={note.href} class="ordered-card-strong card-hover grid min-h-[20rem] content-between p-6">
            <div>
            <p class="metric-label">{note.date}</p>
            <h2 class="mt-3 text-2xl font-black text-white">{note.title}</h2>
            <p class="mt-4 text-sm leading-6 text-slate-400">{note.description}</p>
            </div>
            <div class="mt-5 flex flex-wrap gap-2">
              {note.tags.map((tag) => <span class="ordered-card px-2.5 py-1 text-xs font-bold text-slate-300">{tag}</span>)}
            </div>
          </a>
        ))
      }
    </div>
  </section>
</Layout>
