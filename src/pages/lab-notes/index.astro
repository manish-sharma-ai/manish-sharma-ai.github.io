---
import Badge from "@components/Badge.astro";
import Layout from "@layouts/Layout.astro";
import { LAB_NOTES } from "@data/site";

const title = "Lab Notes — Manish Sharma Lab";
const description =
  "Short technical notes on Laser Metal Deposition, AI process monitoring, RFQ structuring, repairability, and LMD vs SLM decisions.";
---

<Layout title={title} description={description} canonical="/lab-notes">
  <section class="site-shell py-16 md:py-20">
    <div class="max-w-4xl">
      <Badge>Inspection-aware notes</Badge>
      <h1 class="mt-6 text-5xl font-black leading-tight text-white md:text-6xl">Lab Notes</h1>
      <p class="mt-6 text-lg leading-8 text-slate-300">
        Concise public notes for AI-assisted LMD decisions, process monitoring boundaries, repair RFQs, and manufacturing route selection.
      </p>
    </div>
    <div class="mt-10 grid gap-5 md:grid-cols-2">
      {
        LAB_NOTES.map((note) => (
          <a href={note.href} class="glass-panel card-hover rounded-lg p-6">
            <p class="metric-label">{note.date}</p>
            <h2 class="mt-3 text-2xl font-black text-white">{note.title}</h2>
            <p class="mt-4 text-sm leading-6 text-slate-400">{note.description}</p>
            <div class="mt-5 flex flex-wrap gap-2">
              {note.tags.map((tag) => <span class="rounded-md border border-white/10 bg-white/[0.035] px-2.5 py-1 text-xs font-bold text-slate-300">{tag}</span>)}
            </div>
          </a>
        ))
      }
    </div>
  </section>
</Layout>
