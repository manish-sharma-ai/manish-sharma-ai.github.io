---
import Badge from "@components/Badge.astro";
import LabNoteArticle from "@components/LabNoteArticle.astro";
import LabNoteFooter from "@components/LabNoteFooter.astro";
import Layout from "@layouts/Layout.astro";
import NoteBox from "@components/NoteBox.astro";
import { resolveExafuseLink } from "../../config/externalLinks";
import { DISCLAIMER, PERSON, SITE } from "@data/site";

const title = "Traceability Is a Product Feature";
const description =
  "Why LMD/DED decision systems need traceability between inputs, process signals, review decisions, and inspection evidence.";
const exafuseRfqLink = resolveExafuseLink("rfq");

const sections = [
  ["One-line thesis", "Traceability is not admin overhead; it is part of the product value of a decision system."],
  ["Why it matters in LMD/DED", "A useful process-monitoring or RFQ system should connect input assumptions, process signals, expert review, inspection evidence, and the final next action."],
  ["Common mistake", "Keeping images, logs, RFQ notes, operator comments, and inspection results in separate islands."],
  ["Better decision question", "Can a reviewer see why this signal, score, or recommendation was produced and what evidence supports it?"],
  ["What evidence is needed", "Linked job context, input facts, process records, operator notes, inspection results, review decisions, and revision history."],
  ["What changes the decision", "Traceability changes the decision when it links the input facts, process signal, review rationale, inspection result, and final boundary in one record."],
  ["Related playbook/tool", "Use the monitoring/evidence playbook, AI readiness framework, or LMD Decision Brief v1.0 template to keep the decision trail compact."],
  ["Exafuse route if commercial review is needed", `${exafuseRfqLink.label}: use Exafuse for company-owned technical and commercial review.`],
  ["Boundary disclaimer", DISCLAIMER]
];

const boundarySection = sections.find(([heading]) => heading === "Boundary disclaimer");
const readingSections = sections.filter(([heading]) => heading !== "Boundary disclaimer");

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "@id": `${SITE.canonicalUrl}/lab-notes/traceability-is-a-product-feature#article`,
  url: `${SITE.canonicalUrl}/lab-notes/traceability-is-a-product-feature`,
  headline: title,
  description,
  author: { "@id": `${SITE.canonicalUrl}/identity#manish-sharma`, name: PERSON.name }
};
---

<Layout title={`${title} - Manish Sharma Lab`} description={description} canonical="/lab-notes/traceability-is-a-product-feature" jsonLd={jsonLd}>
  <LabNoteArticle title={title} description={description} supportingLabel="Evidence boundary">
    <Fragment slot="eyebrow"><Badge>Lab note</Badge></Fragment>

    {readingSections.map(([heading, text]) => (
      <section class="lab-note-article__section">
          <h2>{heading}</h2>
          <p>{text}</p>
      </section>
    ))}

    {boundarySection && (
      <Fragment slot="supporting">
        <NoteBox title={boundarySection[0]} tone="laser">
          {boundarySection[1]}
        </NoteBox>
      </Fragment>
    )}

    <LabNoteFooter
      slot="footer"
      links={[
        { label: "LMD-AI Readiness Score", href: "/frameworks/lmd-ai-readiness-score" },
        { label: "LMD Quality Evidence Ladder", href: "/frameworks/lmd-quality-evidence-ladder" },
        { label: "Monitoring/evidence playbook", href: "/playbooks#monitoring-evidence" },
        { label: "Decision Brief Template", href: "/brief-template" },
        { label: "For AI Agents", href: "/for-ai-agents" },
        { label: exafuseRfqLink.label, href: exafuseRfqLink.href }
      ]}
    />
  </LabNoteArticle>
</Layout>
