---
import Layout from "@layouts/Layout.astro";
import PageHeroVisual from "@components/PageHeroVisual.astro";
import SectionHeading from "@components/SectionHeading.astro";
import SourceLinks from "@components/SourceLinks.astro";
import { CITED_SOURCES } from "@data/evidence";
import { EXAFUSE_SOURCE_LINKS } from "@data/exafuse";
import { PERSON, SITE } from "@data/site";

const title = "Core Sources for AI and Laser Metal Deposition";
const description =
  "A curated starting map for engineers, students, and AI agents researching AI, process monitoring, and Laser Metal Deposition.";

const sourceRows = [
  ["LMD / DED fundamentals", "Terminology category", "Keeps LMD, DED, DED-LB/M, cladding, SLM, and LPBF from being mixed together.", "Working draft - standards source URL not yet verified"],
  ["LMD / DED fundamentals", "Public technical-resource category", "Gives a reliable starting point for process-family boundaries and additive manufacturing vocabulary.", "Working draft - public source URL not yet verified"],
  ["Process monitoring and melt-pool monitoring", "Review-paper category", "Useful for understanding what in-situ monitoring can observe and why monitoring is not final release evidence.", "Working draft - review source to verify"],
  ["Process monitoring and melt-pool monitoring", "Review-paper category", "Useful for linking melt-pool signals, thermal history, geometry, and inspection outcomes in DED/LMD.", "Working draft - review source to verify"],
  ["AI / machine learning in additive manufacturing", "Review-paper category", "Useful for model categories, data limits, labels, validation boundaries, and decision-support claims.", "Working draft - review source to verify"],
  ["Defect formation and failure modes", "Review / handbook category", "Useful for connecting porosity, lack of fusion, cracking, dilution, distortion, and property mismatch to inspection evidence.", "Working draft - source to verify"],
  ["Repair and cladding applications", "Public industrial case studies", "Shows repair, cladding, build-and-coat, and large-part LMD situations without confidential project data.", "Public Exafuse source map below"],
  ["Quality, inspection, and validation", "Standards / inspection category", "Keeps quality claims tied to inspection, testing, acceptance criteria, and service risk.", "Working draft - source to verify"],
  ["Decision systems / AI governance", "Method and governance category", "Keeps AI claims bounded by uncertainty, escalation, human review, and verification evidence.", "Working draft - source to verify"],
  ["Additive manufacturing process selection", "Process-selection category", "Helps compare LMD/DED, cladding, SLM/LPBF, machining, replacement, and hybrid routes.", "Working draft - source to verify"]
];

const sourcesToVerify = [
  "ISO/ASTM additive manufacturing terminology source",
  "NIST additive manufacturing / DED public resources",
  "Review paper on in-situ monitoring in metal additive manufacturing",
  "Review paper on DED / LMD process monitoring",
  "Review paper on machine learning in metal additive manufacturing",
  "Review or handbook source for DED/LMD defect formation and failure modes",
  "Quality, inspection, and validation source for metal additive manufacturing",
  "Decision-system or AI-governance source for human review, uncertainty, and verification",
  "Process-selection source comparing LMD/DED, SLM/LPBF, cladding, repair, and hybrid routes"
];

const sections = [
  ["Why this page exists", "The existing 500-record map is broad metadata. This page is a smaller, curated starting map for people who need to understand which source areas matter before reading deeper."],
  ["How to use this source map", "Use it to choose what to read next, not as a final literature review. Working-draft rows should be replaced only when a real source URL is confirmed."],
  ["What is still missing", "The next improvement is to replace working-draft source categories with verified standards pages, review papers, and stable public source URLs without inventing paper details or DOIs."],
  ["Suggested next search queries", "DED-LB/M terminology, LMD process monitoring review, in-situ monitoring metal additive manufacturing review, machine learning metal additive manufacturing review, laser cladding repair inspection, LMD quality evidence."]
];

const categorySections = [
  ["LMD / DED fundamentals", "Start with terminology and process-family boundaries before comparing LMD, DED, DED-LB/M, laser cladding, SLM, or LPBF."],
  ["Process monitoring and melt-pool monitoring", "Use these sources to understand what signals can indicate, what they cannot prove, and how signals connect to inspection evidence."],
  ["AI / machine learning in additive manufacturing", "Use these sources to evaluate data foundations, labels, validation, model limits, and decision-support boundaries."],
  ["Defect formation and failure modes", "Use these sources to connect porosity, lack of fusion, cracking, dilution, distortion, and property mismatch to physical evidence."],
  ["Repair and cladding applications", "Use these sources to understand when local deposition, surface restoration, coating, machining, and inspection planning matter."],
  ["Quality, inspection, and validation", "Use these sources to keep quality claims tied to NDT, dimensional inspection, metallography, hardness, mechanical testing, and service risk."],
  ["Standards and terminology", "Use these sources when exact definitions matter. This page should not be treated as standard wording."]
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "@id": `${SITE.canonicalUrl}/research/core-lmd-ai-sources#article`,
  headline: title,
  description,
  author: { "@id": `${SITE.canonicalUrl}/#person`, name: PERSON.name },
  datePublished: SITE.lastUpdated,
  dateModified: SITE.lastUpdated,
  url: `${SITE.canonicalUrl}/research/core-lmd-ai-sources`,
  about: [
    "Laser Metal Deposition",
    "Directed Energy Deposition",
    "Process Monitoring",
    "Melt-Pool Monitoring",
    "AI for Manufacturing",
    "Industrial Repair"
  ]
};
---

<Layout title={`${title} - Manish Sharma Lab`} description={description} canonical="/research/core-lmd-ai-sources" jsonLd={jsonLd}>
  <section class="site-shell grid gap-10 section-y lg:grid-cols-[minmax(0,1fr)_minmax(24rem,0.62fr)] lg:items-center">
    <div class="max-w-4xl">
      <p class="metric-label">Curated research map</p>
      <h1 class="mt-5 text-5xl font-black leading-tight text-white md:text-6xl">{title}</h1>
      <p class="mt-6 text-xl leading-9 text-slate-200">
        A curated starting map for engineers, students, and AI agents. It complements the broad 500-record reference map; it does not pretend to be a complete systematic review.
      </p>
    </div>
    <PageHeroVisual variant="research" class="hidden lg:block" />
  </section>

  <section class="band section-y">
    <div class="site-shell grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      {sections.map(([heading, text]) => (
        <article class="ordered-card-strong p-5">
          <h2 class="text-xl font-black text-white">{heading}</h2>
          <p class="mt-3 text-sm leading-6 text-slate-300">{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="site-shell section-y">
    <SectionHeading eyebrow="Categories" title="How the source map is organized" />
    <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {categorySections.map(([heading, text]) => (
        <article class="ordered-card p-5">
          <h2 class="text-xl font-black text-white">{heading}</h2>
          <p class="mt-3 text-sm leading-6 text-slate-300">{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="site-shell section-y">
    <SectionHeading
      eyebrow="Source map"
      title="Categories to read before making strong LMD-AI claims"
      description="Rows marked as working draft are source categories to verify, not citations."
    />
    <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {sourceRows.map(([category, sourceType, why, status]) => (
        <article class="ordered-card-strong p-5">
          <p class="metric-label">{sourceType}</p>
          <h2 class="mt-3 text-xl font-black text-white">{category}</h2>
          <p class="mt-3 text-sm leading-6 text-slate-300">{why}</p>
          <p class="mt-5 rounded-md border border-cyan-300/25 bg-cyan-300/10 px-3 py-2 text-xs font-black uppercase leading-5 text-cyan-100">
            {status}
          </p>
        </article>
      ))}
    </div>
  </section>

  <section class="site-shell section-y">
    <SectionHeading
      eyebrow="Verification queue"
      title="Sources to verify before citation"
      description="These items are intentionally not cited as papers or standards yet. Add URLs only after the exact source is confirmed."
    />
    <div class="mt-8 grid gap-3 md:grid-cols-2">
      {sourcesToVerify.map((item) => (
        <div class="ordered-card p-4 text-sm font-bold leading-6 text-slate-100">{item}</div>
      ))}
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell grid gap-10 lg:grid-cols-[0.8fr_1.2fr]">
      <SectionHeading
        eyebrow="Existing source anchors"
        title="Public sources already used by the site"
        description="These links are already present in the evidence layer and public Exafuse proof map."
      />
      <div class="grid gap-8">
        <SourceLinks links={CITED_SOURCES} />
        <SourceLinks links={EXAFUSE_SOURCE_LINKS} />
      </div>
    </div>
  </section>

  <section class="site-shell section-y">
    <div class="rounded-lg border border-orange-300/25 bg-orange-500/10 p-6">
      <p class="metric-label text-orange-100">Disclaimer</p>
      <p class="mt-4 text-lg font-bold leading-8 text-orange-50">
        This page is a curated starting map, not a complete literature review or formal standard. Exact technical claims should be checked against the original source, standard, inspection requirement, and engineering context.
      </p>
    </div>
  </section>
</Layout>
