---
import Layout from "@layouts/Layout.astro";
import PageHeroVisual from "@components/PageHeroVisual.astro";
import ResearchSourceCard from "@components/ResearchSourceCard.astro";
import SectionHeading from "@components/SectionHeading.astro";
import SourceLinks from "@components/SourceLinks.astro";
import { EXAFUSE_SOURCE_LINKS } from "@data/exafuse";
import { PERSON, SITE } from "@data/site";

const title = "Core Sources for AI and Laser Metal Deposition";
const seoTitle = "Core LMD / DED and AI Sources - Manish Sharma Lab";
const description =
  "A concise, verified source map for LMD and DED fundamentals, monitoring, applied research, and responsible AI decision support.";

const verifiedSources = [
  {
    title: "NIST Directed Energy Deposition overview",
    publisher: "National Institute of Standards and Technology",
    sourceType: "Government technical overview",
    href: "https://www.nist.gov/additive-manufacturing/research-areas/technologies/directed-energy-deposition",
    usefulFor:
      "A first orientation to the DED process family and NIST's public measurement-science work.",
    doesNotProve:
      "Feasibility, process settings, qualification, or acceptance for a specific component."
  },
  {
    title: "ISO/ASTM 52900:2021 — Fundamentals and vocabulary",
    publisher: "International Organization for Standardization",
    sourceType: "Standards catalogue page",
    href: "https://www.iso.org/standard/74514.html",
    usefulFor:
      "Confirming the official document identity, edition, scope, and vocabulary reference to consult.",
    doesNotProve:
      "Access to the full standard, conformity with it, certification, or correct application to a project."
  },
  {
    title: "ASTM F3187 — Guide for Directed Energy Deposition of Metals",
    publisher: "ASTM International",
    sourceType: "Standards-body announcement",
    href: "https://www.astm.org/news/press-releases/new-astm-additive-manufacturing-standard-focuses-directed-energy-deposition",
    usefulFor:
      "Orienting readers to the guide's intended DED application, setup, operation, documentation, work-practice, and monitoring scope.",
    doesNotProve:
      "The full requirements of the guide, conformance, a qualified procedure, or part acceptance."
  },
  {
    title: "Directed Energy Deposition (DED) Process: State of the Art",
    publisher: "Ahn, 2021",
    sourceType: "Open-access peer-reviewed review",
    href: "https://link.springer.com/article/10.1007/s40684-020-00302-7",
    usefulFor:
      "A structured research overview of DED processes, applications, and open research issues.",
    doesNotProve:
      "That a reviewed finding transfers to a particular machine, material, geometry, or acceptance case."
  },
  {
    title: "Laser metal deposition of lattice structures by columnar built-up",
    publisher: "Sharma et al., 2018",
    sourceType: "Peer-reviewed conference paper",
    href: "https://doi.org/10.1016/j.procir.2018.08.098",
    usefulFor:
      "The methods and results of one published LMD lattice experiment and Manish Sharma's public research record.",
    doesNotProve:
      "General production readiness, performance for other lattices or materials, qualification, or certification."
  },
  {
    title: "In-situ, Parallel Monitoring of Relative Temperature, Material Emission, and Laser Reflection in Powder-blown Directed Energy Deposition",
    publisher: "NIST / JOM, 2024",
    sourceType: "Government-hosted peer-reviewed study",
    href: "https://www.nist.gov/publications/situ-parallel-monitoring-relative-temperature-material-emission-and-laser-reflection",
    usefulFor:
      "A concrete study of parallel relative-temperature, material-emission, and laser-reflection signals in powder-blown DED.",
    doesNotProve:
      "Defect state, finished-part quality, transferable control performance, or release from monitoring signals alone."
  },
  {
    title: "In-situ monitoring and deformation characterization by optical techniques; part I: Laser-aided direct metal deposition for additive manufacturing",
    publisher: "He, Shi and Xie, 2019",
    sourceType: "Peer-reviewed monitoring overview",
    href: "https://www.sciencedirect.com/science/article/pii/S0143816619304397",
    usefulFor:
      "An overview of optical in-situ monitoring approaches and the measurement roles they can play in laser-aided direct metal deposition.",
    doesNotProve:
      "That one sensor, feature, or optical setup is sufficient for defect confirmation, quality assurance, or acceptance."
  },
  {
    title: "NIST AI Risk Management Framework",
    publisher: "National Institute of Standards and Technology",
    sourceType: "Government AI risk framework",
    href: "https://www.nist.gov/itl/ai-risk-management-framework",
    usefulFor:
      "A risk-management lens for designing, evaluating, using, and governing AI-enabled decision support.",
    doesNotProve:
      "Model accuracy, manufacturing fitness, regulatory compliance, safe deployment, or engineering approval."
  }
];

const orientationLinks = [
  {
    label: "OpenAlex 500-record LMD/DED literature map",
    href: "/research/lmd-literature-scan.json",
    description:
      "Broad metadata for discovery and vocabulary. It is not a systematic review or evidence that every record was read in full."
  }
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "@id": `${SITE.canonicalUrl}/research/core-lmd-ai-sources#article`,
  headline: title,
  description,
  author: { "@id": `${SITE.canonicalUrl}/identity#manish-sharma`, name: PERSON.name },
  datePublished: "2026-05-10",
  dateModified: SITE.lastUpdated,
  url: `${SITE.canonicalUrl}/research/core-lmd-ai-sources`,
  about: [
    "Laser Metal Deposition",
    "Directed Energy Deposition",
    "Process Monitoring",
    "AI Risk Management"
  ],
  citation: verifiedSources.map((source) => ({
    "@type": "CreativeWork",
    name: source.title,
    url: source.href
  }))
};
---

<Layout title={seoTitle} description={description} canonical="/research/core-lmd-ai-sources" jsonLd={jsonLd} ogType="article">
  <article class="research-article">
    <header class="site-shell research-article__masthead">
      <div class="research-article__masthead-copy">
        <p>Verified source map</p>
        <h1>{title}</h1>
        <div>
        Eight checked starting points for terminology, DED fundamentals, monitoring, applied LMD research, and AI risk management. Each entry states both its useful role and its evidence boundary.
        </div>
      </div>
      <div class="research-article__masthead-visual"><PageHeroVisual variant="research" /></div>
    </header>

  <section class="research-article__operating-model">
    <div class="site-shell grid gap-4 md:grid-cols-3">
      <article class="ordered-card-strong p-5">
        <p class="metric-label">01 · Identify</p>
        <h2 class="mt-3 text-xl font-black text-white">Open the linked source</h2>
        <p class="mt-3 text-sm leading-6 text-slate-300">Use the title, publisher, source type, and stable link to confirm what you are reading.</p>
      </article>
      <article class="ordered-card-strong p-5">
        <p class="metric-label">02 · Apply</p>
        <h2 class="mt-3 text-xl font-black text-white">Use it for its stated role</h2>
        <p class="mt-3 text-sm leading-6 text-slate-300">A catalogue page, review, experiment, and risk framework answer different questions.</p>
      </article>
      <article class="ordered-card-strong p-5">
        <p class="metric-label">03 · Bound</p>
        <h2 class="mt-3 text-xl font-black text-white">Stop where the evidence stops</h2>
        <p class="mt-3 text-sm leading-6 text-slate-300">None of these sources alone approves a component, process, model, or release decision.</p>
      </article>
    </div>
  </section>

  <section class="site-shell section-y">
    <SectionHeading
      eyebrow="Verified reading set"
      title="Verified sources, with explicit limits"
      description="This is a compact reading map, not a complete literature review. Follow each link and check the original context before carrying a statement into engineering work."
    />
    <div class="mt-10 grid gap-5 lg:grid-cols-2">
      {verifiedSources.map((source, index) => <ResearchSourceCard {...source} index={index} />)}
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell grid gap-10 lg:grid-cols-[0.78fr_1.22fr] lg:items-start">
      <SectionHeading
        eyebrow="Discovery layer"
        title="Broad 500-record orientation map"
        description="Use this separate metadata layer to discover terminology, authors, venues, and possible reading paths. Return to the linked source and exact context for claims."
      />
      <SourceLinks links={orientationLinks} />
    </div>
  </section>

  <section class="site-shell section-y">
    <SectionHeading
      eyebrow="Public company context"
      title="Exafuse orientation links"
      description="These public Exafuse pages provide company, capability, application, and case-study context. They remain separate from the independent standards and research set above and do not replace project-specific review or inspection evidence."
    />
    <div class="mt-10">
      <SourceLinks links={EXAFUSE_SOURCE_LINKS} />
    </div>
  </section>

  <section class="site-shell research-article__boundary">
    <div class="rounded-lg border border-orange-300/25 bg-orange-500/10 p-6">
      <p class="metric-label text-orange-100">Decision boundary</p>
      <p class="mt-4 text-lg font-bold leading-8 text-orange-50">
        Preliminary decision-support only. Final feasibility depends on base material, geometry, service conditions, inspection requirements, and expert review.
      </p>
      <p class="mt-3 text-sm leading-6 text-orange-100/90">
        This page is a curated starting map, not a complete literature review or formal standard. Check exact technical statements against the original source and the applicable engineering context.
      </p>
    </div>
  </section>
  </article>
</Layout>
