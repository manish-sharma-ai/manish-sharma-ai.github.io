---
import Layout from "@layouts/Layout.astro";
import { LINKS } from "@data/site";

const title = "Contact — Manish Sharma Lab";
const description =
  "For professional questions, connect with Manish Sharma on LinkedIn. For industrial Laser Metal Deposition services, case studies, or RFQs, visit Exafuse.";
---

<Layout title={title} description={description} canonical="/contact">
  <section class="site-shell py-16 md:py-20">
    <div class="glass-panel max-w-4xl rounded-lg p-8 md:p-10">
      <p class="metric-label">Contact</p>
      <h1 class="mt-5 text-5xl font-black leading-tight text-white md:text-6xl">Contact</h1>
      <p class="mt-6 text-xl leading-9 text-slate-200">
        For professional questions, connect with me on LinkedIn.
      </p>
      <p class="mt-4 text-xl leading-9 text-slate-200">
        For industrial Laser Metal Deposition services, case studies, or RFQs, visit Exafuse.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href={LINKS.linkedin} class="btn btn-primary" target="_blank" rel="noreferrer">LinkedIn</a>
        <a href={LINKS.exafuse} class="btn btn-laser" target="_blank" rel="noreferrer">Exafuse</a>
        <a href={LINKS.github} class="btn btn-secondary" target="_blank" rel="noreferrer">GitHub</a>
      </div>
    </div>
  </section>
</Layout>
