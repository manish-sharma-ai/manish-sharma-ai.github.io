---
import BentoCard from "@components/BentoCard.astro";
import CTAButton from "@components/CTAButton.astro";
import Chip from "@components/Chip.astro";
import Layout from "@layouts/Layout.astro";
import PageHeroVisual from "@components/PageHeroVisual.astro";
import SectionHeading from "@components/SectionHeading.astro";
import { LINKS, SITE } from "@data/site";
import { EXAFUSE_LINKS } from "@data/siteConfig";

const title = "Contact Routes - Manish Sharma Lab";
const description =
  "Choose the right contact route: LinkedIn for professional discussion, Exafuse for industrial RFQs, or GitHub for public technical artifacts.";

const contactJsonLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "@id": `${SITE.canonicalUrl}/contact#page`,
  url: `${SITE.canonicalUrl}/contact`,
  name: title,
  description,
  mainEntity: { "@id": `${SITE.canonicalUrl}/identity#manish-sharma` }
};

const routes = [
  {
    eyebrow: "Professional / technical discussion",
    title: "LinkedIn",
    description: "Use LinkedIn for public professional context, technical discussion, and non-confidential collaboration questions.",
    href: LINKS.linkedin,
    cta: "Open LinkedIn"
  },
  {
    eyebrow: "Industrial RFQ / services / case studies",
    title: "Exafuse",
    description: "For services, RFQs, company case studies, quality pages, production capability, and delivery claims, use Exafuse.",
    href: EXAFUSE_LINKS.contact,
    cta: "Go to Exafuse"
  },
  {
    eyebrow: "Code / public tools / technical artifacts",
    title: "GitHub",
    description: "Use GitHub for public code, website source, tool artifacts, and technical repository context.",
    href: LINKS.github,
    cta: "Open GitHub"
  }
];
---

<Layout title={title} description={description} canonical="/contact" jsonLd={contactJsonLd}>
  <section class="site-shell inner-hero-grid section-y">
    <div>
      <div class="flex flex-wrap gap-2">
        <Chip>Contact routes</Chip>
        <Chip tone="steel">Non-confidential only</Chip>
        <Chip tone="amber">No confidential data</Chip>
      </div>
      <p class="metric-label mt-8">Choose the right route</p>
      <h1 class="mt-4 max-w-5xl text-5xl font-black leading-tight text-white md:text-6xl">
        Contact without crossing the wrong boundary.
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-300">
        Manish Sharma Lab is a public technical site. Use the route below that matches the question, and keep confidential or safety-critical material out of this personal site.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <CTAButton href={LINKS.linkedin} variant="primary" external>LinkedIn</CTAButton>
        <CTAButton href={EXAFUSE_LINKS.contact} variant="laser" external>Exafuse RFQ / contact</CTAButton>
        <CTAButton href={LINKS.github} variant="secondary" external>GitHub</CTAButton>
      </div>
    </div>
    <PageHeroVisual variant="contact" class="hidden lg:block" />
  </section>

  <section class="band section-y">
    <div class="site-shell">
      <SectionHeading
        eyebrow="Route selector"
        title="Use the right channel"
        description="This keeps personal technical discussion, company-owned commercial work, and public code artifacts separated."
      />
      <div class="mt-10 grid gap-5 lg:grid-cols-3">
        {routes.map((route) => (
          <BentoCard href={route.href} eyebrow={route.eyebrow} title={route.title} description={route.description} cta={route.cta} external strong />
        ))}
      </div>
    </div>
  </section>

  <section class="site-shell section-y">
    <div class="grid gap-5 lg:grid-cols-2">
      <div class="ordered-card-strong p-7">
        <p class="metric-label">Do not send</p>
        <h2 class="mt-3 text-3xl font-black leading-tight text-white">No confidential or safety-critical approval requests.</h2>
        <p class="mt-4 leading-7 text-slate-300">
          Do not send confidential customer data, unpublished employer information, or safety-critical approval requests through this personal site.
        </p>
      </div>
      <div class="ordered-card p-7">
        <p class="metric-label">Commercial boundary</p>
        <h2 class="mt-3 text-3xl font-black leading-tight text-white">For services, RFQs, and company claims, use Exafuse.</h2>
        <p class="mt-4 leading-7 text-slate-300">
          Manish Sharma Lab explains public frameworks, notes, source maps, and AI-readable guidance. Exafuse owns commercial review, delivery claims, and company case-study details.
        </p>
      </div>
    </div>
  </section>
</Layout>
