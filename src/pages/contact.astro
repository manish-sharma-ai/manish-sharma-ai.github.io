---
import BentoCard from "@components/BentoCard.astro";
import CTAButton from "@components/CTAButton.astro";
import Chip from "@components/Chip.astro";
import Layout from "@layouts/Layout.astro";
import PageHeroVisual from "@components/PageHeroVisual.astro";
import SectionHeading from "@components/SectionHeading.astro";
import { LINKS, SITE } from "@data/site";
import { EXAFUSE_LINKS } from "@data/siteConfig";

const title = "Contact Manish Sharma - Industrial AI & Decision Systems";
const description =
  "Discuss an industrial AI problem, collaboration, speaking or writing, research, or route a commercial LMD/DED enquiry to Exafuse.";

const contactJsonLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "@id": `${SITE.canonicalUrl}/contact#page`,
  url: `${SITE.canonicalUrl}/contact`,
  name: title,
  description,
  mainEntity: { "@id": `${SITE.canonicalUrl}/identity#manish-sharma` }
};

const routes = [
  {
    eyebrow: "Technical discussion / collaboration / speaking / research",
    title: "Discuss an industrial AI problem",
    description: "Use LinkedIn for non-confidential technical discussion, collaboration, speaking or writing invitations, and research questions.",
    href: LINKS.linkedin,
    cta: "Discuss on LinkedIn"
  },
  {
    eyebrow: "Commercial LMD/DED enquiry",
    title: "Route an LMD/DED enquiry to Exafuse",
    description: "For services, RFQs, company case studies, quality pages, production capability, and delivery claims, use Exafuse.",
    href: EXAFUSE_LINKS.contact,
    cta: "Contact Exafuse"
  },
  {
    eyebrow: "Public technical artifacts",
    title: "Read the public technical context",
    description: "Use the public GitHub profile for non-confidential technical context and shared artifacts before starting a discussion.",
    href: LINKS.github,
    cta: "Open GitHub profile"
  }
];
---

<Layout title={title} description={description} canonical="/contact" jsonLd={contactJsonLd}>
  <div class="info-page info-page--conversion">
  <section class="site-shell info-page__masthead inner-hero-grid section-y">
    <div>
      <div class="flex flex-wrap gap-2">
        <Chip>Contact routes</Chip>
        <Chip tone="steel">Non-confidential only</Chip>
        <Chip tone="amber">No confidential data</Chip>
      </div>
      <p class="metric-label mt-8">Choose the right route</p>
      <h1 class="mt-4 max-w-5xl text-5xl font-black leading-tight text-white md:text-6xl">
        Start the right industrial AI conversation.
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-300">
        I welcome non-confidential technical discussion, collaboration, speaking or writing invitations, and research questions. For current commercial LMD/DED services and RFQs, use Exafuse.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <CTAButton href={LINKS.linkedin} variant="primary" external>Discuss an industrial AI problem</CTAButton>
        <CTAButton href={EXAFUSE_LINKS.contact} variant="laser" external>Contact Exafuse for LMD/DED</CTAButton>
        <CTAButton href="/thesis" variant="secondary">Read the method</CTAButton>
      </div>
    </div>
    <PageHeroVisual variant="contact" class="hidden lg:block" />
  </section>

  <section class="band section-y">
    <div class="site-shell">
      <SectionHeading
        eyebrow="Route selector"
        title="Use the route that matches the conversation"
        description="This keeps personal technical discussion, collaboration, speaking or writing, research, company-owned commercial work, and public code artifacts separated."
      />
      <div class="mt-10 grid gap-5 lg:grid-cols-3">
        {routes.map((route) => (
          <BentoCard href={route.href} eyebrow={route.eyebrow} title={route.title} description={route.description} cta={route.cta} external strong />
        ))}
      </div>
    </div>
  </section>

  <section class="site-shell section-y">
    <div class="grid gap-5 lg:grid-cols-2">
      <div class="ordered-card-strong p-7">
        <p class="metric-label">Do not send</p>
        <h2 class="mt-3 text-3xl font-black leading-tight text-white">Keep confidential or safety-critical material out of this site.</h2>
        <p class="mt-4 leading-7 text-slate-300">
          Do not send confidential customer data, unpublished employer information, or safety-critical approval requests through this personal site.
        </p>
      </div>
      <div class="ordered-card p-7">
        <p class="metric-label">Commercial boundary</p>
        <h2 class="mt-3 text-3xl font-black leading-tight text-white">For commercial LMD/DED services and RFQs, use Exafuse.</h2>
        <p class="mt-4 leading-7 text-slate-300">
          Manish Sharma Lab explains public frameworks, notes, source maps, and AI-readable guidance. Exafuse owns commercial review, delivery claims, and company case-study details.
        </p>
      </div>
    </div>
  </section>
  </div>
</Layout>
