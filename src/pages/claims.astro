---
import Badge from "@components/Badge.astro";
import Layout from "@layouts/Layout.astro";
import SectionHeading from "@components/SectionHeading.astro";
import { CLAIM_REVIEW_FEEDBACK_ROUTE } from "@data/briefStandard";
import { PUBLIC_CLAIMS, getClaimHref, getClaimHumanExplanation, getClaimSourceStatus } from "@data/publicClaims";
import { PERSON, SITE } from "@data/site";

const title = "Public Claim Source Notes";
const description =
  "Human-readable source notes for public Manish Sharma Lab claims, limitations, review dates, and correction routes.";

const activeClaims = PUBLIC_CLAIMS.filter((claim) => claim.confidence !== "do-not-render");
const heldClaims = PUBLIC_CLAIMS.filter((claim) => claim.confidence === "do-not-render");

const groups = [
  {
    label: "Exafuse public context",
    claims: activeClaims.filter((claim) => claim.sourceType === "exafuse-public")
  },
  {
    label: "Personal/public profile facts",
    claims: activeClaims.filter((claim) => ["personal-public", "public-profile"].includes(claim.sourceType))
  },
  {
    label: "Research/publication facts",
    claims: activeClaims.filter((claim) => claim.sourceType === "published-paper")
  },
  {
    label: "Literature/reference map facts",
    claims: activeClaims.filter((claim) => claim.id.includes("literature"))
  }
].filter((group) => group.claims.length > 0);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": `${SITE.canonicalUrl}/claims#page`,
  url: `${SITE.canonicalUrl}/claims`,
  name: title,
  description,
  author: { "@id": `${SITE.canonicalUrl}/identity#manish-sharma`, name: PERSON.name }
};
---

<Layout title={`${title} - Manish Sharma Lab`} description={description} canonical="/claims" jsonLd={jsonLd}>
  <div class="info-page info-page--policy">
  <section class="site-shell info-page__masthead section-y">
    <div class="max-w-4xl">
      <div class="flex flex-wrap gap-2">
        <Badge>Claim notes</Badge>
        <Badge tone="steel">Source context</Badge>
        <Badge tone="laser">Limitations visible</Badge>
      </div>
      <h1 class="mt-6 text-5xl font-black leading-tight text-white md:text-6xl">Public claims should be auditable.</h1>
      <p class="mt-6 text-lg leading-8 text-slate-300 md:text-xl">
        This page keeps public claims connected to source context, review dates, and limitations. Metrics and profile facts are not free-floating marketing copy.
      </p>
      <p class="mt-4 max-w-3xl rounded-lg border border-amber-300/25 bg-amber-400/10 p-4 text-sm font-bold leading-6 text-amber-50">
        Claims are public context, not transferable feasibility or approval.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a href={CLAIM_REVIEW_FEEDBACK_ROUTE} class="btn btn-secondary">Suggest a claim correction</a>
        <a href="/no-hype" class="btn btn-secondary">Review boundary rules</a>
      </div>
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell grid gap-10">
      {groups.map((group) => (
        <section>
          <SectionHeading eyebrow="Claim group" title={group.label} />
          <div class="mt-8 grid gap-5 lg:grid-cols-2">
            {group.claims.map((claim) => {
              const displayValue = `${claim.value} ${claim.unit}`.trim();
              const sourceStatus = getClaimSourceStatus(claim);
              const sourceHref = getClaimHref(claim);
              const auditFields = [
                ["Source context", `${claim.sourceType} / ${sourceStatus}`],
                ["Last reviewed", claim.lastReviewed],
                ["Where it may appear", claim.allowedPages.length ? claim.allowedPages.join(", ") : "Not used in public page copy until reviewed."],
                ["Related source or page", claim.sourceUrlKey ? "Exafuse public context via current contact or index route" : sourceHref],
                ["Reference id", claim.id]
              ];
              return (
                <article class="ordered-card-strong p-5" data-claim-id={claim.id}>
                  <div class="flex flex-wrap gap-2">
                    <span class="chip">{displayValue || claim.shortLabel}</span>
                    <span class="chip chip--steel">{sourceStatus}</span>
                  </div>
                  <h2 class="mt-4 text-2xl font-black text-white">{claim.shortLabel}</h2>
                  <dl class="mt-5 grid gap-4 text-sm leading-6">
                    <div>
                      <dt class="font-black text-white">Claim</dt>
                      <dd class="mt-1 text-slate-200">{claim.fullText}</dd>
                    </div>
                    <div>
                      <dt class="font-black text-white">Why it matters</dt>
                      <dd class="mt-1 text-slate-300">
                        {getClaimHumanExplanation(claim)}
                      </dd>
                    </div>
                    <div>
                      <dt class="font-black text-white">Limitation</dt>
                      <dd class="mt-1 text-orange-100">{claim.limitation}</dd>
                    </div>
                  </dl>
                  <details class="ordered-card mt-5 p-4">
                    <summary class="flex cursor-pointer items-center justify-between gap-4 text-sm font-black text-white">
                      <span>Review details</span>
                      <span class="metric-label">Collapsed</span>
                    </summary>
                    <dl class="mt-4 grid gap-3 text-sm leading-6">
                    {auditFields.map(([label, value]) => (
                      <div>
                        <dt class="font-black text-white">{label}</dt>
                        <dd class="mt-1 text-slate-300">{value}</dd>
                      </div>
                    ))}
                    </dl>
                    <a href={sourceHref} class="btn btn-secondary mt-5" target={sourceHref.startsWith("http") ? "_blank" : undefined} rel={sourceHref.startsWith("http") ? "noreferrer" : undefined}>
                      Open source/context
                    </a>
                  </details>
                </article>
              );
            })}
          </div>
        </section>
      ))}
    </div>
  </section>

  {heldClaims.length > 0 && (
    <section class="site-shell section-y">
      <details class="ordered-card-strong p-6 md:p-7">
        <summary class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          <span>
            <span class="metric-label">Review queue</span>
            <span class="mt-2 block text-3xl font-black text-white">Held for source review</span>
          </span>
          <span class="chip chip--amber">Collapsed by default</span>
        </summary>
        <p class="mt-5 max-w-3xl rounded-lg border border-amber-300/25 bg-amber-400/10 p-4 text-sm font-bold leading-6 text-amber-50">
          These are not active public claims and should not be used in page copy until source verification is complete.
        </p>
        <div class="mt-8 grid gap-5 lg:grid-cols-2">
          {heldClaims.map((claim) => {
            const fields = [
              ["Value", "Held for source review"],
              ["Claim label", claim.fullText],
              ["Source status", "Not active public copy"],
              ["Source type", claim.sourceType],
              ["Last reviewed", claim.lastReviewed],
              ["Where it may appear", "Not used on public pages until reviewed."],
              ["Limitation", claim.limitation]
            ];
            return (
              <article class="ordered-card p-5" data-claim-id={claim.id}>
                <div class="flex flex-wrap gap-2">
                  <span class="chip chip--steel">{claim.sourceType}</span>
                  <span class="chip chip--amber">not active</span>
                </div>
                <h2 class="mt-4 text-2xl font-black text-white">{claim.shortLabel}</h2>
                <dl class="mt-5 grid gap-3 text-sm leading-6">
                  {fields.map(([label, value]) => (
                    <div>
                      <dt class="font-black text-white">{label}</dt>
                      <dd class="mt-1 text-slate-300">{value}</dd>
                    </div>
                  ))}
                </dl>
              </article>
            );
          })}
        </div>
      </details>
    </section>
  )}

  <section class="site-shell section-y">
    <div class="ordered-card p-6">
      <p class="metric-label">Boundary</p>
      <p class="mt-3 text-base font-semibold leading-7 text-slate-200">
        Project targets are targets, not achieved production results. Exafuse case claims remain company-owned public context. This page does not disclose confidential employer, customer, or private project data.
      </p>
    </div>
  </section>
  </div>
</Layout>
