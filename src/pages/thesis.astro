---
import Badge from "@components/Badge.astro";
import Layout from "@layouts/Layout.astro";
import PageHeroVisual from "@components/PageHeroVisual.astro";
import ProcessLoop from "@components/ProcessLoop.astro";
import SectionHeading from "@components/SectionHeading.astro";
import SignalNotProofExplainer from "@components/SignalNotProofExplainer";
import SourceLinks from "@components/SourceLinks.astro";
import { PERSON, SITE } from "@data/site";
import { EXAFUSE_LINKS } from "@data/siteConfig";

const title = "Industrial AI for Decisions That Need Evidence";
const subtitle = "My working method: Sense -> Model -> Decide -> Verify";
const description =
  "Manish Sharma's working method for industrial AI: connect signals, assumptions, decisions, and verification evidence, grounded in current LMD/DED work at Exafuse.";

const principles = [
  "A signal is not proof.",
  "A model output is not automatically an engineering decision.",
  "Missing information should remain visible.",
  "Confidence should not hide uncertainty.",
  "Human review must be explicit where risk requires it.",
  "Verification must match the consequence of failure.",
  "Useful industrial AI creates traceability, not only predictions."
];

const appliedProof = [
  ["Process monitoring", "Signals from LMD/DED systems can expose instability candidates, drift, and review points."],
  ["Melt-pool signals", "A melt-pool signal can support awareness, but it does not prove final part quality by itself."],
  ["Bead geometry", "Geometry indicators can guide process review and machining planning when tied to inspection evidence."],
  ["Repairability screening", "Material, damage, access, tolerance, inspection, and criticality must remain visible before a recommendation hardens."],
  ["RFQ preparation", "Known facts, missing information, assumptions, risks, and next steps should be separated."],
  ["Process route selection", "LMD, DED, cladding, SLM/LPBF, machining, replacement, or no repair should be compared with explicit trade-offs."],
  ["Inspection evidence", "Dimensional checks, NDT, material evidence, and expert review close the loop where risk requires it."]
];

const links = [
  { label: "LMD / DED domain hub", href: "/domains/lmd-ded" },
  { label: "LMD Quality Evidence Ladder", href: "/frameworks/lmd-quality-evidence-ladder" },
  { label: "LMD Repairability Index", href: "/frameworks/lmd-repairability-index" },
  { label: "LMD RFQ Toolkit", href: "/agent-pack" },
  { label: "Evidence Base", href: "/evidence" },
  { label: "About Manish Sharma", href: "/about" }
];

const stageLinks = [
  {
    stage: "Sense",
    text: "Process signals, images, measurements, logs, human observations, and RFQ inputs.",
    links: [
      { label: "LMD / DED domain hub", href: "/domains/lmd-ded" },
      { label: "Melt-pool monitoring glossary", href: "/glossary/melt-pool-monitoring" },
      { label: "Exafuse technology", href: EXAFUSE_LINKS.technology }
    ]
  },
  {
    stage: "Model",
    text: "AI, statistical, process, and rule-based models with visible assumptions and uncertainty.",
    links: [
      { label: "LMD-AI Readiness Score", href: "/frameworks/lmd-ai-readiness-score" },
      { label: "LMD Failure Atlas", href: "/frameworks/lmd-failure-atlas" },
      { label: "Core LMD-AI Sources", href: "/research/core-lmd-ai-sources" }
    ]
  },
  {
    stage: "Decide",
    text: "Repairability, process route, inspection need, risk level, and next-step recommendations.",
    links: [
      { label: "LMD Repairability Index", href: "/frameworks/lmd-repairability-index" },
      { label: "LMD RFQ Toolkit", href: "/agent-pack" },
      { label: "Tools", href: "/tools" }
    ]
  },
  {
    stage: "Verify",
    text: "Quality evidence, testing, inspection, documentation, release criteria, and expert review.",
    links: [
      { label: "Evidence Base", href: "/evidence" },
      { label: "LMD Quality Evidence Ladder", href: "/frameworks/lmd-quality-evidence-ladder" },
      { label: "Exafuse quality", href: EXAFUSE_LINKS.quality }
    ]
  }
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "@id": `${SITE.canonicalUrl}/thesis#article`,
  headline: title,
  description,
  author: { "@id": `${SITE.canonicalUrl}/identity#manish-sharma`, name: PERSON.name },
  datePublished: "2026-06-24",
  dateModified: SITE.lastUpdated,
  url: `${SITE.canonicalUrl}/thesis`,
  about: ["Industrial AI", "Decision Support Systems", "Machine Vision", "Robotics", "Process Monitoring", "Engineering Evidence"]
};
---

<Layout title={`${title} - Manish Sharma Lab`} description={description} canonical="/thesis" jsonLd={jsonLd}>
  <div class="info-page info-page--thesis">
  <section class="site-shell info-page__masthead grid gap-10 section-y lg:grid-cols-[minmax(0,1fr)_minmax(24rem,0.62fr)] lg:items-center">
    <div class="max-w-4xl">
      <div class="flex flex-wrap gap-2">
        <Badge>Working thesis</Badge>
        <Badge tone="steel">Public operating model</Badge>
        <Badge tone="laser">Evidence-bound</Badge>
      </div>
      <p class="metric-label mt-8">Manish Sharma / working method</p>
      <h1 class="mt-5 text-5xl font-black leading-tight text-white md:text-6xl">{title}</h1>
      <p class="mt-5 text-2xl font-bold text-cyan-100">{subtitle}</p>
      <p class="mt-6 text-lg leading-8 text-slate-300 md:text-xl">
        I use this method because a prediction alone does not finish the industrial job. The output has to be tied to what it observed, the assumptions that may limit it, the decision under consideration, and the evidence that can responsibly check the outcome. LMD/DED is the current proving ground where I can test that discipline in public.
      </p>
    </div>
    <PageHeroVisual variant="frameworks" class="hidden lg:block" />
  </section>

  <section class="band section-y">
    <div class="site-shell">
      <SectionHeading
        eyebrow="Four-stage loop"
        title="Sense, Model, Decide, Verify"
        description="This is my practical operating model for industrial-AI work, not a claim to own a new discipline."
      />
      <div class="mt-10">
        <ProcessLoop variant="full" />
      </div>
    </div>
  </section>

  <section class="site-shell section-y">
    <SectionHeading
      eyebrow="Stage links"
      title="Connect each stage to a source, framework, or tool"
      description="The method is useful only when it routes readers to concrete LMD/DED resources and an explicit verification path."
    />
    <div class="mt-10 grid gap-5 md:grid-cols-2">
      {stageLinks.map((stage) => (
        <article class="ordered-card-strong p-6">
          <h2 class="text-2xl font-black text-white">{stage.stage}</h2>
          <p class="mt-3 text-sm leading-6 text-slate-300">{stage.text}</p>
          <div class="mt-5 flex flex-wrap gap-2">
            {stage.links.map((link) => (
              <a
                href={link.href}
                class="rounded-md border border-white/10 bg-white/[0.035] px-3 py-2 text-xs font-bold uppercase tracking-[0.14em] text-cyan-100 hover:border-cyan-300/40 hover:bg-cyan-300/10 hover:text-white"
                target={link.href.startsWith("http") ? "_blank" : undefined}
                rel={link.href.startsWith("http") ? "noreferrer" : undefined}
              >
                {link.label}
              </a>
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="site-shell section-y">
    <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr]">
      <SectionHeading
        eyebrow="Principles"
        title="Decision support has to keep uncertainty visible"
        description="The model is useful only when the decision path remains inspectable."
      />
      <div class="grid gap-3 md:grid-cols-2">
        {principles.map((principle) => (
          <div class="ordered-card p-4 text-sm font-bold leading-6 text-slate-100">{principle}</div>
        ))}
      </div>
    </div>
  </section>

  <section class="site-shell section-y">
    <SignalNotProofExplainer client:load />
  </section>

  <section class="band section-y">
    <div class="site-shell grid gap-6 lg:grid-cols-[0.8fr_1.2fr]">
      <SectionHeading
        eyebrow="What changes the decision"
        title="Monitoring signals need context before they become useful"
        description="A signal becomes more useful when it can be tied to inspection, calibration, repeatability, and acceptance criteria."
      />
      <div class="grid gap-3 sm:grid-cols-2">
        {["Correlation with inspection", "Drift history", "Sensor calibration", "Image quality", "Process repeatability", "Acceptance criteria"].map((item) => (
          <div class="ordered-card p-4 text-sm font-bold leading-6 text-slate-100">{item}</div>
        ))}
      </div>
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell">
      <SectionHeading
        eyebrow="Applied proof"
        title="LMD / DED is my current proving ground"
        description="My strongest public technical context is AI for Laser Metal Deposition and Directed Energy Deposition at Exafuse. It is where this method meets physical signals, materials, robotics, repair, and inspection."
      />
      <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {appliedProof.map(([heading, text]) => (
          <article class="ordered-card p-5">
            <h2 class="text-xl font-black text-white">{heading}</h2>
            <p class="mt-3 text-sm leading-6 text-slate-300">{text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="site-shell section-y">
    <div class="grid gap-10 lg:grid-cols-[0.82fr_1.18fr]">
      <SectionHeading
        eyebrow="Use with"
        title="Public resources that make the thesis practical"
        description="These links connect my working method to existing LMD/DED frameworks, evidence, and RFQ resources."
      />
      <SourceLinks links={links} />
    </div>
  </section>
  </div>
</Layout>
