---
import Badge from "@components/Badge.astro";
import CTAButton from "@components/CTAButton.astro";
import CopyBlock from "@components/CopyBlock";
import Layout from "@layouts/Layout.astro";
import { resolveExafuseLink } from "../../config/externalLinks";
import { PERSON, SITE } from "@data/site";

const title = "LMD Decision Playbooks";
const description =
  "Practical Laser Metal Deposition playbooks for repair, process route selection, monitoring evidence, and RFQ preparation.";
const exafuseRfqLink = resolveExafuseLink("rfq");

const playbooks = [
  {
    title: "LMD repair playbook",
    situation: "A damaged or worn part may be repairable by local deposition, rebuild, cladding, machining, or replacement.",
    badAssumption: "Local damage automatically means repair is feasible.",
    inputs: ["material grade", "damage depth and extent", "photos", "drawing/CAD", "tolerance target", "service conditions", "inspection requirement"],
    path: ["Confirm material and base-part condition.", "Map damage and access.", "Check post-machining and inspection route.", "Flag criticality.", "Prepare expert-review package."],
    evidence: ["material compatibility", "damage map", "machining allowance", "inspection plan", "acceptance criteria"],
    aiCan: "Structure the RFQ, expose missing facts, compare route signals, and create a review checklist.",
    aiCannot: "Approve repair, certify material, or decide safety-critical release.",
    matchingTool: { label: "LMD Repairability Quick Check", href: "/tools#repairability-module" },
    framework: { label: "LMD Repairability Index", href: "/frameworks/lmd-repairability-index" },
    whatChanges: ["Unknown material", "Cracks beyond visible damage", "Tight tolerance", "No post-machining route", "Safety-critical service", "No inspection plan"],
    checklist: ["Part and material grade", "Damage photos and depth", "Drawing/CAD", "Tolerance and finishing need", "Operating conditions", "Inspection requirement", "Commercial route to Exafuse"]
  },
  {
    title: "LMD vs SLM / LPBF route-selection playbook",
    situation: "A part or feature could be considered for LMD/DED, SLM/LPBF, hybrid manufacturing, machining, or replacement.",
    badAssumption: "One metal AM acronym is automatically better.",
    inputs: ["part size", "feature size", "internal channels", "local addition need", "material", "tolerance", "qualification requirement"],
    path: ["Check scale and local deposition need.", "Check complexity and internal features.", "Check tolerance and post-processing.", "Compare inspection burden.", "Escalate balanced cases."],
    evidence: ["geometry envelope", "feature accessibility", "material route", "finishing plan", "inspection and qualification requirement"],
    aiCan: "Make the route trade-offs explicit and stop unsupported process claims.",
    aiCannot: "Guarantee feasibility or replace process engineering review.",
    matchingTool: { label: "LMD vs SLM Advisor", href: "/tools#route-module" },
    framework: { label: "LMD RFQ Toolkit", href: "/agent-pack" },
    whatChanges: ["Feature size", "Internal channels", "Part size", "Need for local deposition", "Tolerance target", "Material and qualification requirements"],
    checklist: ["Part envelope", "Feature complexity", "Internal-channel requirement", "Material", "Tolerance", "Post-processing plan", "Inspection requirement"]
  },
  {
    title: "Process monitoring vs quality evidence playbook",
    situation: "A process signal, melt-pool image, camera anomaly, or drift trend needs interpretation.",
    badAssumption: "A monitoring signal proves final quality.",
    inputs: ["signal type", "sensor context", "calibration context", "linked part/track/layer", "inspection result", "acceptance criteria"],
    path: ["Classify the signal.", "Check sensor and image context.", "Look for correlation with inspection.", "Separate awareness from proof.", "Define next evidence."],
    evidence: ["dimensional inspection", "NDT when risk requires it", "material evidence", "metallography when relevant", "expert review"],
    aiCan: "Flag anomalies, summarize drift, and suggest inspection questions.",
    aiCannot: "Prove material quality, fatigue behavior, service safety, or certification.",
    matchingTool: { label: "Signal is not proof explainer", href: "/thesis#signal-is-not-proof" },
    framework: { label: "LMD Quality Evidence Ladder", href: "/frameworks/lmd-quality-evidence-ladder" },
    whatChanges: ["Correlation with inspection", "Drift history", "Sensor calibration", "Image quality", "Process repeatability", "Acceptance criteria"],
    checklist: ["Signal source", "Sensor condition", "Linked job context", "Inspection evidence", "Acceptance criteria", "Review decision", "Boundary note"]
  },
  {
    title: "RFQ preparation playbook",
    situation: "A buyer has a rough LMD, repair, cladding, or DED question but not enough structure for review.",
    badAssumption: "A short request is enough for feasibility.",
    inputs: ["part/component", "goal", "material", "damage/build area", "photos", "drawing/CAD", "service conditions", "deadline"],
    path: ["Extract known facts.", "List missing information.", "Flag risk.", "State evidence needed.", "Prepare a compact review brief."],
    evidence: ["material grade", "drawing/CAD", "damage depth", "operating conditions", "tolerance", "inspection requirement", "deadline"],
    aiCan: "Convert free text into a structured RFQ summary and missing-information checklist.",
    aiCannot: "Make a commercial feasibility decision or replace Exafuse review.",
    matchingTool: { label: "RFQ Prompt-to-Structure Converter", href: "/tools#rfq-module" },
    framework: { label: "LMD RFQ Toolkit", href: "/agent-pack" },
    whatChanges: ["Missing material grade", "Missing drawing/CAD", "Missing damage depth", "Missing operating conditions", "Missing tolerance", "Missing deadline"],
    checklist: ["Part/component", "Goal", "Material", "Damage/build area", "Available files", "Missing fields", "Risk flags", "Exafuse review route"]
  }
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": `${SITE.canonicalUrl}/playbooks#page`,
  url: `${SITE.canonicalUrl}/playbooks`,
  name: title,
  description,
  author: { "@id": `${SITE.canonicalUrl}/identity#manish-sharma`, name: PERSON.name },
  hasPart: playbooks.map((playbook) => ({
    "@type": "TechArticle",
    name: playbook.title,
    about: playbook.inputs
  }))
};
---

<Layout title={`${title} - Manish Sharma Lab`} description={description} canonical="/playbooks" jsonLd={jsonLd}>
  <section class="site-shell section-y">
    <div class="max-w-4xl">
      <div class="flex flex-wrap gap-2">
        <Badge>Decision playbooks</Badge>
        <Badge tone="steel">Practical routes</Badge>
        <Badge tone="laser">Decision support only</Badge>
      </div>
      <h1 class="mt-6 text-5xl font-black leading-tight text-white md:text-6xl">Decision playbooks for LMD questions.</h1>
      <p class="mt-6 text-lg leading-8 text-slate-300 md:text-xl">
        These are short decision routes for repair, process selection, monitoring evidence, and RFQ preparation. They turn a vague question into inputs, risks, evidence, and a next action.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <CTAButton href="/tools#lmd-decision-cockpit" variant="primary">Start cockpit</CTAButton>
        <CTAButton href="/brief-template" variant="secondary">Open brief template</CTAButton>
        <CTAButton href={exafuseRfqLink.href} variant="laser" external>{exafuseRfqLink.label}</CTAButton>
      </div>
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell grid gap-6">
      {playbooks.map((playbook) => {
        const checklist = [
          `# ${playbook.title} checklist`,
          "",
          ...playbook.checklist.map((item) => `- [ ] ${item}`),
          "",
          "Confidence is not approval.",
          "Preliminary decision-support only. Final feasibility depends on base material, geometry, service conditions, inspection requirements, and expert review."
        ].join("\n");

        return (
          <article class="ordered-card-strong p-6 md:p-7">
            <div class="grid gap-8 lg:grid-cols-[0.88fr_1.12fr]">
              <div>
                <p class="metric-label">Playbook</p>
                <h2 class="mt-3 text-3xl font-black leading-tight text-white">{playbook.title}</h2>
                <dl class="mt-6 grid gap-4 text-sm leading-6">
                  <div>
                    <dt class="font-black text-white">When this matters</dt>
                    <dd class="mt-1 text-slate-300">{playbook.situation}</dd>
                  </div>
                  <div>
                    <dt class="font-black text-white">Common bad assumption</dt>
                    <dd class="mt-1 text-orange-100">{playbook.badAssumption}</dd>
                  </div>
                  <div>
                    <dt class="font-black text-white">What AI can help with</dt>
                    <dd class="mt-1 text-slate-300">{playbook.aiCan}</dd>
                  </div>
                  <div>
                    <dt class="font-black text-white">What AI cannot prove</dt>
                    <dd class="mt-1 text-orange-100">{playbook.aiCannot}</dd>
                  </div>
                </dl>
                <div class="mt-6 flex flex-wrap gap-3">
                  <CTAButton href={playbook.matchingTool.href} variant="primary">{playbook.matchingTool.label}</CTAButton>
                  <CTAButton href={playbook.framework.href} variant="secondary">{playbook.framework.label}</CTAButton>
                  <CTAButton href={exafuseRfqLink.href} variant="laser" external>{exafuseRfqLink.label}</CTAButton>
                </div>
              </div>
              <div class="grid gap-5">
                {[
                  ["What to ask first", playbook.inputs],
                  ["Decision path", playbook.path],
                  ["What changes the decision", playbook.whatChanges],
                  ["What evidence closes the loop", playbook.evidence],
                  ["What to send for expert review", playbook.checklist]
                ].map(([blockTitle, items]) => (
                  <div class="ordered-card p-5">
                    <h3 class="text-lg font-black text-white">{blockTitle}</h3>
                    <div class="mt-3 flex flex-wrap gap-2">
                      {(items as string[]).map((item) => (
                        <span class="rounded-md border border-white/10 bg-white/[0.035] px-2.5 py-1 text-xs font-bold leading-5 text-slate-300">{item}</span>
                      ))}
                    </div>
                  </div>
                ))}
                <CopyBlock client:load label={`${playbook.title} checklist`} text={checklist} />
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </section>
</Layout>
