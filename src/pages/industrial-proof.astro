---
import Badge from "@components/Badge.astro";
import ExafuseProofMedia from "@components/ExafuseProofMedia.astro";
import Layout from "@layouts/Layout.astro";
import PageHeroVisual from "@components/PageHeroVisual.astro";
import SectionHeading from "@components/SectionHeading.astro";
import SourceLinks from "@components/SourceLinks.astro";
import {
  EXAFUSE_CAPABILITY_SIGNALS,
  EXAFUSE_KNOWLEDGE_SIGNALS,
  EXAFUSE_SOURCE_LINKS
} from "@data/exafuse";
import { EXAFUSE_PUBLIC_PROOF } from "@data/exafusePublicProof";
import { PERSON, SITE } from "@data/site";

const title = "Industrial LMD Evidence Map - Manish Sharma Lab";
const description =
  "Public Exafuse-linked context for structural LMD, repair, build-and-coat workflows, monitoring, and evidence-aware AI boundaries.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": `${SITE.canonicalUrl}/industrial-proof#page`,
  url: `${SITE.canonicalUrl}/industrial-proof`,
  name: title,
  description,
  author: {
    "@id": `${SITE.canonicalUrl}/identity#manish-sharma`,
    "@type": "Person",
    name: PERSON.name
  },
  about: [
    "Laser Metal Deposition",
    "Industrial repair",
    "Process monitoring",
    "Exafuse",
    "Directed Energy Deposition"
  ],
  hasPart: [
    {
      "@type": "Dataset",
      name: "Exafuse public context map",
      url: `${SITE.canonicalUrl}/research/exafuse-public-proof-map.json`
    }
  ]
};

const proofDecisionPatterns: Record<string, { label: string; href: string }> = {
  "cs15-duisburg-bridge": { label: "Start a brief from this pattern", href: "/tools/#preset=monitoring-anomaly" },
  "cs10-nobufil-extrusion-screw": { label: "Start a brief from this pattern", href: "/tools/#preset=rfq" },
  "cs05-valve-seat-ring": { label: "Start a brief from this pattern", href: "/tools/#preset=surface-cladding" },
  "cs13-zipp-drill": { label: "Start a brief from this pattern", href: "/tools/#preset=surface-cladding" }
};

const proofDecisionPatternText: Record<string, string> = {
  "cs15-duisburg-bridge": "Large-scale LMD requires evidence planning, monitoring context, and an inspection boundary.",
  "cs10-nobufil-extrusion-screw": "Repair/RFQ quality depends on complete facts, downtime context, and service context.",
  "cs05-valve-seat-ring": "Surface function needs material, heat, finishing, inspection, and acceptance context.",
  "cs13-zipp-drill": "Build-and-coat routes need geometry, surface function, material, finishing, and validation."
};
---

<Layout title={title} description={description} canonical="/industrial-proof" jsonLd={jsonLd}>
  <div class="industrial-proof">
  <section class="site-shell section-y industrial-proof__masthead">
    <div class="industrial-proof__masthead-grid grid gap-12 lg:grid-cols-[0.88fr_1.12fr] lg:items-end">
      <div>
        <div class="flex flex-wrap gap-2">
          <Badge>Industrial evidence</Badge>
          <Badge tone="laser">Exafuse-linked</Badge>
          <Badge tone="steel">Public sources only</Badge>
        </div>
        <p class="metric-label mt-8">Exafuse public context map</p>
        <h1 class="mt-4 text-5xl font-black leading-tight text-white md:text-6xl">
          The industrial context behind the lab.
        </h1>
        <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-300 md:text-xl">
          This page connects public Exafuse stories to the technical themes I write about here: large-part LMD, repairability, build-and-coat workflows, material breadth, process monitoring, AI image processing, and inspection-aware decision support.
        </p>
      </div>
      <div class="grid gap-4">
        <PageHeroVisual variant="industrial" class="hidden xl:block" />
        <div class="ordered-card-strong industrial-proof__boundary p-6">
          <p class="metric-label">Claim boundary</p>
          <p class="mt-4 text-lg font-bold leading-8 text-white">
            These are public company examples. They support technical context and buyer education; they are not engineering approval, certification, guaranteed outcomes, or confidential project details.
          </p>
          <a href="/research/exafuse-public-proof-map.json" class="btn btn-secondary mt-6">Open context JSON</a>
        </div>
      </div>
    </div>
  </section>

  <section class="band industrial-proof__signals">
    <div class="site-shell grid gap-4 py-6 sm:grid-cols-2 lg:grid-cols-4">
      {EXAFUSE_CAPABILITY_SIGNALS.map((item) => (
        <a href={item.href} class="ordered-card card-hover industrial-proof__signal-card p-4" target="_blank" rel="noreferrer">
          <p class="metric-label">{item.label}</p>
          <p class="mt-2 text-3xl font-black text-white">{item.metric}</p>
          <p class="mt-2 text-sm leading-6 text-slate-400">{item.detail}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="site-shell section-y industrial-proof__cases">
    <SectionHeading
      eyebrow="Documented examples"
      title="Four public stories that make the expertise tangible"
      description="The strongest public context is not just a number. It is the chain from damaged or designed part, through route selection, deposition, finishing, monitoring, inspection, and release planning."
    />
    <div class="industrial-proof__case-grid industrial-proof__case-grid--proof-led mt-10">
      {EXAFUSE_PUBLIC_PROOF.map((item, index) => {
        const pattern = proofDecisionPatterns[item.id];
        return (
        <article class:list={["industrial-proof__case-card industrial-proof__case-card--proof", index === 0 && "industrial-proof__case-card--lead"]}>
          <div class="industrial-proof__case-copy">
            <div>
              <p class="metric-label">Exafuse public case</p>
              <h2 class="mt-3 text-2xl font-black text-white">{item.title}</h2>
              <p class="industrial-proof__case-context">{item.industrialContext}</p>
            </div>
            {item.publicMetrics.length > 0 && (
            <div class="mt-5 flex flex-wrap gap-2">
              {item.publicMetrics.slice(0, 3).map((metric) => (
                <span class="chip chip--steel" title={metric.limitation} data-exafuse-proof-metric={metric.sourcePath}>
                  {metric.value}{metric.unit ? ` ${metric.unit}` : ""} · {metric.label}
                </span>
              ))}
            </div>
          )}
            <p class="industrial-proof__case-lesson">{proofDecisionPatternText[item.id]}</p>
            <p class="industrial-proof__case-limit">{item.whatItDoesNotProve[0]}</p>
            <div class="industrial-proof__case-actions">
              <a href={`/public-work/exafuse/${item.slug}`}>Read the proof story <span aria-hidden="true">→</span></a>
              <a href={pattern.href}>Start a brief from this pattern <span aria-hidden="true">→</span></a>
            </div>
          </div>
          <div class="industrial-proof__case-media">
            <ExafuseProofMedia proof={item} sizes="(max-width: 767px) calc(100vw - 2rem), 42vw" />
          </div>
        </article>
      )})}
    </div>
  </section>

  <section class="band section-y industrial-proof__knowledge">
    <div class="site-shell grid gap-10 lg:grid-cols-[0.85fr_1.15fr]">
      <SectionHeading
        eyebrow="Knowledge signals"
        title="What the Exafuse articles add to this site"
        description="The articles are useful because they are practical and bounded: they explain fit, limits, inputs, evidence and what not to claim."
      />
      <div class="grid gap-4">
        {EXAFUSE_KNOWLEDGE_SIGNALS.map((item) => (
          <article class="ordered-card industrial-proof__knowledge-card grid gap-4 p-5 md:grid-cols-[5rem_1fr_auto] md:items-start">
            <p class="font-mono text-xl font-black text-cyan-100">{item.code}</p>
            <div>
              <h2 class="text-xl font-black text-white">{item.title}</h2>
              <p class="mt-3 text-sm leading-6 text-slate-400">{item.signal}</p>
            </div>
            <a href={item.href} class="text-sm font-bold text-cyan-100 hover:text-white" target="_blank" rel="noreferrer">Source</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="site-shell section-y industrial-proof__interpretation">
    <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr]">
      <SectionHeading
        eyebrow="Interpretation"
        title="How I use these examples"
        description="The site should read like technical interpretation over real industrial work, not a generic portfolio."
      />
      <div class="grid gap-4 md:grid-cols-2">
        {[
          ["More case-led", "Use bridge, hammer, screw and drill examples to explain decisions, not just define acronyms."],
          ["More inspection-led", "Every monitoring or AI statement should route back to inspection, release evidence and claim boundaries."],
          ["More RFQ-led", "The best content asks for material, geometry, damage, finish, inspection and timeline before recommending a process."],
          ["More materials-aware", "Material names are useful only when tied to substrate, duty, dilution, heat input, machining and validation."]
        ].map(([title, text]) => (
          <article class="ordered-card-strong industrial-proof__interpretation-card p-5">
            <h2 class="text-xl font-black text-white">{title}</h2>
            <p class="mt-3 text-sm leading-6 text-slate-400">{text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="band section-y industrial-proof__sources">
    <div class="site-shell grid gap-10 lg:grid-cols-[0.85fr_1.15fr]">
      <SectionHeading eyebrow="Sources" title="Public Exafuse pages used" />
      <SourceLinks links={EXAFUSE_SOURCE_LINKS} />
    </div>
  </section>
  </div>
</Layout>
