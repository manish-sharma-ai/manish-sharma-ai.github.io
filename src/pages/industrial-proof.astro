---
import Badge from "@components/Badge.astro";
import Layout from "@layouts/Layout.astro";
import PageHeroVisual from "@components/PageHeroVisual.astro";
import SectionHeading from "@components/SectionHeading.astro";
import SourceLinks from "@components/SourceLinks.astro";
import {
  EXAFUSE_CAPABILITY_SIGNALS,
  EXAFUSE_KNOWLEDGE_SIGNALS,
  EXAFUSE_PROOF_CASES,
  EXAFUSE_SOURCE_LINKS
} from "@data/exafuse";
import { getClaimSourceStatus } from "@data/publicClaims";
import { PERSON, SITE } from "@data/site";

const title = "Industrial LMD Proof Map - Manish Sharma Lab";
const description =
  "A public Exafuse-linked proof map showing the industrial context behind Manish Sharma Lab: large structural LMD, repair, build-and-coat workflows, material breadth, monitoring, and AI image-processing boundaries.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": `${SITE.canonicalUrl}/industrial-proof#page`,
  url: `${SITE.canonicalUrl}/industrial-proof`,
  name: title,
  description,
  author: {
    "@id": `${SITE.canonicalUrl}/identity#manish-sharma`,
    "@type": "Person",
    name: PERSON.name
  },
  about: [
    "Laser Metal Deposition",
    "Industrial repair",
    "Process monitoring",
    "Exafuse",
    "Directed Energy Deposition"
  ],
  hasPart: [
    {
      "@type": "Dataset",
      name: "Exafuse public proof map",
      url: `${SITE.canonicalUrl}/research/exafuse-public-proof-map.json`
    }
  ]
};

const proofDecisionPatterns: Record<string, { label: string; href: string }> = {
  CS15: { label: "Start a brief from this pattern", href: "/tools/#preset=monitoring-anomaly" },
  CS01: { label: "Start a brief from this pattern", href: "/tools/#preset=worn-shaft" },
  CS10: { label: "Start a brief from this pattern", href: "/tools/#preset=rfq" },
  CS13: { label: "Start a brief from this pattern", href: "/tools/#preset=surface-cladding" }
};

const proofDecisionPatternText: Record<string, string> = {
  CS15: "Large-scale LMD requires evidence planning, monitoring context, and an inspection boundary.",
  CS01: "Local repair needs material, damage depth, machining route, and inspection plan.",
  CS10: "Repair/RFQ quality depends on complete facts, downtime context, and service context.",
  CS13: "Build-and-coat routes need geometry, surface function, material, finishing, and validation."
};
---

<Layout title={title} description={description} canonical="/industrial-proof" jsonLd={jsonLd}>
  <section class="site-shell section-y">
    <div class="grid gap-12 lg:grid-cols-[0.88fr_1.12fr] lg:items-end">
      <div>
        <div class="flex flex-wrap gap-2">
          <Badge>Industrial proof</Badge>
          <Badge tone="laser">Exafuse-linked</Badge>
          <Badge tone="steel">Public sources only</Badge>
        </div>
        <p class="metric-label mt-8">Exafuse Public Proof Map</p>
        <h1 class="mt-4 text-5xl font-black leading-tight text-white md:text-6xl">
          The industrial context behind the lab.
        </h1>
        <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-300 md:text-xl">
          This page connects public Exafuse stories to the technical themes I write about here: large-part LMD, repairability, build-and-coat workflows, material breadth, process monitoring, AI image processing, and inspection-aware decision support.
        </p>
      </div>
      <div class="grid gap-4">
        <PageHeroVisual variant="industrial" class="hidden xl:block" />
        <div class="ordered-card-strong p-6">
          <p class="metric-label">Claim boundary</p>
          <p class="mt-4 text-lg font-bold leading-8 text-white">
            These are public company proof signals. They support technical context and buyer education; they are not engineering approval, certification, guaranteed outcomes, or confidential project details.
          </p>
          <a href="/research/exafuse-public-proof-map.json" class="btn btn-secondary mt-6">Open proof-map JSON</a>
        </div>
      </div>
    </div>
  </section>

  <section class="band">
    <div class="site-shell grid gap-4 py-6 sm:grid-cols-2 lg:grid-cols-4">
      {EXAFUSE_CAPABILITY_SIGNALS.map((item) => (
        <a href={item.href} class="ordered-card card-hover p-4" target="_blank" rel="noreferrer">
          <p class="metric-label">{item.label}</p>
          <p class="mt-2 text-3xl font-black text-white">{item.metric}</p>
          <p class="mt-2 text-sm leading-6 text-slate-400">{item.detail}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="site-shell section-y">
    <SectionHeading
      eyebrow="Case proof"
      title="Four public stories that make the expertise tangible"
      description="The strongest proof is not just a number. It is the chain from damaged or designed part, through route selection, deposition, finishing, monitoring, inspection, and release planning."
    />
    <div class="equal-card-grid mt-10 grid gap-5 md:grid-cols-2">
      {EXAFUSE_PROOF_CASES.map((item) => {
        const pattern = proofDecisionPatterns[item.code];
        return (
        <article class="ordered-card-strong card-hover p-6">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="metric-label">{item.code}</p>
              <h2 class="mt-3 text-2xl font-black text-white">{item.title}</h2>
              <p class="mt-3 inline-block rounded-md border border-cyan-300/25 bg-cyan-300/10 px-2.5 py-1 text-xs font-black uppercase text-cyan-100">
                {item.evidenceStatus}
              </p>
            </div>
            <a href={item.href} class="rounded-md border border-cyan-300/25 px-3 py-2 text-xs font-bold text-cyan-100 hover:bg-cyan-300/10" target="_blank" rel="noreferrer">Open</a>
          </div>
          {item.metricClaims?.length > 0 && (
            <div class="mt-5 flex flex-wrap gap-2">
              {item.metricClaims.map((claim) => (
                <span class="rounded-md border border-white/10 bg-white/[0.035] px-2.5 py-1 text-xs font-bold text-slate-200" data-claim-id={claim.id} title={claim.limitation}>
                  {claim.shortLabel}
                </span>
              ))}
            </div>
          )}
          <p class="mt-4 text-xs font-bold uppercase tracking-[0.14em] text-cyan-100">
            {item.metricClaims?.[0] ? getClaimSourceStatus(item.metricClaims[0]) : "Source activates after Exafuse production migration"}
          </p>
          <p class="mt-5 text-sm leading-6 text-slate-300">{item.lesson}</p>
          <p class="mt-4 border-l border-cyan-300/35 pl-4 text-sm font-semibold leading-6 text-cyan-50">{item.labConnection}</p>
          <div class="mt-4 rounded-lg border border-cyan-300/20 bg-cyan-300/8 p-3">
            <p class="metric-label">Decision pattern extracted</p>
            <p class="mt-2 text-sm font-semibold leading-6 text-cyan-50">{proofDecisionPatternText[item.code]}</p>
          </div>
          <p class="mt-4 rounded-lg border border-white/10 bg-white/[0.035] p-3 text-sm font-semibold leading-6 text-slate-300">
            This is a pattern, not a transfer of feasibility.
          </p>
          <div class="mt-5 flex flex-wrap gap-2">
            {item.relevance.map((signal) => (
              <span class="rounded-md border border-white/10 bg-white/[0.035] px-2.5 py-1 text-xs font-bold text-slate-300">{signal}</span>
            ))}
          </div>
          <a href={pattern.href} class="btn btn-primary mt-6">{pattern.label}</a>
        </article>
      )})}
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell grid gap-10 lg:grid-cols-[0.85fr_1.15fr]">
      <SectionHeading
        eyebrow="Knowledge signals"
        title="What the Exafuse articles add to this site"
        description="The articles are useful because they are practical and bounded: they explain fit, limits, inputs, evidence and what not to claim."
      />
      <div class="grid gap-4">
        {EXAFUSE_KNOWLEDGE_SIGNALS.map((item) => (
          <article class="ordered-card grid gap-4 p-5 md:grid-cols-[5rem_1fr_auto] md:items-start">
            <p class="font-mono text-xl font-black text-cyan-100">{item.code}</p>
            <div>
              <h2 class="text-xl font-black text-white">{item.title}</h2>
              <p class="mt-3 text-sm leading-6 text-slate-400">{item.signal}</p>
            </div>
            <a href={item.href} class="text-sm font-bold text-cyan-100 hover:text-white" target="_blank" rel="noreferrer">Source</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="site-shell section-y">
    <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr]">
      <SectionHeading
        eyebrow="Interpretation"
        title="How I use these examples"
        description="The site should read like technical interpretation over real industrial work, not a generic portfolio."
      />
      <div class="grid gap-4 md:grid-cols-2">
        {[
          ["More case-led", "Use bridge, hammer, screw and drill examples to explain decisions, not just define acronyms."],
          ["More inspection-led", "Every monitoring or AI statement should route back to inspection, release evidence and claim boundaries."],
          ["More RFQ-led", "The best content asks for material, geometry, damage, finish, inspection and timeline before recommending a process."],
          ["More materials-aware", "Material names are useful only when tied to substrate, duty, dilution, heat input, machining and validation."]
        ].map(([title, text]) => (
          <article class="ordered-card-strong p-5">
            <h2 class="text-xl font-black text-white">{title}</h2>
            <p class="mt-3 text-sm leading-6 text-slate-400">{text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell grid gap-10 lg:grid-cols-[0.85fr_1.15fr]">
      <SectionHeading eyebrow="Sources" title="Public Exafuse pages used" />
      <SourceLinks links={EXAFUSE_SOURCE_LINKS} />
    </div>
  </section>
</Layout>
