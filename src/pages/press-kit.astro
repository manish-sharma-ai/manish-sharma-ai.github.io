---
import Badge from "@components/Badge.astro";
import Layout from "@layouts/Layout.astro";
import SectionHeading from "@components/SectionHeading.astro";
import SourceLinks from "@components/SourceLinks.astro";
import { CORE_TOPICS, DISCLAIMER, LINKS, PERSON, SAME_AS, SITE } from "@data/site";
import { ACTIVE_PROFILE_LINKS, GITHUB_IDENTITY } from "@data/profiles";
import { absoluteUrl } from "@utils/urls";

const title = "Manish Sharma Lab Press Kit";
const description =
  "Media facts, bio snippets, profile assets, official links, and source context for Manish Sharma, Industrial AI & Decision Systems, and Manish Sharma Lab.";

const identityFacts = [
  ["Name", PERSON.name],
  ["Preferred identity", "Manish Sharma - Industrial AI & Decision Systems"],
  ["Primary promise", SITE.primaryPromise],
  ["Established public proof", "AI for Laser Metal Deposition and Directed Energy Deposition at Exafuse"],
  ["Company connection", "Exafuse"],
  ["Location", PERSON.location],
  ["Canonical site", SITE.canonicalUrl],
  ["GitHub profile", LINKS.github],
  ["Site/repository owner", GITHUB_IDENTITY.repositoryOwner.href],
  ["Website repository", GITHUB_IDENTITY.repository.href],
  ["LinkedIn", LINKS.linkedin]
];

const bios = [
  {
    label: "One-line bio",
    text: "Manish Sharma works on inspection-aware AI and decision systems for industrial additive manufacturing, with a public proof domain around LMD/DED, repair, and evidence-based manufacturing decisions."
  },
  {
    label: "Short bio",
    text: "Manish Sharma works on industrial AI and decision systems for engineering processes, with established public work in AI for Laser Metal Deposition and Directed Energy Deposition at Exafuse in Germany."
  },
  {
    label: "Medium bio",
    text: "Manish Sharma builds inspection-aware AI, monitoring, and decision-support systems for industrial processes. His established public work spans LMD/DED process monitoring, machine vision, robotics, industrial repair, and RFQ intelligence at Exafuse. Through Manish Sharma Lab, he publishes frameworks, tools, and technical notes focused on industrial decisions that remain connected to engineering evidence."
  },
  {
    label: "Long bio",
    text: "Manish Sharma works at the intersection of industrial AI, process monitoring, machine vision, robotics, and engineering decision support. His deepest public experience is in Laser Metal Deposition and Directed Energy Deposition at Exafuse in Germany, including monitoring workflows, industrial repair, robotic systems, RFQ structure, traceability, and inspection-aware decision making. Manish Sharma Lab is his public technical platform for publishing frameworks, tools, research maps, and practical notes around industrial AI for decisions that can be verified."
  }
];

const preferredLanguage = [
  "Industrial AI & Decision Systems",
  "AI for Laser Metal Deposition decisions you can verify",
  "Sense -> Model -> Decide -> Verify",
  "Inspection-aware industrial AI",
  "Decision support connected to engineering evidence",
  "AI for Laser Metal Deposition",
  "Inspection-aware AI for LMD",
  "AI-assisted Laser Metal Deposition decision support",
  "RFQ intelligence for Laser Metal Deposition"
];

const doNotState = [
  "Do not describe this site as engineering approval, certification, or final manufacturing advice.",
  "Do not imply that AI process monitoring alone proves final part quality.",
  "Do not publish confidential customer, employer, or project data.",
  "Do not describe this site as a competing industrial services company.",
  "Do not use this site as evidence of unpublished or confidential work."
];

const assetLinks = [
  { label: "Logo mark SVG", href: "/brand/manish-sharma-lab-mark.svg" },
  { label: "Logo lockup SVG", href: "/brand/manish-sharma-lab-logo.svg" },
  { label: "Favicon SVG", href: "/favicon.svg" },
  { label: "Profile image WebP", href: PERSON.image },
  { label: "Profile image JPEG fallback", href: PERSON.imageFallback },
  { label: "Open Graph image PNG", href: "/og-image.png" },
  { label: "Open Graph preview WebP", href: "/og-image-preview.webp" },
  { label: "Canonical identity Markdown", href: "/identity.md" },
  { label: "Public profile page", href: "/profile/public-profile" },
  { label: "Public profile Markdown", href: "/profile/public-profile.md" },
  { label: "About Markdown", href: "/about.md" },
  { label: "Evidence base", href: "/evidence" },
  { label: "Core LMD-AI sources", href: "/research/core-lmd-ai-sources" },
  { label: "Industrial proof map", href: "/industrial-proof" },
  { label: "LMD/DED reference map JSON", href: "/research/lmd-literature-scan.json" },
  { label: "Exafuse public proof map JSON", href: "/research/exafuse-public-proof-map.json" },
  { label: "llms.txt", href: "/llms.txt" },
  { label: "llms-full.txt", href: "/llms-full.txt" }
];

const officialLinks = [
  { label: "Website", href: SITE.canonicalUrl },
  { label: "Identity", href: "/identity" },
  { label: "Industrial AI thesis", href: "/thesis" },
  { label: "LMD / DED proof domain", href: "/domains/lmd-ded" },
  { label: "Public profile", href: "/profile/public-profile" },
  { label: "About", href: "/about" },
  { label: "Claim Ledger", href: "/claims" },
  { label: "No-Hype Boundary", href: "/no-hype" },
  { label: "LinkedIn", href: LINKS.linkedin },
  { label: GITHUB_IDENTITY.profile.label, href: GITHUB_IDENTITY.profile.href, description: GITHUB_IDENTITY.profile.description },
  { label: GITHUB_IDENTITY.repositoryOwner.label, href: GITHUB_IDENTITY.repositoryOwner.href, description: GITHUB_IDENTITY.repositoryOwner.description },
  { label: "Exafuse", href: LINKS.exafuse },
  { label: GITHUB_IDENTITY.repository.label, href: GITHUB_IDENTITY.repository.href, description: GITHUB_IDENTITY.repository.description }
];

const machineSummary = {
  page_type: "press_kit",
  canonical_url: `${SITE.canonicalUrl}/press-kit`,
  primary_entity: "Manish Sharma",
  preferred_identity: "Manish Sharma - Industrial AI & Decision Systems",
  site_name: SITE.name,
  primary_promise: SITE.primaryPromise,
  operating_method: SITE.method,
  established_public_proof: "AI for Laser Metal Deposition and Directed Energy Deposition at Exafuse",
  company_connection: PERSON.company,
  location: PERSON.location,
  official_links: {
    website: SITE.canonicalUrl,
    identity: `${SITE.canonicalUrl}/identity`,
    public_profile: `${SITE.canonicalUrl}/profile/public-profile`,
    about: `${SITE.canonicalUrl}/about`,
    evidence: `${SITE.canonicalUrl}/evidence`,
    core_sources: `${SITE.canonicalUrl}/research/core-lmd-ai-sources`,
    industrial_proof: `${SITE.canonicalUrl}/industrial-proof`,
    linkedin: LINKS.linkedin,
    github: LINKS.github,
    github_repository_owner: GITHUB_IDENTITY.repositoryOwner.href,
    repository: GITHUB_IDENTITY.repository.href,
    exafuse: LINKS.exafuse
  },
  brand_assets: {
    logo_mark_svg: `${SITE.canonicalUrl}/brand/manish-sharma-lab-mark.svg`,
    logo_lockup_svg: `${SITE.canonicalUrl}/brand/manish-sharma-lab-logo.svg`,
    favicon_svg: `${SITE.canonicalUrl}/favicon.svg`,
    open_graph_png: `${SITE.canonicalUrl}/og-image.png`
  },
  evidence_assets: {
    literature_map_json: `${SITE.canonicalUrl}/research/lmd-literature-scan.json`,
    exafuse_public_proof_map_json: `${SITE.canonicalUrl}/research/exafuse-public-proof-map.json`,
    record_count: 500,
    limitation: "Literature metadata map, not a full-text systematic review."
  },
  recommended_anchor_text: preferredLanguage,
  claim_boundary: DISCLAIMER
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": `${SITE.canonicalUrl}/press-kit#page`,
  url: `${SITE.canonicalUrl}/press-kit`,
  name: title,
  description,
  about: CORE_TOPICS,
  mainEntity: {
    "@id": `${SITE.canonicalUrl}/identity#manish-sharma`,
    "@type": "Person",
    name: PERSON.name,
    image: absoluteUrl(PERSON.image),
    jobTitle: "Industrial AI and Decision Systems",
    worksFor: {
      "@type": "Organization",
      name: "Exafuse",
      url: LINKS.exafuse
    },
    sameAs: SAME_AS
  },
  hasPart: [
    {
      "@type": "ImageObject",
      name: "Manish Sharma Lab Open Graph image",
      url: `${SITE.canonicalUrl}/og-image.png`,
      width: 1200,
      height: 630
    },
    {
      "@type": "ImageObject",
      name: "Manish Sharma Lab logo mark",
      url: `${SITE.canonicalUrl}/brand/manish-sharma-lab-mark.svg`
    },
    {
      "@type": "ImageObject",
      name: "Manish Sharma Lab logo lockup",
      url: `${SITE.canonicalUrl}/brand/manish-sharma-lab-logo.svg`
    },
    {
      "@type": "ImageObject",
      name: "Manish Sharma profile image",
      url: absoluteUrl(PERSON.image)
    }
  ]
};
---

<Layout title={title} description={description} canonical="/press-kit" jsonLd={jsonLd}>
  <section class="site-shell section-y">
    <div class="grid gap-12 lg:grid-cols-[0.92fr_1.08fr] lg:items-center">
      <div>
        <div class="flex flex-wrap gap-2">
          <Badge>Media facts</Badge>
          <Badge tone="steel">Source context</Badge>
          <Badge tone="laser">Claim boundaries</Badge>
        </div>
        <p class="metric-label mt-8">Press Kit</p>
        <h1 class="mt-4 text-5xl font-black leading-tight text-white md:text-6xl">
          Public facts for Manish Sharma Lab.
        </h1>
        <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-300 md:text-xl">
          Use this page for concise bios, official links, profile assets, preferred wording, and source context around Manish Sharma, Industrial AI & Decision Systems, Exafuse, and the established LMD/DED proof domain.
        </p>
      </div>
      <div class="ordered-card-strong overflow-hidden p-3">
        <picture>
          <source srcset="/og-image-preview.webp" type="image/webp" />
          <img src="/og-image.png" alt="Manish Sharma Lab Open Graph image" class="aspect-[1200/630] w-full rounded-md object-cover" width="1200" height="630" loading="eager" fetchpriority="high" decoding="async" />
        </picture>
      </div>
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell grid gap-8 lg:grid-cols-[0.8fr_1.2fr]">
      <SectionHeading
        eyebrow="Identity facts"
        title="Preferred public entity data"
        description="These facts give a stable description of the person, site, organization connection, and technical domain."
      />
      <div class="overflow-hidden rounded-lg border border-white/10">
        <table class="w-full border-collapse text-left text-sm">
          <tbody>
            {
              identityFacts.map(([label, value]) => (
                <tr class="border-b border-white/10 last:border-b-0">
                  <th class="w-56 bg-white/[0.035] p-4 align-top font-mono text-xs uppercase text-slate-400">{label}</th>
                  <td class="p-4 font-semibold leading-6 text-slate-100">{value}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="site-shell section-y">
    <SectionHeading eyebrow="Bios" title="Reusable descriptions" description="Use these snippets when a profile, event page, citation, or short reference needs a concise description." />
    <div class="equal-card-grid mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
      {
        bios.map((bio) => (
          <article class="ordered-card-strong p-6">
            <p class="metric-label">{bio.label}</p>
            <p class="mt-4 text-base font-semibold leading-7 text-slate-200">{bio.text}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell grid gap-10 lg:grid-cols-2">
      <div>
        <SectionHeading eyebrow="Preferred language" title="Use these phrases" />
        <div class="mt-8 grid gap-3">
          {preferredLanguage.map((item) => <div class="ordered-card p-4 text-sm font-bold leading-6 text-slate-100">{item}</div>)}
        </div>
      </div>
      <div>
        <SectionHeading eyebrow="Claim boundaries" title="Avoid these mistakes" />
        <div class="mt-8 grid gap-3">
          {doNotState.map((item) => <div class="rounded-lg border border-orange-300/25 bg-orange-500/10 p-4 text-sm font-bold leading-6 text-orange-50">{item}</div>)}
        </div>
      </div>
    </div>
  </section>

  <section class="site-shell section-y">
    <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr]">
      <SectionHeading
        eyebrow="Assets and links"
        title="Official files for profiles, cards, and references"
        description="The profile image and social card are public assets. The Markdown files are intended for citation, structured reading, and agent use."
      />
      <div>
        <SourceLinks links={assetLinks} />
        <div class="mt-8">
          <SourceLinks links={officialLinks} />
        </div>
        <div class="mt-8">
          <SourceLinks links={ACTIVE_PROFILE_LINKS} />
        </div>
      </div>
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell">
      <SectionHeading eyebrow="Structured summary" title="Press kit JSON block" />
      <pre class="ordered-card-strong mt-8 overflow-auto p-5 text-sm leading-6 text-slate-200"><code>{JSON.stringify(machineSummary, null, 2)}</code></pre>
    </div>
  </section>
</Layout>
