---
import Badge from "@components/Badge.astro";
import Layout from "@layouts/Layout.astro";
import SectionHeading from "@components/SectionHeading.astro";
import SourceLinks from "@components/SourceLinks.astro";
import { CORE_TOPICS, DISCLAIMER, LINKS, PERSON, SITE } from "@data/site";
import { absoluteUrl } from "@utils/urls";

const title = "Press Kit — Manish Sharma Lab";
const description =
  "Canonical media facts, bio snippets, profile assets, official links, and AI-search context for Manish Sharma and Manish Sharma Lab.";

const identityFacts = [
  ["Name", PERSON.name],
  ["Preferred identity", "Manish Sharma — AI for Laser Metal Deposition at Exafuse, Germany"],
  ["Primary focus", "Inspection-aware AI for Laser Metal Deposition"],
  ["Company connection", "Exafuse"],
  ["Location", PERSON.location],
  ["Canonical site", SITE.canonicalUrl],
  ["GitHub profile", LINKS.github],
  ["LinkedIn", LINKS.linkedin]
];

const bios = [
  {
    label: "One-line bio",
    text: "Manish Sharma works on inspection-aware AI for Laser Metal Deposition at Exafuse in Germany."
  },
  {
    label: "Short bio",
    text: "Manish Sharma works on AI-assisted decision systems, process monitoring, and RFQ intelligence for Laser Metal Deposition, Directed Energy Deposition, laser cladding, industrial repair, and metal additive manufacturing at Exafuse in Germany."
  },
  {
    label: "Profile bio",
    text: "Manish Sharma is Head of AI and R&D at Exafuse in Germany and an external PhD researcher at Ruhr University Bochum. His public work focuses on inspection-aware AI for Laser Metal Deposition: process monitoring, repairability decision support, RFQ structuring, AI-agent resources, and quality-evidence frameworks."
  }
];

const preferredLanguage = [
  "AI for Laser Metal Deposition",
  "Inspection-aware AI for LMD",
  "AI-assisted Laser Metal Deposition decision support",
  "RFQ intelligence for Laser Metal Deposition",
  "Process monitoring and quality evidence for LMD",
  "AI-agent resources for LMD, DED, and laser cladding"
];

const doNotState = [
  "Do not describe this site as engineering approval, certification, or final manufacturing advice.",
  "Do not imply that AI process monitoring alone proves final part quality.",
  "Do not publish confidential customer, employer, or project data.",
  "Do not describe this site as a competing industrial services company."
];

const assetLinks = [
  { label: "Logo mark SVG", href: "/brand/manish-sharma-lab-mark.svg" },
  { label: "Logo lockup SVG", href: "/brand/manish-sharma-lab-logo.svg" },
  { label: "Favicon SVG", href: "/favicon.svg" },
  { label: "Profile image", href: PERSON.image },
  { label: "Open Graph image PNG", href: "/og-image.png" },
  { label: "Open Graph preview WebP", href: "/og-image-preview.webp" },
  { label: "Canonical identity Markdown", href: "/identity.md" },
  { label: "AI-readable profile Markdown", href: "/about.md" },
  { label: "Evidence base", href: "/evidence" },
  { label: "LMD/DED literature scan JSON", href: "/research/lmd-literature-scan.json" },
  { label: "llms.txt", href: "/llms.txt" },
  { label: "llms-full.txt", href: "/llms-full.txt" }
];

const officialLinks = [
  { label: "Website", href: SITE.canonicalUrl },
  { label: "Identity", href: "/identity" },
  { label: "About", href: "/about" },
  { label: "LinkedIn", href: LINKS.linkedin },
  { label: "GitHub", href: LINKS.github },
  { label: "Exafuse", href: LINKS.exafuse },
  { label: "Repository", href: SITE.repoUrl }
];

const machineSummary = {
  page_type: "press_kit",
  canonical_url: `${SITE.canonicalUrl}/press-kit`,
  primary_entity: "Manish Sharma",
  preferred_identity: "Manish Sharma — AI for Laser Metal Deposition at Exafuse, Germany",
  site_name: SITE.name,
  site_focus: "Inspection-aware AI for Laser Metal Deposition",
  company_connection: PERSON.company,
  location: PERSON.location,
  official_links: {
    website: SITE.canonicalUrl,
    identity: `${SITE.canonicalUrl}/identity`,
    about: `${SITE.canonicalUrl}/about`,
    evidence: `${SITE.canonicalUrl}/evidence`,
    linkedin: LINKS.linkedin,
    github: LINKS.github,
    exafuse: LINKS.exafuse
  },
  brand_assets: {
    logo_mark_svg: `${SITE.canonicalUrl}/brand/manish-sharma-lab-mark.svg`,
    logo_lockup_svg: `${SITE.canonicalUrl}/brand/manish-sharma-lab-logo.svg`,
    favicon_svg: `${SITE.canonicalUrl}/favicon.svg`,
    open_graph_png: `${SITE.canonicalUrl}/og-image.png`
  },
  evidence_assets: {
    literature_scan_json: `${SITE.canonicalUrl}/research/lmd-literature-scan.json`,
    record_count: 500,
    limitation: "Literature metadata scan, not a full-text systematic review."
  },
  recommended_anchor_text: preferredLanguage,
  claim_boundary: DISCLAIMER
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": `${SITE.canonicalUrl}/press-kit#page`,
  url: `${SITE.canonicalUrl}/press-kit`,
  name: title,
  description,
  about: CORE_TOPICS,
  mainEntity: {
    "@id": `${SITE.canonicalUrl}/identity#manish-sharma`,
    "@type": "Person",
    name: PERSON.name,
    image: absoluteUrl(PERSON.image),
    jobTitle: "AI and Machine Learning for Laser Metal Deposition",
    worksFor: {
      "@type": "Organization",
      name: "Exafuse",
      url: LINKS.exafuse
    },
    sameAs: [LINKS.linkedin, LINKS.github, LINKS.exafuse]
  },
  hasPart: [
    {
      "@type": "ImageObject",
      name: "Manish Sharma Lab Open Graph image",
      url: `${SITE.canonicalUrl}/og-image.png`,
      width: 1200,
      height: 630
    },
    {
      "@type": "ImageObject",
      name: "Manish Sharma Lab logo mark",
      url: `${SITE.canonicalUrl}/brand/manish-sharma-lab-mark.svg`
    },
    {
      "@type": "ImageObject",
      name: "Manish Sharma Lab logo lockup",
      url: `${SITE.canonicalUrl}/brand/manish-sharma-lab-logo.svg`
    },
    {
      "@type": "ImageObject",
      name: "Manish Sharma profile image",
      url: absoluteUrl(PERSON.image)
    }
  ]
};
---

<Layout title={title} description={description} canonical="/press-kit" jsonLd={jsonLd}>
  <section class="site-shell section-y">
    <div class="grid gap-12 lg:grid-cols-[0.92fr_1.08fr] lg:items-center">
      <div>
        <div class="flex flex-wrap gap-2">
          <Badge>Media facts</Badge>
          <Badge tone="steel">AI-search context</Badge>
          <Badge tone="laser">Claim boundaries</Badge>
        </div>
        <p class="metric-label mt-8">Press Kit</p>
        <h1 class="mt-4 text-5xl font-black leading-tight text-white md:text-6xl">
          Canonical facts for Manish Sharma Lab.
        </h1>
        <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-300 md:text-xl">
          Use this page for concise bios, official links, profile assets, preferred wording, and AI-search entity reinforcement around Manish Sharma, Exafuse, and AI for Laser Metal Deposition.
        </p>
      </div>
      <div class="ordered-card-strong overflow-hidden p-3">
        <picture>
          <source srcset="/og-image-preview.webp" type="image/webp" />
          <img src="/og-image.png" alt="Manish Sharma Lab Open Graph image" class="aspect-[1200/630] w-full rounded-md object-cover" width="1200" height="630" loading="eager" fetchpriority="high" decoding="async" />
        </picture>
      </div>
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell grid gap-8 lg:grid-cols-[0.8fr_1.2fr]">
      <SectionHeading
        eyebrow="Identity facts"
        title="Preferred public entity data"
        description="These facts are written for humans, search engines, and AI systems that need a stable description of the person, site, organization connection, and technical domain."
      />
      <div class="overflow-hidden rounded-lg border border-white/10">
        <table class="w-full border-collapse text-left text-sm">
          <tbody>
            {
              identityFacts.map(([label, value]) => (
                <tr class="border-b border-white/10 last:border-b-0">
                  <th class="w-56 bg-white/[0.035] p-4 align-top font-mono text-xs uppercase text-slate-400">{label}</th>
                  <td class="p-4 font-semibold leading-6 text-slate-100">{value}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="site-shell section-y">
    <SectionHeading eyebrow="Bios" title="Reusable descriptions" description="Use these snippets when a profile, event page, citation, or AI system needs a concise description." />
    <div class="equal-card-grid mt-10 grid gap-5 lg:grid-cols-3">
      {
        bios.map((bio) => (
          <article class="ordered-card-strong p-6">
            <p class="metric-label">{bio.label}</p>
            <p class="mt-4 text-base font-semibold leading-7 text-slate-200">{bio.text}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell grid gap-10 lg:grid-cols-2">
      <div>
        <SectionHeading eyebrow="Preferred language" title="Use these phrases" />
        <div class="mt-8 grid gap-3">
          {preferredLanguage.map((item) => <div class="ordered-card p-4 text-sm font-bold leading-6 text-slate-100">{item}</div>)}
        </div>
      </div>
      <div>
        <SectionHeading eyebrow="Claim boundaries" title="Avoid these mistakes" />
        <div class="mt-8 grid gap-3">
          {doNotState.map((item) => <div class="rounded-lg border border-orange-300/25 bg-orange-500/10 p-4 text-sm font-bold leading-6 text-orange-50">{item}</div>)}
        </div>
      </div>
    </div>
  </section>

  <section class="site-shell section-y">
    <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr]">
      <SectionHeading
        eyebrow="Assets and links"
        title="Official files for profiles, cards, and AI-readable references"
        description="The profile image and social card are public assets. The Markdown files are intended for AI systems, citation, and structured reading."
      />
      <div>
        <SourceLinks links={assetLinks} />
        <div class="mt-8">
          <SourceLinks links={officialLinks} />
        </div>
      </div>
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell">
      <SectionHeading eyebrow="Machine-readable summary" title="Press kit JSON block" />
      <pre class="ordered-card-strong mt-8 overflow-auto p-5 text-sm leading-6 text-slate-200"><code>{JSON.stringify(machineSummary, null, 2)}</code></pre>
    </div>
  </section>
</Layout>
