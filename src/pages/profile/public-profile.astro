---
import Layout from "@layouts/Layout.astro";
import PageHeroVisual from "@components/PageHeroVisual.astro";
import SectionHeading from "@components/SectionHeading.astro";
import SourceLinks from "@components/SourceLinks.astro";
import { ACTIVE_PROFILE_LINKS, GITHUB_IDENTITY } from "@data/profiles";
import { CORE_TOPICS, LINKS, PERSON, SITE } from "@data/site";

const title = "Manish Sharma Public Profile";
const description =
  "Public-safe profile facts for Manish Sharma, focused on Industrial AI & Decision Systems with established public proof in AI for LMD/DED at Exafuse.";

const facts = [
  ["Name", PERSON.name],
  ["Focus", SITE.publicCategory],
  ["Primary promise", SITE.primaryPromise],
  ["Established technical proof", "AI for LMD/DED, process monitoring, robotics, industrial repair, and RFQ intelligence at Exafuse."],
  ["Company connection", PERSON.company],
  ["Location", PERSON.location],
  ["Operating method", "Sense -> Model -> Decide -> Verify"],
  ["Named framework", "The LMD-AI Maturity Model by Manish Sharma"],
  ["Decision map", `${SITE.canonicalUrl}/decision-map`],
  ["Website", SITE.canonicalUrl],
  ["LinkedIn", LINKS.linkedin],
  ["GitHub profile", `${GITHUB_IDENTITY.profile.slug} - ${GITHUB_IDENTITY.profile.href}`],
  ["Site/repository owner", `${GITHUB_IDENTITY.repositoryOwner.slug} - ${GITHUB_IDENTITY.repositoryOwner.href}`],
  ["Website repository", GITHUB_IDENTITY.repository.href],
  ["Exafuse", LINKS.exafuse]
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "@id": `${SITE.canonicalUrl}/profile/public-profile#page`,
  url: `${SITE.canonicalUrl}/profile/public-profile`,
  name: title,
  description,
  mainEntity: {
    "@id": `${SITE.canonicalUrl}/identity#manish-sharma`
  }
};
---

<Layout title={`${title} - Manish Sharma Lab`} description={description} canonical="/profile/public-profile" jsonLd={jsonLd}>
  <section class="site-shell grid gap-10 section-y lg:grid-cols-[minmax(0,1fr)_minmax(24rem,0.62fr)] lg:items-center">
    <div class="max-w-4xl">
      <p class="metric-label">Public profile</p>
      <h1 class="mt-5 text-5xl font-black leading-tight text-white md:text-6xl">{title}</h1>
      <p class="mt-6 text-xl leading-9 text-slate-200">
        A public-safe profile reference for identity facts used across this website. It avoids confidential employer, customer, project, or commercially sensitive information.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/identity" class="btn btn-primary">Canonical Identity</a>
        <a href="/thesis" class="btn btn-secondary">Operating Thesis</a>
        <a href="/domains/lmd-ded" class="btn btn-secondary">LMD / DED Proof Domain</a>
      </div>
    </div>
    <PageHeroVisual variant="profile" class="hidden lg:block" />
  </section>

  <section class="band section-y">
    <div class="site-shell grid gap-10 lg:grid-cols-[0.85fr_1.15fr]">
      <SectionHeading
        eyebrow="Facts"
        title="Public-safe identity facts"
        description="These facts are suitable for public website references, media snippets, AI-agent context, and internal linking."
      />
      <div class="overflow-hidden rounded-lg border border-white/10">
        <table class="w-full border-collapse text-left text-sm">
          <tbody>
            {facts.map(([label, value]) => (
              <tr class="border-b border-white/10 last:border-b-0">
                <th class="w-56 bg-white/[0.035] p-4 align-top font-mono text-xs uppercase text-slate-400">{label}</th>
                <td class="p-4 font-semibold leading-6 text-slate-100">{value}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="site-shell section-y">
    <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr]">
      <SectionHeading eyebrow="Themes" title="Public technical themes" />
      <div class="flex flex-wrap gap-2">
        {CORE_TOPICS.map((topic) => (
          <span class="ordered-card px-3 py-2 text-sm font-bold text-slate-200">{topic}</span>
        ))}
      </div>
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell grid gap-10 lg:grid-cols-[0.85fr_1.15fr]">
      <SectionHeading
        eyebrow="Profiles"
        title="Verified public profile links"
        description="Only active, verified public URLs are shown here. Planned research profiles are tracked in private/docs-facing roadmap notes until real URLs exist."
      />
      <SourceLinks links={ACTIVE_PROFILE_LINKS} />
    </div>
  </section>

  <section class="site-shell section-y">
    <div class="ordered-card-strong p-6">
      <p class="metric-label">Boundary</p>
      <p class="mt-4 text-lg font-semibold leading-8 text-slate-200">
        This page contains public-safe profile information only. It is not confidential company or customer material, and it is not engineering approval, material certification, or final manufacturing advice.
      </p>
    </div>
  </section>
</Layout>
