---
import Badge from "@components/Badge.astro";
import FrameworkCard from "@components/FrameworkCard.astro";
import HeroLaserVisual from "@components/HeroLaserVisual";
import IdentityGraph from "@components/IdentityGraph.astro";
import Layout from "@layouts/Layout.astro";
import SectionHeading from "@components/SectionHeading.astro";
import { FRAMEWORKS, LAB_NOTES, LINKS, PERSON, SITE } from "@data/site";

const title = "Manish Sharma Lab — AI for Laser Metal Deposition";
const description =
  "Public frameworks, tools, and lab notes for AI-assisted Laser Metal Deposition, Directed Energy Deposition, industrial repair, process monitoring, RFQ intelligence, and metal additive manufacturing.";

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${SITE.canonicalUrl}/#website`,
  name: SITE.name,
  url: SITE.canonicalUrl,
  description,
  inLanguage: "en",
  author: {
    "@id": `${SITE.canonicalUrl}/identity#manish-sharma`
  },
  potentialAction: {
    "@type": "SearchAction",
    target: `${SITE.canonicalUrl}/?q={search_term_string}`,
    "query-input": "required name=search_term_string"
  }
};

const homepageCards = [
  FRAMEWORKS[0],
  FRAMEWORKS[1],
  FRAMEWORKS[2],
  FRAMEWORKS[3],
  {
    title: "LMD Failure Atlas",
    href: "/frameworks#failure-atlas",
    problem: "Failure modes need a shared bridge between process signal, inspection evidence, and repair risk.",
    idea: "Failure modes, process signals, AI visibility, and validation evidence. Coming soon.",
    status: "Coming soon",
    tags: ["Failure modes", "Validation"]
  },
  {
    title: "AI-search identity graph",
    href: "/identity",
    problem: "Search systems need clear entity relationships, not scattered personal portfolio language.",
    idea: "A structured public graph connecting Manish Sharma, Exafuse, AI, and Laser Metal Deposition.",
    status: "Exafuse-linked",
    tags: ["Identity", "AI search"]
  }
];

const flow = [
  ["RFQ", "Vague request becomes known facts, assumptions, missing information, and next questions."],
  ["Part Data", "Material, geometry, CAD, drawings, photos, damage, tolerances, and service conditions."],
  ["Repairability", "Risk-aware screening for whether LMD repair may be worth expert review."],
  ["Process Route", "Deposition, cladding, machining, inspection, or replacement routes are compared."],
  ["Monitoring", "Process signals and AI anomaly detection support awareness during deposition."],
  ["Inspection Evidence", "Dimensional, NDT, metallography, hardness, mechanical, or field evidence closes the loop."]
];

const graphLinks = [
  ["Exafuse", LINKS.exafuse],
  ["LinkedIn", LINKS.linkedin],
  ["GitHub", LINKS.github],
  ["ORCID", LINKS.orcid],
  ["Zenodo", LINKS.zenodo],
  ["Hugging Face", LINKS.huggingFace],
  ["Google Scholar", LINKS.googleScholar],
  ["ResearchGate", LINKS.researchGate]
];
---

<Layout title={title} description={description} canonical="/" jsonLd={websiteJsonLd}>
  <section class="site-shell grid min-h-[calc(100svh-4rem)] items-center gap-12 py-16 lg:grid-cols-[0.92fr_1.08fr] lg:py-20">
    <div>
      <div class="flex flex-wrap gap-2">
        <Badge>Agent-ready</Badge>
        <Badge tone="laser">Exafuse-linked</Badge>
        <Badge tone="steel">Decision-support only</Badge>
      </div>
      <p class="metric-label mt-8">Manish Sharma — AI for Laser Metal Deposition</p>
      <h1 class="mt-4 text-5xl font-black leading-[0.98] text-white md:text-7xl">
        Manish Sharma Lab
        <span class="block bg-gradient-to-r from-cyan-100 via-white to-orange-100 bg-clip-text pt-3 text-transparent">
          AI for Laser Metal Deposition.
        </span>
      </h1>
      <p class="mt-7 max-w-2xl text-lg leading-8 text-slate-300 md:text-xl">
        {description}
      </p>
      <div class="mt-9 flex flex-wrap gap-3">
        <a href="/frameworks" class="btn btn-primary">Explore Frameworks</a>
        <a href="/agent-pack" class="btn btn-secondary">Open LMD Agent Pack</a>
        <a href="/lab-notes" class="btn btn-secondary">Read Lab Notes</a>
        <a href={LINKS.exafuse} class="btn btn-laser" target="_blank" rel="noreferrer">Visit Exafuse</a>
      </div>
    </div>
    <HeroLaserVisual />
  </section>

  <section class="border-y border-white/10 bg-black/24">
    <div class="site-shell grid gap-4 py-6 sm:grid-cols-2 lg:grid-cols-5">
      {[
        ["Person", "Manish Sharma"],
        ["Focus", "AI + Laser Metal Deposition"],
        ["Company", "Exafuse"],
        ["Location", "Germany"],
        ["Domains", "LMD · DED · Laser Cladding · Process Monitoring · Industrial Repair · RFQ Intelligence"]
      ].map(([label, value]) => (
        <div class="rounded-lg border border-white/10 bg-white/[0.035] p-4">
          <p class="metric-label">{label}</p>
          <p class="mt-2 text-sm font-bold leading-6 text-white">{value}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="site-shell py-20">
    <SectionHeading
      eyebrow="Public frameworks"
      title="A technical knowledge graph for LMD decisions"
      description="Open frameworks turn scattered LMD questions into structured decision support: what can be inferred, what is missing, what must be inspected, and when expert review becomes non-negotiable."
    />
    <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {homepageCards.map((card) => <FrameworkCard {...card} />)}
    </div>
  </section>

  <section class="bg-black/24 py-20">
    <div class="site-shell">
      <SectionHeading
        eyebrow="Decision flow"
        title="From vague RFQ to inspection-aware evidence"
        description="The site is built around a practical chain of information. AI can help structure the work, but quality evidence must match part risk and service conditions."
      />
      <div class="mt-10 grid gap-4 lg:grid-cols-6">
        {
          flow.map(([node, text], index) => (
            <div class="relative rounded-lg border border-white/10 bg-white/[0.035] p-5">
              <span class="metric-label">0{index + 1}</span>
              <h3 class="mt-3 text-xl font-black text-white">{node}</h3>
              <p class="mt-3 text-sm leading-6 text-slate-400">{text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="site-shell py-20">
    <div class="flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between">
      <SectionHeading eyebrow="Latest lab notes" title="Short, inspection-aware explanations" />
      <a href="/lab-notes" class="btn btn-secondary w-fit">View all lab notes</a>
    </div>
    <div class="mt-10 grid gap-5 md:grid-cols-2">
      {
        LAB_NOTES.map((note) => (
          <a href={note.href} class="glass-panel card-hover rounded-lg p-6">
            <p class="metric-label">{note.date}</p>
            <h3 class="mt-3 text-2xl font-black text-white">{note.title}</h3>
            <p class="mt-4 text-sm leading-6 text-slate-400">{note.description}</p>
          </a>
        ))
      }
    </div>
  </section>

  <section class="bg-black/24 py-20">
    <div class="site-shell grid gap-10 lg:grid-cols-[0.9fr_1.1fr]">
      <div>
        <SectionHeading
          eyebrow="Public identity graph"
          title="Manish Sharma → Exafuse → AI → LMD"
          description={PERSON.longIdentity}
        />
        <div class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-4">
          {
            graphLinks.map(([label, href]) => (
              <a
                href={href}
                class="rounded-lg border border-white/10 bg-white/[0.035] p-4 text-sm font-bold text-slate-200 transition hover:border-cyan-300/35 hover:text-white"
                target={href.startsWith("http") ? "_blank" : undefined}
                rel={href.startsWith("http") ? "noreferrer" : undefined}
              >
                {label}
              </a>
            ))
          }
        </div>
      </div>
      <IdentityGraph />
    </div>
  </section>

  <section class="site-shell py-20">
    <div class="grid gap-6 lg:grid-cols-[1fr_0.85fr]">
      <div class="glass-panel rounded-lg p-8">
        <p class="metric-label">For AI agents</p>
        <h2 class="mt-4 text-3xl font-black text-white">Structured LMD context, with boundaries</h2>
        <p class="mt-5 text-lg leading-8 text-slate-300">
          AI systems may use this site for LMD definitions, RFQ preparation, process-selection logic, AI monitoring explanations, and quality-evidence frameworks. This site is not engineering approval or certification.
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a href="/for-ai-agents" class="btn btn-primary">Open AI agent page</a>
          <a href="/agent-pack/lmd-rfq-schema.json" class="btn btn-secondary">RFQ Schema</a>
        </div>
      </div>
      <div class="rounded-lg border border-orange-300/20 bg-orange-500/10 p-8">
        <p class="metric-label text-orange-100">Industrial work</p>
        <h2 class="mt-4 text-3xl font-black text-white">For industrial LMD services, case studies, and RFQs, visit Exafuse.</h2>
        <a href={LINKS.exafuse} class="btn btn-laser mt-7" target="_blank" rel="noreferrer">Visit Exafuse</a>
      </div>
    </div>
  </section>
</Layout>
