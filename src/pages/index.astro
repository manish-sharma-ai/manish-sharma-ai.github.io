---
import Badge from "@components/Badge.astro";
import Layout from "@layouts/Layout.astro";
import PageHeroVisual from "@components/PageHeroVisual.astro";
import SectionHeading from "@components/SectionHeading.astro";
import { EXAFUSE_PROOF_CASES } from "@data/exafuse";
import { FRAMEWORKS, LAB_NOTES, LINKS, METHOD_LOOP, PERSON, SITE } from "@data/site";

const title = "Manish Sharma Lab - Industrial AI & Decision Systems";
const description =
  "Public frameworks, tools, and technical notes for industrial AI and decision systems, grounded in AI for Laser Metal Deposition and Directed Energy Deposition at Exafuse.";

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${SITE.canonicalUrl}/#website`,
  name: SITE.name,
  url: SITE.canonicalUrl,
  description,
  inLanguage: "en",
  author: {
    "@id": `${SITE.canonicalUrl}/identity#manish-sharma`
  },
  potentialAction: {
    "@type": "SearchAction",
    target: `${SITE.canonicalUrl}/?q={search_term_string}`,
    "query-input": "required name=search_term_string"
  }
};

const identityStrip = [
  ["Name", PERSON.name],
  ["Category", SITE.publicCategory],
  ["Established proof", "AI for LMD / DED at Exafuse"],
  ["Method", "Sense -> Model -> Decide -> Verify"],
  ["Boundary", "Decision support connected to engineering evidence"]
];

const flagshipAssets = [
  {
    title: "LMD Quality Evidence Ladder",
    href: "/frameworks/lmd-quality-evidence-ladder",
    text: "Separate process signals, AI anomaly flags, inspection evidence, and final quality proof.",
    label: "Verify"
  },
  {
    title: "LMD Repairability Index",
    href: "/frameworks/lmd-repairability-index",
    text: "Screen material, damage, access, machining, inspection, economics, and risk before recommending repair.",
    label: "Decide"
  },
  {
    title: "LMD RFQ Toolkit",
    href: "/agent-pack",
    text: "Turn vague LMD requests into known facts, missing information, risks, and next steps.",
    label: "Structure"
  }
];

const additionalAssets = [
  FRAMEWORKS[2],
  FRAMEWORKS[4],
  FRAMEWORKS[5],
  {
    title: "Core LMD-AI Sources",
    href: "/research/core-lmd-ai-sources",
    idea: "Curated starting map for LMD, DED, process monitoring, AI, repair, quality, and terminology sources.",
    status: "Source map"
  },
  {
    title: "Tools",
    href: "/tools",
    idea: "Frontend-only tools for LMD vs SLM, repairability, and RFQ structuring.",
    status: "Workbench"
  },
  {
    title: "Glossary",
    href: "/glossary",
    idea: "Definitions for LMD, DED, laser cladding, and melt-pool monitoring.",
    status: "Definitions"
  }
];

const latestLabNotes = [...LAB_NOTES].slice(-3).reverse();
---

<Layout title={title} description={description} canonical="/" jsonLd={websiteJsonLd}>
  <section class="site-shell grid min-h-[calc(100svh-4.5rem)] items-center gap-12 py-16 lg:grid-cols-[0.96fr_1.04fr] lg:py-20">
    <div>
      <div class="flex flex-wrap gap-2">
        <Badge>Manish Sharma Lab</Badge>
        <Badge tone="steel">Industrial AI / Decision Systems</Badge>
        <Badge tone="laser">LMD / DED proof domain</Badge>
      </div>
      <p class="metric-label mt-8">Manish Sharma Lab</p>
      <h1 class="mt-4 text-5xl font-black leading-[0.98] text-white md:text-7xl">
        Industrial AI for decisions you can verify.
      </h1>
      <p class="mt-7 max-w-3xl text-lg leading-8 text-slate-300 md:text-xl">
        I build AI, monitoring, and decision-support systems for industrial processes, grounded in public work in Laser Metal Deposition and Directed Energy Deposition at Exafuse.
      </p>
      <p class="mt-4 max-w-3xl text-base leading-7 text-slate-400">
        The work connects process signals, models, engineering context, decisions, and physical verification.
      </p>
      <div class="mt-9 flex flex-wrap gap-3">
        <a href="/thesis" class="btn btn-primary">Read the thesis</a>
        <a href="/domains/lmd-ded" class="btn btn-secondary">Explore LMD / DED work</a>
        <a href="/tools" class="btn btn-secondary">Open public tools</a>
        <a href="/identity" class="btn btn-secondary">Public identity</a>
        <a href={LINKS.exafuse} class="btn btn-laser" target="_blank" rel="noreferrer">Visit Exafuse</a>
      </div>
    </div>
    <PageHeroVisual variant="frameworks" class="hidden lg:block" />
  </section>

  <section class="band">
    <div class="site-shell grid gap-3 py-6 sm:grid-cols-2 lg:grid-cols-5">
      {identityStrip.map(([label, value]) => (
        <div class="ordered-card p-4">
          <p class="metric-label">{label}</p>
          <p class="mt-2 text-sm font-bold leading-6 text-white">{value}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="site-shell section-y">
    <SectionHeading
      eyebrow="Operating method"
      title="Sense -> Model -> Decide -> Verify"
      description="The site uses one public operating loop: connect observed signals to model assumptions, decisions, and the evidence needed to verify outcomes."
    />
    <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      {METHOD_LOOP.map((stage, index) => (
        <article class="ordered-card-strong p-6">
          <p class="metric-label">0{index + 1}</p>
          <h2 class="mt-3 text-3xl font-black text-white">{stage.label.toUpperCase()}</h2>
          <p class="mt-4 text-sm leading-6 text-slate-300">{stage.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell grid gap-10 lg:grid-cols-[0.8fr_1.2fr]">
      <div>
        <SectionHeading
          eyebrow="Established public proof"
          title="AI for Laser Metal Deposition and Directed Energy Deposition"
          description="My deepest public work is in LMD/DED process monitoring, robotic workflows, industrial repair, RFQ structure, and inspection-aware decision support at Exafuse."
        />
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/domains/lmd-ded" class="btn btn-primary">LMD / DED hub</a>
          <a href="/evidence" class="btn btn-secondary">Evidence base</a>
          <a href="/industrial-proof" class="btn btn-secondary">Industrial proof map</a>
          <a href={LINKS.exafuse} class="btn btn-laser" target="_blank" rel="noreferrer">Exafuse</a>
        </div>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        {EXAFUSE_PROOF_CASES.slice(0, 4).map((item) => (
          <a href={item.href} class="ordered-card card-hover p-5" target="_blank" rel="noreferrer">
            <p class="metric-label">{item.code}</p>
            <h3 class="mt-3 text-xl font-black text-white">{item.title}</h3>
            <p class="mt-3 text-sm leading-6 text-slate-400">{item.labConnection}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="site-shell section-y">
    <SectionHeading
      eyebrow="Flagship resources"
      title="The three LMD assets to start with"
      description="These public assets make the verification thesis practical inside the established LMD/DED proof domain."
    />
    <div class="mt-10 grid gap-5 lg:grid-cols-3">
      {flagshipAssets.map((asset) => (
        <a href={asset.href} class="ordered-card-strong card-hover grid min-h-[18rem] content-between p-7">
          <span>
            <span class="metric-label">{asset.label}</span>
            <span class="mt-4 block text-3xl font-black leading-tight text-white">{asset.title}</span>
            <span class="mt-5 block text-base leading-7 text-slate-300">{asset.text}</span>
          </span>
          <span class="mt-8 font-mono text-xs font-black uppercase text-cyan-100">Open asset</span>
        </a>
      ))}
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell">
      <SectionHeading
        eyebrow="More public assets"
        title="Frameworks, tools, research, and definitions"
        description="The LMD/DED authority layer remains intact and easy to reach from the broader identity."
      />
      <div class="equal-card-grid mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {additionalAssets.map((asset) => (
          <a href={asset.href} class="ordered-card card-hover p-5">
            <p class="metric-label">{asset.status}</p>
            <h3 class="mt-3 text-xl font-black text-white">{asset.title}</h3>
            <p class="mt-3 text-sm leading-6 text-slate-400">{asset.idea}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="site-shell section-y">
    <div class="flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between">
      <SectionHeading eyebrow="Applied writing" title="Recent notes from the LMD/DED proof domain" />
      <a href="/lab-notes" class="btn btn-secondary w-fit">View all lab notes</a>
    </div>
    <div class="equal-card-grid mt-10 grid gap-5 md:grid-cols-3">
      {latestLabNotes.map((note) => (
        <a href={note.href} class="ordered-card-strong card-hover rounded-lg p-6">
          <p class="metric-label">{note.date}</p>
          <h3 class="mt-3 text-2xl font-black text-white">{note.title}</h3>
          <p class="mt-4 text-sm leading-6 text-slate-400">{note.description}</p>
        </a>
      ))}
    </div>
  </section>
</Layout>
