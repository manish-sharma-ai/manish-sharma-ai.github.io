---
import CTAButton from "@components/CTAButton.astro";
import ExafuseProofMedia from "@components/ExafuseProofMedia.astro";
import Layout from "@layouts/Layout.astro";
import LmdDecisionCockpit from "@components/LmdDecisionCockpit";
import SectionHeading from "@components/SectionHeading.astro";
import { resolveExafuseLink } from "../config/externalLinks";
import { EXAFUSE_PUBLIC_PROOF } from "@data/exafusePublicProof";
import { LAB_NOTES, LINKS, PERSON, SAME_AS, SITE } from "@data/site";

const title = "Manish Sharma — Industrial AI & Decision Systems";
const description =
  "Manish Sharma builds evidence-aware AI systems for industrial decisions. His strongest public work is in LMD/DED, process monitoring, robotics, and engineering decision support at Exafuse.";
const exafuseRfqLink = resolveExafuseLink("rfq");
const flagshipProof = EXAFUSE_PUBLIC_PROOF.find((proof) => proof.id === "cs15-duisburg-bridge");

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": `${SITE.canonicalUrl}/identity#manish-sharma`,
  name: PERSON.name,
  url: `${SITE.canonicalUrl}/identity`,
  sameAs: SAME_AS,
  jobTitle: SITE.publicCategory,
  worksFor: {
    "@type": "Organization",
    name: "Exafuse",
    url: LINKS.exafuse
  },
  knowsAbout: [
    "Industrial AI",
    "Industrial Decision Systems",
    "Decision Support",
    "Evidence-aware AI",
    "Engineering Decision-making",
    "Industrial Automation",
    "Machine Vision",
    "Robotics",
    "Laser Metal Deposition",
    "Directed Energy Deposition",
    "Process Monitoring",
    "RFQ Intelligence",
    "Industrial Repair",
    "Repair and Cladding",
    "Inspection Evidence"
  ]
};

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${SITE.canonicalUrl}/#website`,
  name: SITE.preferredSiteName,
  alternateName: SITE.alternateSiteName,
  url: SITE.canonicalUrl,
  description,
  inLanguage: "en",
  author: { "@id": `${SITE.canonicalUrl}/identity#manish-sharma` }
};

const profilePageJsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "@id": `${SITE.canonicalUrl}/#profile-page`,
  url: SITE.canonicalUrl,
  name: "Manish Sharma — Industrial AI & Decision Systems",
  mainEntity: { "@id": `${SITE.canonicalUrl}/identity#manish-sharma` }
};

const flagshipAssets = [
  {
    title: "LMD Decision Cockpit",
    href: "/tools#lmd-decision-cockpit",
    problem: "A decision starts before every fact is known.",
    helps: "Turn facts, gaps, risk, and evidence needs into a next action.",
    cannot: "Replace engineering approval or final feasibility review.",
    cta: "Run the Cockpit"
  },
  {
    title: "Camera Is Not a Certificate",
    href: "/lab-notes/camera-is-not-a-certificate",
    problem: "A process image can look convincing before it becomes sufficient evidence.",
    helps: "Separate monitoring signals from an inspection-backed quality claim.",
    cannot: "Turn a signal into a release decision.",
    cta: "Read the note"
  }
];

const homepageProcessSteps = [
  {
    index: "01",
    label: "Sense",
    description: "Capture the process signal and its operating context.",
    tone: "success"
  },
  {
    index: "02",
    label: "Model",
    description: "Make assumptions visible.",
    tone: "signal"
  },
  {
    index: "03",
    label: "Decide",
    description: "Plan the evidence needed.",
    tone: "active"
  },
  {
    index: "04",
    label: "Verify",
    description: "Use inspection evidence.",
    tone: "risk"
  }
];

---

<Layout
  title={title}
  description={description}
  canonical="/"
  jsonLd={[websiteJsonLd, personJsonLd, profilePageJsonLd]}
  alternates={[
    { lang: "en", href: "/" },
    { lang: "de", href: "/de" },
    { lang: "x-default", href: "/" }
  ]}
>
  <section class="home-premium-hero home-chapter home-chapter--position" data-page-chapter="position">
    <picture
      class="home-premium-hero__media"
      aria-hidden="true"
      data-audit-context="Illustrative LMD process schematic"
    >
      <source media="(max-width: 639px)" type="image/webp" srcset="/images/melt-pool-hero-1024.webp" />
      <source type="image/webp" srcset="/images/melt-pool-hero.webp" />
      <source media="(max-width: 639px)" srcset="/images/melt-pool-hero-1024.jpg" />
      <img
        src="/images/melt-pool-hero.jpg"
        alt=""
        aria-hidden="true"
        width="1586"
        height="992"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
    </picture>
    <div class="home-premium-hero__wash" aria-hidden="true"></div>
    <div class="site-shell home-hero-grid">
      <div class="home-hero__copy">
        <h1 class="home-hero__title">
          I build AI systems for industrial decisions that need evidence, not just predictions.
        </h1>
        <p class="home-hero__intro">
          I build evidence-aware AI systems for industrial decisions. My deepest public work is in Laser Metal Deposition and Directed Energy Deposition at Exafuse, where signals, models, engineering constraints, and human judgment must resolve into a defensible next action.
        </p>
        <div class="home-hero__actions">
          <CTAButton href="#lmd-decision-cockpit" variant="primary" class="home-hero__primary-action">Run the Decision Cockpit</CTAButton>
          <CTAButton href="/public-work" variant="secondary" class="home-hero__secondary-action">View public proof</CTAButton>
        </div>
        <p class="home-hero__review-note">
          <span>Industrial AI / decision systems. Evidence-aware by design.</span>
          <a href="/thesis">Read the method</a> before using a prediction as a decision.
        </p>
      </div>
    </div>
    <p class="home-premium-hero__image-caption">
      <span class="home-premium-hero__image-caption-title">Melt pool</span>
      <span class="home-premium-hero__image-caption-copy">Created in the laser metal deposition process.</span>
    </p>
  </section>

  {flagshipProof && (
    <section class="home-proof-strip home-chapter home-chapter--proof" data-page-chapter="public-proof" aria-labelledby="home-proof-title">
      <div class="site-shell home-proof-strip__grid">
        <div class="home-proof-strip__lead">
          <p class="metric-label">Public proof</p>
          <h2 id="home-proof-title">A public LMD case, a working decision product, and an authored evidence boundary.</h2>
          <p>Start with physical context, then inspect the decision structure and the limit attached to each source.</p>
          <a href={`/public-work/exafuse/${flagshipProof.slug}`} class="home-proof-strip__story-link">Read the proof story <span aria-hidden="true">→</span></a>
        </div>
        <div class="home-proof-strip__case">
          <ExafuseProofMedia proof={flagshipProof} sizes="(max-width: 767px) calc(100vw - 2rem), 38vw" />
          <div class="home-proof-strip__facts">
            {flagshipProof.publicMetrics.slice(0, 3).map((metric) => (
              <p data-exafuse-proof-metric={metric.sourcePath}><strong>{metric.value}{metric.unit ? ` ${metric.unit}` : ""}</strong><span>{metric.label}</span></p>
            ))}
          </div>
          <p class="home-proof-strip__limit">Monitoring and project scale are public context—not engineering approval or a transferable feasibility claim.</p>
        </div>
        <div class="home-proof-strip__product">
          <p class="metric-label">Working product</p>
          <h3>LMD Decision Cockpit</h3>
          <p>Make the evidence burden, critical gaps, risk, and next action explicit before an industrial handoff.</p>
          <a href="#lmd-decision-cockpit">Open the preview <span aria-hidden="true">→</span></a>
          <p class="metric-label">Authored boundary</p>
          <a href="/lab-notes/camera-is-not-a-certificate">Camera Is Not a Certificate <span aria-hidden="true">→</span></a>
        </div>
      </div>
    </section>
  )}

  <section id="lmd-decision-cockpit" class="home-opening-flow home-cockpit-chapter home-chapter home-chapter--product" data-page-chapter="product" aria-labelledby="home-cockpit-title">
    <div class="home-opening-flow__atmosphere" aria-hidden="true"></div>
    <div class="site-shell home-opening-flow__inner">
      <div class="home-cockpit-chapter__intro">
        <p class="metric-label">Working decision product</p>
        <h2 id="home-cockpit-title">See what the decision needs before asking for confidence.</h2>
        <p>The Cockpit keeps the decision signal, critical gaps, risk, evidence needed, and next action visible. Confidence is not approval.</p>
      </div>
      <section class="home-opening-flow__cockpit" aria-label="LMD Decision Cockpit preview">
        <div class="home-opening-flow__cockpit-route" aria-hidden="true"></div>
        <LmdDecisionCockpit client:visible defaultMode="example" compact exafuseUrl={exafuseRfqLink.href} exafuseLabel={exafuseRfqLink.label} />
        <noscript>
          <div class="ordered-card mt-5 p-5 text-sm leading-6 text-slate-300">
            The worked brief remains readable without JavaScript. To prepare your own handoff, use the <a href="/brief-template" class="font-black text-cyan-100">copyable template</a> or the <a href="/brief-standard" class="font-black text-cyan-100">public brief standard</a>.
          </div>
        </noscript>
      </section>
      <div class="home-cockpit-chapter__actions">
        <CTAButton href="/brief-template" variant="primary">Start your own brief</CTAButton>
        <CTAButton href="/brief-standard" variant="secondary">Open full brief</CTAButton>
      </div>
    </div>
  </section>

  <section class="home-opening-flow home-method-chapter home-chapter home-chapter--method" data-page-chapter="method" data-operating-loop="homepage" aria-labelledby="home-opening-flow-title">
    <div class="home-opening-flow__atmosphere" aria-hidden="true"></div>
    <div class="site-shell home-opening-flow__inner">
      <div class="home-opening-flow__process">
        <div class="home-opening-flow__process-intro">
          <h2 id="home-opening-flow-title">Sense → Model → Decide → Verify</h2>
          <p>To me, a prediction is only one part of the job. The next action, the missing context, and the verification path have to be clear too.</p>
        </div>

        <ol class="home-opening-flow__steps" aria-label="Sense, model, decide, verify process">
          {homepageProcessSteps.map((step) => (
            <li class:list={["home-opening-flow__step", `home-opening-flow__step--${step.tone}`]}>
              <span class="home-opening-flow__step-index">{step.index}</span>
              <strong>{step.label}</strong>
              <span>{step.description}</span>
            </li>
          ))}
        </ol>

        <aside class="home-opening-flow__boundary" aria-label="Decision-support boundary">
          Preliminary decision-support only. Final feasibility depends on base material, geometry, service conditions, inspection requirements, and expert review.
        </aside>

        <div class="home-opening-flow__direction">
          <h3>The broader question behind the current work</h3>
          <p>
            I am studying how this approach can help with decisions based on incomplete physical signals, operational risk, and human responsibility. That is a research direction, not a cross-industry deployment claim.
          </p>
          <ul aria-label="Decision classes under study">
            <li>Incomplete physical signals</li>
            <li>High cost of false confidence</li>
            <li>Model output connected to inspection</li>
            <li>Operational context changes the recommendation</li>
            <li>Human responsibility remains explicit</li>
            <li>Traceability matters after the model runs</li>
          </ul>
        </div>

        <nav class="home-opening-flow__links" aria-label="Method and current work">
          <a href="/thesis">Read the method <span aria-hidden="true">→</span></a>
          <a href="/domains/lmd-ded">See current LMD/DED work <span aria-hidden="true">→</span></a>
        </nav>
      </div>

    </div>
  </section>

  <div class="home-continuation">
    <div class="home-chapter home-chapter--knowledge" data-page-chapter="knowledge">
    <section class="home-section home-section--assets" aria-label="Flagship decision assets">
      <div class="site-shell home-section__inner">
        <SectionHeading
          eyebrow="Selected work"
          title="One public industrial story, supported by a working product and an authored note"
          description="The lead proof is physical and source-backed. The supporting work shows how I structure the decision and its evidence boundary."
        />
        <div class="home-assets-grid home-assets-grid--proof-led">
          {flagshipProof && (
            <article class="home-asset-card home-asset-card--lead">
              <ExafuseProofMedia proof={flagshipProof} sizes="(max-width: 767px) calc(100vw - 2rem), 52vw" />
              <span>
                <p class="metric-label">Flagship industrial proof</p>
                <h3><a href={`/public-work/exafuse/${flagshipProof.slug}`}>{flagshipProof.shortTitle}</a></h3>
                <p>{flagshipProof.mainDecisionLesson}</p>
              </span>
              <a href={`/public-work/exafuse/${flagshipProof.slug}`} class="home-asset-card__action">Read the proof story <span aria-hidden="true">→</span></a>
            </article>
          )}
          {flagshipAssets.map((asset) => (
            <a href={asset.href} class="home-asset-card">
              <span>
                <h3>{asset.title}</h3>
                <dl>
                  <div>
                    <dt>Problem</dt>
                    <dd>{asset.problem}</dd>
                  </div>
                  <div>
                    <dt>Helps decide</dt>
                    <dd>{asset.helps}</dd>
                  </div>
                  <div>
                    <dt>Cannot prove</dt>
                    <dd>{asset.cannot}</dd>
                  </div>
                </dl>
              </span>
              <span class="home-asset-card__action" aria-hidden="true">{asset.cta} <span>→</span></span>
            </a>
          ))}
        </div>
        <a class="home-section__all-link" href="/frameworks">Explore all frameworks <span aria-hidden="true">→</span></a>
      </div>
    </section>

    <section class="home-section home-section--notes" aria-label="Selected authored note">
      <div class="site-shell home-section__inner">
        <div class="home-section__heading-row">
        <SectionHeading
          eyebrow="Authored note"
          title="One idea behind the broader platform"
          description="A first-person note on why model output, context, action, and verification need to stay connected."
        />
          <div class="home-section__actions">
          <CTAButton href="/lab-notes" variant="secondary">All lab notes</CTAButton>
          <CTAButton href="/rss.xml" variant="secondary">RSS feed</CTAButton>
          </div>
        </div>
        <div class="home-notes-grid home-notes-grid--single">
        {LAB_NOTES.slice(0, 1).map((note) => (
          <a href={note.href} class="home-note-card">
            <span>
              <time datetime={note.date}>{note.date}</time>
              <h3>{note.title}</h3>
              <p>{note.description}</p>
            </span>
            <span class="home-note-card__action" aria-hidden="true">Read note <span>→</span></span>
          </a>
        ))}
        </div>
      </div>
    </section>
    </div>

    <div class="home-chapter home-chapter--boundary" data-page-chapter="boundary">
    <section class="home-section home-section--routes" aria-label="Public and commercial routes">
      <div class="site-shell home-section__inner home-route-grid">
      <div class="home-route-card home-route-card--public">
        <p>Personal platform</p>
        <h2>Explore the method, current work, and research questions.</h2>
        <p>{SITE.shortDescription}</p>
        <div class="home-route-card__actions">
          <CTAButton href="/public-work" variant="primary">Explore my work</CTAButton>
          <CTAButton href="/about" variant="secondary">About Manish</CTAButton>
        </div>
      </div>
      <div class="home-route-card home-route-card--commercial">
        <p>Commercial boundary</p>
        <h2>For commercial LMD/DED services and RFQs, use Exafuse.</h2>
        <p>
          My current applied LMD/DED work is carried out through Exafuse. This site shares public methods and notes; company services, case studies, and engineering review belong there.
        </p>
        <div class="home-route-card__actions">
          <CTAButton href={exafuseRfqLink.href} variant="laser" external>{exafuseRfqLink.label}</CTAButton>
          <CTAButton href="/contact" variant="secondary">Contact routes</CTAButton>
        </div>
      </div>
      </div>
    </section>
    <section class="home-section home-section--mission" aria-labelledby="home-mission-title">
      <div class="site-shell home-mission">
        <div>
          <p class="metric-label">Personal mission</p>
          <h2 id="home-mission-title">Build products that make difficult industrial decisions clearer without hiding uncertainty.</h2>
        </div>
        <div>
          <p>I am building toward products and ventures that help people make difficult industrial decisions without hiding uncertainty or replacing engineering responsibility. LMD/DED is where I am proving the method in public today.</p>
          <a href="/contact">Discuss an industrial AI decision problem <span aria-hidden="true">→</span></a>
          <p class="home-mission__context">Suitable for evidence-aware AI workflow design, monitoring and verification architecture, industrial decision-support products, human-in-the-loop engineering systems, and research or product collaboration.</p>
        </div>
      </div>
    </section>
    </div>
    </div>
</Layout>
