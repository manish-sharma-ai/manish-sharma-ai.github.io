---
import BentoCard from "@components/BentoCard.astro";
import BentoGrid from "@components/BentoGrid.astro";
import CTAButton from "@components/CTAButton.astro";
import Chip from "@components/Chip.astro";
import HeroLaserVisual from "@components/HeroLaserVisual";
import Layout from "@layouts/Layout.astro";
import LmdDecisionCockpit from "@components/LmdDecisionCockpit";
import SectionHeading from "@components/SectionHeading.astro";
import { resolveExafuseLink } from "../config/externalLinks";
import { EXAFUSE_PROOF_CASES } from "@data/exafuse";
import { getClaimSourceStatus } from "@data/publicClaims";
import { LINKS, PERSON, SAME_AS, SITE } from "@data/site";

const title = "Manish Sharma Lab - AI for Laser Metal Deposition Decisions";
const description =
  "AI for Laser Metal Deposition decisions you can verify: inspection-aware frameworks, RFQ tools, process-monitoring notes, public Exafuse proof context, and evidence-bound AI guidance.";
const exafuseRfqLink = resolveExafuseLink("rfq");

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": `${SITE.canonicalUrl}/identity#manish-sharma`,
  name: PERSON.name,
  url: `${SITE.canonicalUrl}/identity`,
  sameAs: SAME_AS,
  jobTitle: SITE.publicCategory,
  worksFor: {
    "@type": "Organization",
    name: "Exafuse",
    url: LINKS.exafuse
  },
  knowsAbout: [
    "Laser Metal Deposition",
    "Directed Energy Deposition",
    "Process Monitoring",
    "RFQ Intelligence",
    "Industrial Repair",
    "AI for Manufacturing"
  ]
};

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${SITE.canonicalUrl}/#website`,
  name: SITE.name,
  url: SITE.canonicalUrl,
  description,
  inLanguage: "en",
  author: { "@id": `${SITE.canonicalUrl}/identity#manish-sharma` },
  potentialAction: {
    "@type": "SearchAction",
    target: `${SITE.canonicalUrl}/?q={search_term_string}`,
    "query-input": "required name=search_term_string"
  }
};

const profilePageJsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "@id": `${SITE.canonicalUrl}/#profile-page`,
  url: SITE.canonicalUrl,
  name: "Manish Sharma Lab",
  mainEntity: { "@id": `${SITE.canonicalUrl}/identity#manish-sharma` }
};

const startCards = [
  {
    eyebrow: "Engineer / buyer",
    title: "Structure an LMD, repair, cladding, or RFQ question.",
    href: "/tools",
    cta: "Open tools"
  },
  {
    eyebrow: "Technical reader",
    title: "Understand inspection-aware industrial AI.",
    href: "/thesis",
    cta: "Read thesis"
  },
  {
    eyebrow: "AI agent / developer",
    title: "Use structured public sources safely.",
    href: "/for-ai-agents",
    cta: "Open AI-agent guide"
  }
];

const flagshipAssets = [
  {
    title: "LMD Quality Evidence Ladder",
    href: "/frameworks/lmd-quality-evidence-ladder",
    problem: "Monitoring data is often treated as release proof.",
    helps: "Which evidence level is needed for a claim.",
    cannot: "Final part quality without inspection/testing.",
    cta: "Open framework"
  },
  {
    title: "LMD Repairability Index",
    href: "/frameworks/lmd-repairability-index",
    problem: "Repair requests arrive before material, damage, access, and inspection facts are clear.",
    helps: "Whether a repair candidate is worth expert review.",
    cannot: "Repair feasibility, release, or service safety.",
    cta: "Open index"
  },
  {
    title: "LMD RFQ Toolkit",
    href: "/agent-pack",
    problem: "Vague RFQs hide missing facts and risk flags.",
    helps: "How to structure known facts, gaps, assumptions, and next questions.",
    cannot: "Replace Exafuse commercial review or engineering approval.",
    cta: "Open toolkit"
  }
];

const proofFrameworks: Record<string, { label: string; href: string; proves: string; cannot: string }> = {
  CS15: {
    label: "LMD Quality Evidence Ladder",
    href: "/frameworks/lmd-quality-evidence-ladder",
    proves:
      "Public context for large-part LMD scale, monitoring, validation, and inspection planning in one documented Exafuse case.",
    cannot:
      "It does not prove that monitoring alone certifies quality or that this site can approve structural parts."
  },
  CS01: {
    label: "LMD Repairability Index",
    href: "/frameworks/lmd-repairability-index",
    proves: "Public context for local wear repair, material strategy, finishing, and release-evidence planning.",
    cannot: "It does not prove every hammer or safety-critical part is repairable."
  },
  CS10: {
    label: "LMD RFQ Toolkit",
    href: "/agent-pack",
    proves: "Public context for RFQ intelligence around local damage, downtime pressure, drawings, machining, and inspection needs.",
    cannot: "It does not prove feasibility without part-specific material, damage, geometry, and service context."
  },
  CS13: {
    label: "LMD Quality Evidence Ladder",
    href: "/frameworks/lmd-quality-evidence-ladder",
    proves: "Public context for combining build-up, coating function, material choice, and finishing strategy.",
    cannot: "It does not prove surface performance without application-specific validation."
  }
};

const proofDecisionHelp: Record<string, string> = {
  CS15: "Helps decide how much evidence is needed before large-part LMD monitoring data becomes a defensible engineering discussion.",
  CS01: "Helps decide whether local wear repair should move into expert review instead of becoming an automatic repair claim.",
  CS10: "Helps decide which missing RFQ facts block a repairability conversation.",
  CS13: "Helps decide when build-up and surface function must be planned as one route."
};

const proofDecisionPatterns: Record<string, { label: string; href: string }> = {
  CS15: { label: "Start a brief from this pattern", href: "/tools/#preset=monitoring-anomaly" },
  CS01: { label: "Start a brief from this pattern", href: "/tools/#preset=worn-shaft" },
  CS10: { label: "Start a brief from this pattern", href: "/tools/#preset=rfq" },
  CS13: { label: "Start a brief from this pattern", href: "/tools/#preset=surface-cladding" }
};

const proofDecisionPatternText: Record<string, string> = {
  CS15: "Large-scale LMD requires evidence planning, monitoring context, and an inspection boundary.",
  CS01: "Local repair needs material, damage depth, machining route, and inspection plan.",
  CS10: "Repair/RFQ quality depends on complete facts, downtime context, and service context.",
  CS13: "Build-and-coat routes need geometry, surface function, material, finishing, and validation."
};
---

<Layout title={title} description={description} canonical="/" jsonLd={[websiteJsonLd, personJsonLd, profilePageJsonLd]}>
  <section class="site-shell home-hero-grid section-y">
    <div class="relative">
      <div class="flex flex-wrap gap-2">
        <Chip>Industrial AI & Decision Systems</Chip>
        <Chip tone="steel">LMD / DED proof domain</Chip>
        <Chip tone="amber">Decision support only</Chip>
      </div>
      <p class="home-eyebrow metric-label mt-8">Manish Sharma Lab</p>
      <h1 class="mt-4 max-w-5xl text-5xl font-black leading-[0.95] text-white md:text-7xl">
        AI for Laser Metal Deposition decisions you can verify.
      </h1>
      <p class="hero-copy mt-7 max-w-3xl text-lg leading-8 md:text-xl">
        I build inspection-aware AI frameworks, RFQ tools, and process-monitoring notes for LMD/DED, repair, cladding, and metal additive manufacturing - grounded in public Exafuse work and bounded by engineering evidence.
      </p>
      <div class="mt-6 w-fit rounded-full border border-amber-300/28 bg-amber-400/10 px-4 py-2 text-sm font-black text-amber-100">
        Decision support only. Not final engineering approval.
      </div>
      <div class="mt-9 flex flex-wrap gap-3">
        <CTAButton href="#lmd-decision-cockpit" variant="primary">Start LMD Decision Cockpit</CTAButton>
        <CTAButton href="/decision-map" variant="secondary">Open Decision Map</CTAButton>
        <CTAButton href="/tools" variant="secondary">Open Workbench</CTAButton>
        <CTAButton href="/thesis" variant="secondary">Read Thesis</CTAButton>
        <CTAButton href={exafuseRfqLink.href} variant="laser" external>{exafuseRfqLink.label}</CTAButton>
      </div>
    </div>
    <div class="grid gap-4">
      <HeroLaserVisual />
      <div class="grid gap-3 sm:grid-cols-3">
        {[
          ["Who", PERSON.name],
          ["Builds", "inspection-aware AI tools"],
          ["Proof", "public Exafuse LMD/DED context"]
        ].map(([label, value]) => (
          <div class="ordered-card p-4">
            <p class="metric-label">{label}</p>
            <p class="mt-2 text-sm font-black text-white">{value}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="site-shell pb-12">
    <LmdDecisionCockpit client:visible defaultMode="example" compact exafuseUrl={exafuseRfqLink.href} exafuseLabel={exafuseRfqLink.label} />
  </section>

  <section class="band py-10">
    <div class="site-shell grid gap-6 lg:grid-cols-[0.76fr_0.24fr] lg:items-center">
      <div>
        <p class="metric-label">Thesis in one line</p>
        <h2 class="mt-3 text-4xl font-black leading-tight text-white md:text-5xl">A signal is not proof.</h2>
        <p class="mt-4 max-w-3xl text-base leading-7 text-slate-300">
          Process signals can support review. They do not replace inspection, testing, expert review, or release evidence.
        </p>
      </div>
      <div class="flex flex-wrap gap-3 lg:justify-end">
        <CTAButton href="/thesis#signal-is-not-proof" variant="primary">Try explainer</CTAButton>
        <CTAButton href="/no-hype" variant="secondary">No-hype boundary</CTAButton>
      </div>
    </div>
  </section>

  <section class="site-shell py-8" data-operating-loop="homepage">
    <div class="ordered-card-strong grid gap-5 p-5 md:grid-cols-[0.38fr_0.62fr] md:items-center md:p-6">
      <div>
        <p class="metric-label">One compact operating loop</p>
        <h2 class="mt-3 text-2xl font-black leading-tight text-white md:text-3xl">Sense -> Model -> Decide -> Verify</h2>
      </div>
      <div class="grid gap-4 md:grid-cols-[1fr_auto] md:items-center">
        <p class="text-sm leading-6 text-slate-300">
          Signal, assumption, bounded decision, verification evidence. The detailed doctrine lives in the thesis.
        </p>
        <a href="/thesis" class="btn btn-secondary">Open thesis</a>
      </div>
    </div>
  </section>

  <section class="band py-12">
    <div class="site-shell">
      <SectionHeading eyebrow="Start here" title="Choose the path that matches your question" />
      <BentoGrid class="mt-10">
        {startCards.map((card) => (
          <BentoCard href={card.href} eyebrow={card.eyebrow} title={card.title} cta={card.cta} strong />
        ))}
      </BentoGrid>
    </div>
  </section>

  <section class="site-shell section-y">
    <SectionHeading
      eyebrow="Flagship assets"
      title="Start with the three LMD decision assets"
      description="These are the shortest route from a vague LMD/DED question to a structured decision-support workflow."
    />
    <div class="mt-10 grid gap-5 lg:grid-cols-3">
      {flagshipAssets.map((asset) => (
        <a href={asset.href} class="ordered-card-strong card-hover grid content-between p-6">
          <span>
            <h2 class="text-2xl font-black leading-tight text-white">{asset.title}</h2>
            <dl class="mt-5 grid gap-4 text-sm leading-6">
              <div>
                <dt class="metric-label">Problem</dt>
                <dd class="mt-1 text-slate-300">{asset.problem}</dd>
              </div>
              <div>
                <dt class="metric-label">Helps decide</dt>
                <dd class="mt-1 text-slate-300">{asset.helps}</dd>
              </div>
              <div>
                <dt class="metric-label">Cannot prove</dt>
                <dd class="mt-1 text-slate-300">{asset.cannot}</dd>
              </div>
            </dl>
          </span>
          <span class="mt-6 border-t border-white/10 pt-4 font-mono text-xs font-black uppercase text-cyan-100">{asset.cta}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="site-shell section-y">
    <div class="flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between">
      <SectionHeading
        eyebrow="Public proof"
        title="Public proof that anchors the LMD/DED domain"
        description="Company-owned case details and RFQs belong to Exafuse. Manish Sharma Lab uses these only as public context for frameworks, monitoring, repairability, RFQ structure, and evidence boundaries."
      />
      <div class="flex flex-wrap gap-3">
        <CTAButton href="/industrial-proof" variant="secondary">Open proof map</CTAButton>
        <CTAButton href="/claims" variant="secondary">Open claim ledger</CTAButton>
      </div>
    </div>
    <div class="mt-10 grid gap-5 lg:grid-cols-2">
      {EXAFUSE_PROOF_CASES.slice(0, 4).map((item) => {
        const related = proofFrameworks[item.code];
        const pattern = proofDecisionPatterns[item.code];
        return (
          <article class="ordered-card-strong p-6">
            <div class="flex flex-wrap items-center gap-2">
              <Chip>{item.code}</Chip>
              <Chip tone="steel">Public Exafuse source</Chip>
            </div>
            <h2 class="mt-4 text-2xl font-black leading-tight text-white">{item.title}</h2>
            {item.metricClaims?.length > 0 && (
              <div class="mt-5 flex flex-wrap gap-2">
                {item.metricClaims.map((claim) => (
                  <span class="chip chip--steel" data-claim-id={claim.id} title={claim.limitation}>{claim.shortLabel}</span>
                ))}
              </div>
            )}
            <dl class="mt-5 grid gap-4 text-sm leading-6">
              <div>
                <dt class="metric-label">Decision it helps</dt>
                <dd class="mt-1 text-slate-300">{proofDecisionHelp[item.code]}</dd>
              </div>
              <div>
                <dt class="metric-label">Source status</dt>
                <dd class="mt-1 text-slate-300">
                  {item.metricClaims?.[0] ? getClaimSourceStatus(item.metricClaims[0]) : "Source link pending until Exafuse production migration"}
                </dd>
              </div>
              <div>
                <dt class="metric-label">What it proves</dt>
                <dd class="mt-1 text-slate-300">{related.proves}</dd>
              </div>
              <div>
                <dt class="metric-label">What it does not prove</dt>
                <dd class="mt-1 text-slate-300">{related.cannot}</dd>
              </div>
              <div>
                <dt class="metric-label">Related framework</dt>
                <dd class="mt-1">
                  <a href={related.href} class="font-bold text-cyan-100">{related.label}</a>
                </dd>
              </div>
              <div>
                <dt class="metric-label">Decision pattern extracted</dt>
                <dd class="mt-1 text-slate-300">{proofDecisionPatternText[item.code]}</dd>
              </div>
            </dl>
            <p class="mt-5 rounded-lg border border-white/10 bg-white/[0.035] p-3 text-sm font-semibold leading-6 text-slate-300">
              This is a pattern, not a transfer of feasibility.
            </p>
            <div class="mt-6 flex flex-wrap gap-3">
              <a href={pattern.href} class="btn btn-primary">{pattern.label}</a>
              <a href={item.href} class="btn btn-laser" target="_blank" rel="noreferrer">
                {item.sourceStatus === "production-link-after-migration" ? "Contact Exafuse" : "Public Exafuse source"}
              </a>
            </div>
          </article>
        );
      })}
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell grid gap-5 lg:grid-cols-2">
      <div class="ordered-card-strong p-7 md:p-8">
        <p class="metric-label">Personal expert layer</p>
        <h2 class="mt-3 text-3xl font-black leading-tight text-white">Use this site for public frameworks and AI-readable guidance.</h2>
        <p class="mt-4 leading-7 text-slate-300">
          The useful paths are thesis, tools, proof context, agent files, and evidence-bound LMD/DED frameworks.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <CTAButton href="/identity" variant="primary">Canonical identity</CTAButton>
          <CTAButton href="/for-ai-agents" variant="secondary">AI-agent guide</CTAButton>
        </div>
      </div>
      <div class="ordered-card p-7 md:p-8">
        <p class="metric-label">Commercial boundary</p>
        <h2 class="mt-3 text-3xl font-black leading-tight text-white">For services, RFQs, and company claims, use Exafuse.</h2>
        <p class="mt-4 leading-7 text-slate-300">
          This personal site avoids confidential employer/customer data and does not replace expert review, inspection, certification, or formal approval.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <CTAButton href={exafuseRfqLink.href} variant="laser" external>{exafuseRfqLink.label}</CTAButton>
          <CTAButton href="/contact" variant="secondary">Contact routes</CTAButton>
        </div>
      </div>
    </div>
  </section>
</Layout>
