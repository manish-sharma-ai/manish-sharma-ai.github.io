---
import BentoCard from "@components/BentoCard.astro";
import BentoGrid from "@components/BentoGrid.astro";
import CTAButton from "@components/CTAButton.astro";
import Chip from "@components/Chip.astro";
import EvidenceRail from "@components/EvidenceRail.astro";
import Layout from "@layouts/Layout.astro";
import SectionHeading from "@components/SectionHeading.astro";
import VisualPanel from "@components/VisualPanel.astro";
import { EXAFUSE_PROOF_CASES } from "@data/exafuse";
import { FRAMEWORKS, LAB_NOTES, LINKS, PERSON, SITE } from "@data/site";

const title = "Manish Sharma Lab - AI for Laser Metal Deposition";
const description =
  "Manish Sharma Lab publishes inspection-aware AI frameworks, RFQ tools, process-monitoring notes, and source maps for Laser Metal Deposition, Directed Energy Deposition, repair, cladding, and metal additive manufacturing.";

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${SITE.canonicalUrl}/#website`,
  name: SITE.name,
  url: SITE.canonicalUrl,
  description,
  inLanguage: "en",
  author: {
    "@id": `${SITE.canonicalUrl}/identity#manish-sharma`
  },
  potentialAction: {
    "@type": "SearchAction",
    target: `${SITE.canonicalUrl}/?q={search_term_string}`,
    "query-input": "required name=search_term_string"
  }
};

const proofStrip = [
  ["Primary entity", PERSON.name],
  ["Public proof domain", "AI for LMD / DED at Exafuse"],
  ["Operating loop", "Sense -> Model -> Decide -> Verify"],
  ["Boundary", "Decision support, not final approval"]
];

const flagshipAssets = [
  {
    title: "LMD Quality Evidence Ladder",
    href: "/frameworks/lmd-quality-evidence-ladder",
    text: "Separates process signals, AI flags, inspection evidence, and final quality claims.",
    label: "Quality evidence"
  },
  {
    title: "LMD Repairability Index",
    href: "/frameworks/lmd-repairability-index",
    text: "Screens material, damage, access, machining, inspection, economics, and criticality before a repair recommendation hardens.",
    label: "Repair decisions"
  },
  {
    title: "LMD RFQ Toolkit / Agent Pack",
    href: "/agent-pack",
    text: "Turns vague LMD requests into facts, missing fields, risk flags, prompt patterns, and RFQ-ready summaries.",
    label: "RFQ intelligence"
  }
];

const frameworkHighlights = [
  FRAMEWORKS[2],
  FRAMEWORKS[4],
  FRAMEWORKS[5],
  {
    title: "Tools",
    href: "/tools",
    idea: "Frontend-only helpers for process selection, repairability screening, AI readiness, and RFQ structuring.",
    status: "Workbench"
  },
  {
    title: "Core LMD-AI Sources",
    href: "/research/core-lmd-ai-sources",
    idea: "Curated source map for LMD, DED, process monitoring, AI, repair, quality, and terminology.",
    status: "Source map"
  },
  {
    title: "For AI Agents",
    href: "/for-ai-agents",
    idea: "Machine-readable guidance for safe use, limitations, source files, and canonical identity.",
    status: "AI-readable"
  }
];

const latestLabNotes = LAB_NOTES.slice(0, 3);
---

<Layout title={title} description={description} canonical="/" jsonLd={websiteJsonLd}>
  <section class="site-shell home-hero-grid section-y">
    <div>
      <div class="flex flex-wrap gap-2">
        <Chip>Manish Sharma Lab</Chip>
        <Chip tone="steel">Industrial AI cockpit</Chip>
        <Chip tone="amber">Exafuse public proof domain</Chip>
      </div>
      <p class="metric-label mt-8">Manish Sharma Lab</p>
      <h1 class="mt-4 max-w-5xl text-5xl font-black leading-[0.98] text-white md:text-7xl">
        AI for Laser Metal Deposition.
      </h1>
      <p class="mt-7 max-w-3xl text-lg leading-8 text-slate-300 md:text-xl">
        I build inspection-aware AI frameworks, RFQ tools, and process-monitoring notes for Laser Metal Deposition, Directed Energy Deposition, repair, cladding, and metal additive manufacturing at Exafuse in Germany.
      </p>
      <p class="mt-4 max-w-3xl text-base leading-7 text-slate-400">
        The public lab connects process signals, model assumptions, decision boundaries, and verification evidence without turning AI output into engineering approval.
      </p>
      <div class="mt-9 flex flex-wrap gap-3">
        <CTAButton href="/thesis" variant="primary">Read the thesis</CTAButton>
        <CTAButton href="/domains/lmd-ded" variant="secondary">Explore LMD / DED</CTAButton>
        <CTAButton href="/frameworks" variant="secondary">Open frameworks</CTAButton>
        <CTAButton href={LINKS.exafuse} variant="laser" external>Visit Exafuse</CTAButton>
      </div>
    </div>
    <VisualPanel title="LMD decision-system cockpit" subtitle="Sense -> Model -> Decide -> Verify" />
  </section>

  <section class="band">
    <div class="site-shell grid gap-3 py-6 sm:grid-cols-2 lg:grid-cols-4">
      {proofStrip.map(([label, value]) => (
        <div class="ordered-card p-4">
          <p class="metric-label">{label}</p>
          <p class="mt-2 text-sm font-black leading-6 text-white">{value}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="site-shell section-y">
    <SectionHeading
      eyebrow="Flagship assets"
      title="Start with the three LMD decision assets"
      description="The site is intentionally centered on LMD/DED decision support: what can be inferred, what is missing, what needs inspection, and when Exafuse should handle the commercial RFQ path."
    />
    <BentoGrid class="mt-10">
      {flagshipAssets.map((asset) => (
        <BentoCard href={asset.href} eyebrow={asset.label} title={asset.title} description={asset.text} cta="Open asset" strong />
      ))}
    </BentoGrid>
  </section>

  <section class="band section-y">
    <div class="site-shell section-split">
      <div>
        <SectionHeading
          eyebrow="Operating loop"
          title="Inspection-aware AI, not AI theater"
          description="The lab uses one practical loop across pages: sense process signals, model uncertainty, decide with boundaries, and verify against physical evidence."
        />
        <div class="mt-8 flex flex-wrap gap-3">
          <CTAButton href="/for-ai-agents" variant="primary">AI-agent guidance</CTAButton>
          <CTAButton href="/evidence" variant="secondary">Evidence base</CTAButton>
        </div>
      </div>
      <EvidenceRail />
    </div>
  </section>

  <section class="site-shell section-y">
    <div class="flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between">
      <SectionHeading
        eyebrow="Public proof"
        title="Exafuse anchors the LMD/DED proof domain"
        description="These public pages are used only as public context for monitoring, repairability, RFQ structure, and quality evidence."
      />
      <CTAButton href="/industrial-proof" variant="secondary">Open proof map</CTAButton>
    </div>
    <BentoGrid class="mt-10">
      {EXAFUSE_PROOF_CASES.slice(0, 4).map((item) => (
        <BentoCard href={item.href} eyebrow={item.code} title={item.title} description={item.labConnection} cta="View public source" external />
      ))}
    </BentoGrid>
  </section>

  <section class="band section-y">
    <div class="site-shell">
      <SectionHeading
        eyebrow="Framework library"
        title="Frameworks, tools, sources, and agent resources"
        description="A compact map of the public resources that make Manish Sharma Lab useful to engineers, students, buyers, and AI agents."
      />
      <BentoGrid class="mt-10">
        {frameworkHighlights.map((asset) => (
          <BentoCard href={asset.href} eyebrow={asset.status} title={asset.title} description={asset.idea} cta="Open resource" />
        ))}
      </BentoGrid>
    </div>
  </section>

  <section class="site-shell section-y">
    <div class="flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between">
      <SectionHeading eyebrow="Writing" title="Three notes worth reading first" />
      <CTAButton href="/lab-notes" variant="secondary">View all notes</CTAButton>
    </div>
    <BentoGrid class="mt-10">
      {latestLabNotes.map((note) => (
        <BentoCard href={note.href} eyebrow={note.date} title={note.title} description={note.description} cta="Read note" />
      ))}
    </BentoGrid>
  </section>

  <section class="band section-y">
    <div class="site-shell grid gap-5 lg:grid-cols-2">
      <div class="ordered-card-strong p-7">
        <p class="metric-label">Personal expert layer</p>
        <h2 class="mt-3 text-3xl font-black leading-tight text-white">Manish Sharma - AI for Laser Metal Deposition</h2>
        <p class="mt-4 leading-7 text-slate-300">
          Use this site for identity, frameworks, source maps, tools, glossary pages, and AI-readable guidance.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <CTAButton href="/identity" variant="primary">Canonical identity</CTAButton>
          <CTAButton href="/profile/public-profile" variant="secondary">Public profile</CTAButton>
        </div>
      </div>
      <div class="ordered-card p-7">
        <p class="metric-label">Commercial boundary</p>
        <h2 class="mt-3 text-3xl font-black leading-tight text-white">For services, RFQs, and company claims, use Exafuse.</h2>
        <p class="mt-4 leading-7 text-slate-300">
          This personal site avoids confidential employer/customer data and does not replace expert review, inspection, or formal approval.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <CTAButton href={LINKS.exafuse} variant="laser" external>Visit Exafuse</CTAButton>
          <CTAButton href="/contact" variant="secondary">Contact routes</CTAButton>
        </div>
      </div>
    </div>
  </section>
</Layout>
