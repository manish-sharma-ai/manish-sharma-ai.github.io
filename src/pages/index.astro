---
import BentoCard from "@components/BentoCard.astro";
import CTAButton from "@components/CTAButton.astro";
import Chip from "@components/Chip.astro";
import HeroLaserVisual from "@components/HeroLaserVisual";
import Layout from "@layouts/Layout.astro";
import LmdDecisionCockpit from "@components/LmdDecisionCockpit";
import SectionHeading from "@components/SectionHeading.astro";
import { resolveExafuseLink } from "../config/externalLinks";
import { EXAFUSE_PROOF_CASES } from "@data/exafuse";
import { getClaimSourceStatus } from "@data/publicClaims";
import { LAB_NOTES, LINKS, PERSON, SAME_AS, SITE } from "@data/site";

const title = "Manish Sharma — Industrial AI & Decision Systems";
const description =
  "Manish Sharma builds evidence-aware AI systems for industrial decisions. His strongest public work is in LMD/DED, process monitoring, robotics, and engineering decision support at Exafuse.";
const exafuseRfqLink = resolveExafuseLink("rfq");

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": `${SITE.canonicalUrl}/identity#manish-sharma`,
  name: PERSON.name,
  url: `${SITE.canonicalUrl}/identity`,
  sameAs: SAME_AS,
  jobTitle: SITE.publicCategory,
  worksFor: {
    "@type": "Organization",
    name: "Exafuse",
    url: LINKS.exafuse
  },
  knowsAbout: [
    "Industrial AI",
    "Industrial Decision Systems",
    "Decision Support",
    "Evidence-aware AI",
    "Engineering Decision-making",
    "Industrial Automation",
    "Machine Vision",
    "Robotics",
    "Laser Metal Deposition",
    "Directed Energy Deposition",
    "Process Monitoring",
    "RFQ Intelligence",
    "Industrial Repair",
    "Repair and Cladding",
    "Inspection Evidence"
  ]
};

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${SITE.canonicalUrl}/#website`,
  name: SITE.name,
  url: SITE.canonicalUrl,
  description,
  inLanguage: "en",
  author: { "@id": `${SITE.canonicalUrl}/identity#manish-sharma` },
  potentialAction: {
    "@type": "SearchAction",
    target: `${SITE.canonicalUrl}/?q={search_term_string}`,
    "query-input": "required name=search_term_string"
  }
};

const profilePageJsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "@id": `${SITE.canonicalUrl}/#profile-page`,
  url: SITE.canonicalUrl,
  name: "Manish Sharma — Industrial AI & Decision Systems",
  mainEntity: { "@id": `${SITE.canonicalUrl}/identity#manish-sharma` }
};

const startCards = [
  {
    eyebrow: "Repair decision",
    title: "Evaluate a worn or damaged component.",
    description: "Expose material, damage, access, finishing, and inspection gaps before repair claims harden.",
    href: "/tools/#preset=worn-shaft",
    cta: "Start repair brief"
  },
  {
    eyebrow: "RFQ preparation",
    title: "Turn a rough request into a usable RFQ brief.",
    description: "Separate known facts, critical gaps, useful context, risks, and the next review action.",
    href: "/tools/#preset=rfq",
    cta: "Structure an RFQ"
  },
  {
    eyebrow: "Monitoring evidence",
    title: "Interpret a process signal without overclaiming quality.",
    description: "Connect monitoring context to inspection evidence and keep the release boundary visible.",
    href: "/tools/#preset=monitoring-anomaly",
    cta: "Review a signal"
  },
  {
    eyebrow: "Process selection",
    title: "Compare LMD with SLM / LPBF route signals.",
    description: "Start with part size, local deposition, feature complexity, tolerance, and qualification needs.",
    href: "/tools/#preset=lmd-vs-slm",
    cta: "Compare routes"
  }
];

const flagshipAssets = [
  {
    title: "LMD Quality Evidence Ladder",
    href: "/frameworks/lmd-quality-evidence-ladder",
    problem: "Monitoring data is often treated as release proof.",
    helps: "Which evidence level is needed for a claim.",
    cannot: "Final part quality without inspection/testing.",
    cta: "Open framework"
  },
  {
    title: "LMD Repairability Index",
    href: "/frameworks/lmd-repairability-index",
    problem: "Repair requests arrive before material, damage, access, and inspection facts are clear.",
    helps: "Whether a repair candidate is worth expert review.",
    cannot: "Repair feasibility, release, or service safety.",
    cta: "Open index"
  },
  {
    title: "LMD RFQ Toolkit",
    href: "/agent-pack",
    problem: "Vague RFQs hide missing facts and risk flags.",
    helps: "How to structure known facts, gaps, assumptions, and next questions.",
    cannot: "Replace Exafuse commercial review or engineering approval.",
    cta: "Open toolkit"
  }
];

const homepageProcessSteps = [
  {
    index: "01",
    label: "Sense",
    description: "Capture the process signal and its operating context.",
    tone: "success"
  },
  {
    index: "02",
    label: "Model",
    description: "Make assumptions visible.",
    tone: "signal"
  },
  {
    index: "03",
    label: "Decide",
    description: "Plan the evidence needed.",
    tone: "active"
  },
  {
    index: "04",
    label: "Verify",
    description: "Use inspection evidence.",
    tone: "risk"
  }
];

const proofFrameworks: Record<string, { label: string; href: string; proves: string; cannot: string }> = {
  CS15: {
    label: "LMD Quality Evidence Ladder",
    href: "/frameworks/lmd-quality-evidence-ladder",
    proves:
      "Public context for large-part LMD scale, monitoring, validation, and inspection planning in one documented Exafuse case.",
    cannot:
      "It does not prove that monitoring alone certifies quality or that this site can approve structural parts."
  },
  CS01: {
    label: "LMD Repairability Index",
    href: "/frameworks/lmd-repairability-index",
    proves: "Public context for local wear repair, material strategy, finishing, and release-evidence planning.",
    cannot: "It does not prove every hammer or safety-critical part is repairable."
  },
  CS10: {
    label: "LMD RFQ Toolkit",
    href: "/agent-pack",
    proves: "Public context for RFQ intelligence around local damage, downtime pressure, drawings, machining, and inspection needs.",
    cannot: "It does not prove feasibility without part-specific material, damage, geometry, and service context."
  },
  CS13: {
    label: "LMD Quality Evidence Ladder",
    href: "/frameworks/lmd-quality-evidence-ladder",
    proves: "Public context for combining build-up, coating function, material choice, and finishing strategy.",
    cannot: "It does not prove surface performance without application-specific validation."
  }
};

const proofDecisionHelp: Record<string, string> = {
  CS15: "Helps decide how much evidence is needed before large-part LMD monitoring data becomes a defensible engineering discussion.",
  CS01: "Helps decide whether local wear repair should move into expert review instead of becoming an automatic repair claim.",
  CS10: "Helps decide which missing RFQ facts block a repairability conversation.",
  CS13: "Helps decide when build-up and surface function must be planned as one route."
};

const proofDecisionPatterns: Record<string, { label: string; href: string }> = {
  CS15: { label: "Start a brief from this pattern", href: "/tools/#preset=monitoring-anomaly" },
  CS01: { label: "Start a brief from this pattern", href: "/tools/#preset=worn-shaft" },
  CS10: { label: "Start a brief from this pattern", href: "/tools/#preset=rfq" },
  CS13: { label: "Start a brief from this pattern", href: "/tools/#preset=surface-cladding" }
};

const proofDecisionPatternText: Record<string, string> = {
  CS15: "Large-scale LMD requires evidence planning, monitoring context, and an inspection boundary.",
  CS01: "Local repair needs material, damage depth, machining route, and inspection plan.",
  CS10: "Repair/RFQ quality depends on complete facts, downtime context, and service context.",
  CS13: "Build-and-coat routes need geometry, surface function, material, finishing, and validation."
};
---

<Layout
  title={title}
  description={description}
  canonical="/"
  jsonLd={[websiteJsonLd, personJsonLd, profilePageJsonLd]}
  alternates={[
    { lang: "en", href: "/" },
    { lang: "de", href: "/de" },
    { lang: "x-default", href: "/" }
  ]}
>
  <section class="site-shell home-hero-grid section-y">
    <div class="home-hero__copy">
      <div class="home-hero__tags" aria-label="Technical context">
        <span class="home-hero__tag">Manish Sharma</span>
        <span class="home-hero__tag">Current proof: LMD / DED</span>
      </div>
      <p class="home-hero__eyebrow">
        Industrial AI / decision systems <span class="home-hero__preserve-label">Evidence-aware by design</span>
      </p>
      <h1 class="home-hero__title">
        I build AI systems for industrial decisions that need evidence, not just predictions.
      </h1>
      <p class="home-hero__intro">
        Again and again, I found that a prediction alone did not settle the industrial question. My strongest public work today is in Laser Metal Deposition and Directed Energy Deposition at Exafuse, where I connect signals, models, engineering constraints, and human judgment to the next action and the evidence needed to check it.
      </p>
      <div class="home-hero__actions">
        <CTAButton href="#lmd-decision-cockpit" variant="primary" class="home-hero__primary-action">Explore my work</CTAButton>
        <CTAButton href="/thesis" variant="secondary" class="home-hero__secondary-action">Read how I think</CTAButton>
      </div>
      <p class="home-hero__review-note">Start with the LMD Decision Cockpit, then follow the method and current public work.</p>
    </div>
    <HeroLaserVisual />
  </section>

  <section class="site-shell pb-12">
    <LmdDecisionCockpit client:visible defaultMode="example" compact exafuseUrl={exafuseRfqLink.href} exafuseLabel={exafuseRfqLink.label} />
    <noscript>
      <div class="ordered-card mt-5 p-5 text-sm leading-6 text-slate-300">
        The worked brief remains readable without JavaScript. To prepare your own handoff, use the <a href="/brief-template" class="font-black text-cyan-100">copyable template</a> or the <a href="/brief-standard" class="font-black text-cyan-100">public brief standard</a>.
      </div>
    </noscript>
  </section>

  <section class="process-proof-system" data-operating-loop="homepage" aria-label="Sense, model, decide, verify operating loop">
    <div class="site-shell process-proof-system__inner">
      <div class="process-proof-system__section">
        <div class="process-proof-system__intro">
          <SectionHeading
            eyebrow="How I work / signal to evidence"
            title="Sense → Model → Decide → Verify"
            description="To me, a prediction is only one part of the job. The next action, the missing context, and the verification path have to be clear too."
          />
          <div class="process-proof-system__tags" aria-label="Operating loop characteristics">
            <span class="process-proof-system__tag">Decision support</span>
            <span class="process-proof-system__tag">Evidence boundary</span>
          </div>
          <div class="process-proof-system__actions">
            <CTAButton href="/thesis" variant="primary">Read the method</CTAButton>
            <CTAButton href="/domains/lmd-ded" variant="secondary">See current LMD/DED work</CTAButton>
          </div>
        </div>

        <ol class="process-proof-system__flow" aria-label="Sense, model, decide, verify process">
          {homepageProcessSteps.map((step) => (
            <li class:list={["process-proof-system__step", `process-proof-system__step--${step.tone}`]}>
              <span class="process-proof-system__step-index">{step.index}</span>
              <strong>{step.label}</strong>
              <span>{step.description}</span>
            </li>
          ))}
        </ol>
      </div>

      <div class="process-proof-system__section process-proof-system__section--proof" aria-label="Public context and decision routes">
        <div class="process-proof-system__proof-heading">
          <SectionHeading
            eyebrow="Current proof / decision routes"
            title="LMD/DED is my current proving ground"
            description="It is where signals, materials, machine vision, robotics, repair, inspection, and engineering judgment meet in decisions with real consequences."
          />
          <div class="process-proof-system__tags" aria-label="Proof card characteristics">
            <span class="process-proof-system__tag">Public source context</span>
            <span class="process-proof-system__tag">Decision guidance</span>
          </div>
        </div>

        <dl class="process-proof-system__metadata" aria-label="Evidence status">
          <div>
            <dt>Evidence status</dt>
            <dd>Public source context</dd>
          </div>
        </dl>

        <div class="process-proof-system__cards">
          <a href={flagshipAssets[0].href} class="process-proof-system__card process-proof-system__card--evidence">
            <span class="process-proof-system__card-eyebrow">Evidence / framework</span>
            <h3>{flagshipAssets[0].title}</h3>
            <p>{flagshipAssets[0].helps}</p>
            <dl class="process-proof-system__source-note">
              <div>
                <dt>Source note</dt>
                <dd>Public context only</dd>
              </div>
            </dl>
            <span class="process-proof-system__card-action" aria-hidden="true">Open framework →</span>
          </a>

          <a href={flagshipAssets[1].href} class="process-proof-system__card process-proof-system__card--decision">
            <span class="process-proof-system__card-eyebrow">Decision / framework</span>
            <h3>{flagshipAssets[1].title}</h3>
            <p>{flagshipAssets[1].helps}</p>
            <p class="process-proof-system__boundary"><strong>Not final:</strong> {flagshipAssets[1].cannot}</p>
            <span class="process-proof-system__card-action" aria-hidden="true">Open index →</span>
          </a>
        </div>

        <aside class="process-proof-system__boundary-notice" aria-label="Decision-support boundary">
          <p>Preliminary decision-support only</p>
          <p>Final feasibility depends on base material, geometry, service conditions, inspection requirements, and expert review.</p>
        </aside>
      </div>
    </div>
  </section>

  <div class="home-continuation">
    <section class="home-section home-section--start" aria-label="Start with a decision path">
      <div class="site-shell home-section__inner">
        <SectionHeading eyebrow="Start here" title="Current LMD/DED work: choose the question you need to structure" />
        <div class="home-start-grid">
          {startCards.map((card) => (
            <BentoCard href={card.href} eyebrow={card.eyebrow} title={card.title} description={card.description} cta={card.cta} strong />
          ))}
        </div>
      </div>
    </section>

    <section class="home-section home-section--assets" aria-label="Flagship decision assets">
      <div class="site-shell home-section__inner">
        <SectionHeading
          eyebrow="Selected work"
          title="Three LMD decision assets from the current proving ground"
          description="These specialist artifacts show how I turn vague industrial questions into structured decision-support workflows."
        />
        <div class="home-assets-grid">
          {flagshipAssets.map((asset) => (
            <a href={asset.href} class="home-asset-card">
              <span>
                <h2>{asset.title}</h2>
                <dl>
                  <div>
                    <dt>Problem</dt>
                    <dd>{asset.problem}</dd>
                  </div>
                  <div>
                    <dt>Helps decide</dt>
                    <dd>{asset.helps}</dd>
                  </div>
                  <div>
                    <dt>Cannot prove</dt>
                    <dd>{asset.cannot}</dd>
                  </div>
                </dl>
              </span>
              <span class="home-asset-card__action" aria-hidden="true">{asset.cta} <span>→</span></span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="home-section home-section--proof" aria-label="Documented public examples">
      <div class="site-shell home-section__inner">
        <div class="home-section__heading-row">
          <SectionHeading
            eyebrow="Documented examples"
            title="Current LMD/DED proof, with public source context"
            description="These public examples show why evidence planning matters. Commercial case details and RFQs remain with Exafuse."
          />
          <div class="home-section__actions">
            <CTAButton href="/industrial-proof" variant="secondary">Open evidence map</CTAButton>
            <CTAButton href="/claims" variant="secondary">Review source notes</CTAButton>
          </div>
        </div>
        <div class="home-proof-grid">
      {EXAFUSE_PROOF_CASES.slice(0, 2).map((item) => {
        const related = proofFrameworks[item.code];
        const pattern = proofDecisionPatterns[item.code];
        return (
          <article class="home-proof-card">
            <div class="home-proof-card__tags">
              <Chip>{item.code}</Chip>
              <Chip tone="steel">Public Exafuse source</Chip>
            </div>
            <h2>{item.title}</h2>
            {item.metricClaims?.length > 0 && (
              <div class="home-proof-card__claims">
                {item.metricClaims.map((claim) => (
                  <span class="chip chip--steel" data-claim-id={claim.id} title={claim.limitation}>{claim.shortLabel}</span>
                ))}
              </div>
            )}
            <dl class="home-proof-card__metadata">
              <div>
                <dt>Decision it helps</dt>
                <dd>{proofDecisionHelp[item.code]}</dd>
              </div>
              <div>
              <dt>Source note</dt>
              <dd>
                  {item.metricClaims?.[0] ? getClaimSourceStatus(item.metricClaims[0]) : "Case-specific source available through Exafuse contact or current public pages."}
              </dd>
              </div>
              <div>
                <dt>What the example shows</dt>
                <dd>{related.proves}</dd>
              </div>
              <div>
                <dt>What still needs part-specific review</dt>
                <dd>{related.cannot}</dd>
              </div>
              <div>
                <dt>Related framework</dt>
                <dd>
                  <a href={related.href}>{related.label}</a>
                </dd>
              </div>
              <div>
                <dt>Useful decision pattern</dt>
                <dd>{proofDecisionPatternText[item.code]}</dd>
              </div>
            </dl>
            <p class="home-proof-card__boundary">
              Use the pattern as context only; feasibility still depends on the actual part, material, service conditions, inspection needs, and expert review.
            </p>
            <div class="home-proof-card__actions">
              <a href={pattern.href} class="btn btn-primary">{pattern.label}</a>
              <a href={item.href} class="btn btn-laser" target="_blank" rel="noreferrer">
                {item.sourceStatus === "production-link-after-migration" ? "Contact Exafuse" : "Public Exafuse source"}
              </a>
            </div>
          </article>
        );
      })}
        </div>
      </div>
    </section>

    <section class="home-section home-section--notes" aria-label="Latest field notes">
      <div class="site-shell home-section__inner">
        <div class="home-section__heading-row">
        <SectionHeading
          eyebrow="Latest field notes"
          title="Notes from the current proving ground"
          description="Short technical explanations of the assumptions, evidence gaps, and review questions that often change an LMD/DED decision."
        />
          <div class="home-section__actions">
          <CTAButton href="/lab-notes" variant="secondary">All lab notes</CTAButton>
          <CTAButton href="/rss.xml" variant="secondary">RSS feed</CTAButton>
          </div>
        </div>
        <div class="home-notes-grid">
        {LAB_NOTES.slice(0, 3).map((note) => (
          <a href={note.href} class="home-note-card">
            <span>
              <time datetime={note.date}>{note.date}</time>
              <h2>{note.title}</h2>
              <p>{note.description}</p>
            </span>
            <span class="home-note-card__action" aria-hidden="true">Read note <span>→</span></span>
          </a>
        ))}
        </div>
      </div>
    </section>

    <section class="home-section home-section--routes" aria-label="Public and commercial routes">
      <div class="site-shell home-section__inner home-route-grid">
      <div class="home-route-card home-route-card--public">
        <p>Personal platform</p>
        <h2>Explore the method, current work, and research questions.</h2>
        <p>
          I am studying how this approach can help with decisions based on incomplete physical signals, operational risk, and human responsibility. That is a research direction, not a cross-industry deployment claim.
        </p>
        <div class="home-route-card__actions">
          <CTAButton href="/public-work" variant="primary">Explore my work</CTAButton>
          <CTAButton href="/about" variant="secondary">About Manish</CTAButton>
        </div>
      </div>
      <div class="home-route-card home-route-card--commercial">
        <p>Commercial boundary</p>
        <h2>For commercial LMD/DED services and RFQs, use Exafuse.</h2>
        <p>
          My current applied LMD/DED work is carried out through Exafuse. This site shares public methods and notes; company services, case studies, and engineering review belong there.
        </p>
        <div class="home-route-card__actions">
          <CTAButton href={exafuseRfqLink.href} variant="laser" external>{exafuseRfqLink.label}</CTAButton>
          <CTAButton href="/contact" variant="secondary">Contact routes</CTAButton>
        </div>
      </div>
      </div>
    </section>
    </div>
</Layout>
