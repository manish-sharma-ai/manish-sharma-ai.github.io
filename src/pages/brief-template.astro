---
import Badge from "@components/Badge.astro";
import BriefTemplateActions from "@components/BriefTemplateActions";
import CTAButton from "@components/CTAButton.astro";
import DecisionBriefCard from "@components/DecisionBriefCard";
import Layout from "@layouts/Layout.astro";
import SectionHeading from "@components/SectionHeading.astro";
import SourceLinks from "@components/SourceLinks.astro";
import { BRIEF_EXAMPLES, BRIEF_OUTPUT_MODES, BRIEF_QUALITY_RUBRIC, BRIEF_SCHEMA_PATH } from "@data/briefStandard";
import { resolveExafuseLink } from "../config/externalLinks";
import {
  BRIEF_VERSION,
  WORN_SHAFT_BRIEF,
  formatDecisionBriefMarkdown,
  formatDecisionBriefTemplateMarkdown
} from "../lib/decisionBrief";
import { PERSON, SITE } from "@data/site";

const title = "LMD Decision Brief v1.0";
const description =
  "Copyable no-backend LMD Decision Brief v1.0 template for turning rough LMD/DED questions into bounded decision-support structure before expert review.";
const exafuseRfqLink = resolveExafuseLink("rfq");
const templateMarkdown = formatDecisionBriefTemplateMarkdown();
const exampleMarkdown = formatDecisionBriefMarkdown(WORN_SHAFT_BRIEF);

const why = [
  "Rough LMD questions usually mix facts, assumptions, missing data, and risks.",
  "A single brief format keeps known facts, missing information, risk flags, evidence needs, and review route visible.",
  "The output is easy to copy into email, RFQ notes, agent prompts, or expert-review preparation."
];

const when = [
  "Before asking whether an LMD repair is feasible.",
  "Before comparing LMD with SLM/LPBF, machining, replacement, or cladding.",
  "When process monitoring produces a signal that needs inspection context.",
  "When a buyer request is too vague for a serious technical review."
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "@id": `${SITE.canonicalUrl}/brief-template#article`,
  url: `${SITE.canonicalUrl}/brief-template`,
  headline: title,
  description,
  author: { "@id": `${SITE.canonicalUrl}/identity#manish-sharma`, name: PERSON.name },
  about: ["Laser Metal Deposition", "Decision Support", "RFQ Intelligence", "Industrial Repair"],
  isAccessibleForFree: true
};
---

<Layout title={`${title} - Manish Sharma Lab`} description={description} canonical="/brief-template" jsonLd={jsonLd}>
  <div class="brief-template-page">
  <section class="brief-template-page__masthead site-shell section-y">
    <div class="max-w-4xl">
      <div class="flex flex-wrap gap-2">
        <Badge>{BRIEF_VERSION}</Badge>
        <Badge tone="steel">Copyable Markdown</Badge>
        <Badge tone="laser">No backend</Badge>
      </div>
      <h1 class="mt-6 text-5xl font-black leading-tight text-white md:text-6xl">Use one standard brief for rough LMD questions.</h1>
      <p class="mt-6 text-lg leading-8 text-slate-300 md:text-xl">
        {BRIEF_VERSION} turns a vague repair, cladding, route-selection, monitoring, or RFQ question into known facts, missing information, risk flags, evidence needed, next action, and Exafuse review route.
      </p>
      <p class="mt-4 max-w-3xl rounded-lg border border-amber-300/25 bg-amber-400/10 p-4 text-sm font-bold leading-6 text-amber-50">
        Confidence is not approval. The brief is preliminary decision-support, not engineering release, material certification, or a quality guarantee.
      </p>
      <p class="mt-4 max-w-3xl text-sm font-bold leading-6 text-cyan-100">
        Current version: {BRIEF_VERSION}. Standard output modes: Technical Decision Brief, Exafuse-ready email draft, and AI summary.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <CTAButton href="/tools/#preset=worn-shaft" variant="primary">Start cockpit with this structure</CTAButton>
        <CTAButton href="/brief-standard" variant="secondary">Open public standard</CTAButton>
        <CTAButton href="/demo" variant="secondary">See filled demo</CTAButton>
        <CTAButton href={BRIEF_SCHEMA_PATH} variant="secondary">Open JSON schema</CTAButton>
        <CTAButton href={exafuseRfqLink.href} variant="laser" external>{exafuseRfqLink.label}</CTAButton>
      </div>
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell grid gap-5 lg:grid-cols-2">
      <article class="ordered-card-strong p-6">
        <p class="metric-label">Why this brief exists</p>
        <h2 class="mt-3 text-2xl font-black text-white">It makes uncertainty usable.</h2>
        <ul class="mt-5 grid gap-3 text-sm leading-6 text-slate-300">
          {why.map((item) => <li class="result-card">{item}</li>)}
        </ul>
      </article>
      <article class="ordered-card p-6">
        <p class="metric-label">When to use it</p>
        <h2 class="mt-3 text-2xl font-black text-white">Use it before the recommendation hardens.</h2>
        <ul class="mt-5 grid gap-3 text-sm leading-6 text-slate-300">
          {when.map((item) => <li class="result-card">{item}</li>)}
        </ul>
      </article>
    </div>
  </section>

  <section class="site-shell section-y">
    <div class="grid gap-5 lg:grid-cols-2">
      <article class="ordered-card-strong p-6">
        <p class="metric-label">Brief standard notes</p>
        <h2 class="mt-3 text-2xl font-black text-white">One source object, multiple travel modes.</h2>
        <ul class="mt-5 grid gap-3 text-sm leading-6 text-slate-300">
          {BRIEF_OUTPUT_MODES.map((item) => <li class="result-card">{item}</li>)}
        </ul>
        <p class="mt-5 text-sm font-bold leading-6 text-amber-100">
          No backend, no input storage, no analytics around entered technical content, and no automatic email sending.
        </p>
      </article>
      <article class="ordered-card p-6">
        <p class="metric-label">Brief quality rubric</p>
        <h2 class="mt-3 text-2xl font-black text-white">What makes a brief useful?</h2>
        <p class="mt-4 text-sm font-bold leading-6 text-amber-100">
          This rubric checks brief quality, not technical feasibility.
        </p>
        <ul class="mt-5 grid gap-2 sm:grid-cols-2">
          {BRIEF_QUALITY_RUBRIC.map((item) => <li class="result-card text-sm font-semibold leading-6 text-slate-300">{item}</li>)}
        </ul>
      </article>
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell">
      <SectionHeading
        eyebrow="Standard files"
        title="Schema and non-confidential examples"
        description="Use these files when the brief needs to travel through tools, RFQ notes, assistant prompts, or docs without changing its boundary."
      />
      <div class="mt-8 grid gap-8">
        <SourceLinks links={[{ label: "LMD Decision Brief v1.0 Standard", href: "/brief-standard", description: "Human-readable public standard and adoption package." }, { label: "JSON schema", href: BRIEF_SCHEMA_PATH, description: "Machine-readable schema for exported JSON handoffs." }]} />
        <SourceLinks links={BRIEF_EXAMPLES} />
      </div>
    </div>
  </section>

  <section class="site-shell section-y">
    <div class="grid gap-8 lg:grid-cols-[0.42fr_0.58fr]">
      <div>
        <p class="metric-label">Copy standard</p>
        <h2 class="mt-3 text-3xl font-black leading-tight text-white">Markdown template preview</h2>
        <p class="mt-4 text-sm leading-7 text-slate-300">
          Copy this blank standard when the user has not entered enough information yet. The fields are intentionally plain so they can travel through email, docs, AI agents, and RFQ notes.
        </p>
        <div class="mt-6">
          <BriefTemplateActions client:load exampleBrief={WORN_SHAFT_BRIEF} />
        </div>
      </div>
      <pre class="ordered-card-strong max-h-[44rem] overflow-auto p-5 text-sm leading-6 text-slate-200"><code>{templateMarkdown}</code></pre>
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell grid gap-8 lg:grid-cols-[0.42fr_0.58fr]">
      <div>
        <p class="metric-label">Filled example</p>
        <h2 class="mt-3 text-3xl font-black leading-tight text-white">Non-confidential worn-shaft dummy brief</h2>
        <p class="mt-4 text-sm leading-7 text-slate-300">
          This is not a customer case. It is the default dummy example used by the cockpit so first-time visitors can see the artifact without entering data.
        </p>
        <details class="ordered-card mt-6 p-5">
          <summary class="flex items-center justify-between gap-4 text-sm font-black text-white">
            <span>Open raw Markdown</span>
            <span class="metric-label">Example</span>
          </summary>
          <pre class="mt-4 max-h-[28rem] overflow-auto text-sm leading-6 text-slate-200"><code>{exampleMarkdown}</code></pre>
        </details>
      </div>
      <div class="ordered-card-strong p-5 md:p-6">
        <DecisionBriefCard client:load brief={WORN_SHAFT_BRIEF} exafuseUrl={exafuseRfqLink.href} exafuseLabel={exafuseRfqLink.label} matchingToolHref="/tools/#preset=worn-shaft" matchingToolLabel="Run in cockpit" />
      </div>
    </div>
  </section>
  </div>
</Layout>
