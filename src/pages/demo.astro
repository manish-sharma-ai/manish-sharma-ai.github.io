---
import Badge from "@components/Badge.astro";
import CopyBlock from "@components/CopyBlock";
import CTAButton from "@components/CTAButton.astro";
import DecisionBriefCard from "@components/DecisionBriefCard";
import Layout from "@layouts/Layout.astro";
import SourceLinks from "@components/SourceLinks.astro";
import { BRIEF_EXAMPLES, BRIEF_SCHEMA_PATH } from "@data/briefStandard";
import { resolveExafuseLink } from "../config/externalLinks";
import { BRIEF_VERSION, WORN_SHAFT_BRIEF, formatDecisionBriefMarkdown } from "../lib/decisionBrief";
import { PERSON, SITE } from "@data/site";

const title = "Before / after: vague request to usable brief";
const seoTitle = "LMD Request to Decision Brief Demo - Manish Sharma Lab";
const description =
  "Non-confidential walkthrough showing how a vague LMD repair request becomes a structured Decision Brief with facts, gaps, risks, and evidence needs.";
const exafuseRfqLink = resolveExafuseLink("rfq");
const demoMarkdown = formatDecisionBriefMarkdown(WORN_SHAFT_BRIEF);

const beforeText = "Worn steel shaft near bearing seat. Photos available. CAD missing. Tight tolerance. Operating conditions unknown.";
const afterBullets = [
  ["Known facts", "Steel material family, local wear near bearing seat, photos available, tight tolerance mentioned."],
  ["Critical gaps", "Exact material grade, CAD/drawing, damage depth, dimensions, operating conditions, inspection requirement."],
  ["Risk flags", "Tight tolerance, unknown service conditions, and missing CAD keep the package from expert-review readiness."],
  ["Evidence burden", "High inspection burden."],
  ["Next action", "Prepare an Exafuse-ready review package with missing facts clearly marked."],
  ["Exafuse review route", "Request Exafuse review after material, geometry, damage, and inspection facts are structured."]
];

const steps = [
  {
    label: "Vague request",
    text: "Worn steel shaft near bearing seat. Photos available. CAD missing. Tight tolerance. Operating conditions unknown."
  },
  {
    label: "Structured facts",
    text: "The site extracts a repair situation, steel material family, local wear near a bearing seat, photos available, and tight tolerance."
  },
  {
    label: "Missing information",
    text: "Exact material grade, CAD/drawing, damage depth, dimensions, operating conditions, inspection requirement, and deadline stay visible."
  },
  {
    label: "Risk flags",
    text: "Tight tolerance likely requires machining and dimensional inspection. Unknown service conditions can change the evidence burden."
  },
  {
    label: "Evidence needed",
    text: "Material grade, damage map, machining allowance, tolerance target, inspection requirement, and expert review."
  },
  {
    label: "Decision brief",
    text: "The final artifact is a copyable LMD Decision Brief v1.0, not a feasibility approval."
  },
  {
    label: "Exafuse review route",
    text: "Use Exafuse for commercial and technical review after the non-confidential structure is ready."
  }
];

const outputModes = [
  "Technical Decision Brief",
  "Exafuse-Ready Email Draft",
  "AI Summary",
  "Missing-information checklist",
  "Evidence-needed checklist",
  "Markdown, JSON, and print/PDF handoff"
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "@id": `${SITE.canonicalUrl}/demo#article`,
  url: `${SITE.canonicalUrl}/demo`,
  headline: title,
  description,
  author: { "@id": `${SITE.canonicalUrl}/identity#manish-sharma`, name: PERSON.name },
  about: ["Laser Metal Deposition", "Decision Support", "RFQ Intelligence", "Industrial Repair"]
};
---

<Layout title={seoTitle} description={description} canonical="/demo" jsonLd={jsonLd}>
  <div class="demo-page">
  <section class="demo-page__masthead site-shell section-y">
    <div class="max-w-4xl">
      <div class="flex flex-wrap gap-2">
        <Badge>Before / after</Badge>
        <Badge tone="steel">Dummy data</Badge>
        <Badge tone="laser">{BRIEF_VERSION}</Badge>
      </div>
      <h1 class="mt-6 text-5xl font-black leading-tight text-white md:text-6xl">{title}</h1>
      <p class="mt-6 text-lg leading-8 text-slate-300 md:text-xl">
        This walkthrough uses non-confidential dummy data. It shows how the site exposes known facts, missing information, risk flags, evidence needs, and the Exafuse review route without storing or sending inputs.
      </p>
      <p class="mt-4 max-w-3xl text-base font-bold leading-7 text-cyan-100">
        The final object is portable: copy it into review notes, email, AI-agent context, Markdown docs, JSON handoff, or print/PDF.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <CTAButton href="/tools/#preset=worn-shaft" variant="primary">Run this in cockpit</CTAButton>
        <CTAButton href="/brief-standard" variant="secondary">Open brief standard</CTAButton>
        <CTAButton href="/brief-template" variant="secondary">Start your own brief</CTAButton>
        <CTAButton href={exafuseRfqLink.href} variant="laser" external>{exafuseRfqLink.label}</CTAButton>
      </div>
    </div>
  </section>

  <section class="band section-y premium-flow-tool-surface">
    <div class="site-shell grid gap-5 lg:grid-cols-2">
      <article class="ordered-card p-6">
        <p class="metric-label">Before</p>
        <h2 class="mt-3 text-3xl font-black text-white">Vague request</h2>
        <p class="mt-5 rounded-lg border border-white/10 bg-white/[0.035] p-4 text-base font-bold leading-7 text-slate-200">{beforeText}</p>
      </article>
      <article class="ordered-card-strong p-6">
        <p class="metric-label">After</p>
        <h2 class="mt-3 text-3xl font-black text-white">Usable brief</h2>
        <ul class="mt-5 grid gap-3 text-sm leading-6 text-slate-300">
          {afterBullets.map(([label, text]) => (
            <li class="result-card">
              <span class="font-black text-white">{label}:</span> {text}
            </li>
          ))}
        </ul>
        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          <CopyBlock client:load label="Copy this example brief" text={demoMarkdown} />
          <div class="ordered-card p-4">
            <p class="metric-label">Start</p>
            <a href="/tools/#preset=worn-shaft" class="btn btn-primary mt-3">Start your own brief</a>
          </div>
        </div>
      </article>
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell">
      <div class="grid gap-4">
        {steps.map((step, index) => (
          <article class="ordered-card-strong grid gap-4 p-5 md:grid-cols-[5rem_1fr] md:items-start">
            <div class="font-mono text-3xl font-black text-cyan-100">{String(index + 1).padStart(2, "0")}</div>
            <div>
              <h2 class="text-2xl font-black text-white">{step.label}</h2>
              <p class="mt-3 text-sm leading-6 text-slate-300">{step.text}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="site-shell section-y">
    <div class="grid gap-8 lg:grid-cols-[0.42fr_0.58fr]">
      <div>
        <p class="metric-label">Final artifact</p>
        <h2 class="mt-3 text-3xl font-black leading-tight text-white">{BRIEF_VERSION}</h2>
        <p class="mt-4 text-sm leading-7 text-slate-300">
          The demo ends with a clean brief that can be copied as a technical brief, Exafuse-ready email draft, AI summary, Markdown, JSON, print/PDF, or grouped checklist.
        </p>
        <div class="mt-5 grid gap-2 sm:grid-cols-2">
          {outputModes.map((mode) => <span class="result-card text-sm font-semibold leading-6 text-slate-300">{mode}</span>)}
        </div>
        <div class="mt-6 flex flex-wrap gap-3">
          <CTAButton href="/tools/#preset=worn-shaft" variant="primary">Run in cockpit</CTAButton>
          <CTAButton href="/brief-template" variant="secondary">Start your own brief</CTAButton>
        </div>
        <div class="mt-6">
          <CopyBlock client:load label="Copy this example brief" text={demoMarkdown} />
        </div>
      </div>
      <div class="ordered-card-strong p-5 md:p-6">
        <DecisionBriefCard client:load brief={WORN_SHAFT_BRIEF} exafuseUrl={exafuseRfqLink.href} exafuseLabel={exafuseRfqLink.label} matchingToolHref="/tools/#preset=worn-shaft" matchingToolLabel="Run this in cockpit" />
      </div>
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell">
      <div class="grid gap-8 lg:grid-cols-[0.34fr_0.66fr] lg:items-start">
        <div>
          <p class="metric-label">Standard files</p>
          <h2 class="mt-3 text-3xl font-black leading-tight text-white">Reuse the artifact outside the demo.</h2>
          <p class="mt-4 text-sm leading-7 text-slate-300">
            The demo is one dummy path through the same portable standard. Use the schema and examples for AI-agent context, review notes, or tool checks.
          </p>
        </div>
        <div class="grid gap-8">
          <SourceLinks links={[{ label: "LMD Decision Brief v1.0 Standard", href: "/brief-standard", description: "Human-readable standard and adoption package." }, { label: "JSON schema", href: BRIEF_SCHEMA_PATH, description: "Machine-readable validation contract." }]} />
          <SourceLinks links={BRIEF_EXAMPLES} />
        </div>
      </div>
    </div>
  </section>
  </div>
</Layout>
