---
import Badge from "@components/Badge.astro";
import Layout from "@layouts/Layout.astro";
import PageHeroVisual from "@components/PageHeroVisual.astro";
import { SITE, SITE_MAP_GROUPS } from "@data/site";

const title = "Site Map - Manish Sharma Lab";
const description =
  "A complete linked map of Manish Sharma Lab: identity, evidence, industrial proof, frameworks, tools, lab notes, glossary pages, RFQ resources, and public files.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": `${SITE.canonicalUrl}/site-map#page`,
  url: `${SITE.canonicalUrl}/site-map`,
  name: title,
  description,
  hasPart: SITE_MAP_GROUPS.flatMap((group) =>
    group.links.map((link) => ({
      "@type": "WebPage",
      name: link.label,
      url: link.href.startsWith("http") ? link.href : `${SITE.canonicalUrl}${link.href}`
    }))
  )
};
---

<Layout title={title} description={description} canonical="/site-map" jsonLd={jsonLd}>
  <section class="site-shell grid gap-10 section-y lg:grid-cols-[minmax(0,1fr)_minmax(24rem,0.62fr)] lg:items-center">
    <div class="max-w-4xl">
      <Badge>Linked map</Badge>
      <p class="metric-label mt-8">Website Navigation</p>
      <h1 class="mt-4 text-5xl font-black leading-tight text-white md:text-6xl">Find every page by purpose.</h1>
      <p class="mt-6 text-lg leading-8 text-slate-300 md:text-xl">
        This map keeps the site easy to follow: profile, proof, frameworks, tools, notes, glossary definitions, RFQ resources, and public reference files.
      </p>
    </div>
    <PageHeroVisual variant="profile" class="hidden lg:block" />
  </section>

  <section class="band section-y">
    <div class="site-shell grid gap-5">
      {SITE_MAP_GROUPS.map((group) => (
        <section class="ordered-card-strong p-5 md:p-6" aria-labelledby={`${group.label.toLowerCase().replaceAll(" ", "-")}-heading`}>
          <div class="grid gap-6 lg:grid-cols-[0.35fr_0.65fr]">
            <div>
              <p class="metric-label">{group.label}</p>
              <h2 id={`${group.label.toLowerCase().replaceAll(" ", "-")}-heading`} class="mt-3 text-2xl font-black text-white">{group.label}</h2>
              <p class="mt-3 text-sm leading-6 text-slate-400">{group.description}</p>
            </div>
            <div class="grid gap-3 md:grid-cols-2">
              {group.links.map((link) => (
                <a
                  href={link.href}
                  class="ordered-card card-hover grid min-h-32 content-between p-4"
                  target={link.href.startsWith("http") ? "_blank" : undefined}
                  rel={link.href.startsWith("http") ? "noreferrer" : undefined}
                >
                  <span>
                    <span class="block text-sm font-black text-white">{link.label}</span>
                    <span class="mt-2 block text-xs leading-5 text-slate-400">{link.description}</span>
                  </span>
                  <span class="mt-4 font-mono text-xs font-bold text-cyan-200">{link.href}</span>
                </a>
              ))}
            </div>
          </div>
        </section>
      ))}
    </div>
  </section>
</Layout>
