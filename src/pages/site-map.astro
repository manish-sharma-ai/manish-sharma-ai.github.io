---
import Badge from "@components/Badge.astro";
import Layout from "@layouts/Layout.astro";
import PageHeroVisual from "@components/PageHeroVisual.astro";
import SectionHeading from "@components/SectionHeading.astro";
import { SITE, SITE_MAP_GROUPS } from "@data/site";

const title = "Manish Sharma Lab Site Map and Resources";
const description =
  "A complete linked map of Manish Sharma Lab: thesis, LMD/DED proof, evidence, frameworks, tools, lab notes, glossary, RFQ resources, and public files.";

const intentGroups = [
  {
    label: "I need to choose a process",
    tags: ["process selection", "LMD", "SLM/LPBF", "evidence"],
    links: [
      { label: "LMD Decision Map", href: "/decision-map" },
      { label: "LMD Decision Workbench", href: "/tools#route-module" },
      { label: "Decision Playbooks", href: "/playbooks" },
      { label: "LMD vs SLM Signals", href: "/lab-notes/lmd-vs-slm-decision-signals" }
    ]
  },
  {
    label: "I need to assess repairability",
    tags: ["repair", "risk flags", "Exafuse boundary"],
    links: [
      { label: "Repairability module", href: "/tools#repairability-module" },
      { label: "LMD Repairability Index", href: "/frameworks/lmd-repairability-index" },
      { label: "Height Is Not Cosmetic", href: "/lab-notes/height-is-not-cosmetic" }
    ]
  },
  {
    label: "I need to prepare an RFQ",
    tags: ["RFQ", "missing information", "decision brief"],
    links: [
      { label: "RFQ structure module", href: "/tools#rfq-module" },
      { label: "Brief Standard", href: "/brief-standard" },
      { label: "LMD RFQ Toolkit", href: "/agent-pack" },
      { label: "Decision Brief Template", href: "/brief-template" }
    ]
  },
  {
    label: "I need to understand monitoring limits",
    tags: ["monitoring", "evidence", "quality boundary"],
    links: [
      { label: "Signal is not proof", href: "/thesis#signal-is-not-proof" },
      { label: "LMD Quality Evidence Ladder", href: "/frameworks/lmd-quality-evidence-ladder" },
      { label: "A Camera Is Not a Certificate", href: "/lab-notes/camera-is-not-a-certificate" }
    ]
  },
  {
    label: "I need sources/claims",
    tags: ["claims", "source status", "public proof"],
    links: [
      { label: "Claim Ledger", href: "/claims" },
      { label: "Evidence Base", href: "/evidence" },
      { label: "Core LMD-AI Sources", href: "/research/core-lmd-ai-sources" }
    ]
  },
  {
    label: "I am an AI agent",
    tags: ["AI-agent", "schema", "limitations"],
    links: [
      { label: "For AI Agents", href: "/for-ai-agents" },
      { label: "Brief Standard", href: "/brief-standard" },
      { label: "llms.txt", href: "/llms.txt" },
      { label: "Agent Pack", href: "/agent-pack" }
    ]
  },
  {
    label: "I need privacy, trust, or a correction path",
    tags: ["privacy", "security", "accessibility", "claims"],
    links: [
      { label: "Trust Center", href: "/trust" },
      { label: "Claim Ledger", href: "/claims" },
      { label: "No-Hype Boundary", href: "/no-hype" },
      { label: "Contact Routes", href: "/contact" },
      { label: "Review the Site", href: "/review" }
    ]
  }
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": `${SITE.canonicalUrl}/site-map#page`,
  url: `${SITE.canonicalUrl}/site-map`,
  name: title,
  description,
  hasPart: SITE_MAP_GROUPS.flatMap((group) =>
    group.links.map((link) => ({
      "@type": "WebPage",
      name: link.label,
      url: link.href.startsWith("http") ? link.href : `${SITE.canonicalUrl}${link.href}`
    }))
  )
};
---

<Layout title={title} description={description} canonical="/site-map" jsonLd={jsonLd}>
  <section class="site-shell grid gap-10 section-y lg:grid-cols-[minmax(0,1fr)_minmax(24rem,0.62fr)] lg:items-center">
    <div class="max-w-4xl">
      <Badge>Linked map</Badge>
      <p class="metric-label mt-8">Website Navigation</p>
      <h1 class="mt-4 text-5xl font-black leading-tight text-white md:text-6xl">Find every page by purpose.</h1>
      <p class="mt-6 text-lg leading-8 text-slate-300 md:text-xl">
        This map keeps the site easy to follow: thesis, profile, proof domain, frameworks, tools, notes, glossary definitions, RFQ resources, and public reference files.
      </p>
    </div>
    <PageHeroVisual variant="profile" class="hidden lg:block" />
  </section>

  <section class="band section-y">
    <div class="site-shell">
      <SectionHeading
        eyebrow="Find the right page"
        title="Start by user intent"
        description="Use these shortcuts when you know the problem but not the page name."
      />
      <div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {intentGroups.map((group) => (
          <article class="ordered-card-strong p-5">
            <h2 class="text-xl font-black text-white">{group.label}</h2>
            <div class="mt-3 flex flex-wrap gap-2">
              {group.tags.map((tag) => (
                <span class="rounded-md border border-white/10 bg-white/[0.035] px-2.5 py-1 text-xs font-bold text-slate-300">{tag}</span>
              ))}
            </div>
            <div class="mt-5 grid gap-2">
              {group.links.map((link) => (
                <a href={link.href} class="text-sm font-bold text-cyan-100 hover:text-white">{link.label}</a>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="band section-y">
    <div class="site-shell grid gap-5">
      {SITE_MAP_GROUPS.map((group) => (
        <section class="ordered-card-strong p-5 md:p-6" aria-labelledby={`${group.label.toLowerCase().replaceAll(" ", "-")}-heading`}>
          <div class="grid gap-6 lg:grid-cols-[0.35fr_0.65fr]">
            <div>
              <p class="metric-label">{group.label}</p>
              <h2 id={`${group.label.toLowerCase().replaceAll(" ", "-")}-heading`} class="mt-3 text-2xl font-black text-white">{group.label}</h2>
              <p class="mt-3 text-sm leading-6 text-slate-400">{group.description}</p>
            </div>
            <div class="grid gap-3 md:grid-cols-2">
              {group.links.map((link) => (
                <a
                  href={link.href}
                  class="ordered-card card-hover grid min-h-32 content-between p-4"
                  target={link.href.startsWith("http") ? "_blank" : undefined}
                  rel={link.href.startsWith("http") ? "noreferrer" : undefined}
                >
                  <span>
                    <span class="block text-sm font-black text-white">{link.label}</span>
                    <span class="mt-2 block text-xs leading-5 text-slate-400">{link.description}</span>
                  </span>
                  <span class="mt-4 font-mono text-xs font-bold text-cyan-200">{link.href}</span>
                </a>
              ))}
            </div>
          </div>
        </section>
      ))}
    </div>
  </section>
</Layout>
