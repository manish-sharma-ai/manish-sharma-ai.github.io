---
interface Stage {
  label: string;
  title: string;
  text: string;
}

interface Props {
  stages?: Stage[];
  compact?: boolean;
}

const {
  stages = [
    {
      label: "01",
      title: "Sense",
      text: "Process signals, images, measurements, operator notes, and missing-information cues."
    },
    {
      label: "02",
      title: "Model",
      text: "AI, statistical models, engineering rules, uncertainty, and traceable assumptions."
    },
    {
      label: "03",
      title: "Decide",
      text: "Repairability, process route, inspection need, risk level, and next action."
    },
    {
      label: "04",
      title: "Verify",
      text: "Inspection, testing, documentation, measured outcomes, and acceptance criteria."
    }
  ],
  compact = false
} = Astro.props;
---

<div class:list={["evidence-rail ordered-card-strong relative overflow-hidden p-4 md:p-5", compact ? "is-compact" : ""]}>
  <div class="absolute inset-x-8 top-1/2 hidden h-px bg-gradient-to-r from-cyan-300/0 via-cyan-300/45 to-orange-300/0 md:block" aria-hidden="true"></div>
  <div class="relative grid gap-3 md:grid-cols-4">
    {stages.map((stage) => (
      <article class="ordered-card min-h-[10rem] p-4">
        <div class="flex items-center justify-between gap-3">
          <span class="metric-label">{stage.label}</span>
          <span class="h-2 w-2 rounded-full bg-cyan-200 shadow-[0_0_18px_rgba(51,214,255,0.75)]" aria-hidden="true"></span>
        </div>
        <h3 class="mt-4 text-2xl font-black text-white">{stage.title}</h3>
        <p class="mt-3 text-sm leading-6 text-slate-300">{stage.text}</p>
      </article>
    ))}
  </div>
</div>
