---
interface Stage {
  label: string;
  title: string;
  text: string;
}

interface Props {
  stages?: Stage[];
  compact?: boolean;
}

const {
  stages = [
    {
      label: "01",
      title: "Sense",
      text: "Process signals, images, measurements, operator notes, and missing-information cues."
    },
    {
      label: "02",
      title: "Model",
      text: "AI, statistical models, engineering rules, uncertainty, and traceable assumptions."
    },
    {
      label: "03",
      title: "Decide",
      text: "Repairability, process route, inspection need, risk level, and next action."
    },
    {
      label: "04",
      title: "Verify",
      text: "Inspection, testing, documentation, measured outcomes, and acceptance criteria."
    }
  ],
  compact = false
} = Astro.props;
---

<section class:list={["evidence-rail", compact ? "is-compact" : ""]} data-visual-type="illustrative-workflow" aria-label="Evidence workflow">
  <header class="evidence-rail__header">
    <p class="evidence-rail__eyebrow">Illustrative workflow</p>
    <p class="evidence-rail__summary">Read left to right: collect a signal, structure its risk, choose evidence, then verify the claim.</p>
  </header>
  <ol class="evidence-rail__stages" aria-label="Evidence workflow stages">
    {stages.map((stage) => (
      <li class:list={["evidence-rail__stage", stage.title === "Verify" ? "is-verify" : ""]}>
        <div class="evidence-rail__stage-head">
          <span class="evidence-rail__index">{stage.label}</span>
          <span class="evidence-rail__signal" aria-hidden="true"></span>
        </div>
        <h3 class="evidence-rail__stage-title">{stage.title}</h3>
        <p class="evidence-rail__stage-text">{stage.text}</p>
      </li>
    ))}
  </ol>
</section>
