---
const stages = [
  ["Person", "Manish Sharma", "Public technical author and practitioner."],
  ["Focus", "Industrial AI", "Decision systems, monitoring, and evidence-aware workflows."],
  ["Technical domain", "LMD / DED", "Repair, cladding, process monitoring, and RFQ structure."],
  ["Company context", "Exafuse", "Public LMD/DED context; commercial review remains with Exafuse."]
];
---

<figure class="identity-model diagram-frame" data-visual-type="navigation-model">
  <figcaption class="diagram-frame__header">
    <p class="metric-label">Public profile model</p>
    <h2 class="mt-2 text-xl font-black leading-tight text-white">How the public technical profile is organized</h2>
    <p class="mt-2 text-sm leading-6 text-slate-300">Read left to right: person, focus, technical domain, then public company context.</p>
  </figcaption>
  <ol class="identity-model__steps">
    {stages.map(([label, title, text], index) => (
      <li>
        <span class="identity-model__index">{String(index + 1).padStart(2, "0")}</span>
        <span>
          <span class="metric-label block">{label}</span>
          <strong>{title}</strong>
          <small>{text}</small>
        </span>
      </li>
    ))}
  </ol>
</figure>
