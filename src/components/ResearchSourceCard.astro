---
import { internalHref } from "@utils/urls";

interface Props {
  index: number;
  title: string;
  publisher: string;
  sourceType: string;
  href: string;
  usefulFor: string;
  doesNotProve: string;
}

const { index, title, publisher, sourceType, href, usefulFor, doesNotProve } = Astro.props;
---

<article class="research-source-card">
  <div class="research-source-card__metadata">
    <p>{String(index + 1).padStart(2, "0")} · {sourceType}</p>
    <p>{publisher}</p>
  </div>
  <h3>{title}</h3>
  <dl>
    <div class="research-source-card__use">
      <dt>Useful for</dt>
      <dd>{usefulFor}</dd>
    </div>
    <div class="research-source-card__boundary">
      <dt>Does not prove</dt>
      <dd>{doesNotProve}</dd>
    </div>
  </dl>
  <a href={internalHref(href)} class="research-source-card__action">
    Open verified source <span aria-hidden="true">↗</span>
  </a>
</article>
