---
interface LinkItem {
  label: string;
  href: string;
}

interface Props {
  links: LinkItem[];
}

const { links } = Astro.props;
---

<div class="equal-card-grid grid gap-3 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
  {
    links.map((link) => (
      <a
        href={link.href}
        class="ordered-card card-hover flex min-h-16 items-center justify-between gap-4 p-4 text-sm font-bold text-slate-200"
        target={link.href.startsWith("http") ? "_blank" : undefined}
        rel={link.href.startsWith("http") ? "noreferrer" : undefined}
      >
        <span>{link.label}</span>
        <span class="font-mono text-cyan-200/80">&rarr;</span>
      </a>
    ))
  }
</div>
