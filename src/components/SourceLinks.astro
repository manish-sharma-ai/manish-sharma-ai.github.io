---
import LinkCard from "@components/LinkCard.astro";

interface LinkItem {
  label: string;
  href?: string | null;
  status?: string;
  description?: string;
}

interface Props {
  links: LinkItem[];
}

const { links } = Astro.props;
---

<div class="equal-card-grid grid gap-3 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
  {links.map((link) => <LinkCard {...link} />)}
</div>
