---
interface LinkItem {
  label: string;
  href: string;
}

interface Props {
  links: LinkItem[];
}

const { links } = Astro.props;
---

<div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
  {
    links.map((link) => (
      <a
        href={link.href}
        class="rounded-lg border border-white/10 bg-white/[0.035] p-4 text-sm font-bold text-slate-200 transition hover:border-cyan-300/35 hover:text-white"
        target={link.href.startsWith("http") ? "_blank" : undefined}
        rel={link.href.startsWith("http") ? "noreferrer" : undefined}
      >
        {link.label}
      </a>
    ))
  }
</div>
