---
import { METHOD_LOOP } from "@data/site";

interface Props {
  variant?: "full" | "compact" | "micro";
  title?: string;
  subtitle?: string;
}

const {
  variant = "compact",
  title = "Sense -> Model -> Decide -> Verify",
  subtitle = "Signals, assumptions, bounded decisions, and verification evidence."
} = Astro.props;

const isFull = variant === "full";
const isMicro = variant === "micro";
const stageText = isMicro
  ? METHOD_LOOP.map((stage) => ({ ...stage, text: stage.text.split(".")[0] + "." }))
  : METHOD_LOOP;
---

<section class:list={["process-loop ordered-card-strong", `process-loop--${variant}`, isMicro ? "p-4" : "p-6 md:p-7"]} aria-labelledby={`process-loop-${variant}`}>
  <div class:list={["grid gap-4", isFull ? "lg:grid-cols-[0.82fr_1.18fr] lg:items-start" : ""]}>
    <div>
      <p class="metric-label">Operating loop</p>
      <h2 id={`process-loop-${variant}`} class:list={["mt-3 font-black leading-tight text-white", isMicro ? "text-xl" : "text-3xl md:text-4xl"]}>
        {title}
      </h2>
      {!isMicro && <p class="mt-3 max-w-3xl text-sm leading-6 text-slate-300">{subtitle}</p>}
    </div>
    {isFull && (
      <p class="rounded-lg border border-amber-300/25 bg-amber-400/10 p-4 text-sm font-bold leading-6 text-amber-50">
        Confidence is not approval. The loop is useful only when process signals, model assumptions, decisions, and verification evidence stay separate.
      </p>
    )}
  </div>

  <div class:list={["mt-5 grid gap-3", isMicro ? "grid-cols-2 md:grid-cols-4" : "md:grid-cols-4"]}>
    {stageText.map((stage, index) => (
      <article class:list={["ordered-card", isMicro ? "p-3" : "min-h-[9rem] p-4"]}>
        <div class="flex items-center justify-between gap-3">
          <span class="metric-label">{String(index + 1).padStart(2, "0")}</span>
          <span class:list={["h-2 w-2 rounded-full", index === 3 ? "bg-orange-300" : "bg-cyan-200"]} aria-hidden="true"></span>
        </div>
        <h3 class:list={["mt-3 font-black text-white", isMicro ? "text-base" : "text-2xl"]}>{stage.label}</h3>
        {!isMicro && <p class="mt-3 text-sm leading-6 text-slate-300">{stage.text}</p>}
      </article>
    ))}
  </div>

  {isFull && (
    <div class="mt-5 rounded-lg border border-white/10 bg-black/24 p-4 text-sm leading-6 text-slate-300">
      Use Sense for observed inputs, Model for assumptions and uncertainty, Decide for bounded recommendations, and Verify for inspection, testing, documentation, measured outcomes, and expert review.
    </div>
  )}
</section>
