---
import { LINKS, NAV_GROUPS } from "@data/site";

const normalize = (value: string) => (value === "/" ? "/" : value.replace(/\/$/, ""));
const currentPath = normalize(Astro.url.pathname);
const isActive = (href: string) => {
  const normalizedHref = normalize(href);
  return currentPath === normalizedHref || (normalizedHref !== "/" && currentPath.startsWith(`${normalizedHref}/`));
};
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-graphite-950/86 shadow-[0_1px_0_rgba(255,255,255,0.04)] backdrop-blur-xl" data-site-header>
  <div class="site-shell grid min-h-[4.5rem] grid-cols-[auto_1fr_auto] items-center gap-5">
    <a href="/" class="group flex min-w-0 items-center gap-3 rounded-lg sm:min-w-[13.25rem]" aria-label="Manish Sharma Lab home">
      <span class="grid h-11 w-11 shrink-0 place-items-center rounded-xl border border-white/10 bg-white/[0.035] shadow-glow transition group-hover:border-cyan-300/35 group-hover:bg-cyan-300/8 group-focus-visible:border-cyan-300/50">
        <img src="/brand/manish-sharma-lab-mark.svg" alt="" class="h-9 w-9" width="36" height="36" decoding="async" />
      </span>
      <span class="leading-tight">
        <span class="block text-sm font-black text-white">Manish Sharma Lab</span>
        <span class="metric-label hidden whitespace-nowrap text-[0.62rem] sm:block">AI for LMD / DED</span>
      </span>
    </a>

    <nav class="hidden items-center justify-center gap-1 xl:flex" aria-label="Primary navigation">
      {NAV_GROUPS.map((group) => {
        const groupActive = group.items.some((item) => isActive(item.href));
        return (
          <details class="nav-flyout group relative" data-nav-flyout>
            <summary class:list={["nav-trigger list-none", groupActive ? "is-active" : ""]}>
              {group.label}
              <span class="nav-caret" aria-hidden="true"></span>
            </summary>
            <div class="nav-panel absolute left-1/2 top-full mt-3 w-[min(31rem,calc(100vw-2rem))] -translate-x-1/2 rounded-lg border border-cyan-100/14 bg-[#070b10] p-3 shadow-panel">
              <p class="px-3 py-2 text-xs font-semibold leading-5 text-slate-400">{group.description}</p>
              <div class="grid gap-1">
                {group.items.map((item) => (
                  <a
                    href={item.href}
                    class:list={["nav-menu-link", isActive(item.href) ? "is-active" : ""]}
                  >
                    <span class="text-sm font-black text-white">{item.label}</span>
                    <span class="text-xs leading-5 text-slate-400">{item.description}</span>
                  </a>
                ))}
              </div>
            </div>
          </details>
        );
      })}
    </nav>

    <div class="hidden items-center justify-end gap-2 xl:flex">
      <button
        type="button"
        data-command-trigger
        class="utility-button gap-2 px-3 py-2"
        aria-label="Search all pages"
      >
        Search <span class="keycap">Ctrl K</span>
      </button>
      <a href={LINKS.exafuse} class="btn btn-laser min-h-10 px-3 py-2 text-sm" target="_blank" rel="noreferrer">
        Exafuse
      </a>
    </div>

    <details class="group relative justify-self-end xl:hidden" data-mobile-menu>
      <summary class="utility-button list-none px-3 py-2 text-white">
        Menu
      </summary>
      <div class="nav-panel absolute right-0 mt-3 max-h-[78vh] w-[min(92vw,24rem)] overflow-auto rounded-lg border border-cyan-100/14 bg-[#070b10] p-3 shadow-panel">
        <nav class="grid gap-4" aria-label="Mobile navigation">
          {NAV_GROUPS.map((group) => (
            <div class="rounded-lg border border-white/10 bg-white/[0.025] p-2">
              <p class="metric-label px-2 py-2">{group.label}</p>
              <div class="grid gap-1">
                {group.items.map((item) => (
                  <a
                    href={item.href}
                    class:list={["nav-menu-link py-2 text-sm", isActive(item.href) ? "is-active" : ""]}
                  >
                    {item.label}
                  </a>
                ))}
              </div>
            </div>
          ))}
          <button
            type="button"
            data-command-trigger
            class="utility-button justify-start px-3 py-3 text-left text-sm text-white"
          >
            Search all pages
          </button>
          <a href={LINKS.exafuse} class="rounded-md border border-orange-300/35 bg-orange-500/10 px-3 py-3 text-sm font-bold text-orange-100 transition hover:border-orange-200/60 hover:bg-orange-400/15 hover:text-white" target="_blank" rel="noreferrer">
            Visit Exafuse
          </a>
        </nav>
      </div>
    </details>
  </div>
</header>

<script is:inline>
  const navFlyouts = Array.from(document.querySelectorAll("[data-nav-flyout]"));
  const mobileMenu = document.querySelector("[data-mobile-menu]");

  const setSummaryExpanded = (flyout) => {
    const summary = flyout.querySelector("summary");
    summary?.setAttribute("aria-expanded", String(flyout.open));
  };

  const setMobileExpanded = () => {
    const summary = mobileMenu?.querySelector("summary");
    summary?.setAttribute("aria-expanded", String(mobileMenu.open));
  };

  const closeMobileMenu = () => {
    if (!mobileMenu) return;

    mobileMenu.open = false;
    setMobileExpanded();
  };

  const closeNavFlyouts = (except = null) => {
    navFlyouts.forEach((flyout) => {
      if (flyout !== except) {
        flyout.open = false;
        setSummaryExpanded(flyout);
      }
    });
  };

  navFlyouts.forEach((flyout) => {
    setSummaryExpanded(flyout);

    flyout.addEventListener("toggle", () => {
      setSummaryExpanded(flyout);
      if (!flyout.open) return;

      closeNavFlyouts(flyout);
    });
  });

  setMobileExpanded();
  mobileMenu?.addEventListener("toggle", setMobileExpanded);

  document.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof Element)) return;

    if (!target.closest("[data-site-header]")) {
      closeNavFlyouts();
      closeMobileMenu();
    }
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      closeNavFlyouts();
      closeMobileMenu();
    }
  });

  document.addEventListener("site-command-open", () => {
    closeNavFlyouts();
    closeMobileMenu();
  });
</script>
