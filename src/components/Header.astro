---
import BrandMark from "@components/BrandMark.astro";
import MobileMenu from "@components/MobileMenu.astro";
import { LINKS, PRIMARY_NAV_ITEMS, RESOURCE_NAV_ITEMS } from "@data/site";

const normalize = (value: string) => (value === "/" ? "/" : value.replace(/\/$/, ""));
const currentPath = normalize(Astro.url.pathname);
const isActive = (href: string) => {
  const normalizedHref = normalize(href);
  return currentPath === normalizedHref || (normalizedHref !== "/" && currentPath.startsWith(`${normalizedHref}/`));
};

const resourcesActive = RESOURCE_NAV_ITEMS.some((item) => isActive(item.href));
---

<header class="site-header" data-site-header>
  <div class="site-shell site-header__inner">
    <a href="/" class="brand-lockup rounded-2xl" aria-label="Manish Sharma Lab home">
      <BrandMark uid="header-brand-mark" />
      <span class="min-w-0 leading-tight">
        <span class="block truncate text-sm font-black text-white">Manish Sharma Lab</span>
        <span class="metric-label hidden truncate sm:block">Industrial AI / decisions</span>
      </span>
    </a>

    <nav class="primary-nav" aria-label="Primary navigation">
      {PRIMARY_NAV_ITEMS.map((item) => (
        <a href={item.href} class:list={["nav-trigger", isActive(item.href) ? "is-active" : ""]} aria-current={isActive(item.href) ? "page" : undefined}>
          {item.label}
        </a>
      ))}
      <details class="relative" data-nav-flyout>
        <summary class:list={["nav-trigger list-none", resourcesActive ? "is-active" : ""]} aria-expanded="false">
          Resources
        </summary>
        <div class="nav-panel absolute left-1/2 top-full mt-3 w-[min(92vw,34rem)] -translate-x-1/2 rounded-[24px] border border-cyan-100/14 p-4">
          <div class="grid gap-2 sm:grid-cols-2" aria-label="Secondary navigation">
            {RESOURCE_NAV_ITEMS.map((item) => (
              <a href={item.href} class:list={["nav-menu-link", isActive(item.href) ? "is-active" : ""]} aria-current={isActive(item.href) ? "page" : undefined}>
                <span class="text-sm font-black">{item.label}</span>
                <span class="text-xs leading-5 text-slate-400">{item.description}</span>
              </a>
            ))}
          </div>
        </div>
      </details>
    </nav>

    <div class="site-actions">
      <button type="button" data-command-trigger class="utility-button gap-2 px-4 py-2" aria-label="Search Ctrl K - search all pages">
        Search <span class="keycap">Ctrl K</span>
      </button>
      <a href={LINKS.exafuse} class="btn btn-laser min-h-10 px-4 py-2 text-sm" target="_blank" rel="noreferrer">
        Exafuse
      </a>
      <a href="/contact" class="utility-button px-4 py-2">Contact</a>
    </div>

    <MobileMenu />
  </div>
</header>

<script is:inline>
  const navFlyouts = Array.from(document.querySelectorAll("[data-nav-flyout]"));
  const mobileMenu = document.querySelector("[data-mobile-menu]");

  const setSummaryExpanded = (flyout) => {
    const summary = flyout.querySelector("summary");
    summary?.setAttribute("aria-expanded", String(flyout.open));
  };

  const setMobileExpanded = () => {
    const summary = mobileMenu?.querySelector("summary");
    summary?.setAttribute("aria-expanded", String(Boolean(mobileMenu?.open)));
  };

  const closeMobileMenu = () => {
    if (!mobileMenu) return;
    mobileMenu.open = false;
    setMobileExpanded();
  };

  const closeNavFlyouts = (except = null) => {
    navFlyouts.forEach((flyout) => {
      if (flyout !== except) {
        flyout.open = false;
        setSummaryExpanded(flyout);
      }
    });
  };

  navFlyouts.forEach((flyout) => {
    setSummaryExpanded(flyout);
    flyout.addEventListener("toggle", () => {
      setSummaryExpanded(flyout);
      if (flyout.open) closeNavFlyouts(flyout);
    });
  });

  setMobileExpanded();
  mobileMenu?.addEventListener("toggle", setMobileExpanded);

  document.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof Element)) return;
    if (!target.closest("[data-site-header]")) {
      closeNavFlyouts();
      closeMobileMenu();
    }
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      closeNavFlyouts();
      closeMobileMenu();
    }
  });

  document.addEventListener("site-command-open", () => {
    closeNavFlyouts();
    closeMobileMenu();
  });
</script>
