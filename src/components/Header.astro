---
import MobileMenu from "@components/MobileMenu.astro";
import BrandMark from "@components/BrandMark.astro";
import { LINKS, PRIMARY_NAV_ITEMS, RESOURCE_NAV_ITEMS } from "@data/site";
import { RESOURCE_NAV_GROUPS } from "@data/resourceNavigation";

interface Props {
  lang?: "en" | "de";
}

const { lang = "en" } = Astro.props;
const normalize = (value: string) => (value === "/" ? "/" : value.replace(/\/$/, ""));
const currentPath = normalize(Astro.url.pathname);
const isActive = (href: string) => {
  const normalizedHref = normalize(href);
  return currentPath === normalizedHref || (normalizedHref !== "/" && currentPath.startsWith(`${normalizedHref}/`));
};

const workSectionPaths = [
  "/public-work",
  "/domains/lmd-ded",
  "/tools",
  "/frameworks",
  "/decision-map",
  "/agent-pack",
  "/brief-standard",
  "/brief-template",
  "/demo",
  "/playbooks"
];
const workSectionActive = workSectionPaths.some((href) => isActive(href));
const primaryActive = PRIMARY_NAV_ITEMS.some((item) => isActive(item.href)) || workSectionActive;
const resourcesActive = !primaryActive && RESOURCE_NAV_ITEMS.some((item) => isActive(item.href));

const primaryLabelsDe: Record<string, string> = {
  "/": "Startseite",
  "/public-work": "Arbeit",
  "/thesis": "Methode",
  "/lab-notes": "Notizen",
  "/about": "Über mich"
};

const resourceCopyDe: Record<string, { label: string; description: string }> = {
  "/domains/lmd-ded": { label: "LMD / DED Arbeit", description: "Aktuelles Anwendungsfeld für industrielle KI-Entscheidungssysteme" },
  "/tools": { label: "Entscheidungswerkzeuge", description: "Cockpit, Prozessvergleich, Reparatur und RFQ-Werkzeuge" },
  "/public-work": { label: "Öffentliche Arbeit", description: "Ausgewählte Arbeit, öffentliche Nachweise und Grenzen" },
  "/frameworks": { label: "Frameworks", description: "Qualität, Reparatur, Datenreife und Monitoring" },
  "/resources": { label: "Alle Ressourcen", description: "Vollständige Übersicht der öffentlichen technischen Ebene" },
  "/decision-map": { label: "Entscheidungskarte", description: "Routen für Reparatur, Cladding, AM und LPBF" },
  "/agent-pack": { label: "RFQ-Werkzeugkasten", description: "Schemas, Prompts, Regeln und Checklisten" },
  "/brief-standard": { label: "Kurzbrief-Standard", description: "LMD Decision Brief v1.0 mit Schema und Beispielen" },
  "/evidence": { label: "Quellen", description: "Öffentliche Quellen und technische Einordnung" },
  "/lab-notes": { label: "Fachnotizen", description: "Kurze technische Notizen zu LMD/DED" },
  "/glossary": { label: "Glossar", description: "Begriffe für LMD, DED, Cladding und Monitoring" },
  "/for-ai-agents": { label: "Für KI-Systeme", description: "Nutzungshinweise und klare Grenzen" },
  "/trust": { label: "Vertrauen", description: "Datenschutz, Sicherheit, Barrierefreiheit und Grenzen" },
  "/review": { label: "Feedback geben", description: "Kurzes Feedback direkt im Browser erstellen; die Eingaben bleiben auf diesem Gerät." },
  "/identity": { label: "Profil", description: "Offizielle öffentliche Identitätsseite" },
  "/press-kit": { label: "Pressekit", description: "Bios, Links und freigegebene Beschreibungen" },
  "/site-map": { label: "Sitemap", description: "Alle Seiten und öffentlichen Dateien" }
};

const navItems =
  lang === "de"
    ? PRIMARY_NAV_ITEMS.map((item) => ({ ...item, label: primaryLabelsDe[item.href] ?? item.label }))
    : PRIMARY_NAV_ITEMS;

const resourceItems =
  lang === "de"
    ? RESOURCE_NAV_ITEMS.map((item) => ({ ...item, ...(resourceCopyDe[item.href] ?? {}) }))
    : RESOURCE_NAV_ITEMS;

const resourceGroups = RESOURCE_NAV_GROUPS.map((group) => ({
  ...group,
  label: lang === "de" ? group.labelDe : group.label,
  items: group.items.map((item) => resourceItems.find((candidate) => candidate.href === item.href) ?? item)
}));

const copy =
  lang === "de"
    ? {
        homeLabel: "Zur Startseite von Manish Sharma",
        subtitle: "Lab / Industrielle KI & Entscheidungen",
        primaryNav: "Hauptnavigation",
        resources: "Referenz",
        secondaryNav: "Weitere Navigation",
        search: "Suche",
        searchAria: "Suche öffnen, Strg K",
        contact: "Kontakt",
        allResources: "Alle Ressourcen"
      }
    : {
        homeLabel: "Manish Sharma home",
        subtitle: "Lab / Industrial AI & decisions",
        primaryNav: "Primary navigation",
        resources: "Reference",
        secondaryNav: "Secondary navigation",
        search: "Search",
        searchAria: "Search Ctrl K - search all pages",
        contact: "Contact",
        allResources: "All resources"
      };
---

<header class="site-header" data-site-header>
  <div class="site-shell site-header__inner">
    <a href="/" class="brand-lockup" aria-label={copy.homeLabel}>
      <BrandMark uid="header-brand-mark" />
      <span class="site-header__brand-copy">
        <span class="site-header__brand">Manish Sharma</span>
        <span class="site-header__descriptor">{copy.subtitle}</span>
      </span>
    </a>

    <nav class="primary-nav" aria-label={copy.primaryNav}>
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            "nav-trigger",
            isActive(item.href) ? "is-active" : "",
            item.href === "/public-work" && workSectionActive && !isActive(item.href) ? "is-section-active" : ""
          ]}
          aria-current={isActive(item.href) ? "page" : undefined}
        >
          {item.label}
        </a>
      ))}
      <details class="site-header__resources" data-nav-flyout>
        <summary class:list={["nav-trigger list-none", resourcesActive ? "is-active" : ""]} aria-expanded="false">
          <span>{copy.resources}</span>
          <span class="nav-trigger__chevron" aria-hidden="true">⌄</span>
        </summary>
        <div class="nav-panel nav-dropdown">
          <div class="nav-dropdown__groups" aria-label={copy.secondaryNav}>
            {resourceGroups.map((group) => (
              <section class="nav-dropdown__group">
                <p class="metric-label">{group.label}</p>
                <div class="nav-dropdown__links">
                  {group.items.map((item) => (
                    <a href={item.href} class:list={["nav-menu-link", isActive(item.href) ? "is-active" : ""]} aria-current={isActive(item.href) ? "page" : undefined}>
                      <span class="text-sm font-black">{item.label}</span>
                      <span class="text-xs leading-5 text-slate-400">{item.description}</span>
                    </a>
                  ))}
                </div>
              </section>
            ))}
          </div>
          <div class="nav-panel__actions">
            <a href="/resources" class="utility-button">{copy.allResources}</a>
            <a href={LINKS.exafuse} class="btn btn-laser min-h-10 px-4 py-2 text-sm" target="_blank" rel="noreferrer">
              Exafuse
            </a>
          </div>
        </div>
      </details>
    </nav>

    <nav class="site-actions" aria-label={copy.secondaryNav}>
      <button type="button" data-command-trigger class="utility-button site-actions__search" aria-label={copy.searchAria}>
        {copy.search}
      </button>
      <a href="/contact" class="site-actions__contact">{copy.contact}</a>
    </nav>

    <MobileMenu lang={lang} />
  </div>
</header>

<script is:inline>
  const navFlyouts = Array.from(document.querySelectorAll("[data-nav-flyout]"));
  const mobileMenu = document.querySelector("[data-mobile-menu]");

  const setSummaryExpanded = (flyout) => {
    const summary = flyout.querySelector("summary");
    summary?.setAttribute("aria-expanded", String(flyout.open));
  };

  const setMobileExpanded = () => {
    const summary = mobileMenu?.querySelector("summary");
    summary?.setAttribute("aria-expanded", String(Boolean(mobileMenu?.open)));
  };

  const closeMobileMenu = () => {
    if (!mobileMenu) return;
    mobileMenu.open = false;
    setMobileExpanded();
  };

  const closeNavFlyouts = (except = null) => {
    navFlyouts.forEach((flyout) => {
      if (flyout !== except) {
        flyout.open = false;
        setSummaryExpanded(flyout);
      }
    });
  };

  navFlyouts.forEach((flyout) => {
    setSummaryExpanded(flyout);
    flyout.addEventListener("toggle", () => {
      setSummaryExpanded(flyout);
      if (flyout.open) closeNavFlyouts(flyout);
    });
  });

  setMobileExpanded();
  mobileMenu?.addEventListener("toggle", setMobileExpanded);

  document.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof Element)) return;
    if (!target.closest("[data-site-header]")) {
      closeNavFlyouts();
      closeMobileMenu();
    }
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      closeNavFlyouts();
      closeMobileMenu();
    }
  });

  document.addEventListener("site-command-open", () => {
    closeNavFlyouts();
    closeMobileMenu();
  });
</script>
