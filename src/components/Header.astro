---
import BrandMark from "@components/BrandMark.astro";
import MobileMenu from "@components/MobileMenu.astro";
import { LINKS, PRIMARY_NAV_ITEMS, RESOURCE_NAV_ITEMS } from "@data/site";

interface Props {
  lang?: "en" | "de";
}

const { lang = "en" } = Astro.props;
const normalize = (value: string) => (value === "/" ? "/" : value.replace(/\/$/, ""));
const currentPath = normalize(Astro.url.pathname);
const isActive = (href: string) => {
  const normalizedHref = normalize(href);
  return currentPath === normalizedHref || (normalizedHref !== "/" && currentPath.startsWith(`${normalizedHref}/`));
};

const resourcesActive = RESOURCE_NAV_ITEMS.some((item) => isActive(item.href));

const primaryLabelsDe: Record<string, string> = {
  "/": "Startseite",
  "/thesis": "These",
  "/domains/lmd-ded": "LMD / DED",
  "/tools": "Werkzeuge",
  "/public-work": "Nachweise",
  "/about": "Über mich"
};

const resourceCopyDe: Record<string, { label: string; description: string }> = {
  "/frameworks": { label: "Frameworks", description: "Qualität, Reparatur, Datenreife und Monitoring" },
  "/decision-map": { label: "Entscheidungskarte", description: "Routen für Reparatur, Cladding, AM und LPBF" },
  "/agent-pack": { label: "RFQ-Werkzeugkasten", description: "Schemas, Prompts, Regeln und Checklisten" },
  "/brief-standard": { label: "Kurzbrief-Standard", description: "LMD Decision Brief v1.0 mit Schema und Beispielen" },
  "/evidence": { label: "Quellen", description: "Öffentliche Quellen und technische Einordnung" },
  "/lab-notes": { label: "Fachnotizen", description: "Kurze technische Notizen zu LMD/DED" },
  "/glossary": { label: "Glossar", description: "Begriffe für LMD, DED, Cladding und Monitoring" },
  "/for-ai-agents": { label: "Für KI-Systeme", description: "Nutzungshinweise und klare Grenzen" },
  "/trust": { label: "Vertrauen", description: "Datenschutz, Sicherheit, Barrierefreiheit und Grenzen" },
  "/review": { label: "Website prüfen", description: "Kurzer Browser-lokaler Review ohne Datenerfassung" },
  "/identity": { label: "Profil", description: "Offizielle öffentliche Identitätsseite" },
  "/press-kit": { label: "Pressekit", description: "Bios, Links und freigegebene Beschreibungen" },
  "/site-map": { label: "Sitemap", description: "Alle Seiten und öffentlichen Dateien" }
};

const navItems =
  lang === "de"
    ? PRIMARY_NAV_ITEMS.map((item) => ({ ...item, label: primaryLabelsDe[item.href] ?? item.label }))
    : PRIMARY_NAV_ITEMS;

const resourceItems =
  lang === "de"
    ? RESOURCE_NAV_ITEMS.map((item) => ({ ...item, ...(resourceCopyDe[item.href] ?? {}) }))
    : RESOURCE_NAV_ITEMS;

const copy =
  lang === "de"
    ? {
        homeLabel: "Zur Startseite von Manish Sharma Lab",
        subtitle: "Industrielle KI / Entscheidungen",
        primaryNav: "Hauptnavigation",
        resources: "Ressourcen",
        secondaryNav: "Weitere Navigation",
        search: "Suche",
        searchAria: "Suche öffnen, Strg K",
        contact: "Kontakt"
      }
    : {
        homeLabel: "Manish Sharma Lab home",
        subtitle: "Industrial AI / decisions",
        primaryNav: "Primary navigation",
        resources: "Resources",
        secondaryNav: "Secondary navigation",
        search: "Search",
        searchAria: "Search Ctrl K - search all pages",
        contact: "Contact"
      };
---

<header class="site-header" data-site-header>
  <div class="site-shell site-header__inner">
    <a href="/" class="brand-lockup rounded-2xl" aria-label={copy.homeLabel}>
      <BrandMark uid="header-brand-mark" />
      <span class="min-w-0 leading-tight">
        <span class="block truncate text-sm font-black text-white">Manish Sharma Lab</span>
        <span class="metric-label hidden truncate sm:block">{copy.subtitle}</span>
      </span>
    </a>

    <nav class="primary-nav" aria-label={copy.primaryNav}>
      {navItems.map((item) => (
        <a href={item.href} class:list={["nav-trigger", isActive(item.href) ? "is-active" : ""]} aria-current={isActive(item.href) ? "page" : undefined}>
          {item.label}
        </a>
      ))}
      <details class="relative" data-nav-flyout>
        <summary class:list={["nav-trigger list-none", resourcesActive ? "is-active" : ""]} aria-expanded="false">
          {copy.resources}
        </summary>
        <div class="nav-panel absolute left-1/2 top-full mt-3 w-[min(92vw,34rem)] -translate-x-1/2 rounded-[24px] border border-cyan-100/14 p-4">
          <div class="grid gap-2 sm:grid-cols-2" aria-label={copy.secondaryNav}>
            {resourceItems.map((item) => (
              <a href={item.href} class:list={["nav-menu-link", isActive(item.href) ? "is-active" : ""]} aria-current={isActive(item.href) ? "page" : undefined}>
                <span class="text-sm font-black">{item.label}</span>
                <span class="text-xs leading-5 text-slate-400">{item.description}</span>
              </a>
            ))}
          </div>
        </div>
      </details>
    </nav>

    <div class="site-actions">
      <button type="button" data-command-trigger class="utility-button gap-2 px-4 py-2" aria-label={copy.searchAria}>
        {copy.search} <span class="keycap">Ctrl K</span>
      </button>
      <a href={LINKS.exafuse} class="btn btn-laser min-h-10 px-4 py-2 text-sm" target="_blank" rel="noreferrer">
        Exafuse
      </a>
      <a href="/contact" class="utility-button px-4 py-2">{copy.contact}</a>
    </div>

    <MobileMenu lang={lang} />
  </div>
</header>

<script is:inline>
  const navFlyouts = Array.from(document.querySelectorAll("[data-nav-flyout]"));
  const mobileMenu = document.querySelector("[data-mobile-menu]");

  const setSummaryExpanded = (flyout) => {
    const summary = flyout.querySelector("summary");
    summary?.setAttribute("aria-expanded", String(flyout.open));
  };

  const setMobileExpanded = () => {
    const summary = mobileMenu?.querySelector("summary");
    summary?.setAttribute("aria-expanded", String(Boolean(mobileMenu?.open)));
  };

  const closeMobileMenu = () => {
    if (!mobileMenu) return;
    mobileMenu.open = false;
    setMobileExpanded();
  };

  const closeNavFlyouts = (except = null) => {
    navFlyouts.forEach((flyout) => {
      if (flyout !== except) {
        flyout.open = false;
        setSummaryExpanded(flyout);
      }
    });
  };

  navFlyouts.forEach((flyout) => {
    setSummaryExpanded(flyout);
    flyout.addEventListener("toggle", () => {
      setSummaryExpanded(flyout);
      if (flyout.open) closeNavFlyouts(flyout);
    });
  });

  setMobileExpanded();
  mobileMenu?.addEventListener("toggle", setMobileExpanded);

  document.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof Element)) return;
    if (!target.closest("[data-site-header]")) {
      closeNavFlyouts();
      closeMobileMenu();
    }
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      closeNavFlyouts();
      closeMobileMenu();
    }
  });

  document.addEventListener("site-command-open", () => {
    closeNavFlyouts();
    closeMobileMenu();
  });
</script>
