---
import { internalHref } from "@utils/urls";

interface Props {
  lastUpdated: string;
  lang?: "en" | "de";
}

const { lastUpdated, lang = "en" } = Astro.props;
const formattedDate = new Intl.DateTimeFormat(lang === "de" ? "de-DE" : "en-GB", {
  day: "numeric",
  month: "long",
  year: "numeric",
  timeZone: "UTC"
}).format(new Date(`${lastUpdated}T00:00:00Z`));

const copy = lang === "de"
  ? {
      label: "Seiteninformationen",
      date: "In diesem Website-Release geprüft",
      owner: "Verantwortlich",
      status: "Status",
      statusValue: "Öffentliche technische Ressource",
      ownerValue: "Manish Sharma Lab",
      boundary: "Entscheidungsunterst\u00fctzung, keine technische Freigabe.",
      correction: "Eine Korrektur, Quellenfrage oder Zugangsbarriere melden"
    }
  : {
      label: "Page information",
      date: "Reviewed in this site release",
      owner: "Owner",
      status: "Status",
      statusValue: "Public technical resource",
      ownerValue: "Manish Sharma Lab",
      boundary: "Decision support, not engineering approval.",
      correction: "Report a correction, source question, or access barrier"
    };
---

<aside class="site-shell page-provenance" aria-label={copy.label}>
  <details class="page-provenance__details">
    <summary class="page-provenance__summary">
      <span>{copy.label}</span>
      <span class="page-provenance__date">{formattedDate}</span>
    </summary>
    <div class="page-provenance__facts">
      <div>
        <p>{copy.date}</p>
        <time datetime={lastUpdated}>{formattedDate}</time>
      </div>
      <div>
        <p>{copy.owner}</p>
        <p>{copy.ownerValue}</p>
      </div>
      <div>
        <p>{copy.status}</p>
        <p>{copy.statusValue}</p>
      </div>
    </div>
    <div class="page-provenance__boundary">
      <p>{copy.boundary}</p>
      <a href={internalHref("/contact")}>{copy.correction}</a>
    </div>
  </details>
</aside>
