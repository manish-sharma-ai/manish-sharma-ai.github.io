---
type Variant =
  | "agent"
  | "cladding"
  | "contact"
  | "ded"
  | "evidence"
  | "failure"
  | "frameworks"
  | "glossary"
  | "industrial"
  | "lmd"
  | "maturity"
  | "meltpool"
  | "notes"
  | "profile"
  | "quality"
  | "readiness"
  | "repairability"
  | "research"
  | "tools"
  | "default";

interface Props {
  variant?: Variant;
  class?: string;
}

type VisualModel = {
  title: string;
  label: string;
  summary: string;
  classification: "Conceptual framework" | "Illustrative workflow" | "Navigation model";
  steps: string[];
  readingDirection: string;
};

const models: Record<Variant, VisualModel> = {
  default: {
    title: "From process signal to evidence",
    label: "Process model",
    summary: "A compact way to keep a process observation separate from a quality claim.",
    classification: "Illustrative workflow",
    steps: ["Observe the process", "Structure the question", "Verify with evidence"],
    readingDirection: "left to right: process observation, decision context, verification"
  },
  agent: {
    title: "From prompt to review-ready brief",
    label: "Agent workflow",
    summary: "A prompt becomes structured facts, clear gaps, and a review route.",
    classification: "Illustrative workflow",
    steps: ["Prompt or RFQ", "Known facts and gaps", "Expert review route"],
    readingDirection: "left to right: request, structure, escalation"
  },
  contact: {
    title: "Choose the right contact route",
    label: "Contact model",
    summary: "The public lab explains concepts; Exafuse handles commercial and technical requests.",
    classification: "Navigation model",
    steps: ["Public question", "Technical context", "Appropriate contact route"],
    readingDirection: "left to right: question, context, next route"
  },
  evidence: {
    title: "Evidence strengthens in stages",
    label: "Evidence model",
    summary: "Monitoring can inform a review, while inspection and testing support stronger claims.",
    classification: "Conceptual framework",
    steps: ["Process signal", "Inspection evidence", "Validated claim"],
    readingDirection: "left to right: signal, evidence, claim boundary"
  },
  frameworks: {
    title: "A framework structures the question",
    label: "Framework model",
    summary: "Use a framework to make facts, risks, and evidence needs explicit before acting.",
    classification: "Conceptual framework",
    steps: ["Question", "Risk and evidence", "Bounded action"],
    readingDirection: "left to right: question, review, next action"
  },
  quality: {
    title: "Quality evidence is a ladder",
    label: "Evidence ladder",
    summary: "Each step can strengthen confidence, but no single process signal is final proof.",
    classification: "Conceptual framework",
    steps: ["Monitoring signal", "Inspection method", "Evidence for review"],
    readingDirection: "left to right: observe, inspect, substantiate"
  },
  repairability: {
    title: "Repairability starts with technical facts",
    label: "Repair screening",
    summary: "Technical suitability, qualification burden, and commercial context must remain separate.",
    classification: "Conceptual framework",
    steps: ["Technical suitability", "Qualification burden", "Commercial context"],
    readingDirection: "left to right: technical facts, evidence burden, business context"
  },
  readiness: {
    title: "AI readiness depends on connected data",
    label: "Readiness model",
    summary: "Data capture becomes useful only when it is linked to inspection and review outcomes.",
    classification: "Conceptual framework",
    steps: ["Capture process data", "Link records and labels", "Validate against outcomes"],
    readingDirection: "left to right: capture, connect, validate"
  },
  failure: {
    title: "A signal is not a confirmed failure",
    label: "Failure-evidence model",
    summary: "Name the possible mode, inspect for evidence, then select a bounded action.",
    classification: "Conceptual framework",
    steps: ["Possible failure mode", "Process or AI signal", "Validation evidence"],
    readingDirection: "left to right: possible mode, indication, verification"
  },
  maturity: {
    title: "Maturity builds from records to validation",
    label: "Maturity path",
    summary: "AI capability follows data quality, traceability, review rules, and validated outcomes.",
    classification: "Conceptual framework",
    steps: ["Consistent records", "Connected decision support", "Validated control candidate"],
    readingDirection: "left to right: records, assistance, validation"
  },
  glossary: {
    title: "Terminology keeps process choices clear",
    label: "Terminology model",
    summary: "Separate the parent process, the route, and the application before comparing options.",
    classification: "Conceptual framework",
    steps: ["Parent process", "Specific route", "Practical application"],
    readingDirection: "left to right: category, route, use case"
  },
  lmd: {
    title: "LMD is a laser-based DED route",
    label: "LMD context",
    summary: "The route is often considered for local addition, repair, cladding, and larger features.",
    classification: "Conceptual framework",
    steps: ["Laser energy", "Material deposition", "Repair or build feature"],
    readingDirection: "left to right: energy, deposition, use case"
  },
  ded: {
    title: "DED is a broader process family",
    label: "DED context",
    summary: "Energy source and feedstock vary by system; LMD is one laser-based route within the family.",
    classification: "Conceptual framework",
    steps: ["Energy source", "Feedstock", "Deposited material"],
    readingDirection: "left to right: energy, feedstock, deposit"
  },
  cladding: {
    title: "Cladding links surface need to deposition route",
    label: "Cladding context",
    summary: "Surface function, base material, finishing, and validation belong in the same conversation.",
    classification: "Conceptual framework",
    steps: ["Base surface", "Deposited layer", "Required surface function"],
    readingDirection: "left to right: substrate, deposit, intended function"
  },
  meltpool: {
    title: "Melt-pool monitoring supports awareness",
    label: "Monitoring model",
    summary: "A live signal can prompt review, but inspection determines what the signal means for the part.",
    classification: "Illustrative workflow",
    steps: ["Live process signal", "Anomaly or trend", "Inspection question"],
    readingDirection: "left to right: observe, flag, investigate"
  },
  industrial: {
    title: "Public cases provide context, not transferability",
    label: "Public evidence model",
    summary: "A documented example can explain a pattern while each new part still needs its own review.",
    classification: "Conceptual framework",
    steps: ["Public case context", "Relevant decision pattern", "Part-specific review"],
    readingDirection: "left to right: context, pattern, review"
  },
  notes: {
    title: "A field note moves from observation to action",
    label: "Note model",
    summary: "Short notes make the uncertainty visible before they suggest a next step.",
    classification: "Illustrative workflow",
    steps: ["Observation", "Technical question", "Bounded next step"],
    readingDirection: "left to right: observe, question, act"
  },
  profile: {
    title: "Public technical profile",
    label: "Profile model",
    summary: "Identity, public work, and verified profile links are deliberately separated from company services.",
    classification: "Navigation model",
    steps: ["Person", "Public technical work", "Verified public links"],
    readingDirection: "left to right: person, work, public reference"
  },
  research: {
    title: "Research sources answer different questions",
    label: "Source model",
    summary: "Standards, reviews, public cases, and source notes each contribute a distinct kind of context.",
    classification: "Conceptual framework",
    steps: ["Terminology and standards", "Research and reviews", "Public industrial context"],
    readingDirection: "left to right: define, investigate, contextualize"
  },
  tools: {
    title: "Tools make information gaps visible",
    label: "Tool workflow",
    summary: "The workbench turns inputs into missing information, risk flags, and a clear next action.",
    classification: "Illustrative workflow",
    steps: ["Known inputs", "Gaps and risks", "Structured next action"],
    readingDirection: "left to right: input, structure, next action"
  }
};

const { variant = "default", class: className = "" } = Astro.props;
const visual = models[variant] ?? models.default;
---

<figure class:list={["page-hero-model diagram-frame", className]} data-visual-type={visual.classification.toLowerCase()}>
  <figcaption class="diagram-frame__header">
    <p class="metric-label">{visual.classification}</p>
    <h2 class="mt-2 text-xl font-black leading-tight text-white">{visual.title}</h2>
    <p class="mt-2 text-sm leading-6 text-slate-300">{visual.summary}</p>
  </figcaption>
  <ol class="page-hero-model__steps" aria-label={visual.title}>
    {visual.steps.map((step, index) => (
      <li>
        <span class="page-hero-model__index">{String(index + 1).padStart(2, "0")}</span>
        <span>{step}</span>
      </li>
    ))}
  </ol>
  <p class="diagram-frame__direction"><strong>Reading direction:</strong> {visual.readingDirection}.</p>
</figure>
