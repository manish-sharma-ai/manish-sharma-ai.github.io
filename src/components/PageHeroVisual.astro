---
type Variant =
  | "agent"
  | "cladding"
  | "contact"
  | "ded"
  | "evidence"
  | "failure"
  | "frameworks"
  | "glossary"
  | "industrial"
  | "lmd"
  | "maturity"
  | "meltpool"
  | "notes"
  | "profile"
  | "quality"
  | "readiness"
  | "repairability"
  | "research"
  | "tools"
  | "default";

type VisualKind =
  | "evidence"
  | "framework"
  | "identity"
  | "industrial"
  | "notes"
  | "process"
  | "research"
  | "route"
  | "schema"
  | "taxonomy"
  | "tools";

interface Props {
  variant?: Variant;
  class?: string;
}

const variants: Record<Variant, {
  title: string;
  label: string;
  focus: string;
  subfocus: string;
  kind: VisualKind;
  accent: string;
  cards: string[];
  nodes: string[];
  layers: string[];
}> = {
  default: {
    title: "LMD process signal visual",
    label: "process layer",
    focus: "AI + LMD",
    subfocus: "signals to evidence",
    kind: "process",
    accent: "#33d6ff",
    cards: ["Melt pool", "Bead", "Inspection"],
    nodes: ["LMD", "RFQ", "AI", "QA"],
    layers: ["Signal", "Risk", "Evidence"]
  },
  agent: {
    title: "Agent schema and safety boundary visual",
    label: "agent map",
    focus: "schemas + limits",
    subfocus: "prompt to structured review",
    kind: "schema",
    accent: "#33d6ff",
    cards: ["RFQ schema", "Rules", "Checklist"],
    nodes: ["Prompt", "Fields", "Risk", "Review"],
    layers: ["Use for", "Do not use", "Escalate"]
  },
  contact: {
    title: "Contact route visual",
    label: "route map",
    focus: "contact paths",
    subfocus: "public lab to Exafuse",
    kind: "route",
    accent: "#ffb547",
    cards: ["Question", "Context", "Next step"],
    nodes: ["LinkedIn", "GitHub", "Exafuse", "RFQ"],
    layers: ["Professional", "Technical", "Industrial"]
  },
  evidence: {
    title: "Evidence ladder visual",
    label: "proof boundary",
    focus: "quality evidence",
    subfocus: "monitoring is not release",
    kind: "evidence",
    accent: "#33d6ff",
    cards: ["Signal", "Inspection", "Source"],
    nodes: ["Melt pool", "NDT", "Data", "Claim"],
    layers: ["Process signal", "Inspection", "Validation", "Field evidence"]
  },
  frameworks: {
    title: "Framework stack visual",
    label: "decision layer",
    focus: "frameworks",
    subfocus: "risk to evidence",
    kind: "framework",
    accent: "#33d6ff",
    cards: ["Repairability", "AI readiness", "Quality"],
    nodes: ["RFQ", "Risk", "Evidence", "Decision"],
    layers: ["Question", "Signal", "Evidence", "Decision"]
  },
  quality: {
    title: "Quality evidence ladder visual",
    label: "evidence ladder",
    focus: "quality proof",
    subfocus: "monitoring to inspection",
    kind: "evidence",
    accent: "#33d6ff",
    cards: ["Monitoring", "NDT", "Release"],
    nodes: ["Signal", "Defect", "Inspect", "Accept"],
    layers: ["Signal", "AI flag", "NDT", "Release evidence"]
  },
  repairability: {
    title: "Repairability scoring visual",
    label: "repair index",
    focus: "repairability",
    subfocus: "material, damage, access",
    kind: "framework",
    accent: "#33d6ff",
    cards: ["Material", "Damage", "Access"],
    nodes: ["Part", "Material", "Machining", "Inspect"],
    layers: ["Known facts", "Missing info", "Risk flags", "Candidate band"]
  },
  readiness: {
    title: "AI readiness visual",
    label: "data foundation",
    focus: "AI readiness",
    subfocus: "logs to inspection labels",
    kind: "framework",
    accent: "#33d6ff",
    cards: ["Logs", "Images", "Labels"],
    nodes: ["Camera", "Machine", "CAD", "Inspection"],
    layers: ["Capture", "Link", "Label", "Validate"]
  },
  failure: {
    title: "Failure atlas visual",
    label: "failure map",
    focus: "failure modes",
    subfocus: "signal to validation",
    kind: "framework",
    accent: "#ff4d2e",
    cards: ["Porosity", "Cracking", "Distortion"],
    nodes: ["Mode", "Signal", "AI flag", "Evidence"],
    layers: ["Failure mode", "Process signal", "AI visibility", "Validation"]
  },
  maturity: {
    title: "Maturity model visual",
    label: "maturity path",
    focus: "LMD-AI maturity",
    subfocus: "records to closed loop",
    kind: "framework",
    accent: "#9cc9d9",
    cards: ["Records", "Analytics", "Governance"],
    nodes: ["Level 0", "Level 2", "Level 4", "Level 5"],
    layers: ["Records", "Traceability", "Decision support", "Governance"]
  },
  glossary: {
    title: "Glossary taxonomy visual",
    label: "term boundary",
    focus: "terminology",
    subfocus: "LMD, DED, cladding",
    kind: "taxonomy",
    accent: "#9cc9d9",
    cards: ["Term", "Meaning", "Use case"],
    nodes: ["LMD", "DED", "SLM", "Cladding"],
    layers: ["Parent process", "Route", "Application"]
  },
  lmd: {
    title: "Laser Metal Deposition taxonomy visual",
    label: "term focus",
    focus: "LMD",
    subfocus: "local metal addition",
    kind: "taxonomy",
    accent: "#33d6ff",
    cards: ["Repair", "Cladding", "Feature"],
    nodes: ["DED", "LMD", "SLM", "Repair"],
    layers: ["Laser route", "Melt zone", "Deposit path"]
  },
  ded: {
    title: "Directed Energy Deposition taxonomy visual",
    label: "parent family",
    focus: "DED",
    subfocus: "heat source + feedstock",
    kind: "taxonomy",
    accent: "#9cc9d9",
    cards: ["Powder", "Wire", "Laser"],
    nodes: ["DED", "LMD", "Wire", "Powder"],
    layers: ["Family", "Route", "Feedstock"]
  },
  cladding: {
    title: "Laser cladding taxonomy visual",
    label: "surface route",
    focus: "cladding",
    subfocus: "surface and repair layer",
    kind: "taxonomy",
    accent: "#ffb547",
    cards: ["Surface", "Coating", "Repair"],
    nodes: ["LMD", "Clad", "Wear", "Corrosion"],
    layers: ["Base", "Interface", "Clad layer"]
  },
  meltpool: {
    title: "Melt-pool monitoring visual",
    label: "monitoring signal",
    focus: "melt pool",
    subfocus: "signal, not certificate",
    kind: "evidence",
    accent: "#33d6ff",
    cards: ["Signal", "Anomaly", "Inspect"],
    nodes: ["Pool", "Thermal", "AI", "NDT"],
    layers: ["Live signal", "Pattern", "Risk", "Inspection"]
  },
  industrial: {
    title: "Industrial proof visual",
    label: "public case map",
    focus: "industrial proof",
    subfocus: "repair, cladding, build",
    kind: "industrial",
    accent: "#ff4d2e",
    cards: ["Case", "Metric", "Lesson"],
    nodes: ["Part", "Scale", "Repair", "Evidence"],
    layers: ["Large part", "Local repair", "Inspection"]
  },
  notes: {
    title: "Lab note signal visual",
    label: "working note",
    focus: "field notes",
    subfocus: "observation to takeaway",
    kind: "notes",
    accent: "#33d6ff",
    cards: ["Observe", "Question", "Takeaway"],
    nodes: ["Signal", "Risk", "Context", "Review"],
    layers: ["Observation", "Boundary", "Next step"]
  },
  profile: {
    title: "Public identity graph visual",
    label: "entity map",
    focus: "Manish Sharma",
    subfocus: "AI for LMD",
    kind: "identity",
    accent: "#33d6ff",
    cards: ["Identity", "Public work", "Profiles"],
    nodes: ["Manish", "AI", "LMD", "Exafuse"],
    layers: ["Person", "Domain", "Company", "Public work"]
  },
  research: {
    title: "Research source network visual",
    label: "source terrain",
    focus: "research map",
    subfocus: "standards, reviews, cases",
    kind: "research",
    accent: "#9cc9d9",
    cards: ["Standards", "Reviews", "Cases"],
    nodes: ["ISO", "NIST", "Review", "Case"],
    layers: ["Terminology", "Monitoring", "AI", "Quality"]
  },
  tools: {
    title: "LMD tool console visual",
    label: "tool console",
    focus: "LMD tools",
    subfocus: "input to recommendation",
    kind: "tools",
    accent: "#33d6ff",
    cards: ["Part", "Material", "Damage"],
    nodes: ["Input", "Missing", "Risk", "Next"],
    layers: ["Known", "Missing", "Risk", "Next step"]
  }
};

const { variant = "default", class: className = "" } = Astro.props;
const visual = variants[variant] ?? variants.default;
const titleId = `page-hero-visual-title-${variant}`;
const descId = `page-hero-visual-desc-${variant}`;
const sourceNodes = [
  { x: 260, y: 152 },
  { x: 412, y: 92 },
  { x: 560, y: 176 },
  { x: 704, y: 116 },
  { x: 642, y: 306 },
  { x: 438, y: 338 },
  { x: 292, y: 280 }
];
---

<div
  class:list={["page-hero-visual glass-panel relative overflow-hidden rounded-lg p-3 md:p-4", className]}
  style={`--page-visual-accent: ${visual.accent}`}
  aria-label={`${visual.title} visual`}
>
  <svg class="aspect-[16/10] w-full" viewBox="0 0 920 575" role="img" aria-labelledby={`${titleId} ${descId}`}>
    <title id={titleId}>{visual.title}</title>
    <desc id={descId}>
      A dark technical visual in the Manish Sharma Lab style, adapted to the page theme.
    </desc>
    <defs>
      <linearGradient id={`${variant}-trace`} x1="0" x2="1" y1="0" y2="0">
        <stop offset="0%" stop-color="#30404b" />
        <stop offset="54%" stop-color="#7392a0" />
        <stop offset="100%" stop-color={visual.accent} />
      </linearGradient>
      <linearGradient id={`${variant}-beam`} x1="0" x2="1" y1="0" y2="0">
        <stop offset="0%" stop-color="#ff4d2e" stop-opacity="0.08" />
        <stop offset="58%" stop-color="#ff4d2e" stop-opacity="0.9" />
        <stop offset="100%" stop-color="#ffb547" stop-opacity="0.76" />
      </linearGradient>
      <radialGradient id={`${variant}-heat`}>
        <stop offset="0%" stop-color="#fff3c4" stop-opacity="1" />
        <stop offset="30%" stop-color="#ffb547" stop-opacity="0.94" />
        <stop offset="68%" stop-color="#ff4d2e" stop-opacity="0.4" />
        <stop offset="100%" stop-color="#ff4d2e" stop-opacity="0" />
      </radialGradient>
      <filter id={`${variant}-glow`} x="-70%" y="-70%" width="240%" height="240%">
        <feGaussianBlur stdDeviation="8" result="blur" />
        <feMerge>
          <feMergeNode in="blur" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
    </defs>

    <rect width="920" height="575" rx="18" fill="#071018" />
    <rect x="18" y="18" width="884" height="539" rx="14" fill="none" stroke="rgba(156, 201, 217, 0.16)" />
    <g opacity="0.2">
      {Array.from({ length: 14 }).map((_, index) => (
        <line x1={index * 70 + 8} x2={index * 70 + 8} y1="18" y2="557" stroke="#9cc9d9" stroke-width="1" />
      ))}
      {Array.from({ length: 10 }).map((_, index) => (
        <line x1="18" x2="902" y1={index * 58 + 32} y2={index * 58 + 32} stroke="#9cc9d9" stroke-width="1" />
      ))}
    </g>

    <g transform="translate(34 28)" font-family="JetBrains Mono, Consolas, monospace">
      <text x="0" y="16" fill="#9cc9d9" font-size="12" letter-spacing="1.6">{visual.label}</text>
      <text x="0" y="46" fill="#ffffff" font-size="30" font-weight="800">{visual.focus}</text>
      <text x="0" y="72" fill="#9cc9d9" font-size="13">{visual.subfocus}</text>
    </g>

    {visual.kind === "process" && (
      <g>
        <path d="M154 390 C260 348 352 360 440 404 S650 474 788 410" fill="none" stroke="#1d2934" stroke-width="64" stroke-linecap="round" opacity="0.92" />
        <path class="page-bead-trace" d="M154 390 C260 348 352 360 440 404 S650 474 788 410" fill="none" stroke={`url(#${variant}-trace)`} stroke-width="18" stroke-linecap="round" />
        <line x1="356" y1="96" x2="458" y2="342" stroke="rgba(255, 77, 46, 0.14)" stroke-width="34" stroke-linecap="round" />
        <line class="page-laser-core" x1="356" y1="96" x2="458" y2="342" stroke={`url(#${variant}-beam)`} stroke-width="4" stroke-linecap="round" filter={`url(#${variant}-glow)`} />
        <circle class="page-heat-core" cx="458" cy="342" r="54" fill={`url(#${variant}-heat)`} filter={`url(#${variant}-glow)`} />
        <g fill="none" stroke={visual.accent} stroke-width="2" opacity="0.62">
          <path class="page-signal-line" d="M470 310 C540 242 612 226 684 236" />
          <path class="page-signal-line page-signal-line-alt" d="M500 360 C574 346 638 372 704 420" />
        </g>
      </g>
    )}

    {visual.kind === "tools" && (
      <g>
        <g transform="translate(58 120)">
          {visual.cards.map((card, index) => (
            <g class="page-card-drift" transform={`translate(0 ${index * 68})`}>
              <rect width="230" height="48" rx="9" fill="rgba(5, 10, 14, 0.78)" stroke="rgba(156, 201, 217, 0.2)" />
              <text x="18" y="29" fill="#e7f6fa" font-family="JetBrains Mono, Consolas, monospace" font-size="12" font-weight="800">{card}</text>
              <line x1="136" x2="206" y1="24" y2="24" stroke={index === 1 ? "#ffb547" : visual.accent} stroke-width="3" opacity="0.64" />
            </g>
          ))}
        </g>
        <path class="page-router-line" d="M308 216 C388 216 418 292 492 292" fill="none" stroke={visual.accent} stroke-width="2" />
        <path class="page-router-line page-signal-line-alt" d="M308 284 C395 284 414 332 492 332" fill="none" stroke="#ffb547" stroke-width="2" />
        <g transform="translate(505 142)">
          <rect width="326" height="248" rx="14" fill="rgba(5, 10, 14, 0.72)" stroke="rgba(51, 214, 255, 0.26)" />
          <text x="24" y="36" fill="#9cc9d9" font-family="JetBrains Mono, Consolas, monospace" font-size="12">advisor output</text>
          {visual.layers.map((layer, index) => (
            <g transform={`translate(24 ${70 + index * 40})`}>
              <rect width={index === 0 ? 210 : index === 1 ? 248 : 166} height="16" rx="8" fill={index === 2 ? "#ff4d2e" : visual.accent} opacity={index === 2 ? "0.34" : "0.42"} />
              <text x="0" y="34" fill="#d8e6ec" font-family="JetBrains Mono, Consolas, monospace" font-size="10">{layer}</text>
            </g>
          ))}
        </g>
        <path d="M348 454 C440 418 532 426 642 458" fill="none" stroke="#263640" stroke-width="36" stroke-linecap="round" />
        <path class="page-bead-trace" d="M350 454 C440 418 532 426 642 458" fill="none" stroke={`url(#${variant}-trace)`} stroke-width="10" stroke-linecap="round" />
      </g>
    )}

    {visual.kind === "framework" && (
      <g>
        <g transform="translate(88 140)">
          {visual.layers.map((layer, index) => (
            <g class="page-card-drift" transform={`translate(${index * 34} ${index * 68})`}>
              <rect width={300 - index * 18} height="48" rx="9" fill="rgba(5, 10, 14, 0.78)" stroke={index === visual.layers.length - 1 ? visual.accent : "rgba(156, 201, 217, 0.2)"} />
              <text x="18" y="29" fill="#e7f6fa" font-family="JetBrains Mono, Consolas, monospace" font-size="12" font-weight="800">{layer}</text>
            </g>
          ))}
        </g>
        <path class="page-router-line" d="M425 196 C532 150 630 170 744 116" fill="none" stroke={visual.accent} stroke-width="2" />
        <path class="page-router-line page-signal-line-alt" d="M425 280 C548 280 622 274 774 324" fill="none" stroke="#ffb547" stroke-width="2" />
        <g transform="translate(535 94)">
          {visual.nodes.map((node, index) => {
            const x = [40, 176, 250, 110][index] ?? 40;
            const y = [70, 34, 156, 220][index] ?? 70;
            const color = index === 1 ? "#ffb547" : index === 3 ? "#ff4d2e" : visual.accent;
            return (
              <g class="page-pulse-node" transform={`translate(${x} ${y})`}>
                <circle r="22" fill={color} opacity="0.12" />
                <circle r="6" fill={color} />
                <text x="-28" y="38" fill="#c6d7df" font-family="JetBrains Mono, Consolas, monospace" font-size="10">{node}</text>
              </g>
            );
          })}
        </g>
        <rect x="548" y="146" width="278" height="166" rx="14" fill="rgba(5, 10, 14, 0.44)" stroke="rgba(156, 201, 217, 0.16)" />
      </g>
    )}

    {visual.kind === "evidence" && (
      <g>
        <g transform="translate(92 118)">
          {visual.layers.map((layer, index) => (
            <g transform={`translate(${index * 104} ${index * 58})`}>
              <rect class="page-card-drift" width="178" height="52" rx="9" fill={index === 0 ? "rgba(51, 214, 255, 0.1)" : "rgba(5, 10, 14, 0.76)"} stroke={index === visual.layers.length - 1 ? "#ffb547" : "rgba(156, 201, 217, 0.22)"} />
              <text x="16" y="31" fill="#e7f6fa" font-family="JetBrains Mono, Consolas, monospace" font-size="11" font-weight="800">{layer}</text>
            </g>
          ))}
        </g>
        <path class="page-router-line" d="M165 174 L270 232 L374 290 L478 348" fill="none" stroke={visual.accent} stroke-width="2.4" />
        <g transform="translate(585 126)">
          <circle class="page-heat-core" cx="80" cy="80" r="58" fill={`url(#${variant}-heat)`} filter={`url(#${variant}-glow)`} />
          <path class="page-wave-line" d="M0 178 C48 132 100 224 164 174 S260 166 304 120" fill="none" stroke={visual.accent} stroke-width="3" />
          <rect x="164" y="22" width="128" height="66" rx="10" fill="rgba(5, 10, 14, 0.7)" stroke="rgba(255, 181, 71, 0.35)" />
          <text x="184" y="60" fill="#ffde9c" font-family="JetBrains Mono, Consolas, monospace" font-size="11">not release</text>
        </g>
      </g>
    )}

    {visual.kind === "taxonomy" && (
      <g>
        <g transform="translate(455 278)">
          <ellipse rx="260" ry="154" fill="rgba(51, 214, 255, 0.06)" stroke="rgba(51, 214, 255, 0.28)" />
          <ellipse rx="168" ry="104" fill="rgba(156, 201, 217, 0.055)" stroke="rgba(156, 201, 217, 0.24)" transform="translate(-82 18)" />
          <ellipse rx="142" ry="88" fill="rgba(255, 181, 71, 0.055)" stroke="rgba(255, 181, 71, 0.28)" transform="translate(92 22)" />
          {visual.nodes.map((node, index) => {
            const x = [-158, -46, 86, 176][index] ?? 0;
            const y = [-26, 38, -42, 50][index] ?? 0;
            const color = index === 1 ? visual.accent : index === 3 ? "#ffb547" : "#9cc9d9";
            return (
              <g class="page-pulse-node" transform={`translate(${x} ${y})`}>
                <circle r="24" fill={color} opacity="0.12" />
                <circle r="6" fill={color} />
                <text x="-34" y="38" fill="#e7f6fa" font-family="JetBrains Mono, Consolas, monospace" font-size="12" font-weight="800">{node}</text>
              </g>
            );
          })}
        </g>
        <g transform="translate(86 122)">
          {visual.layers.map((layer, index) => (
            <g transform={`translate(0 ${index * 54})`}>
              <rect width="212" height="38" rx="8" fill="rgba(5, 10, 14, 0.72)" stroke="rgba(156, 201, 217, 0.18)" />
              <text x="16" y="25" fill="#d8e6ec" font-family="JetBrains Mono, Consolas, monospace" font-size="11">{layer}</text>
            </g>
          ))}
        </g>
        <path class="page-router-line" d="M290 296 C360 246 434 224 520 248" fill="none" stroke={visual.accent} stroke-width="2" />
      </g>
    )}

    {visual.kind === "research" && (
      <g>
        <g>
          <path class="page-router-line" d="M260 152 L412 92 L560 176 L704 116 L642 306 L438 338 L292 280 Z" fill="none" stroke="rgba(156, 201, 217, 0.42)" stroke-width="2" />
          {sourceNodes.map((point, index) => {
            const color = index % 3 === 0 ? visual.accent : index % 3 === 1 ? "#ffb547" : "#9cc9d9";
            return (
              <g class="page-pulse-node" transform={`translate(${point.x} ${point.y})`}>
                <circle r="20" fill={color} opacity="0.12" />
                <circle r="5" fill={color} />
              </g>
            );
          })}
        </g>
        <g transform="translate(66 372)">
          {visual.cards.map((card, index) => (
            <g transform={`translate(${index * 190} 0)`}>
              <rect width="166" height="64" rx="10" fill="rgba(5, 10, 14, 0.76)" stroke="rgba(156, 201, 217, 0.2)" />
              <text x="16" y="29" fill="#e7f6fa" font-family="JetBrains Mono, Consolas, monospace" font-size="12" font-weight="800">{card}</text>
              <line x1="16" x2="112" y1="44" y2="44" stroke={index === 1 ? "#ffb547" : visual.accent} stroke-width="2" opacity="0.6" />
            </g>
          ))}
        </g>
        <rect x="640" y="368" width="190" height="80" rx="12" fill="rgba(51, 214, 255, 0.07)" stroke="rgba(51, 214, 255, 0.22)" />
        <text x="664" y="410" fill="#d8e6ec" font-family="JetBrains Mono, Consolas, monospace" font-size="12">curated, not complete</text>
      </g>
    )}

    {visual.kind === "identity" && (
      <g transform="translate(460 288)">
        <circle r="72" fill="rgba(51, 214, 255, 0.09)" stroke="rgba(51, 214, 255, 0.32)" />
        <text x="-58" y="6" fill="#ffffff" font-family="JetBrains Mono, Consolas, monospace" font-size="15" font-weight="800">{visual.nodes[0]}</text>
        {visual.nodes.slice(1).map((node, index) => {
          const angle = [-140, -18, 108][index] * (Math.PI / 180);
          const x = Math.cos(angle) * 230;
          const y = Math.sin(angle) * 150;
          const color = index === 2 ? "#ff4d2e" : visual.accent;
          return (
            <g>
              <line class="page-router-line" x1="0" y1="0" x2={x} y2={y} stroke={color} stroke-width="2" opacity="0.62" />
              <g class="page-pulse-node" transform={`translate(${x} ${y})`}>
                <circle r="36" fill={color} opacity="0.12" />
                <circle r="7" fill={color} />
                <text x="-34" y="54" fill="#e7f6fa" font-family="JetBrains Mono, Consolas, monospace" font-size="12" font-weight="800">{node}</text>
              </g>
            </g>
          );
        })}
        <g transform="translate(-344 160)">
          {visual.cards.map((card, index) => (
            <text x={index * 142} y="0" fill="#9cc9d9" font-family="JetBrains Mono, Consolas, monospace" font-size="11">{card}</text>
          ))}
        </g>
      </g>
    )}

    {visual.kind === "schema" && (
      <g>
        <g transform="translate(74 122)">
          {visual.cards.map((card, index) => (
            <g transform={`translate(0 ${index * 72})`}>
