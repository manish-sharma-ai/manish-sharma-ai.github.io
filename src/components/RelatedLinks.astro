---
import { RELATED_LINK_SETS } from "@data/site";
import { internalHref } from "@utils/urls";

interface Props {
  path: string;
  lang?: "en" | "de";
}

const { path, lang = "en" } = Astro.props;
const normalize = (value: string) => {
  if (value === "/") return "/";
  return value.replace(/\/$/, "");
};

const currentPath = normalize(path);
const shouldSkip = currentPath === "/" || currentPath === "/site-map";

const linkSet = RELATED_LINK_SETS.find((set) => {
  const exact = set.exact?.map(normalize) ?? [];
  const prefixes = set.prefixes?.map(normalize) ?? [];
  return exact.includes(currentPath) || prefixes.some((prefix) => currentPath === prefix || currentPath.startsWith(`${prefix}/`));
});

const links = linkSet
  ? [
      ...linkSet.links.filter((link) => normalize(link.href) !== currentPath).slice(0, 3),
      {
        label: lang === "de" ? "Vollständige Sitemap" : "Full Site Map",
        href: "/site-map",
        description:
          lang === "de"
            ? "Alle Seiten und öffentlichen Dateien in einer Karte."
            : "Every page and public machine-readable asset in one linked map."
      }
    ]
  : [];

const openLabel = lang === "de" ? "Öffnen" : "Open";
const sectionId = `closing-path-${currentPath.replace(/[^a-z0-9]+/gi, "-").replace(/^-|-$/g, "") || "home"}`;
---

{!shouldSkip && linkSet && links.length > 0 && (
  <section class="closing-path" aria-labelledby={sectionId} data-closing-path>
    <div class="site-shell closing-path__inner">
      <header class="closing-path__header">
        <p class="closing-path__eyebrow">{linkSet.eyebrow}</p>
        <h2 id={sectionId} class="closing-path__title">{linkSet.title}</h2>
      </header>
      <ul class="closing-path__links">
        {links.map((link, index) => (
          <li class="closing-path__item">
            <a
              href={internalHref(link.href)}
              class="closing-path__link"
              target={link.href.startsWith("http") ? "_blank" : undefined}
              rel={link.href.startsWith("http") ? "noreferrer" : undefined}
            >
              <span class="closing-path__index" aria-hidden="true">{String(index + 1).padStart(2, "0")}</span>
              <span class="closing-path__copy">
                <span class="closing-path__label">{link.label}</span>
                <span class="closing-path__description">{link.description}</span>
              </span>
              <span class="closing-path__action">{openLabel} <span aria-hidden="true">→</span></span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
)}
