---
import { RELATED_LINK_SETS } from "@data/site";

interface Props {
  path: string;
  lang?: "en" | "de";
}

const { path, lang = "en" } = Astro.props;
const normalize = (value: string) => {
  if (value === "/") return "/";
  return value.replace(/\/$/, "");
};

const currentPath = normalize(path);
const shouldSkip = currentPath === "/" || currentPath === "/site-map";

const linkSet = RELATED_LINK_SETS.find((set) => {
  const exact = set.exact?.map(normalize) ?? [];
  const prefixes = set.prefixes?.map(normalize) ?? [];
  return exact.includes(currentPath) || prefixes.some((prefix) => currentPath === prefix || currentPath.startsWith(`${prefix}/`));
});

const links = linkSet
  ? [
      ...linkSet.links.filter((link) => normalize(link.href) !== currentPath).slice(0, 3),
      {
        label: lang === "de" ? "Vollständige Sitemap" : "Full Site Map",
        href: "/site-map",
        description:
          lang === "de"
            ? "Alle Seiten und öffentlichen Dateien in einer Karte."
            : "Every page and public machine-readable asset in one linked map."
      }
    ]
  : [];

const openLabel = lang === "de" ? "Öffnen" : "Open";
---

{!shouldSkip && linkSet && links.length > 0 && (
  <section class="border-t border-white/10 bg-black/20 py-12">
    <div class="site-shell">
      <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="metric-label">{linkSet.eyebrow}</p>
          <h2 class="mt-3 text-2xl font-black text-white md:text-3xl">{linkSet.title}</h2>
        </div>
      </div>
      <div class="mt-7 grid gap-3 md:grid-cols-2 xl:grid-cols-4">
        {links.map((link) => (
          <a
            href={link.href}
            class="ordered-card card-hover group grid min-h-32 content-between p-4"
            target={link.href.startsWith("http") ? "_blank" : undefined}
            rel={link.href.startsWith("http") ? "noreferrer" : undefined}
          >
            <span>
              <span class="block text-sm font-black text-white">{link.label}</span>
              <span class="mt-2 block text-xs leading-5 text-slate-400">{link.description}</span>
            </span>
            <span class="mt-4 font-mono text-xs font-bold text-cyan-200">{openLabel} <span class="inline-block transition group-hover:translate-x-1 group-focus-visible:translate-x-1">&rarr;</span></span>
          </a>
        ))}
      </div>
    </div>
  </section>
)}
