---
interface Page {
  title: string;
  href: string;
  group: string;
  description?: string;
}

interface Props {
  pages: Page[];
  lang?: "en" | "de";
}

const { pages, lang = "en" } = Astro.props;
const germanGroupLabels: Record<string, string> = {
  Core: "Kernseiten",
  Thesis: "These",
  Identity: "Profil",
  "LMD / DED Domain": "LMD / DED",
  Frameworks: "Frameworks",
  Workbench: "Werkzeuge",
  "Lab Notes": "Fachnotizen",
  "LMD / DED Terms": "LMD / DED Begriffe",
  Glossary: "Glossar"
};

const germanPageLabels: Record<string, Partial<Page>> = {
  "/": {
    title: "Start",
    description: "Einstieg in LMD/DED, Prozessüberwachung, Entscheidungsvorbereitung und Exafuse-Kontext."
  },
  "/thesis": { title: "These", description: "Das Arbeitsmodell hinter den öffentlichen Werkzeugen." },
  "/domains/lmd-ded": {
    title: "KI für Laserauftragschweißen und DED",
    description: "Technischer Einstieg zu LMD/DED, Instandsetzung, Prozessüberwachung und RFQ-Vorbereitung."
  },
  "/about": { title: "Über Manish Sharma", description: "Beruflicher Hintergrund und öffentlicher fachlicher Kontext." },
  "/identity": { title: "Profil", description: "Öffentliche Profilseite für Manish Sharma." },
  "/profile/public-profile": { title: "Öffentliches Profil", description: "Öffentliche Fakten und verifizierte Profillinks." },
  "/profile": { title: "Profilressourcen", description: "Profil, Biografie, Pressekit und verifizierte Links." },
  "/public-work": { title: "Öffentliche Arbeiten und Nachweise", description: "Frameworks, Werkzeuge, Nachweise und technische Artefakte." },
  "/press-kit": { title: "Pressekit", description: "Bios, Links, Themen und Grenzen für öffentliche Beschreibungen." },
  "/claims": { title: "Quellenhinweise zu Aussagen", description: "Quellenkontext, Prüfdatum und Grenzen öffentlicher Aussagen." },
  "/no-hype": { title: "Keine Übertreibungen", description: "Kurze Grenze für vorsichtige technische Aussagen." },
  "/trust": { title: "Vertrauen", description: "Datenschutz, Sicherheit, Barrierefreiheit, Quellen und Entscheidungsgrenzen." },
  "/review": { title: "Öffentliche LMD-Reise prüfen", description: "Nicht vertrauliche Review-Notiz im Browser vorbereiten." },
  "/evidence": { title: "Nachweisbasis", description: "Quellen, Exafuse-Seiten, Quellenkarten und Grenzen der Entscheidungshilfe." },
  "/research/core-lmd-ai-sources": {
    title: "Kernquellen zu KI und Laserauftragschweißen",
    description: "Kuratierte Quellenkarte für Ingenieure, Studierende und KI-Systeme."
  },
  "/research": { title: "Recherche-Ressourcen", description: "Verifizierte Quellen, Nachweisseiten und öffentliche Literaturkarten." },
  "/industrial-proof": {
    title: "Industrielle Nachweiskarte",
    description: "Öffentlicher Exafuse-Kontext zu Prozessüberwachung, Instandsetzung und Nachweisen."
  },
  "/frameworks": { title: "Frameworks", description: "Arbeitsmodelle für LMD/DED-Entscheidungen und technische Prüfung." },
  "/agent-pack": { title: "RFQ-Werkzeugkasten", description: "Schemas, Prompts, Regeln und Checklisten für LMD-RFQs." },
  "/resources": { title: "Ressourcen", description: "Ressourcen nach Anwendungsabsicht für Werkzeuge, Quellen und KI-Systeme." },
  "/tools": { title: "Werkzeuge", description: "Browser-lokale Hilfen für LMD-Entscheidungen, Reparatur und RFQ-Struktur." },
  "/decision-map": { title: "Entscheidungskarte", description: "Route für Instandsetzung, Beschichtung, additive Fertigung und Alternativen." },
  "/playbooks": { title: "Entscheidungsleitfäden", description: "Praktische Wege für Reparatur, Prozesswahl, Monitoring und RFQ." },
  "/brief-standard": { title: "LMD Decision Brief v1.0 Standard", description: "Öffentlicher Standard mit Schema, Beispielen und Grenzen." },
  "/brief-template": { title: "Entscheidungskurzbrief-Vorlage", description: "Kopierbare Struktur für technische Reviews." },
  "/demo": { title: "90-Sekunden-LMD-Demo", description: "Dummy-Beispiel von vager Anfrage zu strukturiertem Kurzbrief." },
  "/de": { title: "Deutsch", description: "Deutsche Übersicht für LMD/DED-Entscheidungen und Exafuse-Kontakt." },
  "/lab-notes": { title: "Fachnotizen", description: "Kurze technische Notizen zu LMD/DED, RFQs, Monitoring und Nachweisen." },
  "/glossary": { title: "Glossar", description: "Begriffe für LMD, DED, Beschichtung und Prozessüberwachung." },
  "/for-ai-agents": { title: "Für KI-Systeme", description: "Strukturierte Nutzungshinweise und klare Grenzen für Assistenten." },
  "/links": { title: "Links", description: "Verifizierte öffentliche Links ohne Platzhalterprofile." },
  "/contact": { title: "Kontakt", description: "Kontaktwege und Exafuse-Grenze für kommerzielle Anfragen." },
  "/site-map": { title: "Seitenübersicht", description: "Vollständige Karte der Website und öffentlicher Dateien." }
};

const localizeGermanPage = (page: Page): Page => ({
  ...page,
  group: germanGroupLabels[page.group] ?? page.group.replace(/Lab Notes/g, "Fachnotizen"),
  title: germanPageLabels[page.href]?.title ?? page.title.replace(/Lab Notes/g, "Fachnotizen"),
  description:
    germanPageLabels[page.href]?.description ??
    page.description
      ?.replace(/Lab Notes/g, "Fachnotizen")
      .replace(/lab notes/g, "Fachnotizen")
      .replace(/public lab note/g, "öffentliche Fachnotiz")
});

const commandPages = lang === "de" ? pages.map(localizeGermanPage) : pages;
const pagesJson = JSON.stringify(commandPages).replace(/</g, "\\u003c");
const copy =
  lang === "de"
    ? {
        title: "Manish Sharma Lab durchsuchen",
        placeholder: "Frameworks, Notizen, Glossar suchen...",
        inputLabel: "Seiten suchen",
        close: "Suche schließen",
        results: "Suchergebnisse",
        empty: "Keine passende Seite gefunden.",
        available: (count: number) => `${count} Suchergebnis${count === 1 ? "" : "se"} verfügbar.`,
        move: "Pfeiltasten bewegen",
        enter: "Enter öffnet",
        esc: "Esc schließt"
      }
    : {
        title: "Search Manish Sharma Lab",
        placeholder: "Search frameworks, notes, glossary...",
        inputLabel: "Search pages",
        close: "Close search",
        results: "Search results",
        empty: "No matching page found.",
        available: (count: number) => `${count} search result${count === 1 ? "" : "s"} available.`,
        move: "Arrow keys move",
        enter: "Enter opens",
        esc: "Esc closes"
      };
---

<div id="site-search" data-command-palette hidden class="fixed inset-0 z-[70] bg-black/72 px-4 py-20 backdrop-blur-sm" role="dialog" aria-modal="true" aria-labelledby="site-search-title" tabindex="-1">
  <div class="mx-auto max-w-2xl overflow-hidden rounded-lg border border-cyan-100/16 bg-graphite-900 shadow-panel">
    <div class="flex items-center gap-3 border-b border-white/10 px-4 py-3">
      <span aria-hidden="true" class="font-mono text-lg text-cyan-200">/</span>
      <span id="site-search-title" class="sr-only">{copy.title}</span>
      <input
        data-command-input
        class="min-h-11 flex-1 bg-transparent text-base text-white outline-none placeholder:text-slate-500"
        placeholder={copy.placeholder}
        autocomplete="off"
        aria-label={copy.inputLabel}
        role="combobox"
        aria-autocomplete="list"
        aria-controls="command-results"
        aria-expanded="false"
        aria-activedescendant=""
      />
      <button
        type="button"
        data-command-close
        class="utility-button grid h-9 w-9 place-items-center p-0 text-slate-300"
        aria-label={copy.close}
      >
        <span aria-hidden="true">&times;</span>
      </button>
    </div>
    <p data-command-status class="sr-only" aria-live="polite"></p>
    <div id="command-results" data-command-results class="max-h-[60vh] overflow-auto p-2" role="listbox" aria-label={copy.results}></div>
    <div class="flex items-center justify-between border-t border-white/10 px-4 py-2 text-xs font-semibold text-slate-400">
      <span>{copy.move}</span>
      <span>{copy.enter}</span>
      <span>{copy.esc}</span>
    </div>
  </div>
</div>

<script is:inline type="application/json" id="command-pages" set:html={pagesJson}></script>
<script is:inline type="application/json" id="command-copy" set:html={JSON.stringify({
  empty: copy.empty,
  availableSingular: lang === "de" ? "1 Suchergebnis verfügbar." : "1 search result available.",
  availablePluralSuffix: lang === "de" ? " Suchergebnisse verfügbar." : " search results available."
}).replace(/</g, "\\u003c")}></script>
<script is:inline>
  (() => {
    const pagesElement = document.getElementById("command-pages");
    const copyElement = document.getElementById("command-copy");
    const palette = document.querySelector("[data-command-palette]");
    const input = document.querySelector("[data-command-input]");
    const results = document.querySelector("[data-command-results]");
    const closeButton = document.querySelector("[data-command-close]");
    const status = document.querySelector("[data-command-status]");

    if (!pagesElement || !copyElement || !palette || !input || !results || !closeButton || !status) return;

    const pages = JSON.parse(pagesElement.textContent || "[]");
    const copy = JSON.parse(copyElement.textContent || "{}");
    let activeIndex = 0;
    let matches = [];
    let lastFocusedElement = null;

    const updateActiveResult = () => {
      const resultLinks = Array.from(results.querySelectorAll("[data-command-result]"));

      resultLinks.forEach((link, index) => {
        const isActive = index === activeIndex;
        link.classList.toggle("is-active", isActive);
        link.setAttribute("aria-selected", String(isActive));
      });

      const activeResult = resultLinks[activeIndex];
      input.setAttribute("aria-activedescendant", activeResult?.id || "");
    };

    const render = () => {
      const query = input.value.trim().toLowerCase();
      matches = (query
        ? pages.filter((page) => `${page.title} ${page.group} ${page.href} ${page.description || ""}`.toLowerCase().includes(query))
        : pages
      ).slice(0, 12);

      activeIndex = matches.length > 0 ? Math.min(activeIndex, matches.length - 1) : -1;
      results.textContent = "";

      if (matches.length === 0) {
        const empty = document.createElement("p");
        empty.className = "px-3 py-6 text-sm text-slate-400";
        empty.textContent = copy.empty || "No matching page found.";
        results.append(empty);
        input.setAttribute("aria-activedescendant", "");
        status.textContent = copy.empty || "No matching page found.";
        return;
      }

      matches.forEach((page, index) => {
        const link = document.createElement("a");
        link.id = `command-result-${index}`;
        link.href = page.href;
        link.className = "command-result";
        link.dataset.commandResult = "";
        link.setAttribute("role", "option");
        link.setAttribute("aria-selected", String(index === activeIndex));

        const title = document.createElement("span");
        title.className = "text-sm font-bold text-white";
        title.textContent = page.title;

        const meta = document.createElement("span");
        meta.className = "font-mono text-xs text-slate-400";
        meta.textContent = `${page.group} - ${page.href}`;

        link.append(title);

        if (page.description) {
          const description = document.createElement("span");
          description.className = "text-xs leading-5 text-slate-400";
          description.textContent = page.description;
          link.append(description);
        }

        link.append(meta);
        link.addEventListener("mouseenter", () => {
          activeIndex = index;
          updateActiveResult();
        });
        link.addEventListener("click", hide);
        results.append(link);
      });

      updateActiveResult();
      status.textContent = matches.length === 1
        ? (copy.availableSingular || "1 search result available.")
        : `${matches.length}${copy.availablePluralSuffix || " search results available."}`;
    };

    const backgroundElements = Array.from(palette.parentElement?.children || []).filter(
      (element) => element !== palette && element instanceof HTMLElement && element.tagName !== "SCRIPT"
    );

    function setBackgroundInert(value) {
      backgroundElements.forEach((element) => {
        element.inert = value;
        if (value) element.setAttribute("aria-hidden", "true");
        else element.removeAttribute("aria-hidden");
      });
    }

    function show(initialQuery = "") {
      document.dispatchEvent(new CustomEvent("site-command-open"));
      lastFocusedElement = document.activeElement instanceof HTMLElement ? document.activeElement : null;
      palette.hidden = false;
      document.body.style.overflow = "hidden";
      setBackgroundInert(true);
      input.setAttribute("aria-expanded", "true");
      input.value = initialQuery;
      activeIndex = 0;
      render();
      window.setTimeout(() => input.focus(), 30);
    }

    function hide() {
      palette.hidden = true;
      document.body.style.overflow = "";
      input.setAttribute("aria-expanded", "false");
      input.setAttribute("aria-activedescendant", "");
      setBackgroundInert(false);
      if (lastFocusedElement) {
        lastFocusedElement.focus();
      }
    }

    document.addEventListener("keydown", (event) => {
      if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === "k") {
        event.preventDefault();
        show();
      }

      if (event.key === "Escape" && !palette.hidden) {
        hide();
      }
    });

    document.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      if (target.closest("[data-command-trigger]")) {
        event.preventDefault();
        show("");
      }

      if (target === palette || target.closest("[data-command-close]")) {
        hide();
      }
    });

    input.addEventListener("input", () => {
      activeIndex = 0;
      render();
    });

    input.addEventListener("keydown", (event) => {
      if (matches.length === 0) return;

      if (event.key === "ArrowDown") {
        event.preventDefault();
        activeIndex = (activeIndex + 1) % matches.length;
        updateActiveResult();
      }

      if (event.key === "ArrowUp") {
        event.preventDefault();
        activeIndex = (activeIndex - 1 + matches.length) % matches.length;
        updateActiveResult();
      }

      if (event.key === "Enter" && activeIndex >= 0) {
        event.preventDefault();
        window.location.href = matches[activeIndex].href;
      }
    });

    palette.addEventListener("keydown", (event) => {
      if (event.key !== "Tab") return;
      const focusable = Array.from(
        palette.querySelectorAll('input, button, a[href], [tabindex]:not([tabindex="-1"])')
      ).filter((element) => element instanceof HTMLElement && !element.hidden);
      if (focusable.length === 0) return;

      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (event.shiftKey && (document.activeElement === first || !palette.contains(document.activeElement))) {
        event.preventDefault();
        last.focus();
      } else if (!event.shiftKey && document.activeElement === last) {
        event.preventDefault();
        first.focus();
      }
    });

    const initialQuery = new URLSearchParams(window.location.search).get("q")?.trim();
    if (initialQuery) show(initialQuery);
  })();
</script>
