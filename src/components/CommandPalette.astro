---
interface Page {
  title: string;
  href: string;
  group: string;
  description?: string;
}

interface Props {
  pages: Page[];
}

const { pages } = Astro.props;
const pagesJson = JSON.stringify(pages).replace(/</g, "\\u003c");
---

<div id="site-search" data-command-palette hidden class="fixed inset-0 z-[70] bg-black/72 px-4 py-20 backdrop-blur-sm" role="dialog" aria-modal="true" aria-labelledby="site-search-title" tabindex="-1">
  <div class="mx-auto max-w-2xl overflow-hidden rounded-lg border border-cyan-100/16 bg-graphite-900 shadow-panel">
    <div class="flex items-center gap-3 border-b border-white/10 px-4 py-3">
      <span aria-hidden="true" class="font-mono text-lg text-cyan-200">/</span>
      <span id="site-search-title" class="sr-only">Search Manish Sharma Lab</span>
      <input
        data-command-input
        class="min-h-11 flex-1 bg-transparent text-base text-white outline-none placeholder:text-slate-500"
        placeholder="Search frameworks, notes, glossary..."
        autocomplete="off"
        aria-label="Search pages"
        role="combobox"
        aria-autocomplete="list"
        aria-controls="command-results"
        aria-expanded="false"
        aria-activedescendant=""
      />
      <button
        type="button"
        data-command-close
        class="utility-button grid h-9 w-9 place-items-center p-0 text-slate-300"
        aria-label="Close search"
      >
        <span aria-hidden="true">&times;</span>
      </button>
    </div>
    <p data-command-status class="sr-only" aria-live="polite"></p>
    <div id="command-results" data-command-results class="max-h-[60vh] overflow-auto p-2" role="listbox" aria-label="Search results"></div>
    <div class="flex items-center justify-between border-t border-white/10 px-4 py-2 text-xs font-semibold text-slate-400">
      <span>Arrow keys move</span>
      <span>Enter opens</span>
      <span>Esc closes</span>
    </div>
  </div>
</div>

<script is:inline type="application/json" id="command-pages" set:html={pagesJson}></script>
<script is:inline>
  (() => {
    const pagesElement = document.getElementById("command-pages");
    const palette = document.querySelector("[data-command-palette]");
    const input = document.querySelector("[data-command-input]");
    const results = document.querySelector("[data-command-results]");
    const closeButton = document.querySelector("[data-command-close]");
    const status = document.querySelector("[data-command-status]");

    if (!pagesElement || !palette || !input || !results || !closeButton || !status) return;

    const pages = JSON.parse(pagesElement.textContent || "[]");
    let activeIndex = 0;
    let matches = [];
    let lastFocusedElement = null;

    const updateActiveResult = () => {
      const resultLinks = Array.from(results.querySelectorAll("[data-command-result]"));

      resultLinks.forEach((link, index) => {
        const isActive = index === activeIndex;
        link.classList.toggle("is-active", isActive);
        link.setAttribute("aria-selected", String(isActive));
      });

      const activeResult = resultLinks[activeIndex];
      input.setAttribute("aria-activedescendant", activeResult?.id || "");
    };

    const render = () => {
      const query = input.value.trim().toLowerCase();
      matches = (query
        ? pages.filter((page) => `${page.title} ${page.group} ${page.href} ${page.description || ""}`.toLowerCase().includes(query))
        : pages
      ).slice(0, 12);

      activeIndex = matches.length > 0 ? Math.min(activeIndex, matches.length - 1) : -1;
      results.textContent = "";

      if (matches.length === 0) {
        const empty = document.createElement("p");
        empty.className = "px-3 py-6 text-sm text-slate-400";
        empty.textContent = "No matching page found.";
        results.append(empty);
        input.setAttribute("aria-activedescendant", "");
        status.textContent = "No matching page found.";
        return;
      }

      matches.forEach((page, index) => {
        const link = document.createElement("a");
        link.id = `command-result-${index}`;
        link.href = page.href;
        link.className = "command-result";
        link.dataset.commandResult = "";
        link.setAttribute("role", "option");
        link.setAttribute("aria-selected", String(index === activeIndex));

        const title = document.createElement("span");
        title.className = "text-sm font-bold text-white";
        title.textContent = page.title;

        const meta = document.createElement("span");
        meta.className = "font-mono text-xs text-slate-400";
        meta.textContent = `${page.group} - ${page.href}`;

        link.append(title);

        if (page.description) {
          const description = document.createElement("span");
          description.className = "text-xs leading-5 text-slate-400";
          description.textContent = page.description;
          link.append(description);
        }

        link.append(meta);
        link.addEventListener("mouseenter", () => {
          activeIndex = index;
          updateActiveResult();
        });
        link.addEventListener("click", hide);
        results.append(link);
      });

      updateActiveResult();
      status.textContent = `${matches.length} search result${matches.length === 1 ? "" : "s"} available.`;
    };

    const backgroundElements = Array.from(palette.parentElement?.children || []).filter(
      (element) => element !== palette && element instanceof HTMLElement && element.tagName !== "SCRIPT"
    );

    function setBackgroundInert(value) {
      backgroundElements.forEach((element) => {
        element.inert = value;
        if (value) element.setAttribute("aria-hidden", "true");
        else element.removeAttribute("aria-hidden");
      });
    }

    function show(initialQuery = "") {
      document.dispatchEvent(new CustomEvent("site-command-open"));
      lastFocusedElement = document.activeElement instanceof HTMLElement ? document.activeElement : null;
      palette.hidden = false;
      document.body.style.overflow = "hidden";
      setBackgroundInert(true);
      input.setAttribute("aria-expanded", "true");
      input.value = initialQuery;
      activeIndex = 0;
      render();
      window.setTimeout(() => input.focus(), 30);
    }

    function hide() {
      palette.hidden = true;
      document.body.style.overflow = "";
      input.setAttribute("aria-expanded", "false");
      input.setAttribute("aria-activedescendant", "");
      setBackgroundInert(false);
      if (lastFocusedElement) {
        lastFocusedElement.focus();
      }
    }

    document.addEventListener("keydown", (event) => {
      if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === "k") {
        event.preventDefault();
        show();
      }

      if (event.key === "Escape" && !palette.hidden) {
        hide();
      }
    });

    document.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      if (target.closest("[data-command-trigger]")) {
        event.preventDefault();
        show("");
      }

      if (target === palette || target.closest("[data-command-close]")) {
        hide();
      }
    });

    input.addEventListener("input", () => {
      activeIndex = 0;
      render();
    });

    input.addEventListener("keydown", (event) => {
      if (matches.length === 0) return;

      if (event.key === "ArrowDown") {
        event.preventDefault();
        activeIndex = (activeIndex + 1) % matches.length;
        updateActiveResult();
      }

      if (event.key === "ArrowUp") {
        event.preventDefault();
        activeIndex = (activeIndex - 1 + matches.length) % matches.length;
        updateActiveResult();
      }

      if (event.key === "Enter" && activeIndex >= 0) {
        event.preventDefault();
        window.location.href = matches[activeIndex].href;
      }
    });

    palette.addEventListener("keydown", (event) => {
      if (event.key !== "Tab") return;
      const focusable = Array.from(
        palette.querySelectorAll('input, button, a[href], [tabindex]:not([tabindex="-1"])')
      ).filter((element) => element instanceof HTMLElement && !element.hidden);
      if (focusable.length === 0) return;

      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (event.shiftKey && (document.activeElement === first || !palette.contains(document.activeElement))) {
        event.preventDefault();
        last.focus();
      } else if (!event.shiftKey && document.activeElement === last) {
        event.preventDefault();
        first.focus();
      }
    });

    const initialQuery = new URLSearchParams(window.location.search).get("q")?.trim();
    if (initialQuery) show(initialQuery);
  })();
</script>
