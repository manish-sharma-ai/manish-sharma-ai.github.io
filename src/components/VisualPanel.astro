---
interface Props {
  title?: string;
  subtitle?: string;
}

const { title = "Sense -> Model -> Decide -> Verify", subtitle = "Decision-system cockpit" } = Astro.props;

const nodes = [
  {
    label: "Sense",
    text: "Process signals, images, logs, measurements, operator notes, and missing-information cues."
  },
  {
    label: "Model",
    text: "AI outputs, engineering rules, uncertainty bands, traceable assumptions, and known gaps."
  },
  {
    label: "Decide",
    text: "Repairability, process route, RFQ risk, inspection need, and the next bounded action."
  },
  {
    label: "Verify",
    text: "Inspection, testing, documentation, measured outcomes, and expert review before approval."
  }
];
---

<div class="cockpit-panel" role="group" aria-labelledby="visual-panel-title">
  <div class="cockpit-grid" aria-hidden="true"></div>
  <div class="cockpit-content p-6 md:p-8">
    <div class="grid gap-5 lg:grid-cols-[0.9fr_1.1fr] lg:items-end">
      <div>
        <p class="metric-label">{subtitle}</p>
        <h2 id="visual-panel-title" class="mt-3 text-3xl font-black leading-tight text-white md:text-5xl">{title}</h2>
      </div>
      <div class="flex flex-wrap gap-2 lg:justify-end">
        {["process signal", "bounded decision", "inspection evidence"].map((item) => (
          <span class="chip chip--steel justify-center">{item}</span>
        ))}
      </div>
    </div>

    <div class="smdv-loop">
      <div class="smdv-loop__nodes">
        {nodes.map((node, index) => (
          <article class:list={["smdv-node", index === nodes.length - 1 ? "smdv-node--verify" : ""]}>
            <span class="smdv-node__index">{String(index + 1).padStart(2, "0")}</span>
            <span>
              <span class="block text-2xl font-black leading-tight text-white">{node.label}</span>
              <span class="mt-3 block text-sm leading-6 text-slate-300">{node.text}</span>
            </span>
          </article>
        ))}
      </div>
    </div>

    <div class="smdv-boundary">
      <p class="metric-label">Boundary condition</p>
      <p class="text-lg font-black leading-tight text-white">Decision support, not final engineering approval.</p>
      <p class="max-w-4xl text-sm leading-6 text-slate-300">
        Preliminary decision-support only. Final feasibility depends on base material, geometry, service conditions, inspection requirements, and expert review.
      </p>
    </div>
  </div>
</div>
