---
interface Props {
  title?: string;
  subtitle?: string;
}

const { title = "Sense -> Model -> Decide -> Verify", subtitle = "Decision-system cockpit" } = Astro.props;

const nodes = [
  ["Sense", "signals"],
  ["Model", "assumptions"],
  ["Decide", "risk"],
  ["Verify", "evidence"]
];
---

<div class="cockpit-panel">
  <div class="cockpit-grid" aria-hidden="true"></div>
  <div class="cockpit-content p-6 md:p-8">
    <div>
      <p class="metric-label">{subtitle}</p>
      <h2 class="mt-3 text-3xl font-black leading-tight text-white md:text-4xl">{title}</h2>
    </div>
    <div class="grid gap-4">
      {nodes.map(([label, text], index) => (
        <div class="cockpit-node grid grid-cols-[auto_1fr_auto] items-center gap-4">
          <span class="font-mono text-xs font-black text-cyan-100">{String(index + 1).padStart(2, "0")}</span>
          <span>
            <span class="block text-lg font-black text-white">{label}</span>
            <span class="block text-sm text-slate-400">{text}</span>
          </span>
          <span class="h-2 w-2 rounded-full bg-cyan-200 shadow-[0_0_18px_rgba(51,214,255,0.75)]" aria-hidden="true"></span>
        </div>
      ))}
    </div>
    <div class="grid gap-3 sm:grid-cols-3">
      {["process signals", "inspection path", "expert review"].map((item) => (
        <span class="chip chip--steel justify-center">{item}</span>
      ))}
    </div>
  </div>
</div>
