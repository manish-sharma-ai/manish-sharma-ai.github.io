---
interface Props {
  label: string;
  href: string;
  description: string;
}

const { label, href, description } = Astro.props;
const isExternal = href.startsWith("http");
---

<article class="resource-card">
  <a href={href} target={isExternal ? "_blank" : undefined} rel={isExternal ? "noreferrer" : undefined}>
    <h3>{label}</h3>
    <p>{description}</p>
    <span class="resource-card__action">Open resource <span aria-hidden="true">→</span></span>
  </a>
</article>
