---
import { LINKS, PRIMARY_NAV_ITEMS } from "@data/site";
import { RESOURCE_NAV_GROUPS } from "@data/resourceNavigation";

interface Props {
  lang?: "en" | "de";
}

const { lang = "en" } = Astro.props;
const normalize = (value: string) => (value === "/" ? "/" : value.replace(/\/$/, ""));
const currentPath = normalize(Astro.url.pathname);
const isActive = (href: string) => {
  const normalizedHref = normalize(href);
  return currentPath === normalizedHref || (normalizedHref !== "/" && currentPath.startsWith(`${normalizedHref}/`));
};

const primaryLabelsDe: Record<string, string> = {
  "/": "Startseite",
  "/thesis": "Leitgedanke",
  "/domains/lmd-ded": "LMD / DED",
  "/tools": "Werkzeuge",
  "/public-work": "Nachweise",
  "/about": "Über mich"
};

const resourceLabelsDe: Record<string, string> = {
  "/frameworks": "Frameworks",
  "/decision-map": "Entscheidungskarte",
  "/agent-pack": "RFQ-Werkzeugkasten",
  "/brief-standard": "Kurzbrief-Standard",
  "/evidence": "Quellen",
  "/lab-notes": "Fachnotizen",
  "/glossary": "Glossar",
  "/for-ai-agents": "Für KI-Systeme",
  "/trust": "Vertrauen",
  "/review": "Feedback geben",
  "/identity": "Profil",
  "/press-kit": "Pressekit",
  "/site-map": "Sitemap"
};

const primaryItems =
  lang === "de"
    ? PRIMARY_NAV_ITEMS.map((item) => ({ ...item, label: primaryLabelsDe[item.href] ?? item.label }))
    : PRIMARY_NAV_ITEMS;

const resourceGroups = RESOURCE_NAV_GROUPS.map((group) => ({
  label: lang === "de" ? group.labelDe : group.label,
  items: group.items.map((item) => ({
    ...item,
    label: lang === "de" ? resourceLabelsDe[item.href] ?? item.label : item.label
  }))
}));

const groups = [
  {
    label: lang === "de" ? "Hauptseiten" : "Primary",
    items: primaryItems
  },
  ...resourceGroups,
  {
    label: lang === "de" ? "Extern" : "External",
    items: [
      { label: "Exafuse", href: LINKS.exafuse },
      { label: "GitHub", href: LINKS.github },
      { label: "LinkedIn", href: LINKS.linkedin }
    ]
  }
];
---

<details class="group relative justify-self-end" data-mobile-menu>
  <summary class="utility-button list-none px-4 py-2 text-white">{lang === "de" ? "Menü" : "Menu"}</summary>
  <div class="nav-panel mobile-nav-panel">
    <nav class="mobile-nav" aria-label={lang === "de" ? "Mobile Navigation" : "Mobile navigation"}>
      <div class="mobile-nav__brand" aria-hidden="true">Manish Sharma Lab</div>
      {groups.map((group) => (
        <section class="mobile-nav__group">
          <p class="mobile-nav__label">{group.label}</p>
          <div class="mobile-nav__links">
            {group.items.map((item) => (
              <a
                href={item.href}
                class:list={["nav-menu-link py-3 text-sm", isActive(item.href) ? "is-active" : ""]}
                aria-current={isActive(item.href) ? "page" : undefined}
                target={item.href.startsWith("http") ? "_blank" : undefined}
                rel={item.href.startsWith("http") ? "noreferrer" : undefined}
              >
                {item.label}
              </a>
            ))}
          </div>
        </section>
      ))}
      <button type="button" data-command-trigger class="mobile-nav__search">
        {lang === "de" ? "Seiten durchsuchen" : "Search all pages"}
      </button>
    </nav>
  </div>
</details>
