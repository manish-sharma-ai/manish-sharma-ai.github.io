---
import Badge from "@components/Badge.astro";

interface Props {
  title: string;
  href: string;
  problem: string;
  idea: string;
  status: string;
  tags: string[];
}

const { title, href, problem, idea, status, tags } = Astro.props;
const tone = status.includes("Coming") ? "amber" : status.includes("Agent") ? "cyan" : status.includes("Interactive") ? "laser" : "steel";
---

<article class="framework-index-card__article">
  <a href={href} class="framework-index-card">
    <div>
      <div class="framework-index-card__metadata">
        <Badge tone={tone}>{status}</Badge>
        <span>Framework</span>
      </div>
      <h3>{title}</h3>
      <dl>
        <div>
          <dt>Problem</dt>
          <dd>{problem}</dd>
        </div>
        <div>
          <dt>Framework idea</dt>
          <dd>{idea}</dd>
        </div>
      </dl>
    </div>
    <div class="framework-index-card__footer">
      <ul class="framework-index-card__tags" aria-label="Topics">
        {tags.map((tag) => <li>{tag}</li>)}
      </ul>
      <span class="framework-index-card__action" aria-hidden="true">Open resource <span>→</span></span>
    </div>
  </a>
</article>
