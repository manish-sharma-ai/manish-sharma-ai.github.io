---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  as?: "h1" | "h2";
}

const { eyebrow, title, description, as = "h2" } = Astro.props as Props;
const Heading = as;
---

<div class="max-w-3xl">
  {eyebrow && <p class="metric-label">{eyebrow}</p>}
  <Heading class="mt-3 text-3xl font-black leading-tight text-white md:text-4xl">{title}</Heading>
  {description && <p class="mt-4 text-lg leading-8 text-slate-300">{description}</p>}
  <div class="section-heading-mark mt-5" aria-hidden="true"><span></span></div>
</div>
