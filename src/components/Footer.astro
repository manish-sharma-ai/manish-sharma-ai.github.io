---
import BrandMark from "@components/BrandMark.astro";
import { LINKS } from "@data/site";
import { internalHref } from "@utils/urls";

interface Props {
  lang?: "en" | "de";
}

const { lang = "en" } = Astro.props;

const footerColumnsEn = [
  {
    label: "Explore",
    links: [
      { label: "Method", href: "/thesis" },
      { label: "Public Work", href: "/public-work" },
      { label: "LMD / DED", href: "/domains/lmd-ded" },
      { label: "Frameworks", href: "/frameworks" }
    ]
  },
  {
    label: "Tools & briefs",
    links: [
      { label: "Tools", href: "/tools" },
      { label: "Decision Map", href: "/decision-map" },
      { label: "Brief Standard", href: "/brief-standard" },
      { label: "Agent Pack", href: "/agent-pack" }
    ]
  },
  {
    label: "Resources & notes",
    links: [
      { label: "Resources", href: "/resources" },
      { label: "Lab Notes", href: "/lab-notes" },
      { label: "RSS Feed", href: "/rss.xml" },
      { label: "For AI Agents", href: "/for-ai-agents" },
      { label: "Deutsch", href: "/de" }
    ]
  },
  {
    label: "About & trust",
    links: [
      { label: "Identity", href: "/identity" },
      { label: "About", href: "/about" },
      { label: "Press Kit", href: "/press-kit" },
      { label: "Trust Center", href: "/trust" }
    ]
  }
];

const footerColumnsDe = [
  {
    label: "Entdecken",
    links: [
      { label: "Methode", href: "/thesis" },
      { label: "Öffentliche Arbeit", href: "/public-work" },
      { label: "LMD / DED", href: "/domains/lmd-ded" },
      { label: "Frameworks", href: "/frameworks" }
    ]
  },
  {
    label: "Werkzeuge & Kurzbriefe",
    links: [
      { label: "Werkzeuge", href: "/tools" },
      { label: "Entscheidungskarte", href: "/decision-map" },
      { label: "Kurzbrief-Standard", href: "/brief-standard" },
      { label: "RFQ-Werkzeugkasten", href: "/agent-pack" }
    ]
  },
  {
    label: "Ressourcen & Notizen",
    links: [
      { label: "Ressourcen", href: "/resources" },
      { label: "Fachnotizen", href: "/lab-notes" },
      { label: "RSS Feed", href: "/rss.xml" },
      { label: "Für KI-Systeme", href: "/for-ai-agents" },
      { label: "Deutsch", href: "/de" }
    ]
  },
  {
    label: "Profil & Vertrauen",
    links: [
      { label: "Profil", href: "/identity" },
      { label: "Über mich", href: "/about" },
      { label: "Pressekit", href: "/press-kit" },
      { label: "Vertrauen", href: "/trust" }
    ]
  }
];

const footerColumns = lang === "de" ? footerColumnsDe : footerColumnsEn;
const copy =
  lang === "de"
    ? {
        subtitle: "LMD, Prozessüberwachung und industrielle KI",
        promise: "Industrielle KI für Entscheidungen mit belastbaren Nachweisen.",
        description:
          "Öffentliche Methoden, Frameworks, Quellenkarten, Werkzeuge und Fachnotizen. Kommerzielle LMD/DED-Leistungen, Angebotsanfragen, Lieferzusagen und firmeneigene Fallstudien gehören zu Exafuse.",
        contact: "Kontakt",
        search: "Suche",
        exafuse: "Exafuse öffnen",
        connect: "Verbinden",
        github: "GitHub-Profil von Manish Sharma",
        linkedin: "LinkedIn-Profil von Manish Sharma",
        boundary: "Entscheidungshilfe, keine technische Freigabe.",
        trust: "Vertrauen & Datenschutz",
      }
    : {
        subtitle: "Industrial AI / Decision Systems",
        promise: "AI for industrial decisions that need evidence, not just predictions.",
        description:
          "Public frameworks, source maps, tools, lab notes, and AI guidance. Commercial services, RFQs, delivery claims, and company case studies belong to Exafuse.",
        contact: "Contact",
        search: "Search",
        exafuse: "Visit Exafuse",
        connect: "Connect",
        github: "Manish Sharma on GitHub",
        linkedin: "Manish Sharma on LinkedIn",
        boundary: "Decision-support content, not engineering approval.",
        trust: "Trust & privacy",
      };
---

<footer class="site-footer">
  <div class="site-shell site-footer__main">
    <section class="site-footer__identity" aria-label="Manish Sharma">
      <div class="site-footer__brand">
        <BrandMark uid="footer-brand-mark" />
        <div>
          <p class="site-footer__name">Manish Sharma</p>
          <p class="site-footer__subtitle">{copy.subtitle}</p>
        </div>
      </div>
      <p class="site-footer__promise">{copy.promise}</p>
      <p class="site-footer__description">{copy.description}</p>
      <div class="site-footer__actions">
        <a href={internalHref("/contact")} class="btn btn-primary site-footer__contact">{copy.contact}</a>
        <a href={LINKS.exafuse} target="_blank" rel="noreferrer" class="site-footer__exafuse">
          {copy.exafuse} <span aria-hidden="true">↗</span>
        </a>
        <nav class="site-footer__profiles" aria-label={copy.connect}>
          <div class="site-footer__socials">
            <a href={LINKS.github} target="_blank" rel="noreferrer" aria-label={copy.github} title="GitHub">
              <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path fill="currentColor" d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48v-1.7c-2.78.6-3.37-1.18-3.37-1.18-.45-1.16-1.1-1.47-1.1-1.47-.9-.62.07-.61.07-.61 1 .07 1.52 1.03 1.52 1.03.89 1.53 2.33 1.09 2.9.84.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.95 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.64 0 0 .84-.27 2.75 1.02A9.56 9.56 0 0 1 12 6.8c.85 0 1.7.11 2.5.34 1.91-1.29 2.75-1.02 2.75-1.02.55 1.37.2 2.39.1 2.64.64.7 1.03 1.59 1.03 2.68 0 3.85-2.34 4.69-4.57 4.94.36.31.68.9.68 1.82v2.7c0 .27.18.58.69.48A10 10 0 0 0 12 2Z" />
              </svg>
              <span class="sr-only">GitHub</span>
            </a>
            <a href={LINKS.linkedin} target="_blank" rel="noreferrer" aria-label={copy.linkedin} title="LinkedIn">
              <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path fill="currentColor" d="M6.94 8.5A1.72 1.72 0 1 0 6.94 5a1.72 1.72 0 0 0 0 3.5ZM5.45 9.8h3v9.7h-3V9.8Zm4.88 0h2.88v1.33h.04c.4-.76 1.38-1.56 2.84-1.56 3.04 0 3.6 2 3.6 4.6v5.33h-3v-4.73c0-1.13-.02-2.58-1.57-2.58-1.57 0-1.81 1.23-1.81 2.5v4.81h-3V9.8Z" />
              </svg>
              <span class="sr-only">LinkedIn</span>
            </a>
          </div>
        </nav>
        <button type="button" data-command-trigger class="site-footer__utility">{copy.search}</button>
      </div>
    </section>

    <div class="site-footer__groups">
      {footerColumns.map((column) => (
        <nav class="site-footer__group" aria-label={column.label}>
          <p>{column.label}</p>
          <ul>
            {column.links.map((item) => (
              <li>
                <a
                  href={internalHref(item.href)}
                  class="footer-link"
                  target={item.href.startsWith("http") ? "_blank" : undefined}
                  rel={item.href.startsWith("http") ? "noreferrer" : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      ))}
    </div>

  </div>

  <div class="site-shell site-footer__legal">
    <div class="site-footer__legal-content">
      <div class="site-footer__legal-meta">
        <span>&copy; {new Date().getFullYear()} Manish Sharma.</span>
        <a href={internalHref("/trust")} class="footer-link font-bold text-slate-300">{copy.trust}</a>
      </div>
      <span class="site-footer__boundary">{copy.boundary}</span>
    </div>
  </div>
</footer>
