---
import BrandMark from "@components/BrandMark.astro";
import { LINKS } from "@data/site";

interface Props {
  lang?: "en" | "de";
}

const { lang = "en" } = Astro.props;

const footerColumnsEn = [
  {
    label: "Core",
    links: [
      { label: "Thesis", href: "/thesis" },
      { label: "Evidence", href: "/public-work" },
      { label: "LMD / DED", href: "/domains/lmd-ded" },
      { label: "Frameworks", href: "/frameworks" }
    ]
  },
  {
    label: "Workbench",
    links: [
      { label: "Resources", href: "/resources" },
      { label: "Tools", href: "/tools" },
      { label: "Decision Map", href: "/decision-map" },
      { label: "Brief Standard", href: "/brief-standard" },
      { label: "Agent Pack", href: "/agent-pack" },
      { label: "Lab Notes", href: "/lab-notes" },
      { label: "RSS Feed", href: "/rss.xml" },
      { label: "For AI Agents", href: "/for-ai-agents" },
      { label: "Deutsch", href: "/de" }
    ]
  },
  {
    label: "Identity",
    links: [
      { label: "Identity", href: "/identity" },
      { label: "About", href: "/about" },
      { label: "Public Profile", href: "/profile/public-profile" },
      { label: "Press Kit", href: "/press-kit" },
      { label: "Trust Center", href: "/trust" }
    ]
  },
  {
    label: "External",
    links: [
      { label: "Exafuse", href: LINKS.exafuse, external: true },
      { label: "GitHub", href: LINKS.github, external: true },
      { label: "LinkedIn", href: LINKS.linkedin, external: true }
    ]
  }
];

const footerColumnsDe = [
  {
    label: "Kernseiten",
    links: [
      { label: "Leitgedanke", href: "/thesis" },
      { label: "Nachweise", href: "/public-work" },
      { label: "LMD / DED", href: "/domains/lmd-ded" },
      { label: "Frameworks", href: "/frameworks" }
    ]
  },
  {
    label: "Werkzeuge",
    links: [
      { label: "Ressourcen", href: "/resources" },
      { label: "Werkzeuge", href: "/tools" },
      { label: "Entscheidungskarte", href: "/decision-map" },
      { label: "Kurzbrief-Standard", href: "/brief-standard" },
      { label: "RFQ-Werkzeugkasten", href: "/agent-pack" },
      { label: "Fachnotizen", href: "/lab-notes" },
      { label: "RSS Feed", href: "/rss.xml" },
      { label: "Für KI-Systeme", href: "/for-ai-agents" },
      { label: "Deutsch", href: "/de" }
    ]
  },
  {
    label: "Profil",
    links: [
      { label: "Profil", href: "/identity" },
      { label: "Über mich", href: "/about" },
      { label: "Öffentliches Profil", href: "/profile/public-profile" },
      { label: "Pressekit", href: "/press-kit" },
      { label: "Vertrauen", href: "/trust" }
    ]
  },
  {
    label: "Extern",
    links: [
      { label: "Exafuse", href: LINKS.exafuse, external: true },
      { label: "GitHub", href: LINKS.github, external: true },
      { label: "LinkedIn", href: LINKS.linkedin, external: true }
    ]
  }
];

const footerColumns = lang === "de" ? footerColumnsDe : footerColumnsEn;
const copy =
  lang === "de"
    ? {
        subtitle: "LMD, Prozessüberwachung und industrielle KI",
        promise: "Werkzeuge und Fachwissen für fundierte LMD-Entscheidungen.",
        description:
          "Öffentliche Frameworks, Quellenkarten, Werkzeuge und Fachnotizen. Kommerzielle Leistungen, Angebotsanfragen, Lieferzusagen und firmeneigene Fallstudien gehören zu Exafuse.",
        contact: "Kontakt",
        search: "Suche",
        exafuse: "Exafuse öffnen",
        boundary: "Entscheidungshilfe, keine technische Freigabe.",
        trust: "Vertrauen & Datenschutz",
      }
    : {
        subtitle: "Industrial AI / Decision Systems",
        promise: "AI for Laser Metal Deposition decisions you can verify.",
        description:
          "Public frameworks, source maps, tools, lab notes, and AI guidance. Commercial services, RFQs, delivery claims, and company case studies belong to Exafuse.",
        contact: "Contact",
        search: "Search",
        exafuse: "Visit Exafuse",
        boundary: "Decision-support content, not engineering approval.",
        trust: "Trust & privacy",
      };
---

<footer class="border-t border-white/10 bg-black/30">
  <div class="site-shell grid gap-8 py-12 lg:grid-cols-[0.92fr_1.08fr] lg:items-stretch">
    <div class="ordered-card-strong p-6 md:p-7">
      <div class="flex items-center gap-3">
        <BrandMark uid="footer-brand-mark" />
        <div>
          <p class="text-sm font-black text-white">Manish Sharma Lab</p>
          <p class="metric-label mt-1">{copy.subtitle}</p>
        </div>
      </div>
      <p class="mt-6 max-w-xl text-xl font-black leading-tight text-white">
        {copy.promise}
      </p>
      <p class="mt-4 max-w-xl text-sm leading-6 text-slate-400">
        {copy.description}
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a href="/contact" class="btn btn-primary min-h-10 px-4 py-2 text-sm">{copy.contact}</a>
        <button type="button" data-command-trigger class="btn btn-secondary min-h-10 px-4 py-2 text-sm">{copy.search}</button>
        <a href={LINKS.exafuse} target="_blank" rel="noreferrer" class="btn btn-laser min-h-10 px-4 py-2 text-sm">{copy.exafuse}</a>
      </div>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
      {footerColumns.map((column) => (
        <div class="ordered-card p-5">
          <p class="metric-label">{column.label}</p>
          <div class="mt-4 grid gap-2">
            {column.links.map((item) => (
              <a
                href={item.href}
                class="footer-link rounded-xl px-2 py-1.5 text-sm font-bold leading-5 text-slate-300 hover:bg-white/[0.045]"
                target={item.href.startsWith("http") ? "_blank" : undefined}
                rel={item.href.startsWith("http") ? "noreferrer" : undefined}
              >
                {item.label}
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="site-shell grid gap-4 border-t border-white/10 py-6 text-sm text-slate-400 md:grid-cols-[1fr_auto] md:items-center">
    <div class="flex flex-wrap gap-x-5 gap-y-2">
      <span>&copy; {new Date().getFullYear()} Manish Sharma Lab.</span>
      <span>{copy.boundary}</span>
      <a href="/trust" class="footer-link font-bold text-slate-300">{copy.trust}</a>
    </div>
  </div>
</footer>
