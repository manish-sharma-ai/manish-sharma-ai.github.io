---
import { LINKS, NAV_GROUPS, SITE } from "@data/site";
---

<footer class="border-t border-white/10 bg-black/28">
  <div class="site-shell grid gap-10 py-12 lg:grid-cols-[1.25fr_1.75fr]">
    <div>
      <div class="flex items-center gap-3">
        <img src="/brand/manish-sharma-lab-mark.svg" alt="" class="h-10 w-10" width="40" height="40" loading="lazy" decoding="async" />
        <p class="metric-label">Manish Sharma Lab</p>
      </div>
      <p class="mt-3 max-w-xl text-lg font-semibold text-white">
        Industrial AI and decision systems for engineering processes, grounded in public LMD/DED work at Exafuse.
      </p>
      <p class="mt-4 text-sm leading-6 text-slate-400">
        {SITE.primaryPromise} Public technical content is decision-support oriented and connected to engineering evidence.
      </p>
      <div class="mt-6 flex flex-wrap gap-2">
        <a href="/site-map" class="btn btn-secondary min-h-10 px-3 py-2 text-sm">Site Map</a>
        <button type="button" data-command-trigger class="btn btn-secondary min-h-10 px-3 py-2 text-sm">Search</button>
      </div>
    </div>

    <div class="grid gap-5 sm:grid-cols-2 xl:grid-cols-4">
      {NAV_GROUPS.map((group) => (
        <div class="ordered-card p-4">
          <p class="metric-label">{group.label}</p>
          <div class="mt-4 grid gap-2 text-sm text-slate-300">
            {group.items.slice(0, 6).map((item) => (
              <a href={item.href} class="footer-link -mx-2 rounded-md px-2 py-1 leading-5 hover:bg-white/[0.045]">{item.label}</a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="site-shell grid gap-6 border-t border-white/10 py-6 text-sm text-slate-500 md:grid-cols-[1fr_auto] md:items-center">
    <div class="flex flex-wrap gap-x-5 gap-y-2">
      <span>&copy; {new Date().getFullYear()} Manish Sharma Lab.</span>
      <a href={SITE.repoUrl} target="_blank" rel="noreferrer" class="footer-link">Website repository</a>
      <a href={LINKS.github} target="_blank" rel="noreferrer" class="footer-link">GitHub profile</a>
      <a href={LINKS.linkedin} target="_blank" rel="noreferrer" class="footer-link">LinkedIn</a>
    </div>
    <span>Canonical site: {SITE.canonicalUrl}</span>
  </div>
</footer>
