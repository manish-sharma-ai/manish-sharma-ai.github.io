---
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import CommandPalette from "@components/CommandPalette.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import RelatedLinks from "@components/RelatedLinks.astro";
import PageProvenance from "@components/PageProvenance.astro";
import SiteShell from "@components/SiteShell.astro";
import { COMMAND_PAGES, PERSON, SITE } from "@data/site";
import { absoluteUrl, canonicalPath, normalizeStructuredDataUrls, routePath } from "@utils/urls";
import "@styles/global.css";

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  image?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  lastUpdated?: string;
  lang?: "en" | "de";
  robots?: string;
  ogType?: "website" | "article";
  alternates?: Array<{ lang: string; href: string }>;
}

const {
  title,
  description = SITE.description,
  canonical = canonicalPath(Astro.url.pathname),
  image = "/og-image.png",
  jsonLd = [],
  lastUpdated = SITE.lastUpdated,
  lang = "en",
  robots = "index, follow, max-image-preview:large",
  ogType: requestedOgType,
  alternates = []
} = Astro.props;

const canonicalUrl = absoluteUrl(canonical);
const imageUrl = absoluteUrl(image);
const titleText = title;
const ogLocale = lang === "de" ? "de_DE" : "en_US";
const route = routePath(canonical);
const ogType = requestedOgType ?? (route.startsWith("/lab-notes/") ? "article" : "website");
const jsonLdItems = Array.isArray(jsonLd) ? jsonLd : [jsonLd];
const commandPagePaths = new Set(COMMAND_PAGES.map((page) => routePath(page.href)));
const homeLabel = lang === "de" ? "Startseite" : "Home";
const skipLabel = lang === "de" ? "Zum Inhalt springen" : "Skip to content";

const breadcrumbItems =
  route === "/"
    ? []
    : route
        .split("/")
        .filter(Boolean)
        .map((segment, index, segments) => {
          const itemPath = `/${segments.slice(0, index + 1).join("/")}`;
          return {
            itemPath,
            isLast: index === segments.length - 1,
            name: segment
              .split("-")
              .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
              .join(" ")
          };
        })
        .filter((item) => item.isLast || commandPagePaths.has(routePath(item.itemPath)))
        .map((item, index) => ({
          "@type": "ListItem",
          position: index + 2,
          name: item.name,
          item: absoluteUrl(item.itemPath)
        }));

const breadcrumbJsonLd =
  breadcrumbItems.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: [
          {
            "@type": "ListItem",
            position: 1,
            name: homeLabel,
            item: absoluteUrl("/")
          },
          ...breadcrumbItems
        ]
      }
    : null;

const allJsonLd = [...jsonLdItems, breadcrumbJsonLd].filter(Boolean).map(normalizeStructuredDataUrls);
const normalizedCanonical = route;
const pageFamily =
  normalizedCanonical === "/"
    ? "home"
    : normalizedCanonical === "/404"
      ? "recovery"
      : normalizedCanonical === "/tools" ||
          normalizedCanonical === "/decision-map" ||
          normalizedCanonical === "/brief-template" ||
          normalizedCanonical === "/demo" ||
          normalizedCanonical === "/review"
        ? "tool"
        : normalizedCanonical.startsWith("/lab-notes/") ||
            normalizedCanonical.startsWith("/frameworks/") ||
            normalizedCanonical.startsWith("/glossary/") ||
            normalizedCanonical === "/thesis" ||
            normalizedCanonical === "/research/core-lmd-ai-sources"
          ? "long-form"
          : normalizedCanonical === "/lab-notes" ||
              normalizedCanonical === "/frameworks" ||
              normalizedCanonical === "/glossary" ||
              normalizedCanonical === "/research" ||
              normalizedCanonical === "/resources"
            ? "listing"
            : normalizedCanonical === "/public-work" ||
                normalizedCanonical.startsWith("/public-work/exafuse/") ||
                normalizedCanonical === "/evidence" ||
                normalizedCanonical === "/industrial-proof" ||
                normalizedCanonical === "/claims"
              ? "evidence"
              : "information";
const pageMode =
  normalizedCanonical === "/" ||
  normalizedCanonical === "/about" ||
  normalizedCanonical === "/thesis" ||
  normalizedCanonical === "/contact" ||
  normalizedCanonical === "/identity" ||
  normalizedCanonical.startsWith("/lab-notes")
    ? "editorial"
    : "instrument";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content={PERSON.name} />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="color-scheme" content="dark" />
    <title>{titleText}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content="#050608" />
    <link rel="canonical" href={canonicalUrl} />
    {alternates.map((alternate) => <link rel="alternate" hreflang={alternate.lang} href={absoluteUrl(alternate.href)} />)}
    <link rel="alternate" type="application/rss+xml" title={`${SITE.name} RSS`} href={absoluteUrl("/rss.xml")} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content={SITE.preferredSiteName} />
    <meta property="og:title" content={titleText} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:secure_url" content={imageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={titleText} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="last-modified" content={lastUpdated} />
    {allJsonLd.map((item) => <script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />)}
  </head>
  <body>
    <a class="skip-link" href="#main-content">{skipLabel}</a>
    <SiteShell>
      <Header lang={lang} />
      <Breadcrumbs path={route} title={titleText} lang={lang} />
      <main id="main-content">
        <div class:list={["page-flow", `page-flow--${pageFamily}`, `page-mode--${pageMode}`]} data-page-family={pageFamily} data-page-mode={pageMode}>
          <div class="page-flow__content"><slot /></div>
          <div class="page-flow__ending">
            <RelatedLinks path={route} lang={lang} />
            <PageProvenance lastUpdated={lastUpdated} lang={lang} />
          </div>
        </div>
      </main>
      <Footer lang={lang} />
      <CommandPalette pages={COMMAND_PAGES} lang={lang} />
    </SiteShell>
  </body>
</html>
